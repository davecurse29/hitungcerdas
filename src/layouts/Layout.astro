---
// Master Layout untuk semua halaman HitungCerdas
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: object;
  breadcrumb?: object;
}

const {
  title,
  description,
  keywords = [],
  canonical,
  ogImage = 'https://hitungcerdas.net/og-image.png',
  ogType = 'website',
  jsonLd,
  breadcrumb,
} = Astro.props;

const siteUrl = 'https://hitungcerdas.net';
const fullUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "HitungCerdas",
  "description": "18 kalkulator keuangan, bisnis, dan islami online gratis untuk masyarakat Indonesia",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Any",
  "url": siteUrl,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "IDR" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "127" }
};
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  {/* ── Title & Description ── */}
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="author" content="HitungCerdas" />
  <meta name="robots" content="index, follow, max-image-preview:large" />

  {/* ── Theme ── */}
  <meta name="theme-color" content="#0A2540" />
  <meta name="google-site-verification" content="sanMNF1i87E8Tc2Ooz-vHw2FHEpQ6DhVpQ29H3HiPN4" />

  {/* ── Canonical ── */}
  <link rel="canonical" href={fullUrl} />

  {/* ── Open Graph ── */}
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={fullUrl} />
  <meta property="og:site_name" content="HitungCerdas" />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  {/* ── Twitter Card ── */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {/* ── Favicon ── */}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  {/* ── Fonts (Preconnect for performance) ── */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  {/* ── Tabler Icons CDN ── */}
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"
  />

  {/* ── Schema.org JSON-LD ── */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd || defaultJsonLd)} />

  {breadcrumb && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  )}

  {/* ── Google AdSense ── */}
  <script
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7503808144261296"
    crossorigin="anonymous"
  ></script>
</head>
<body>
  <Header />

  <main>
    <slot />
  </main>

  <Footer />

  {/* ── Back to Top Button ── */}
  <button class="bttp" id="bttp" aria-label="Kembali ke atas">
    <i class="ti ti-arrow-up"></i>
  </button>

  {/* ── Toast Notification ── */}
  <div class="toast" id="toast">
    <i class="ti ti-check"></i>
    <span id="toastText">Tersalin!</span>
  </div>

  {/* ── Cloudflare Analytics ── */}
  <script
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447"
    integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ=="
    data-cf-beacon='{"version":"2024.11.0","token":"17baf21aa07846ffa89b64e450cfa7ac","r":1}'
    crossorigin="anonymous"
  ></script>

  {/* ── HTML to Canvas (for report card export) ── */}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" defer></script>

  {/* ── Chart.js (for visual data charts) ── */}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>

  {/* ── Global Calculator Utility (v2) ── */}
  <script src="/js/calculator-utils.js" defer></script>

  {/* ── Global Scripts ── */}
  <script is:inline>
    // ─── Back to Top ───
    (function() {
      const btn = document.getElementById('bttp');
      if (!btn) return;
      window.addEventListener('scroll', () => {
        btn.classList.toggle('show', window.scrollY > 300);
      }, { passive: true });
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })();

    // ─── Toast (Global Helper) ───
    window.showToast = function(msg) {
      const t = document.getElementById('toast');
      const txt = document.getElementById('toastText');
      if (!t || !txt) return;
      txt.textContent = msg || 'Tersalin!';
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2200);
    };

    // ─── Copy Helper ───
    window.copyText = async function(text, msg) {
      try {
        await navigator.clipboard.writeText(text);
        window.showToast(msg || 'Tersalin ke clipboard!');
      } catch (e) {
        window.showToast('Gagal copy. Coba pilih manual.');
      }
    };

    // ─── Scroll Reveal ───
    (function() {
      if (!('IntersectionObserver' in window)) return;
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('shown');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    })();

    // ─── Active Nav Link ───
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('header nav a').forEach(link => {
        const href = link.getAttribute('href');
        if (!href) return;
        if (href === path || (href !== '/' && path.startsWith(href))) {
          link.classList.add('active');
        }
      });
    })();
  </script>
</body>
</html>
