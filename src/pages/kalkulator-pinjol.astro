</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';

const $ = (id) => document.getElementById(id);

const PLATFORM_PRESETS = {
  custom: null,
  kredivo: { bunga: 0.083, admin: 6, layanan: 0, label: 'Kredivo' },
  akulaku: { bunga: 0.117, admin: 5, layanan: 0, label: 'Akulaku' },
  danarupiah: { bunga: 0.1, admin: 5, layanan: 1, label: 'DanaRupiah' },
  amartha: { bunga: 0.2, admin: 3, layanan: 0, label: 'Amartha' },
  kreditpintar: { bunga: 0.4, admin: 6, layanan: 0, label: 'Kredit Pintar' },
  rupiahcepat: { bunga: 0.4, admin: 8, layanan: 0, label: 'RupiahCepat' },
};

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

$('platform').addEventListener('change', () => {
  const preset = PLATFORM_PRESETS[$('platform').value];
  if (preset) {
    $('bunga').value = preset.bunga;
    $('admin').value = preset.admin;
    $('layanan').value = preset.layanan;
  }
  recalculate();
});

function recalculate() {
  const pinjaman = parseRupiah($('pinjaman').value);
  const tenor = parseInt($('tenor').value) || 30;
  const bungaPerHari = parseFloat($('bunga').value) || 0;
  const adminPersen = parseFloat($('admin').value) || 0;
  const layananPersen = parseFloat($('layanan').value) || 0;
  const hariTelat = parseInt($('hariTelat').value) || 0;
  const dendaPersen = parseFloat($('dendaPersen').value) || 0;

  if (!pinjaman || pinjaman <= 0) return;

  const totalBunga = pinjaman * (bungaPerHari / 100) * tenor;
  const biayaAdmin = pinjaman * (adminPersen / 100);
  const biayaLayanan = pinjaman * (layananPersen / 100);
  const biayaAwal = biayaAdmin + biayaLayanan;
  const jumlahDiterima = pinjaman - biayaAwal;
  const totalDenda = pinjaman * (dendaPersen / 100) * hariTelat;
  const totalBayar = pinjaman + totalBunga + totalDenda;
  const totalBiayaSemua = totalBunga + biayaAwal + totalDenda;

  // APR
  const apr = (totalBunga / pinjaman) * (365 / tenor) * 100;
  // Severity ratio: total cost vs principal
  const severityRatio = (totalBiayaSemua / pinjaman) * 100;

  $('totalBayar').textContent = formatRupiah(totalBayar);
  $('tenorLabel').textContent = `(${tenor} hari)`;
  $('cicilanSecondary').innerHTML = `Pinjaman cair (setelah biaya awal): <strong>${formatRupiah(jumlahDiterima)}</strong>`;
  $('resJumlahDiterima').textContent = formatRupiah(jumlahDiterima);
  $('resTotalBunga').textContent = formatRupiah(totalBunga);
  $('resTotalBiaya').textContent = formatRupiah(totalBiayaSemua);
  $('resApr').textContent = formatPercent(apr, 0);

  $('severityPercent').textContent = formatPercent(severityRatio, 1);
  $('severityFill').style.width = `${Math.min(severityRatio, 100)}%`;
  
  if (severityRatio < 20) {
    $('severityHint').textContent = 'Biaya wajar';
  } else if (severityRatio < 40) {
    $('severityHint').textContent = '⚠️ Biaya tinggi — consider alternatif';
  } else {
    $('severityHint').textContent = '🚨 Biaya SANGAT TINGGI — kemungkinan pinjol ilegal!';
  }

  // Warning telat
  if (hariTelat > 0) {
    $('warningTelat').style.display = 'flex';
    $('warningTelatText').innerHTML = `
      <strong>🚨 Simulasi Telat ${hariTelat} hari:</strong><br>
      Total denda: <strong>${formatRupiah(totalDenda)}</strong>. 
      Plus pinjol legal lapor ke <strong>SLIK OJK</strong>, score kredit kamu rusak 5+ tahun.
    `;
  } else {
    $('warningTelat').style.display = 'none';
  }
}

['tenor','bunga','admin','layanan','hariTelat','dendaPersen'].forEach(id => {
  $(id).addEventListener('input', recalculate);
  $(id).addEventListener('change', recalculate);
});

recalculate();
</script>