---
// src/pages/kalkulator-kta.astro
// Kalkulator KTA Pro — Bunga flat/efektif + APR + 4 bank comparison
import CalculatorLayout from '../components/CalculatorLayout.astro';
---

<CalculatorLayout
  title="Kalkulator KTA — Hitung Cicilan Kredit Tanpa Agunan Bank Indonesia 2026"
  description="Kalkulator KTA online gratis. Hitung cicilan kredit tanpa agunan, bandingkan bunga flat vs efektif, dan compare KTA BCA, Mandiri, Permata, OCBC dengan APR."
  icon="🏦"
  category="KALKULATOR KEUANGAN"
  categoryColor="teal"
  breadcrumb={[
    { label: 'Kalkulator Keuangan', href: '/kalkulator-keuangan' },
    { label: 'Kalkulator KTA' }
  ]}
>

  <div class="calc-grid">
    <!-- LEFT: Input -->
    <div class="calc-panel">
      <h3>Detail Pinjaman KTA</h3>

      <div class="form-group">
        <label class="form-label">Jumlah Pinjaman</label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="pinjaman" class="form-input" value="50.000.000" inputmode="numeric" data-format="rupiah" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Tenor</label>
          <select id="tenor" class="form-input">
            <option value="12">12 bulan (1 thn)</option>
            <option value="24">24 bulan (2 thn)</option>
            <option value="36" selected>36 bulan (3 thn)</option>
            <option value="48">48 bulan (4 thn)</option>
            <option value="60">60 bulan (5 thn)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Jenis Bunga</label>
          <select id="jenisBunga" class="form-input">
            <option value="flat" selected>Flat (umum di KTA)</option>
            <option value="efektif">Efektif (anuitas)</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Suku Bunga <span class="form-hint" id="bungaHint">KTA flat 0,9-1,5%/bulan</span></label>
        <div class="form-input-suffix">
          <input type="number" id="bunga" class="form-input" value="1.0" min="0" max="5" step="0.05" />
          <span class="suffix" id="bungaUnit">% /bulan</span>
        </div>
      </div>

      <details class="advanced-toggle">
        <summary>Biaya Tambahan (opsional)</summary>
        <div class="form-row" style="margin-top: 12px;">
          <div class="form-group">
            <label class="form-label">Provisi <span class="form-hint">1-3%</span></label>
            <div class="form-input-suffix">
              <input type="number" id="provisi" class="form-input" value="2" min="0" max="5" step="0.1" />
              <span class="suffix">%</span>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Asuransi Jiwa <span class="form-hint">0,5-1,5%</span></label>
            <div class="form-input-suffix">
              <input type="number" id="asuransi" class="form-input" value="1" min="0" max="3" step="0.1" />
              <span class="suffix">%</span>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Admin & Materai</label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="admin" class="form-input" value="250.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </details>

      <div class="info-box">
        <span class="info-box-icon">ℹ️</span>
        <div>
          <strong>Tip:</strong> KTA umumnya pakai bunga <strong>flat</strong>. Bunga flat 1%/bulan setara efektif ~1,8%/bulan. Selalu bandingkan APR untuk fair compare.
        </div>
      </div>
    </div>

    <!-- RIGHT: Results -->
    <div class="calc-panel calc-panel-dark">
      <h3 style="color: rgba(255,255,255,0.85);">Hasil Simulasi</h3>

      <div class="result-main">
        <span class="label">CICILAN PER BULAN</span>
        <div class="value" id="cicilanPerBulan">Rp 0</div>
        <div class="cicilan-secondary" id="cicilanSecondary">
          Pinjaman cair: <strong>Rp 0</strong>
        </div>
      </div>

      <div class="result-grid">
        <div class="result-card">
          <span class="label">JUMLAH DITERIMA</span>
          <span class="value" id="resJumlahDiterima">Rp 0</span>
        </div>
        <div class="result-card warning">
          <span class="label">TOTAL BUNGA</span>
          <span class="value" id="resTotalBunga">Rp 0</span>
        </div>
        <div class="result-card warning">
          <span class="label">TOTAL BAYAR</span>
          <span class="value" id="resTotalBayar">Rp 0</span>
        </div>
        <div class="result-card">
          <span class="label">APR EFEKTIF</span>
          <span class="value" id="resApr">0%</span>
        </div>
      </div>

      <div class="warning-box" id="warningBox" style="display:none;">
        <span class="warning-icon">⚠️</span>
        <div id="warningText"></div>
      </div>

      <div class="action-buttons">
        <button class="btn-action primary" onclick="window.print()">🖨️ Print / Save PDF</button>
      </div>
    </div>
  </div>

  <!-- Bank Comparison -->
  <section class="bank-section">
    <h2>🏦 Bandingkan KTA Bank Populer Indonesia</h2>
    <p class="section-sub">Estimasi cicilan untuk pinjaman <strong id="pinjamanDisplay">Rp 50.000.000</strong> tenor <strong id="tenorDisplay">36 bulan</strong>. Bunga aktual tergantung profil kredit & promo.</p>

    <div class="bank-grid">
      <div class="bank-card">
        <div class="bank-name">
          <div class="bank-logo">BCA</div>
          <h4>BCA KTA</h4>
        </div>
        <table class="bank-table">
          <tr><td>Bunga Flat</td><td><strong>0,99%/bln</strong></td></tr>
          <tr><td>Tenor</td><td>1-5 tahun</td></tr>
          <tr><td>Max Pinjaman</td><td>Rp 100jt</td></tr>
          <tr><td>Cicilan</td><td id="bankBcaCicilan">-</td></tr>
          <tr class="bank-total"><td>Total Bayar</td><td id="bankBcaTotal">-</td></tr>
        </table>
      </div>
      <div class="bank-card">
        <div class="bank-name">
          <div class="bank-logo">Mandiri</div>
          <h4>Mandiri KSM</h4>
        </div>
        <table class="bank-table">
          <tr><td>Bunga Flat</td><td><strong>1,05%/bln</strong></td></tr>
          <tr><td>Tenor</td><td>1-15 tahun</td></tr>
          <tr><td>Max Pinjaman</td><td>Rp 500jt</td></tr>
          <tr><td>Cicilan</td><td id="bankMandiriCicilan">-</td></tr>
          <tr class="bank-total"><td>Total Bayar</td><td id="bankMandiriTotal">-</td></tr>
        </table>
      </div>
      <div class="bank-card">
        <div class="bank-name">
          <div class="bank-logo">Permata</div>
          <h4>Permata KTA</h4>
        </div>
        <table class="bank-table">
          <tr><td>Bunga Flat</td><td><strong>0,88%/bln</strong></td></tr>
          <tr><td>Tenor</td><td>1-5 tahun</td></tr>
          <tr><td>Max Pinjaman</td><td>Rp 300jt</td></tr>
          <tr><td>Cicilan</td><td id="bankPermataCicilan">-</td></tr>
          <tr class="bank-total"><td>Total Bayar</td><td id="bankPermataTotal">-</td></tr>
        </table>
      </div>
      <div class="bank-card">
        <div class="bank-name">
          <div class="bank-logo">OCBC</div>
          <h4>OCBC KTA</h4>
        </div>
        <table class="bank-table">
          <tr><td>Bunga Flat</td><td><strong>0,79%/bln</strong></td></tr>
          <tr><td>Tenor</td><td>1-5 tahun</td></tr>
          <tr><td>Max Pinjaman</td><td>Rp 200jt</td></tr>
          <tr><td>Cicilan</td><td id="bankOcbcCicilan">-</td></tr>
          <tr class="bank-total"><td>Total Bayar</td><td id="bankOcbcTotal">-</td></tr>
        </table>
      </div>
    </div>

    <div class="info-box" style="margin-top: 20px;">
      <span class="info-box-icon">⚠️</span>
      <div>
        <strong>Disclaimer:</strong> Data bunga adalah estimasi standar publikasi bank. Bunga aktual tergantung profil kredit, score BI Checking, riwayat nasabah, dan promo berlaku. Selalu konfirmasi ke bank resmi.
      </div>
    </div>
  </section>

  <!-- Flat vs Efektif Converter -->
  <section class="converter-section">
    <h2>🔄 Konverter Bunga Flat ↔ Efektif</h2>
    <p class="section-sub">Bandingkan bunga KTA yang dipublish bank — sering pakai bunga flat tapi nominal kecil, padahal efektif lebih tinggi</p>

    <div class="converter-grid">
      <div class="converter-card">
        <h4>Bunga Flat ke Efektif</h4>
        <p>Jika bunga flat <strong><span id="convFlat">1,0</span>%/bulan</strong>, setara dengan:</p>
        <div class="converter-result">
          <span id="convEfektif">~1,80</span>%<small>/bulan efektif</small>
        </div>
        <p class="converter-hint">Atau <strong><span id="convAprFromFlat">21,6</span>%</strong> APR</p>
      </div>
      <div class="converter-card">
        <h4>Rumus Konversi</h4>
        <p style="font-size: 13px; line-height: 1.7;">
          <strong>Efektif ≈ Flat × 1,8</strong> (untuk tenor 24-36 bulan)<br>
          <strong>APR = Bunga efektif tahunan</strong> (× 12)<br>
          <small style="color: var(--ink-3);">Bank wajib publish APR menurut OJK</small>
        </p>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="tips-section">
    <h2>💡 Tips Ambil KTA Cerdas</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon">⚠️</div>
        <h4>KTA = Bunga Tertinggi</h4>
        <p>Bunga KTA flat 1-1,5%/bulan = APR 22-32%/tahun. Bandingkan dulu dengan KPR (8-12%) atau gadai BPKB (12-18%).</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">📋</div>
        <h4>Cek APR, Bukan Bunga Flat</h4>
        <p>Bank A bunga flat 0,8% + admin tinggi, vs Bank B bunga 1% admin rendah — APR-nya bisa setara. Compare yang tepat.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">🎯</div>
        <h4>Cicilan Max 30% Gaji</h4>
        <p>Total cicilan KTA + KPR + kredit lain harus &lt;30% take-home pay. Lebih dari itu = risiko gagal bayar.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">💳</div>
        <h4>Alternatif Lebih Murah</h4>
        <p>Gadai emas (1,5%/bulan), pinjam koperasi (0,8-1%), gadai BPKB (1,2-1,5%). KTA hanya untuk emergency tanpa jaminan.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section-calc">
    <h2>❓ Pertanyaan Umum KTA</h2>
    <div class="faq-list">
      <details class="faq-item" open>
        <summary>Apa itu KTA dan beda dengan KPR/KKB?</summary>
        <div class="faq-answer">
          <p><strong>KTA (Kredit Tanpa Agunan):</strong> Pinjaman tanpa jaminan apapun. Bank cuma cek slip gaji & BI Checking. Risiko bank tinggi, jadi bunga tinggi (1-1,5%/bulan flat).</p>
          <p><strong>KPR/KKB:</strong> Pinjaman dengan jaminan rumah/kendaraan. Risiko bank rendah karena ada aset, jadi bunga rendah (6-12%/tahun efektif).</p>
          <p>KTA cocok untuk: renovasi rumah, dana darurat, modal usaha kecil. Hindari KTA untuk konsumsi/lifestyle.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Berapa minimal gaji untuk apply KTA?</summary>
        <div class="faq-answer">
          <p>Umumnya bank syarat minimal:</p>
          <p><strong>BCA, Mandiri, BRI:</strong> Min Rp 3jt/bulan, masa kerja 1-2 tahun</p>
          <p><strong>Permata, OCBC, Maybank:</strong> Min Rp 5jt/bulan, masa kerja 2 tahun</p>
          <p><strong>HSBC, Standard Chartered:</strong> Min Rp 10jt/bulan, masa kerja 2 tahun</p>
          <p>Max plafond KTA biasanya 5-10x gaji bulanan.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apa bedanya bunga flat dan bunga efektif?</summary>
        <div class="faq-answer">
          <p><strong>Bunga Flat:</strong> Bunga dihitung dari pokok awal selama tenor. Cicilan konstan. Standar KTA.</p>
          <p>Contoh: KTA 50jt, 1%/bln flat, 36 bulan = bunga 50jt × 1% × 36 = Rp 18jt.</p>
          <p><strong>Bunga Efektif:</strong> Bunga dihitung dari sisa pokok (yang menyusut). Standar KPR.</p>
          <p>Aturan praktis: <strong>Flat 1%/bulan ≈ Efektif 1,8%/bulan ≈ APR 21,6%/tahun</strong></p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Bagaimana cara mempercepat lunas KTA?</summary>
        <div class="faq-answer">
          <p><strong>Pelunasan Dipercepat:</strong> Banyak bank kasih opsi lunas lebih awal, tapi ada denda 2-5% dari sisa pokok.</p>
          <p>Hitung: kalau pelunasan dipercepat hemat bunga &gt; denda, layak. Kalau tidak, biarkan lunas normal.</p>
          <p><strong>Refinancing ke Bunga Lebih Rendah:</strong> Pindahkan KTA ke bank lain dengan bunga lebih rendah. Pertimbangkan biaya provisi & denda lunas dipercepat.</p>
          <p><strong>Strategi Terbaik:</strong> Bayar 1-2 cicilan ekstra per tahun (THR/bonus) untuk potong total bunga signifikan.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apa risiko gagal bayar KTA?</summary>
        <div class="faq-answer">
          <p><strong>Telat 1-30 hari:</strong> Denda 1-3% dari cicilan + bunga harian. SMS/email peringatan.</p>
          <p><strong>Telat 30-90 hari:</strong> Score BI Checking jadi "Macet" (Kol 5). Susah apply kredit baru 5-10 tahun.</p>
          <p><strong>Telat &gt;90 hari:</strong> Debt collector. Karena tanpa agunan, bank tidak bisa sita aset, tapi bisa tuntut hukum perdata.</p>
          <p>Tip: kalau kesulitan bayar, hubungi bank untuk restructuring (perpanjang tenor) sebelum default.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Related -->
  <section class="related-section">
    <h2>Kalkulator Terkait</h2>
    <div class="related-grid">
      <a href="/kalkulator-pinjol" class="related-card">
        <span class="related-icon">📱</span>
        <h4>Kalkulator Pinjol</h4>
        <p>Hitung bunga pinjaman online & total cost</p>
      </a>
      <a href="/kalkulator-kpr" class="related-card">
        <span class="related-icon">🏠</span>
        <h4>Kalkulator KPR</h4>
        <p>Beli rumah jauh lebih murah dari KTA</p>
      </a>
      <a href="/kalkulator-gaji-bersih" class="related-card">
        <span class="related-icon">💼</span>
        <h4>Kalkulator Gaji Bersih</h4>
        <p>Cek apakah cicilan KTA aman dari take-home pay</p>
      </a>
    </div>
  </section>

</CalculatorLayout>

<style>
.cicilan-secondary {
  margin-top: 12px; padding-top: 12px;
  border-top: 1px dashed rgba(255,255,255,0.15);
  font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.5;
}
.cicilan-secondary strong { color: rgba(255,255,255,0.9); }

.warning-box {
  display: flex; gap: 12px;
  margin-top: 16px; padding: 14px 16px;
  background: rgba(248,113,113,0.12);
  border-left: 3px solid #F87171;
  border-radius: 10px;
  font-size: 13.5px;
  color: #FCA5A5; line-height: 1.55;
}
.warning-icon { flex-shrink: 0; font-size: 18px; }
.warning-box strong { color: #FECACA; }

.action-buttons {
  display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap;
}
.action-buttons .btn-action.primary {
  flex: 1; background: var(--gold); color: var(--navy);
}
.action-buttons .btn-action.primary:hover { background: #FCD34D; }

.advanced-toggle {
  border: 1px dashed var(--line); border-radius: 10px;
  padding: 8px 14px; margin-bottom: 16px;
}
.advanced-toggle summary {
  cursor: pointer; list-style: none;
  font-size: 13.5px; font-weight: 600; color: var(--ink-2);
  display: flex; align-items: center; gap: 6px;
}
.advanced-toggle summary::-webkit-details-marker { display: none; }
.advanced-toggle summary::before {
  content: "▸"; transition: transform .2s; font-size: 12px; color: var(--ink-3);
}
.advanced-toggle[open] summary::before { transform: rotate(90deg); }

.bank-section, .converter-section, .tips-section, .faq-section-calc, .related-section {
  margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--line);
}
.bank-section h2, .converter-section h2, .tips-section h2, .faq-section-calc h2, .related-section h2 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(24px, 3.5vw, 32px);
  margin: 0 0 8px; color: var(--ink);
}
.section-sub { font-size: 14.5px; color: var(--ink-3); margin: 0 0 24px; }
.section-sub strong { color: var(--ink); }

.bank-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 16px;
}
.bank-card {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 20px;
  transition: all .2s;
}
.bank-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}
.bank-name {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--line);
}
.bank-logo {
  width: 48px; height: 48px;
  background: linear-gradient(135deg, #14B8A6, #0D9488);
  color: #fff;
  border-radius: 10px;
  display: grid;
  place-items: center;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-align: center;
  padding: 4px;
}
.bank-name h4 {
  font-size: 15.5px;
  font-weight: 700;
  margin: 0;
  color: var(--ink);
}
.bank-table {
  width: 100%;
  font-size: 13px;
  border-collapse: collapse;
}
.bank-table td {
  padding: 6px 0;
  color: var(--ink-3);
}
.bank-table td:last-child {
  text-align: right;
  color: var(--ink);
  font-weight: 500;
}
.bank-total td {
  padding-top: 10px !important;
  border-top: 1px dashed var(--line);
  color: var(--ink) !important;
  font-weight: 700;
}
.bank-total td:last-child {
  color: #14B8A6 !important;
  font-size: 15px;
}

.converter-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (max-width: 700px) {
  .converter-grid { grid-template-columns: 1fr; }
}
.converter-card {
  background: var(--bg-soft);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 24px;
}
.converter-card h4 {
  font-size: 15.5px;
  font-weight: 700;
  margin: 0 0 12px;
  color: var(--ink);
}
.converter-card p {
  font-size: 14px;
  color: var(--ink-2);
  margin: 0 0 12px;
  line-height: 1.5;
}
.converter-card p:last-child { margin-bottom: 0; }
.converter-result {
  font-family: var(--font-display);
  font-size: 42px;
  line-height: 1;
  color: #14B8A6;
  margin: 12px 0;
}
.converter-result small {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--ink-3);
  margin-left: 4px;
}
.converter-hint {
  font-size: 13px !important;
  color: var(--ink-3) !important;
}

.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}
.tip-card {
  background: var(--bg-soft); border-radius: 16px;
  padding: 22px; border: 1px solid var(--line);
}
.tip-icon { font-size: 28px; margin-bottom: 10px; }
.tip-card h4 {
  font-size: 15.5px; font-weight: 700; margin: 0 0 8px; color: var(--ink);
}
.tip-card p {
  font-size: 13.5px; color: var(--ink-3); line-height: 1.55; margin: 0;
}

.faq-section-calc .faq-list { max-width: 100%; }
.faq-section-calc .faq-item {
  background: #fff; border: 1px solid var(--line);
  border-radius: 14px; margin-bottom: 10px; overflow: hidden;
}
.faq-section-calc .faq-item summary {
  list-style: none; cursor: pointer; padding: 16px 20px;
  font-weight: 600; font-size: 14.5px; color: var(--ink);
  display: flex; justify-content: space-between; align-items: center;
}
.faq-section-calc .faq-item summary::-webkit-details-marker { display: none; }
.faq-section-calc .faq-item summary::after {
  content: "+"; font-size: 22px; color: var(--ink-3); transition: transform .2s;
}
.faq-section-calc .faq-item[open] summary::after {
  transform: rotate(45deg); color: var(--blue);
}
.faq-section-calc .faq-answer {
  padding: 0 20px 18px; font-size: 14px;
  color: var(--ink-2); line-height: 1.6;
}
.faq-section-calc .faq-answer p { margin: 0 0 8px; }
.faq-section-calc .faq-answer p:last-child { margin-bottom: 0; }

.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.related-card {
  display: flex; flex-direction: column; padding: 22px;
  background: #fff; border: 1px solid var(--line);
  border-radius: 16px; text-decoration: none; color: var(--ink);
  transition: all .2s;
}
.related-card:hover {
  transform: translateY(-2px); box-shadow: var(--shadow-lg);
  color: var(--ink); text-decoration: none;
}
.related-icon { font-size: 32px; margin-bottom: 10px; }
.related-card h4 { font-size: 15.5px; font-weight: 700; margin: 0 0 6px; }
.related-card p { font-size: 13px; color: var(--ink-3); margin: 0; }

@media print {
  .site-header, .site-footer, .breadcrumb, .action-buttons,
  .tips-section, .faq-section-calc, .related-section { display: none !important; }
  .calc-page { padding: 0; }
  .calc-panel-dark { background: #fff !important; color: #000 !important; border: 1px solid #ccc; }
  .calc-panel-dark * { color: #000 !important; }
  .result-main .value { color: #000 !important; }
}
</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';
import { hitungCicilan, hitungTotalBunga } from '../utils/loan.js';

const $ = (id) => document.getElementById(id);

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

function updateBungaHint() {
  const jenis = $('jenisBunga').value;
  if (jenis === 'flat') {
    $('bungaHint').textContent = 'KTA flat 0,9-1,5%/bulan';
    $('bungaUnit').textContent = '% /bulan';
    $('bunga').value = '1.0';
  } else {
    $('bungaHint').textContent = 'KTA efektif setara ~12-21%/tahun';
    $('bungaUnit').textContent = '% /tahun';
    $('bunga').value = '15';
  }
}

function recalculate() {
  const pinjaman = parseRupiah($('pinjaman').value);
  const tenor = parseInt($('tenor').value) || 12;
  const jenisBunga = $('jenisBunga').value;
  const bungaInput = parseFloat($('bunga').value) || 0;
  const provisiPersen = parseFloat($('provisi').value) || 0;
  const asuransiPersen = parseFloat($('asuransi').value) || 0;
  const admin = parseRupiah($('admin').value);

  if (!pinjaman || pinjaman <= 0) return;

  let cicilan, totalBunga;
  if (jenisBunga === 'flat') {
    totalBunga = pinjaman * (bungaInput / 100) * tenor;
    cicilan = (pinjaman + totalBunga) / tenor;
  } else {
    cicilan = hitungCicilan(pinjaman, bungaInput, tenor);
    totalBunga = hitungTotalBunga(pinjaman, bungaInput, tenor);
  }

  const totalBayar = cicilan * tenor;
  const provisi = pinjaman * (provisiPersen / 100);
  const asuransi = pinjaman * (asuransiPersen / 100);
  const biayaAwal = provisi + asuransi + admin;
  const jumlahDiterima = pinjaman - biayaAwal;

  const apr = (totalBunga / pinjaman) / (tenor / 12) * 100;

  $('cicilanPerBulan').textContent = formatRupiah(cicilan);
  $('cicilanSecondary').innerHTML = `Pinjaman cair (setelah biaya awal): <strong>${formatRupiah(jumlahDiterima)}</strong>`;
  $('resJumlahDiterima').textContent = formatRupiah(jumlahDiterima);
  $('resTotalBunga').textContent = formatRupiah(totalBunga);
  $('resTotalBayar').textContent = formatRupiah(totalBayar);
  $('resApr').textContent = formatPercent(apr, 1);

  const totalCostRatio = (totalBunga / pinjaman) * 100;
  if (totalCostRatio > 30) {
    $('warningBox').style.display = 'flex';
    $('warningText').innerHTML = `<strong>⚠️ Total bunga ${formatPercent(totalCostRatio, 1)} dari pinjaman.</strong> Pertimbangkan alternatif: gadai BPKB, KPR refinancing, atau pinjaman koperasi yang bunganya lebih rendah.`;
  } else {
    $('warningBox').style.display = 'none';
  }

  $('pinjamanDisplay').textContent = formatRupiah(pinjaman);
  $('tenorDisplay').textContent = `${tenor} bulan`;

  const banks = {
    Bca: 0.99,
    Mandiri: 1.05,
    Permata: 0.88,
    Ocbc: 0.79,
  };
  Object.entries(banks).forEach(([key, bungaFlat]) => {
    const b = pinjaman * (bungaFlat / 100) * tenor;
    const c = (pinjaman + b) / tenor;
    const total = pinjaman + b;
    $(`bank${key}Cicilan`).textContent = formatRupiah(c);
    $(`bank${key}Total`).textContent = formatRupiah(total);
  });

  const currentFlat = jenisBunga === 'flat' ? bungaInput : (bungaInput / 12);
  const efektifApprox = currentFlat * 1.8;
  const aprFromFlat = efektifApprox * 12;
  $('convFlat').textContent = formatPercent(currentFlat, 2).replace('%','');
  $('convEfektif').textContent = '~' + formatPercent(efektifApprox, 2).replace('%','');
  $('convAprFromFlat').textContent = formatPercent(aprFromFlat, 1).replace('%','');
}

$('jenisBunga').addEventListener('change', () => {
  updateBungaHint();
  recalculate();
});
['tenor','bunga','provisi','asuransi'].forEach(id => {
  $(id).addEventListener('input', recalculate);
  $(id).addEventListener('change', recalculate);
});

updateBungaHint();
recalculate();
</script>