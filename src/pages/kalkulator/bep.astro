  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#2563EB;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#0891B2;border-color:#0891B2;background:#ECFEFF}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#EFF4FF;color:#2563EB;border:1px solid #D6E4FF;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#E0EBFF}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#2563EB}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#2563EB;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#8FB4FF}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(37,99,235,.16);color:#8FB4FF;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(37,99,235,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#3B82F6}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}

  /* ==== investasi: stacked composition bar ==== */
  .aic-stack{display:flex;height:24px;border-radius:6px;overflow:hidden;margin-top:2px}
  .aic-stack .seg{display:flex;align-items:center;justify-content:center;min-width:0}
  .aic-stack .seg-modal{background:#DBEAFE}
  .aic-stack .seg-cuan{background:#10B981}
  .aic-stack .seg-lbl{font-size:10px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:0 5px}
  .seg-modal .seg-lbl{color:#1E40AF}
  .seg-cuan .seg-lbl{color:#fff}
  .aic-legend{display:flex;gap:16px;margin-top:9px;font-size:11px;color:#475569}
  .aic-legend .dot{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:6px}
  .aic-legend .modal .dot{background:#93C5FD}
  .aic-legend .cuan .dot{background:#10B981}
  .aic-legend b{color:#0A2540}
  .aic-verdict.info{color:#2563EB}
  .aic-verdict b{font-weight:700}
  .aic-dark .aic-stack .seg-modal{background:#24406B}
  .aic-dark .seg-modal .seg-lbl{color:#BFD4FF}
  .aic-dark .aic-legend{color:#A9B7C9}
  .aic-dark .aic-legend b{color:#E8EEF6}
  .aic-dark .aic-legend .modal .dot{background:#3B82F6}
  .aic-dark .aic-verdict.info{color:#8FB4FF}
</style>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC) fn(); else setTimeout(function(){ ready(fn); }, 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { fixed: $('fixed'), harga: $('harga'), variabel: $('variabel'), target: $('target'), proyeksi: $('proyeksi') };
      [els.fixed, els.harga, els.variabel, els.target].forEach(el => { if (el) el.addEventListener('input', HC.fmtInput); });
      /* [#3 guard] Pasang tombol utama LEBIH DULU: walau init lain error, Hitung tetap hidup */
      var _bH = $('btnHitung'); if (_bH) _bH.addEventListener('click', hitung);
      var _bR = $('btnReset'); if (_bR) _bR.addEventListener('click', reset);

      let lastCalc = null;

      function renderSens(fixed, harga, variabel) {
        var body = $('sensBody'); if (!body) return;
        var mk0 = harga - variabel, bep0 = fixed / mk0;
        function bepFor(h, v) { var m = h - v; return { m: m, bep: m > 0 ? fixed / m : null }; }
        var rows = [
          { label: 'Harga jual \u221210%', h: harga * 0.9, v: variabel },
          { label: 'Sekarang', h: harga, v: variabel, base: true },
          { label: 'Harga jual +10%', h: harga * 1.1, v: variabel },
          { label: 'Biaya variabel +10%', h: harga, v: variabel * 1.1 },
          { label: 'Biaya variabel \u221210%', h: harga, v: variabel * 0.9 }
        ];
        var html = '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:12px">'
          + '<thead><tr style="text-align:left;color:var(--text-mute);border-bottom:1px solid var(--border)">'
          + '<th style="padding:6px 8px;font-weight:600">Skenario</th>'
          + '<th style="padding:6px 8px;font-weight:600;text-align:right">Margin/unit</th>'
          + '<th style="padding:6px 8px;font-weight:600;text-align:right">BEP (unit)</th>'
          + '<th style="padding:6px 8px;font-weight:600;text-align:right">vs Sekarang</th></tr></thead><tbody>';
        rows.forEach(function (r) {
          var res = bepFor(r.h, r.v);
          var mTxt = res.m > 0 ? HC.fmt(res.m) : '<span style="color:#DC2626">' + HC.fmt(res.m) + '</span>';
          var bepTxt, deltaTxt;
          if (res.bep === null) {
            bepTxt = '<span style="color:#DC2626">tak tercapai</span>';
            deltaTxt = '<span style="color:#DC2626;font-weight:700">\u26a0 rugi/unit</span>';
          } else {
            bepTxt = Math.ceil(res.bep).toLocaleString('id-ID');
            if (r.base) { deltaTxt = '<span style="color:var(--text-mute)">\u2014</span>'; }
            else {
              var pct = (res.bep - bep0) / bep0 * 100;
              var up = pct > 0.05, down = pct < -0.05;
              var col = up ? '#DC2626' : (down ? '#059669' : 'var(--text-mute)');
              var arr = up ? '\u25b2' : (down ? '\u25bc' : '');
              deltaTxt = '<span style="color:' + col + ';font-weight:700">' + arr + ' ' + (pct > 0 ? '+' : '') + pct.toFixed(0) + '%</span>';
            }
          }
          var rowStyle = r.base ? 'background:#EEF2FF;font-weight:700' : '';
          html += '<tr style="border-bottom:1px solid var(--border);' + rowStyle + '">'
            + '<td style="padding:7px 8px">' + r.label + '</td>'
            + '<td style="padding:7px 8px;text-align:right">' + mTxt + '</td>'
            + '<td style="padding:7px 8px;text-align:right">' + bepTxt + '</td>'
            + '<td style="padding:7px 8px;text-align:right">' + deltaTxt + '</td></tr>';
        });
        html += '</tbody></table></div>';
        var d10 = bepFor(harga * 0.9, variabel), u10 = bepFor(harga * 1.1, variabel);
        if (d10.bep !== null && u10.bep !== null) {
          var pd = (d10.bep - bep0) / bep0 * 100, pu = (u10.bep - bep0) / bep0 * 100;
          html += '<div style="margin-top:10px;padding:11px 13px;border-radius:12px;background:#FFFBEB;border:1px solid #FDE68A;font-size:12.5px;line-height:1.6;color:#92400E">'
            + '<i class="ti ti-bulb"></i> Harga jual turun 10% membuat BEP <b>naik +' + pd.toFixed(0) + '%</b>, sedangkan naik 10% hanya menurunkannya ' + Math.abs(pu).toFixed(0) + '%. '
            + 'Harga jual adalah <b>tuas paling kuat</b> ke titik impasmu \u2014 hati-hati kasih diskon besar, dan naikkan harga sedikit saja bisa mempercepat balik modal.</div>';
        } else if (d10.bep === null) {
          html += '<div style="margin-top:10px;padding:11px 13px;border-radius:12px;background:#FEF2F2;border:1px solid #FECACA;font-size:12.5px;line-height:1.6;color:#991B1B">'
            + '<i class="ti ti-alert-triangle"></i> Marginmu tipis: turun harga 10% saja sudah membuat tiap unit <b>rugi</b> (harga di bawah biaya variabel). Titik impasmu rapuh \u2014 prioritaskan naikkan harga atau tekan biaya variabel.</div>';
        }
        body.innerHTML = html;
      }
      function hitung() {
        const fixed = HC.parseRp(els.fixed.value);
        const harga = HC.parseRp(els.harga.value);
        const variabel = HC.parseRp(els.variabel.value);
        const target = HC.parseRp(els.target.value);

        if (fixed === 0) { HC.toast('Masukkan biaya tetap dulu', 'error'); return; }
        if (harga === 0) { HC.toast('Masukkan harga jual per unit', 'error'); return; }
        if (harga <= variabel) { HC.toast('Harga jual harus di atas biaya variabel', 'error'); return; }

        const mk = harga - variabel;
        const mkRatio = mk / harga * 100;
        const bepUnit = fixed / mk;
        const bepRupiah = bepUnit * harga;

        $('bepUnit').textContent = Math.ceil(bepUnit).toLocaleString('id-ID') + ' unit';
        $('bepMeta').textContent = `setara omzet ${HC.fmt(bepRupiah)}`;
        $('bepRupiah').textContent = HC.fmt(bepRupiah);
        $('mk').textContent = HC.fmt(mk);
        $('mkRatio').textContent = mkRatio.toFixed(1) + '%';
        $('fcOut').textContent = HC.fmt(fixed);

        $('bepInfo').innerHTML = `\ud83c\udfaf Kamu harus menjual <b>${Math.ceil(bepUnit).toLocaleString('id-ID')} unit/bulan</b> (omzet <b>${HC.fmt(bepRupiah)}</b>) hanya untuk menutup biaya \u2014 belum untung. Penjualan ke-${(Math.ceil(bepUnit) + 1).toLocaleString('id-ID')} dan seterusnya barulah menghasilkan laba <b>${HC.fmt(mk)}/unit</b>.`;

        let targetData = null;
        if (target > 0) {
          const unitTarget = (fixed + target) / mk;
          const omzetTarget = unitTarget * harga;
          $('targetSection').style.display = '';
          $('targetBody').innerHTML = `Untuk laba <b>${HC.fmt(target)}/bulan</b>, kamu perlu menjual <b>${Math.ceil(unitTarget).toLocaleString('id-ID')} unit</b> (omzet <b>${HC.fmt(omzetTarget)}</b>) \u2014 yaitu ${Math.ceil(unitTarget - bepUnit).toLocaleString('id-ID')} unit di atas titik impas.`;
          targetData = { target, unitTarget: Math.ceil(unitTarget), omzetTarget };
        } else {
          $('targetSection').style.display = 'none';
        }

        // ===== Grafik Titik Impas =====
        var proyeksi = parseInt(els.proyeksi.value) || 0;
        var xMax = Math.ceil(bepUnit * 2);
        if (proyeksi > xMax) xMax = Math.ceil(proyeksi * 1.15);
        if (xMax < 2) xMax = 2;
        var yMax = harga * xMax;
        var PL = 46, PR = 306, PT = 14, PB = 164;
        var X = function(u) { return (PL + (u / xMax) * (PR - PL)).toFixed(1); };
        var Y = function(v) { return (PB - (v / yMax) * (PB - PT)).toFixed(1); };
        var svg = '<svg viewBox="0 0 320 190" style="width:100%;height:auto" xmlns="http://www.w3.org/2000/svg">';
        svg += '<polygon points="' + X(0) + ',' + Y(0) + ' ' + X(bepUnit) + ',' + Y(bepRupiah) + ' ' + X(0) + ',' + Y(fixed) + '" fill="#FEE2E2"/>';
        svg += '<polygon points="' + X(bepUnit) + ',' + Y(bepRupiah) + ' ' + X(xMax) + ',' + Y(harga * xMax) + ' ' + X(xMax) + ',' + Y(fixed + variabel * xMax) + '" fill="#DCFCE7"/>';
        svg += '<line x1="' + X(0) + '" y1="' + Y(0) + '" x2="' + X(xMax) + '" y2="' + Y(0) + '" stroke="#CBD5E1" stroke-width="1"/>';
        svg += '<line x1="' + X(0) + '" y1="' + Y(0) + '" x2="' + X(0) + '" y2="' + PT + '" stroke="#CBD5E1" stroke-width="1"/>';
        svg += '<line x1="' + X(0) + '" y1="' + Y(fixed) + '" x2="' + X(xMax) + '" y2="' + Y(fixed) + '" stroke="#94A3B8" stroke-width="1.5" stroke-dasharray="4 3"/>';
        svg += '<line x1="' + X(0) + '" y1="' + Y(fixed) + '" x2="' + X(xMax) + '" y2="' + Y(fixed + variabel * xMax) + '" stroke="#DC2626" stroke-width="2"/>';
        svg += '<line x1="' + X(0) + '" y1="' + Y(0) + '" x2="' + X(xMax) + '" y2="' + Y(harga * xMax) + '" stroke="#4F46E5" stroke-width="2"/>';
        svg += '<line x1="' + X(bepUnit) + '" y1="' + Y(0) + '" x2="' + X(bepUnit) + '" y2="' + Y(bepRupiah) + '" stroke="#4338CA" stroke-width="1" stroke-dasharray="3 3"/>';
        svg += '<circle cx="' + X(bepUnit) + '" cy="' + Y(bepRupiah) + '" r="4" fill="#4338CA"/>';
        svg += '<text x="' + X(bepUnit) + '" y="' + (PB + 13) + '" font-size="9" fill="#4338CA" text-anchor="middle" font-weight="700">BEP ' + Math.ceil(bepUnit) + '</text>';
        svg += '<text x="' + X(xMax) + '" y="' + (PB + 13) + '" font-size="8" fill="#94A3B8" text-anchor="end">unit →</text>';
        svg += '<text x="' + PL + '" y="' + (PT - 4) + '" font-size="8" fill="#94A3B8">Rp</text>';
        svg += '</svg>';
        $('bepChart').innerHTML = svg;

        // ===== Margin of Safety =====
        var mosData = null;
        if (proyeksi > 0) {
          var sec = $('mosSection'); sec.style.display = '';
          if (proyeksi >= bepUnit) {
            var mosPct = (proyeksi - bepUnit) / proyeksi * 100;
            var labaP = (proyeksi - bepUnit) * mk;
            sec.style.background = '#F0FDF4'; sec.style.border = '1px solid #BBF7D0';
            $('mosBody').style.color = '#166534';
            $('mosBody').innerHTML = 'Di proyeksi <b>' + proyeksi.toLocaleString('id-ID') + ' unit</b>, kamu <b>' + mosPct.toFixed(1) + '% di atas titik impas</b>. Penjualan boleh turun s/d ' + mosPct.toFixed(1) + '% sebelum mulai rugi. Perkiraan laba: <b>' + HC.fmt(labaP) + '/bulan</b>.';
            mosData = { proyeksi: proyeksi, mosPct: mosPct, laba: labaP, aman: true };
          } else {
            var kurang = Math.ceil(bepUnit) - proyeksi;
            var rugiP = (bepUnit - proyeksi) * mk;
            sec.style.background = '#FEF2F2'; sec.style.border = '1px solid #FECACA';
            $('mosBody').style.color = '#991B1B';
            $('mosBody').innerHTML = 'Proyeksi <b>' + proyeksi.toLocaleString('id-ID') + ' unit</b> masih <b>' + kurang.toLocaleString('id-ID') + ' unit di bawah titik impas</b> — pada level ini usaha masih rugi sekitar <b>' + HC.fmt(rugiP) + '/bulan</b>. Naikkan penjualan/harga atau tekan biaya.';
            mosData = { proyeksi: proyeksi, shortfall: kurang, rugi: rugiP, aman: false };
          }
        } else {
          $('mosSection').style.display = 'none';
        }

        lastCalc = { fixed, harga, variabel, mk, mkRatio, bepUnit: Math.ceil(bepUnit), bepRupiah, target: targetData, mos: mosData };
        var _mosC = null;
        if (mosData) { if (mosData.aman) _mosC = { aman: true, proyeksi: proyeksi.toLocaleString('id-ID'), mosPct: mosData.mosPct.toFixed(1), labaTxt: HC.fmt(mosData.laba) }; else _mosC = { aman: false, proyeksi: proyeksi.toLocaleString('id-ID'), shortfall: mosData.shortfall.toLocaleString('id-ID'), rugiTxt: HC.fmt(mosData.rugi) }; }
        window.HCBep = { bepUnitTxt: Math.ceil(bepUnit).toLocaleString('id-ID'), bepRupiahTxt: HC.fmt(bepRupiah), mkTxt: HC.fmt(mk), mkRatio: mkRatio.toFixed(1), fixedTxt: HC.fmt(fixed), hargaTxt: HC.fmt(harga), variabelTxt: HC.fmt(variabel), target: targetData ? { labaTxt: HC.fmt(target), unit: targetData.unitTarget.toLocaleString('id-ID') } : null, mos: _mosC };
        if (HC.history) HC.history.push('bep', { inputs: HC.history.capture(['fixed','harga','variabel','target','proyeksi']), summary: 'Tetap ' + sRp(lastCalc.fixed) + ' \u00b7 Hrg ' + sRp(lastCalc.harga) + ' \u00b7 Var ' + sRp(lastCalc.variabel), metrics: [{ k: 'BEP', v: lastCalc.bepUnit.toLocaleString('id-ID') + ' unit' }, { k: 'Omzet', v: HC.fmt(lastCalc.bepRupiah) }] });
        renderSens(fixed, harga, variabel);
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('BEP berhasil dihitung!');
      }

      function reset() {
        els.fixed.value = '5.000.000'; els.harga.value = '12.500'; els.variabel.value = '7.500'; els.target.value = '0'; els.proyeksi.value = '0';
        $('targetSection').style.display = 'none'; $('mosSection').style.display = 'none';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        scenA = null; scenB = null; var _sr = $('scenResult'); if (_sr) { _sr.style.display = 'none'; _sr.innerHTML = ''; } lastCalc = null; window.HCBep = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        let insight = `Titik impas ${c.bepUnit.toLocaleString('id-ID')} unit/bulan (omzet ${HC.fmt(c.bepRupiah)}). Margin kontribusi ${HC.fmt(c.mk)}/unit (${c.mkRatio.toFixed(1)}%). Di atas BEP, tiap unit beri laba ${HC.fmt(c.mk)}.`;
        if (c.target) insight += ` Untuk laba ${HC.fmt(c.target.target)}/bln perlu jual ${c.target.unitTarget.toLocaleString('id-ID')} unit.`;
        if (c.mos && c.mos.aman) insight += ` Margin of safety ${c.mos.mosPct.toFixed(1)}% di proyeksi ${c.mos.proyeksi.toLocaleString('id-ID')} unit (laba ${HC.fmt(c.mos.laba)}).`;
        insight += ' Estimasi edukatif.';
        const results = [
          { label: 'BEP (unit)', value: c.bepUnit.toLocaleString('id-ID') + ' unit', highlight: true },
          { label: 'BEP (omzet)', value: HC.fmt(c.bepRupiah), highlight: true },
          { label: 'Margin Kontribusi/unit', value: HC.fmt(c.mk) },
          { label: 'Rasio MK', value: c.mkRatio.toFixed(1) + '%' },
        ];
        if (c.target) results.push({ label: 'Unit utk Target Laba', value: c.target.unitTarget.toLocaleString('id-ID') + ' unit' });
        if (c.mos && c.mos.aman) results.push({ label: 'Margin of Safety', value: c.mos.mosPct.toFixed(1) + '%' });
        return HC.buildReportCard({
          title: '\ud83c\udfaf Hitung BEP (Titik Impas)',
          color: '#4F46E5', color2: '#4338CA',
          heroLabel: 'BEP (Titik Impas)',
          heroValue: c.bepUnit.toLocaleString('id-ID') + ' unit',
          heroSubtext: `setara omzet ${HC.fmt(c.bepRupiah)}/bulan`,
          inputs: [
            { label: '\ud83c\udfe2 Biaya Tetap', value: HC.fmt(c.fixed) },
            { label: '\ud83c\udff7\ufe0f Harga Jual/unit', value: HC.fmt(c.harga) },
            { label: '\ud83d\udce6 Biaya Variabel/unit', value: HC.fmt(c.variabel) },
          ],
          results, insight, slug: 'bep',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        let t = `\ud83c\udfaf *Hitung BEP - HitungCerdas*\n\nBiaya tetap/bln: ${HC.fmt(c.fixed)}\nHarga jual/unit: ${HC.fmt(c.harga)}\nBiaya variabel/unit: ${HC.fmt(c.variabel)}\n\n\ud83c\udfaf *BEP: ${c.bepUnit.toLocaleString('id-ID')} unit/bln*\n\ud83d\udcb0 Setara omzet: ${HC.fmt(c.bepRupiah)}\n\ud83d\udcc8 Margin kontribusi: ${HC.fmt(c.mk)}/unit (${c.mkRatio.toFixed(1)}%)`;
        if (c.target) t += `\n\n\ud83c\udfc6 Target laba ${HC.fmt(c.target.target)}: jual ${c.target.unitTarget.toLocaleString('id-ID')} unit`;
        t += `\n\nHitung di: https://hitungcerdas.net/kalkulator/bep`;
        return t;
      }

      // ===== Skenario A vs B =====
      var scenA = null, scenB = null;
      function scenFmt(v, t) { if (t === 'pct') return v.toFixed(1) + '%'; if (t === 'unit') return Math.round(v).toLocaleString('id-ID') + ' unit'; return HC.fmt(v); }
      function sRp(v) { if (v >= 1e6) return (v / 1e6).toFixed(v % 1e6 ? 1 : 0).replace('.', ',') + 'jt'; if (v >= 1e3) return (v / 1e3).toFixed(v % 1e3 ? 1 : 0).replace('.', ',') + 'rb'; return String(v); }
      function buildSnap() {
        var c = lastCalc;
        return { label: 'Tetap ' + sRp(c.fixed) + ' \u00b7 Hrg ' + sRp(c.harga) + ' \u00b7 Var ' + sRp(c.variabel), rows: [ { k: 'BEP (Unit)', v: c.bepUnit, t: 'unit' }, { k: 'BEP (Omzet)', v: c.bepRupiah, t: 'rp' }, { k: 'Margin Kontribusi/unit', v: c.mk, t: 'rp' } ] };
      }
      function snapScenario(slot) {
        hitung();
        if (!lastCalc) { HC.toast('Isi data dulu sebelum simpan skenario', 'error'); return; }
        var snap = buildSnap();
        if (slot === 'A') scenA = snap; else scenB = snap;
        HC.toast('Tersimpan sebagai Skenario ' + slot);
        renderScenario();
      }
      function renderScenario() {
        var box = $('scenResult');
        if (!box) return;
        if (!scenA && !scenB) { box.style.display = 'none'; box.innerHTML = ''; return; }
        box.style.display = '';
        var ref = scenA || scenB, both = scenA && scenB;
        var html = '<table class="compare-table"><thead><tr><th>Metrik</th>'
          + '<th class="right">A' + (scenA ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenA.label + '</span>' : '') + '</th>'
          + '<th class="right">B' + (scenB ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenB.label + '</span>' : '') + '</th>'
          + (both ? '<th class="right">Selisih</th>' : '') + '</tr></thead><tbody>';
        for (var i = 0; i < ref.rows.length; i++) {
          var rk = ref.rows[i].k, t = ref.rows[i].t;
          var av = scenA ? scenFmt(scenA.rows[i].v, t) : '\u2014';
          var bv = scenB ? scenFmt(scenB.rows[i].v, t) : '\u2014';
          var sel = '';
          if (both) { var d = scenB.rows[i].v - scenA.rows[i].v; sel = '<td class="right">' + (Math.abs(d) < 0.5 ? '\u2014' : (d > 0 ? '+' : '\u2212') + scenFmt(Math.abs(d), t)) + '</td>'; }
          html += '<tr' + (i === 0 ? ' class="active"' : '') + '><td>' + rk + '</td><td class="right">' + av + '</td><td class="right">' + bv + '</td>' + sel + '</tr>';
        }
        html += '</tbody></table>';
        if (both) {
          var d0 = scenB.rows[0].v - scenA.rows[0].v, msg;
          if (Math.abs(d0) < 0.5) msg = 'Kedua skenario setara di BEP unit.';
          else { var bBetter = d0 < 0; msg = 'Skenario ' + (bBetter ? 'B' : 'A') + ' lebih efisien \u2014 BEP lebih rendah, selisih ' + scenFmt(Math.abs(d0), 'unit') + '.'; }
          html += '<p style="font-size:13px;margin-top:8px;font-weight:600;color:var(--green-dark,#047857)">' + msg + '</p>';
        }
        box.innerHTML = html;
        box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      document.querySelectorAll('.adv-toggle').forEach(function (t) { t.addEventListener('click', function () { t.parentElement.classList.toggle('open'); }); });
      var _bSA = $('btnScenA'); if (_bSA) _bSA.addEventListener('click', function () { snapScenario('A'); });
      var _bSB = $('btnScenB'); if (_bSB) _bSB.addEventListener('click', function () { snapScenario('B'); });
      var _bSR = $('btnScenReset'); if (_bSR) _bSR.addEventListener('click', function () { scenA = null; scenB = null; renderScenario(); HC.toast('Skenario direset', 'info'); });

            function renderHist() {
        if (HC.history) HC.history.render('bep', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('exportImg').addEventListener('click', () => { if (!window.html2canvas) { HC.toast('Fitur simpan gambar belum siap, coba sebentar lagi', 'info'); return; } const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'bep-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { if (!window.html2canvas) { HC.toast('Fitur simpan gambar belum siap, coba sebentar lagi', 'info'); return; } const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'bep'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { if (!window.html2canvas) { HC.toast('Fitur simpan gambar belum siap, coba sebentar lagi', 'info'); return; } const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'bep-' + Date.now()); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function renderGround(){
        var d=window.HCBep;
        var ctx='<div class="aic-ctx"><i class="ti ti-target-arrow"></i> BEP: <b>'+(d?esc(d.bepUnitTxt)+' unit/bln':'-')+'</b></div>';
        if(!d){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat titik impas & margin kontribusimu.</div>'; return; }
        var rows='<div style="display:flex;justify-content:space-between;font-size:12px;margin:4px 0"><span>BEP omzet/bln</span><b>'+esc(d.bepRupiahTxt)+'</b></div>'
          +'<div style="display:flex;justify-content:space-between;font-size:12px;margin:4px 0"><span>Margin kontribusi/unit</span><b>'+esc(d.mkTxt)+' ('+d.mkRatio+'%)</b></div>';
        var verdict='';
        if(d.mos){ if(d.mos.aman) verdict='<div class="aic-verdict good"><i class="ti ti-circle-check"></i> Proyeksimu '+d.mos.mosPct+'% di atas titik impas (aman).</div>'; else verdict='<div class="aic-verdict warn"><i class="ti ti-alert-triangle"></i> Proyeksi masih '+d.mos.shortfall+' unit di bawah titik impas (rugi).</div>'; }
        ground.innerHTML=ctx+'<div style="margin:8px 0">'+rows+'</div>'+verdict;
      }
      function buildContext(){
        var d=window.HCBep;
        if(!d) return 'Pengguna belum menghitung BEP. Minta mereka mengisi biaya tetap, harga jual, dan biaya variabel per unit lalu klik Hitung Sekarang.';
        var lines=['Kalkulator: BEP / Break-Even Point (titik impas usaha, basis per bulan).',
          'Biaya tetap per bulan: '+d.fixedTxt+'. Harga jual per unit: '+d.hargaTxt+'. Biaya variabel per unit: '+d.variabelTxt+'.',
          'Margin kontribusi: '+d.mkTxt+' per unit ('+d.mkRatio+'% dari harga jual).',
          'BEP (titik impas): '+d.bepUnitTxt+' unit per bulan, setara omzet '+d.bepRupiahTxt+' per bulan.'];
        if(d.target) lines.push('Untuk target laba '+d.target.labaTxt+'/bulan, perlu menjual '+d.target.unit+' unit.');
        if(d.mos){ if(d.mos.aman) lines.push('Pada proyeksi '+d.mos.proyeksi+' unit: '+d.mos.mosPct+'% di atas titik impas (aman), perkiraan laba '+d.mos.labaTxt+'/bulan.'); else lines.push('Pada proyeksi '+d.mos.proyeksi+' unit: masih '+d.mos.shortfall+' unit di bawah titik impas, rugi sekitar '+d.mos.rugiTxt+'/bulan.'); }
        lines.push('ATURAN UNTUKMU (AI): Gunakan HANYA angka di atas, jangan mengarang. Bantu UMKM memahami titik impas dan margin kontribusi, serta cara MENURUNKAN BEP: tekan biaya tetap (sewa, gaji tetap), naikkan harga jual, atau turunkan biaya variabel per unit (negosiasi bahan, efisiensi). Ingat BEP ini dihitung per bulan dari biaya tetap bulanan. Bahasa sederhana dan suportif. Untuk hitung HPP atau harga jual, arahkan ke kalkulator HPP / Harga Jual. Jangan menjawab di luar topik bisnis dan titik impas.');
        return lines.join('\n');
      }
      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Kenapa BEP-ku setinggi ini?','Gimana biar cepat balik modal?','Apa itu margin kontribusi?','Biaya tetap vs variabel apa bedanya?','Kalau harga dinaikkan, BEP turun?','BEP-ku sehat gak buat UMKM?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Jelaskan titik impasku','Gimana biar BEP turun?','Apa itu margin kontribusi?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
</Layout>
