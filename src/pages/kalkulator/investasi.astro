<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { modal: $('modal'), topup: $('topup'), ret: $('ret'), tahun: $('tahun'),
                    inflasiToggle: $('inflasiToggle'), inflasiSkenario: $('inflasiSkenario'),
                    inflasiBox: $('inflationBox') };
      [els.modal, els.topup].forEach(el => el.addEventListener('input', HC.fmtInput));
      var goalTargetEl = $('goalTarget'); if (goalTargetEl) goalTargetEl.addEventListener('input', HC.fmtInput);
      document.querySelectorAll('.quick-btns button').forEach(btn => btn.addEventListener('click', () => { els.ret.value = btn.dataset.r; }));
      var pj=$('pajakInstrumen'); if(pj) pj.addEventListener('change', renderPajak);
      els.inflasiToggle.addEventListener('change', () => els.inflasiBox.classList.toggle('active', els.inflasiToggle.checked));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      function compound(pv, topup, retYr, tahun) {
        const r = retYr / 100 / 12;
        const n = tahun * 12;
        // FV of lump sum + FV of annuity
        const fvLump = pv * Math.pow(1 + r, n);
        const fvAnnuity = r === 0 ? topup * n : topup * ((Math.pow(1 + r, n) - 1) / r);
        return fvLump + fvAnnuity;
      }

      let lastCalc = null;

      function hitung() {
        const modal = HC.parseRp(els.modal.value);
        const topup = HC.parseRp(els.topup.value);
        const ret = parseFloat(els.ret.value) || 0;
        const tahun = parseInt(els.tahun.value);
        if (modal === 0 && topup === 0) { HC.toast('Masukkan modal awal atau top-up dulu', 'error'); return; }

        const fv = compound(modal, topup, ret, tahun);
        const totalSetor = modal + topup * tahun * 12;
        const untung = fv - totalSetor;

        const useInflasi = els.inflasiToggle.checked;
        let realFv = fv, realReturn = ret, inflasi = 0, skenario = null;
        if (useInflasi) {
          skenario = els.inflasiSkenario.value;
          inflasi = HC.INFLATION_RATES[skenario];
          realReturn = ret - inflasi;
          realFv = fv / Math.pow(1 + inflasi / 100, tahun);
        }

        $('nilaiAkhir').textContent = HC.fmt(fv);
        $('metaInfo').textContent = `${tahun} tahun · Return ${ret}%/thn${useInflasi ? ` (real ${realReturn.toFixed(1)}%)` : ''}`;
        $('totalSetor').textContent = HC.fmt(totalSetor);
        $('totalUntung').textContent = HC.fmt(untung);

        if (useInflasi) {
          $('realReturnItem').style.display = '';
          $('realValueItem').style.display = '';
          $('realReturnVal').textContent = realReturn.toFixed(2) + '%';
          $('realValue').textContent = HC.fmt(realFv);
        } else {
          $('realReturnItem').style.display = 'none';
          $('realValueItem').style.display = 'none';
        }

        // Milestones (5-year breakdown)
        const checkpoints = [1, 3, 5, 10, 15, 20, 25, 30].filter(y => y <= tahun);
        if (!checkpoints.includes(tahun)) checkpoints.push(tahun);
        $('milestoneBody').innerHTML = checkpoints.map(y => {
          const v = compound(modal, topup, ret, y);
          const setor = modal + topup * y * 12;
          return `<tr class="${y === tahun ? 'active' : ''}"><td>Tahun ${y}</td><td class="right">${HC.fmt(setor)}</td><td class="right">${HC.fmt(v)}</td><td class="right" style="color:var(--green-dark);font-weight:700">+${HC.fmt(v - setor)}</td></tr>`;
        }).join('');

        // Compare returns
        const compares = [
          { label: '🏦 Deposito', r: 4 },
          { label: '🛡️ ORI/SBR', r: 6 },
          { label: '📊 Reksadana Campuran', r: 8 },
          { label: '📈 Reksadana Saham', r: 12 },
          { label: '🥇 Emas Antam (avg)', r: 8.5 },
        ];
        $('returnBody').innerHTML = compares.map(c => {
          const v = compound(modal, topup, c.r, tahun);
          return `<tr class="${Math.abs(c.r - ret) < 0.5 ? 'active' : ''}"><td>${c.label}</td><td class="right">${c.r}%/thn</td><td class="right">${HC.fmt(v)}</td><td class="right" style="color:var(--green-dark)">+${HC.fmt(v - totalSetor)}</td></tr>`;
        }).join('');

        lastCalc = { modal, topup, ret, tahun, fv, totalSetor, untung, useInflasi, skenario, inflasi, realReturn, realFv };
        renderPajak();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Proyeksi berhasil dihitung!');
      }

      function renderPajak() {
        if (!lastCalc) return;
        const fv = lastCalc.fv, untung = Math.max(0, lastCalc.untung);
        const t = $('pajakInstrumen').value;
        let pajak = 0, rate = '';
        if (t === 'reksadana') { pajak = 0; rate = '0% — bebas pajak di level investor'; }
        else if (t === 'deposito') { pajak = untung * 0.20; rate = '20% × keuntungan (bunga)'; }
        else if (t === 'obligasi') { pajak = untung * 0.10; rate = '10% × keuntungan (kupon)'; }
        else if (t === 'saham') { pajak = fv * 0.001; rate = '0,1% × nilai jual di bursa'; }
        else if (t === 'crypto') { pajak = fv * 0.0021; rate = '0,21% PPh final × nilai jual (PPN dihapus 2026)'; }
        const net = fv - pajak;
        $('pajakBody').innerHTML =
          `<div class="result-grid">`
          + `<div class="result-item"><div class="result-item-label">Nilai Akhir (kotor)</div><div class="result-item-value">${HC.fmt(fv)}</div></div>`
          + `<div class="result-item"><div class="result-item-label">Estimasi Pajak</div><div class="result-item-value result-warn">${pajak > 0 ? '−' + HC.fmt(pajak) : 'Rp 0'}</div></div>`
          + `<div class="result-item"><div class="result-item-label">Nilai Akhir Bersih</div><div class="result-item-value result-strong">${HC.fmt(net)}</div></div>`
          + `<div class="result-item"><div class="result-item-label">Tarif Pajak</div><div class="result-item-value" style="font-size:12px;line-height:1.4">${rate}</div></div>`
          + `</div>`;
      }


      // ===== Skenario A vs B =====
      let scenA = null, scenB = null;
      function scenFmt(v, t) { return t === 'pct' ? v.toFixed(1) + '%' : HC.fmt(v); }
      function buildSnap() { var c = lastCalc; return { label: c.tahun + 'thn @ ' + c.ret + '%', rows: [ {k:'Nilai Akhir', v:c.fv, t:'rp'}, {k:'Total Setor', v:c.totalSetor, t:'rp'}, {k:'Keuntungan', v:c.untung, t:'rp'} ] }; }
      function snapScenario(slot) {
        hitung(); // refresh dari input terkini agar snapshot selalu akurat (anti lupa klik Hitung)
        if (!lastCalc) { HC.toast('Isi data dulu sebelum simpan skenario', 'error'); return; }
        var snap = buildSnap();
        if (slot === 'A') scenA = snap; else scenB = snap;
        HC.toast('Tersimpan sebagai Skenario ' + slot + ' (' + snap.label + ')');
        renderScenario();
        var _sb = $('scenResult'); if (_sb) _sb.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      function renderScenario() {
        var box = $('scenResult');
        if (!scenA && !scenB) { box.style.display = 'none'; return; }
        box.style.display = '';
        var ref = scenA || scenB, both = scenA && scenB;
        var html = '<table class="compare-table"><thead><tr><th>Metrik</th>'
          + '<th class="right">A' + (scenA ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenA.label + '</span>' : '') + '</th>'
          + '<th class="right">B' + (scenB ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenB.label + '</span>' : '') + '</th>'
          + (both ? '<th class="right">Selisih</th>' : '') + '</tr></thead><tbody>';
        for (var i = 0; i < ref.rows.length; i++) {
          var k = ref.rows[i].k, t = ref.rows[i].t;
          var av = scenA ? scenFmt(scenA.rows[i].v, t) : '—';
          var bv = scenB ? scenFmt(scenB.rows[i].v, t) : '—';
          var sel = '';
          if (both) { var d = scenB.rows[i].v - scenA.rows[i].v; sel = '<td class="right">' + (Math.abs(d) < 0.005 ? '—' : (d > 0 ? '+' : '\u2212') + scenFmt(Math.abs(d), t)) + '</td>'; }
          html += '<tr' + (i === 0 ? ' class="active"' : '') + '><td>' + k + '</td><td class="right">' + av + '</td><td class="right">' + bv + '</td>' + sel + '</tr>';
        }
        html += '</tbody></table>';
        if (both) {
          var lower = false, d = scenB.rows[0].v - scenA.rows[0].v, pk = scenA.rows[0].k, t0 = scenA.rows[0].t;
          var msg;
          if (Math.abs(d) < 0.005) msg = 'Kedua skenario setara di ' + pk + '.';
          else { var bBetter = lower ? d < 0 : d > 0; msg = 'Skenario ' + (bBetter ? 'B' : 'A') + ' lebih ' + (lower ? 'hemat' : 'unggul') + ' \u2014 ' + pk + ' selisih ' + scenFmt(Math.abs(d), t0) + '.'; }
          html += '<p style="font-size:13px;margin-top:8px;font-weight:600;color:var(--green-dark,#047857)">' + msg + '</p>';
        }
        box.innerHTML = html;
        box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      var bSA = $('btnScenA'); if (bSA) bSA.addEventListener('click', function () { snapScenario('A'); });
      var bSB = $('btnScenB'); if (bSB) bSB.addEventListener('click', function () { snapScenario('B'); });
      var bSR = $('btnScenReset'); if (bSR) bSR.addEventListener('click', function () { scenA = null; scenB = null; renderScenario(); HC.toast('Skenario direset', 'info'); });

      function reset() {
        scenA = null; scenB = null; var _sr=$('scenResult'); if(_sr) _sr.style.display='none';
        els.modal.value = '10.000.000'; els.topup.value = '1.000.000'; els.ret.value = '10';
        els.tahun.value = '10'; els.inflasiToggle.checked = false; els.inflasiBox.classList.remove('active');
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        let insight;
        if (c.useInflasi) {
          const beat = c.realReturn > 0;
          insight = beat
            ? `Real return ${c.realReturn.toFixed(2)}% MENGALAHKAN inflasi ${c.inflasi}%. Daya beli investasi naik ${HC.fmt(c.realFv - c.modal - c.topup * c.tahun * 12)}.`
            : `⚠️ Real return ${c.realReturn.toFixed(2)}% di bawah inflasi! Daya beli investasi TURUN. Cari instrumen dengan return lebih tinggi.`;
        } else {
          insight = `Compound effect ${c.tahun} tahun menggandakan modal ${((c.fv / c.totalSetor)).toFixed(1)}× lipat. ${c.ret >= 8 ? 'Return cukup baik untuk lawan inflasi.' : 'Pertimbangkan instrumen dengan return lebih tinggi (reksadana saham, ORI).'}`;
        }

        const inputs = [
          { label: '💰 Modal Awal', value: HC.fmt(c.modal) },
          { label: '📥 Top-up/Bulan (DCA)', value: HC.fmt(c.topup) },
          { label: '📊 Return Tahunan', value: `${c.ret}% (nominal)` },
          { label: '📅 Jangka Waktu', value: `${c.tahun} tahun` },
        ];
        if (c.useInflasi) {
          inputs.push({ label: '🔥 Inflasi Asumsi', value: `${c.inflasi}% (${c.skenario})` });
          inputs.push({ label: '✨ Real Return', value: `${c.realReturn.toFixed(2)}%` });
        }

        const results = [
          { label: 'Nilai Akhir', value: HC.fmt(c.fv), highlight: true },
          { label: 'Total Setor', value: HC.fmt(c.totalSetor) },
          { label: 'Total Keuntungan', value: HC.fmt(c.untung), highlight: true },
          { label: 'Multiplier', value: `${(c.fv / c.totalSetor).toFixed(2)}×` },
        ];
        if (c.useInflasi) {
          results.push({ label: 'Daya Beli Real', value: HC.fmt(c.realFv) });
          results.push({ label: 'Selisih Inflasi', value: HC.fmt(c.fv - c.realFv) });
        }

        return HC.buildReportCard({
          title: '📈 Proyeksi Investasi Compound',
          color: '#10B981', color2: '#065F46',
          heroLabel: 'Nilai Akhir Investasi',
          heroValue: HC.fmt(c.fv),
          heroSubtext: `${c.tahun} tahun · Return ${c.ret}%/thn${c.useInflasi ? ` · Real ${c.realReturn.toFixed(1)}%` : ''}`,
          inputs, results, insight, slug: 'investasi',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `📈 *Proyeksi Investasi - HitungCerdas*\n\nModal: ${HC.fmt(c.modal)}\nTop-up: ${HC.fmt(c.topup)}/bln\nReturn: ${c.ret}%/thn\nDurasi: ${c.tahun} tahun${c.useInflasi ? `\nInflasi: ${c.inflasi}%` : ''}\n\n💰 *Nilai Akhir: ${HC.fmt(c.fv)}*\n📊 Total Setor: ${HC.fmt(c.totalSetor)}\n💵 Keuntungan: +${HC.fmt(c.untung)}${c.useInflasi ? `\n✨ Real Value: ${HC.fmt(c.realFv)}` : ''}\n\nHitung: https://hitungcerdas.net/kalkulator/investasi`;
      }

      function hitungGoal() {
        const target = HC.parseRp($('goalTarget').value);
        const modal = HC.parseRp(els.modal.value);
        const ret = parseFloat(els.ret.value) || 0;
        const tahun = parseInt(els.tahun.value);
        if (target <= 0) { HC.toast('Masukkan target nominal dulu', 'error'); return; }
        const r = ret / 100 / 12, n = tahun * 12;
        const fvModal = modal * Math.pow(1 + r, n);
        const annuityFactor = r === 0 ? n : ((Math.pow(1 + r, n) - 1) / r);
        const topupNeeded = (target - fvModal) / annuityFactor;
        const box = $('goalResult');
        box.style.display = '';
        if (topupNeeded <= 0) {
          box.innerHTML = `✅ Modal awal <b>${HC.fmt(modal)}</b> dengan return ${ret}%/thn <b>sudah cukup</b> mencapai <b>${HC.fmt(target)}</b> dalam ${tahun} tahun — tanpa perlu nabung bulanan.`;
        } else {
          const totalSetor = modal + topupNeeded * n;
          const dariBunga = target - totalSetor;
          box.innerHTML = `🎯 Untuk capai <b>${HC.fmt(target)}</b> dalam <b>${tahun} tahun</b> (asumsi return ${ret}%/thn), kamu perlu nabung:<br><b style="color:var(--green-dark);font-size:16px">${HC.fmt(topupNeeded)}/bulan</b><br><span style="color:var(--text-mute);font-size:12px">Total setoran ${HC.fmt(totalSetor)} + hasil bunga berbunga ${HC.fmt(dariBunga)}.</span>`;
        }
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      var btnGoal = $('btnGoal'); if (btnGoal) btnGoal.addEventListener('click', hitungGoal);
      // Smart-link: terima ?topup= / ?modal= dari Gaji Bersih, auto-isi & hitung
      (function(){ try {
        var q = new URLSearchParams(location.search), tu = q.get('topup'), md = q.get('modal'), did = false;
        if (tu && !isNaN(+tu) && +tu > 0) { els.topup.value = Number(tu).toLocaleString('id-ID'); did = true; }
        if (md && !isNaN(+md) && +md > 0) { els.modal.value = Number(md).toLocaleString('id-ID'); did = true; }
        if (did) { hitung(); HC.toast('Nilai dari Gaji Bersih sudah diisi'); }
      } catch(e){} })();
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'investasi-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'investasi'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });

      // ── Salin Link Hasil (share via URL) ──
      function buildShareUrl(){
        var p = new URLSearchParams();
        p.set('md', String(HC.parseRp(els.modal.value)||0));
        p.set('tu', String(HC.parseRp(els.topup.value)||0));
        p.set('rt', els.ret.value||'0');
        p.set('th', els.tahun.value);
        p.set('inf', els.inflasiToggle.checked ? '1' : '0');
        p.set('sk', els.inflasiSkenario.value);
        return location.origin + location.pathname + '?' + p.toString();
      }
      function setNum(el, val){ el.value = val; el.dispatchEvent(new Event('input', {bubbles:true})); }
      function loadFromUrl(){
        var q = new URLSearchParams(location.search);
        if (!q.has('md')) return false;
        setNum(els.modal, q.get('md'));
        if (q.has('tu')) setNum(els.topup, q.get('tu'));
        if (q.has('rt')) els.ret.value = q.get('rt');
        if (q.has('th')) els.tahun.value = q.get('th');
        if (q.has('inf')) { els.inflasiToggle.checked = (q.get('inf') === '1'); els.inflasiBox.classList.toggle('active', els.inflasiToggle.checked); }
        if (q.has('sk')) els.inflasiSkenario.value = q.get('sk');
        return true;
      }
      $('exportLink').addEventListener('click', function(){ HC.copyText(buildShareUrl(), 'Link tersalin!'); });
      if (loadFromUrl()) { hitung(); }
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function readData(){
        var nilaiTxt=($('nilaiAkhir')||{}).textContent||'Rp 0';
        var setorTxt=($('totalSetor')||{}).textContent||'Rp 0';
        var untungTxt=($('totalUntung')||{}).textContent||'Rp 0';
        return { nilaiTxt:nilaiTxt, nilaiNum:num(nilaiTxt),
          setorTxt:setorTxt, setorNum:num(setorTxt),
          untungTxt:untungTxt, untungNum:num(untungTxt),
          modal:($('modal')||{}).value||'', topup:($('topup')||{}).value||'',
          ret:($('ret')||{}).value||'', tahun:($('tahun')||{}).value||'' };
      }


      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-trending-up"></i> Investasi \u00b7 Jadi <b>'+esc(d.nilaiTxt)+'</b></div>';
        if(!d.nilaiNum || !d.setorNum){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat komposisi modal vs cuan.</div>'; return; }
        var mPct=Math.max(0,Math.min(100, d.setorNum/d.nilaiNum*100));
        var cPct=Math.max(0,100-mPct);
        ground.innerHTML=ctx
          +'<div class="aic-stack"><div class="seg seg-modal" style="width:'+mPct.toFixed(1)+'%"><span class="seg-lbl">Modal</span></div><div class="seg seg-cuan" style="width:'+cPct.toFixed(1)+'%"><span class="seg-lbl">Cuan</span></div></div>'
          +'<div class="aic-legend"><span class="modal"><span class="dot"></span>Modal: <b>'+esc(d.setorTxt)+'</b></span><span class="cuan"><span class="dot"></span>Cuan: <b>'+esc(d.untungTxt)+'</b></span></div>'
          +'<div class="aic-verdict info"><i class="ti ti-seeding"></i> Dari setoran <b>'+esc(d.setorTxt)+'</b> tumbuh jadi <b>'+esc(d.nilaiTxt)+'</b> (asumsi return '+esc(d.ret)+'%/thn).</div>';
      }


      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Investasi (proyeksi pertumbuhan dengan asumsi return tetap).',
          d.modal?('Modal awal: Rp '+d.modal+'.'):'',
          (d.topup && d.topup!=='0')?('Setoran rutin per bulan: Rp '+d.topup+'.'):'Tanpa setoran rutin.',
          'Asumsi return: '+d.ret+'% per tahun. Jangka waktu: '+d.tahun+' tahun.',
          'Total yang disetor: '+d.setorTxt+'.',
          'Total keuntungan (asumsi): '+d.untungTxt+'.',
          'Nilai akhir (asumsi): '+d.nilaiTxt+'.',
          'PENTING: angka ini PROYEKSI berbasis asumsi return tetap, BUKAN jaminan. Return investasi nyata berfluktuasi setiap tahun dan bisa rugi. Jangan menjanjikan hasil pasti.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsg('ai',data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Hasil segini realistis gak?','Gimana kalau nabung lebih lama?','Apa aja risikonya?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>

