---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('investasi')!;
const related = getRelatedCalculators('investasi', 3);

const faqs = [
  { question: 'Apa beda nominal return dan real return?', answer: '<strong>Nominal return</strong> = return mentah (misal 10%/thn). <strong>Real return</strong> = nominal return DIKURANGI inflasi (Fisher Equation). Jika nominal 10% dan inflasi 5%, real return cuma 5% — daya beli investasimu hanya naik 5%, bukan 10%! Selalu hitung real return untuk perencanaan finansial yang akurat.' },
  { question: 'Bagaimana cara kerja compound interest?', answer: 'Compound interest = bunga atas bunga. Misal investasi Rp 10jt, return 10%/thn. Tahun 1 jadi Rp 11jt, tahun 2 jadi Rp 12,1jt (bukan Rp 12jt!), tahun 30 jadi Rp 174,5jt — 17× lipat! Rumusnya: <strong>FV = PV × (1+r)<sup>n</sup></strong>. Kuncinya: <strong>waktu</strong>.' },
  { question: 'Mengapa inflasi penting dalam investasi?', answer: 'Inflasi 3-5%/thn menggerus daya beli. Deposito 4%/thn dengan inflasi 5% berarti <strong>RUGI RIIL 1%/thn</strong>! Investasi minimal harus kalahkan inflasi. Itu sebabnya reksadana saham (12-15%/thn) lebih baik dari deposito (3-5%/thn) untuk jangka panjang.' },
  { question: 'Instrumen investasi apa yang cocok di Indonesia?', answer: '<strong>Pemula</strong>: Reksadana Pasar Uang (4-6%/thn, low risk). <strong>Konservatif</strong>: ORI/SBR (5-7%/thn, dijamin negara). <strong>Moderate</strong>: Reksadana Campuran (7-10%/thn). <strong>Agresif</strong>: Saham/Reksadana Saham (12-15%/thn jangka panjang). <strong>Hedge inflasi</strong>: Emas Antam (8-10%/thn rata-rata 10 tahun).' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#10B981;--cat-color2:#065F46">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#D1FAE5;color:#065F46"><i class="ti ti-chart-line"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M40 150L40 50M40 150L160 150" stroke="#FFF" stroke-width="3" stroke-linecap="round"/>
            <path d="M40 130L70 100L100 110L130 60L160 70" stroke="#FBBF24" stroke-width="4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="160" cy="70" r="6" fill="#FBBF24"/>
            <text x="160" y="48" text-anchor="end" font-size="14" font-weight="900" fill="#FBBF24" font-family="Inter">+150%</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#10B981 0%,#065F46 100%)"><i class="ti ti-chart-line"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Investasi Compound Interest</h2><p class="calc-card-sub">Proyeksi DCA + adjustment inflasi (real return)</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Modal Awal</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="modal" class="has-prefix" value="10.000.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Top-up per Bulan (DCA) <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="topup" class="has-prefix" value="1.000.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Return Tahunan (Nominal)</label>
              <div class="input-wrap"><input type="number" id="ret" class="has-suffix" value="10" step="0.5" /><span class="input-suffix">%</span></div>
              <div class="quick-btns">
                <button type="button" data-r="4">Deposito 4%</button>
                <button type="button" data-r="6">SBR 6%</button>
                <button type="button" data-r="8">Reksadana 8%</button>
                <button type="button" data-r="12">Saham 12%</button>
              </div></div>

            <div class="field"><label>Jangka Waktu</label>
              <select id="tahun">
                <option value="5">5 tahun</option>
                <option value="10" selected>10 tahun</option>
                <option value="15">15 tahun</option>
                <option value="20">20 tahun</option>
                <option value="25">25 tahun</option>
                <option value="30">30 tahun</option>
              </select></div>

            <div class="inflation-box" id="inflationBox">
              <label class="inflation-toggle">
                <input type="checkbox" id="inflasiToggle" />
                <span>🔥 Hitung Real Return (After Inflation)</span>
              </label>
              <div class="inflation-options">
                <label>Skenario Inflasi:</label>
                <select id="inflasiSkenario">
                  <option value="rendah">📉 Rendah (3.0%)</option>
                  <option value="normal" selected>📊 Normal (4.5%)</option>
                  <option value="tinggi">📈 Tinggi (6.0%)</option>
                  <option value="krisis">⚠️ Krisis (8.0%)</option>
                </select>
                <p class="inflation-note">Real return = Nominal return - Inflasi. Investasi yang menang inflasi = naik daya beli sesungguhnya.</p>
              </div>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>

            <div style="margin-top:14px;padding:13px;border:1px dashed var(--border,#CBD5E1);border-radius:12px">
              <div style="font-size:13px;font-weight:700;margin-bottom:8px"><i class="ti ti-target"></i> Mode Target — berapa harus nabung/bulan?</div>
              <div class="field"><label>Target Nominal yang Ingin Dicapai</label>
                <div class="input-wrap"><span class="input-prefix">Rp</span>
                  <input type="text" id="goalTarget" class="has-prefix" value="500.000.000" inputmode="numeric" /></div></div>
              <button type="button" class="btn-reset" id="btnGoal" style="width:100%"><i class="ti ti-target"></i> Hitung Nabung Bulanan</button>
              <div id="goalResult" style="display:none;margin-top:10px;font-size:13px;line-height:1.6"></div>
              <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 Pakai modal awal, return & jangka waktu di atas. Aku hitung mundur: berapa top-up bulanan biar tercapai targetmu.</p>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-chart-line result-placeholder-icon"></i>
              <div class="result-placeholder-title">Proyeksi investasi akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi modal & return, klik <strong>"Hitung Sekarang"</strong> untuk lihat compound effect.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Nilai Akhir Investasi</div>
                <div class="result-value" id="nilaiAkhir">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="metaInfo">0 tahun</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Total Setor</div><div class="result-item-value" id="totalSetor">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Keuntungan</div><div class="result-item-value result-strong" id="totalUntung">Rp 0</div></div>
                <div class="result-item" id="realReturnItem" style="display:none"><div class="result-item-label">Real Return (after inflasi)</div><div class="result-item-value" id="realReturnVal">0%</div></div>
                <div class="result-item" id="realValueItem" style="display:none"><div class="result-item-label">Daya Beli Nyata</div><div class="result-item-value result-warn" id="realValue">Rp 0</div></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-target"></i>&nbsp; Milestone Pertumbuhan</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Tahun</th><th class="right">Total Setor</th><th class="right">Nilai Investasi</th><th class="right">Keuntungan</th></tr></thead>
                    <tbody id="milestoneBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Bandingkan Berbagai Return</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Instrumen</th><th class="right">Return</th><th class="right">Nilai Akhir</th><th class="right">Keuntungan</th></tr></thead>
                    <tbody id="returnBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section open">
                <div class="adv-toggle"><span><i class="ti ti-receipt-tax"></i>&nbsp; Pajak Hasil Investasi (PPh Final)</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div class="field" style="margin-bottom:0"><label>Jenis Instrumen</label>
                    <select id="pajakInstrumen">
                      <option value="reksadana">Reksadana (saham/campuran) — bebas pajak investor</option>
                      <option value="saham">Saham (jual di bursa) — PPh final 0,1%</option>
                      <option value="deposito">Deposito — PPh final 20% bunga</option>
                      <option value="obligasi">Obligasi/SBN/ORI/SBR — PPh final 10% kupon</option>
                      <option value="crypto">Crypto — PPh final 0,21% (PPN dihapus 2026)</option>
                    </select></div>
                  <div id="pajakBody" style="margin-top:12px"></div>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 Pajak investasi di Indonesia umumnya <strong>PPh final</strong> (sekali potong, tidak digabung penghasilan lain). Reksa dana bebas pajak di level investor; keuntungan jual saham tidak dipajaki (hanya bea 0,1% saat jual); bunga deposito & kupon obligasi dipotong final. Angka ini estimasi sederhana.</p>
                </div>
              </div>

              <div class="adv-section" id="scenBlock">
                <div class="adv-toggle"><span><i class="ti ti-columns"></i>&nbsp; Bandingkan Skenario A vs B</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <p style="font-size:12px;color:var(--text-mute);margin:0 0 8px;line-height:1.5">Atur input skenario pertama lalu klik <b>Simpan sbg A</b>. Ubah input, klik <b>Simpan sbg B</b>. Otomatis dihitung ulang saat disimpan — tabel perbandingan muncul sendiri.</p>
                  <div style="display:flex;gap:8px">
                    <button type="button" class="btn-reset" id="btnScenA" style="flex:1"><i class="ti ti-bookmark"></i> Simpan sbg A</button>
                    <button type="button" class="btn-reset" id="btnScenB" style="flex:1"><i class="ti ti-bookmark"></i> Simpan sbg B</button>
                  </div>
                  <div id="scenResult" style="display:none;margin-top:10px"></div>
                  <button type="button" id="btnScenReset" style="margin-top:8px;background:none;border:none;color:var(--text-mute);font-size:12px;cursor:pointer;text-decoration:underline">Reset skenario</button>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn link" id="exportLink"><i class="ti ti-link" style="color:#0891B2"></i><span style="color:#0891B2">Salin Link</span></button>
              </div>

              <!-- ===== AI COACH KEPUTUSAN (mandiri) ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung sama hasilnya? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu pahami hasil investasimu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal investasimu..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hasil hitunganmu, bukan nasihat keuangan berlisensi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Kekuatan Compound Interest + Disiplin DCA</h2>
      <p>Compound interest = "keajaiban dunia kedelapan" (Einstein). Investasi Rp 10jt + top-up Rp 1jt/bln dengan return 10%/thn selama 20 tahun jadi <strong>~Rp 770 juta</strong>. Modal cuma Rp 250jt, untung Rp 520jt dari compound effect. Sebelum berinvestasi, pastikan <a href="/kalkulator/dana-darurat">dana darurat</a> sudah cukup. Mau investasi demi beli rumah? Hitung <a href="/kalkulator/kpr">simulasi KPR</a>.</p>
      <p><strong>Tapi waspada inflasi!</strong> Jika inflasi 5%/thn, real return cuma 5%. Daya beli Rp 770jt 20 thn lagi setara <strong>Rp 290jt</strong> uang hari ini. Selalu pilih instrumen yang return-nya kalahkan inflasi minimal 3-5%.</p>
      <div class="cta-box"><h3>Hitung Proyeksi Investasimu</h3><p>Aktifkan mode inflasi untuk lihat real return, klik "Hitung Sekarang".</p></div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Investasi" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EFF4FF;border:1px solid #C7DBFF;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E4EDFF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#2563EB;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EFF4FF;color:#2563EB;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#2563EB;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#2563EB;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#EFF4FF;color:#2563EB;border:1px solid #D6E4FF;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#E0EBFF}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#2563EB}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#2563EB;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
