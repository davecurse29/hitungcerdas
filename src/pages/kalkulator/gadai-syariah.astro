  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#F7FEE7;color:#65A30D;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#65A30D;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#65A30D;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#4D7C0F;border-color:#4D7C0F;background:#F7FEE7}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#F7FEE7;color:#65A30D;border:1px solid #D9F99D;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#ECFCCB}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#65A30D}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#65A30D;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#A3E635}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#A3E635}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#A3E635}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#A3E635}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(101,163,13,.16);color:#A3E635;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(101,163,13,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#84CC16}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}
</style>
<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        var v=function(id){ return ((($(id)||{}).textContent)||'').trim(); };
        var val=function(id){ return ($(id)||{}).value||''; };
        var pj=v('pinjaman');
        var taks=val('taksiran');
        return {
          taksiran:taks, taksiranTxt:(window.HC?HC.fmt(HC.parseRp(taks||'')||0):taks),
          pinjaman:pj, totalMunah:v('totalMunah'), adminOut:v('adminOut'), totalTebus:v('totalTebus'), totalBiaya:v('totalBiaya'),
          pct:val('pct'), munah:val('munah'), hari:val('hari'), admin:val('admin'),
          hasResult:(pj!=='Rp 0' && pj!=='')
        };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-diamond"></i> Gadai Emas Syariah (Rahn)</div>';
        if(!d.hasResult){ ground.innerHTML=ctx+'<div class="aic-nogauge">Klik "Hitung Sekarang" dulu untuk lihat estimasi gadaimu.</div>'; return; }
        var rowf=function(l,x){ return '<div style="display:flex;justify-content:space-between;gap:10px;font-size:12.5px;padding:3px 0;border-bottom:1px solid rgba(120,120,120,.15)"><span>'+l+'</span><b>'+esc(x)+'</b></div>'; };
        var rows='';
        if(d.taksiranTxt) rows+=rowf('Taksiran emas', d.taksiranTxt);
        if(d.pinjaman) rows+=rowf('Uang pinjaman', d.pinjaman);
        if(d.totalMunah) rows+=rowf("Biaya mu'nah (titip)", d.totalMunah);
        if(d.adminOut && d.adminOut!=='Rp 0') rows+=rowf('Admin', d.adminOut);
        if(d.totalTebus) rows+=rowf('Total tebusan', d.totalTebus);
        var verdict='<div class="aic-verdict warn"><i class="ti ti-info-circle"></i> Mu\'nah = biaya titip & pemeliharaan emas (dihitung dari nilai emas, bukan dari besar pinjaman) \u2014 itulah yang membuatnya bukan riba.</div>';
        ground.innerHTML=ctx+'<div style="margin:8px 0">'+rows+'</div>'+verdict;
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Gadai Emas Syariah (Rahn) \u2014 pinjaman dengan jaminan emas.',
          'Input: taksiran emas Rp '+d.taksiran+', plafon (FTV) '+d.pct+'% dari taksiran, tarif mu\'nah '+d.munah+', tenor '+d.hari+' hari, admin Rp '+d.admin+'.',
          'Hasil: uang pinjaman '+d.pinjaman+', total biaya mu\'nah '+d.totalMunah+', admin '+d.adminOut+', total tebusan '+d.totalTebus+' (dibayar saat menebus emas).',
          'Acuan untuk jawabanmu: Rahn adalah akad gadai syariah \u2014 kamu menyerahkan emas sebagai jaminan (marhun) dan menerima pinjaman (marhun bih). Lembaga mengenakan MU\'NAH (ujrah): biaya penitipan & pemeliharaan emas yang dihitung dari NILAI/berat emas, BUKAN dari besarnya pinjaman \u2014 inilah yang membedakannya dari bunga (riba) pada gadai konvensional yang mengenakan sewa modal atas pinjaman. Plafon pinjaman (FTV) umumnya sekitar 80-95% dari taksiran tergantung lembaga. Tenor biasanya 4 bulan (\u00b1120 hari) dan bisa diperpanjang dengan membayar mu\'nah lagi. Total tebusan = pinjaman + mu\'nah + admin, dibayar saat menebus emas. Bila tidak ditebus sampai jatuh tempo, emas bisa dilelang untuk menutup kewajiban. Pilih Pegadaian Syariah atau bank syariah yang diawasi OJK & Dewan Pengawas Syariah. Pakai sapaan "kamu", jawab ringkas & hangat, dan JANGAN mengarang angka di luar data.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function typeInto(bubble, text, done){ var n=0, len=text.length, step=Math.max(2, Math.round(len/90)); var t=setInterval(function(){ n=Math.min(len, n+step); bubble.innerHTML=mdToHtml(text.slice(0,n)); msgs.scrollTop=msgs.scrollHeight; if(n>=len){ clearInterval(t); done&&done(); } }, 18); }
      function mkCopyBtn(text){ var b=document.createElement('button'); b.type='button'; b.className='aic-copy'; b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>'; b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); }); return b; }
      function addMsgTyped(text){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); }); return row; }
      var FOLLOWUPS=["Mu'nah beda sama bunga?",'Bisa pinjam berapa dari emasku?','Kalau telat tebus gimana?','Kenapa Rahn halal?','Tenornya berapa lama?','Bisa diperpanjang nggak?','Emasku aman nggak?','Gadai di mana yang syariah?'];
      function renderFollowups(){ chips.innerHTML=''; var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;}); var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;}); pool.slice(0,3).forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b); }); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=["Mu'nah beda sama bunga?",'Bisa pinjam berapa dari emasku?','Kalau telat tebus gimana?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },800); }); }
    });
  })();
</script>
</Layout>
