---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('kredit-investasi')!;
const related = getRelatedCalculators('kredit-investasi', 3);

const faqs = [
  { question: 'Apa itu Kredit Investasi (KI)?', answer: 'KI adalah fasilitas kredit bank untuk membiayai <strong>barang modal jangka panjang</strong> — beli mesin, bangun pabrik, kendaraan operasional, atau ekspansi usaha. Beda dengan Kredit Modal Kerja (KMK) yang untuk kebutuhan operasional harian. KI biasanya bertenor panjang (5-10 tahun), berplafon besar, dan memerlukan agunan.' },
  { question: 'Metode bunga mana yang paling murah: flat, efektif, atau anuitas?', answer: '<strong>Efektif dan anuitas jauh lebih murah dari flat</strong>. Bunga flat dihitung dari pokok awal terus-menerus, sedangkan efektif/anuitas dari sisa pokok yang menyusut. Sebagai gambaran, bunga flat ~11%/tahun kira-kira setara efektif ~20%/tahun. KI korporasi umumnya memakai efektif/anuitas. Selalu tanya bank: angka bunganya flat atau efektif?' },
  { question: 'Berapa biaya provisi dan administrasi KI?', answer: 'Biaya <strong>provisi umumnya 1-2% dari plafon</strong> (sebagian bank sampai 1-4%), dipotong di muka saat pencairan. Biaya administrasi biasanya nominal tetap. Di luar itu masih ada biaya notaris, appraisal (penilaian agunan), asuransi, dan pengikatan agunan (APHT). Hitung semua biaya ini sebagai "total biaya kredit", bukan hanya bunga.' },
  { question: 'Kalau dilunasi/dipercepat, kena penalti?', answer: 'Umumnya ya. Besaran penalti <strong>tidak diatur baku oleh BI/OJK</strong> sehingga berbeda tiap bank — umumnya sekitar <strong>1-3% dari sisa pokok</strong> (sebagian produk 2-5%). Untuk pelunasan sebagian, kamu bisa memilih: <strong>perpendek tenor</strong> (angsuran tetap, lunas lebih cepat, hemat bunga maksimal) atau <strong>perkecil angsuran</strong> (tenor tetap, cicilan jadi ringan). Selalu konfirmasi besaran penalti & masa berlakunya ke bank.' },
  { question: 'Apa itu grace period (masa tenggang) di KI?', answer: 'Khas KI: pada <strong>masa konstruksi</strong> (mis. saat pabrik masih dibangun dan belum menghasilkan), debitur sering hanya diwajibkan <strong>membayar bunga saja</strong> dulu, sementara cicilan pokok ditunda sampai proyek mulai beroperasi. Ini meringankan arus kas di awal. (Fitur simulasi grace period akan ditambahkan di versi berikutnya.)' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#0D9488;--cat-color2:#0F766E">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#CCFBF1;color:#0F766E"><i class="ti ti-building-factory"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <rect x="48" y="95" width="104" height="55" rx="4" fill="#FFF" stroke="#FBBF24" stroke-width="2"/>
            <path d="M62 95 V70 l16 12 V70 l16 12 V70 l16 12 V95 Z" fill="#0F766E"/>
            <rect x="118" y="78" width="14" height="72" fill="#0D9488"/>
            <rect x="58" y="120" width="14" height="14" rx="2" fill="#FBBF24" opacity=".85"/>
            <rect x="82" y="120" width="14" height="14" rx="2" fill="#FBBF24" opacity=".6"/>
            <circle cx="125" cy="66" r="6" fill="#FBBF24" opacity=".8"/>
            <circle cx="125" cy="66" r="11" fill="none" stroke="#FBBF24" stroke-width="1.5" opacity=".4"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%)"><i class="ti ti-building-factory"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Kredit Investasi 2026</h2><p class="calc-card-sub">Simulasi cicilan KI bank: anuitas / efektif / flat + biaya & pelunasan sebagian</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Plafon Pinjaman</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="plafon" class="has-prefix" value="500.000.000" inputmode="numeric" /></div>
            </div>

            <div class="field">
              <label>Tenor Pinjaman</label>
              <select id="tenor">
                <option value="12">12 bulan (1 thn)</option>
                <option value="24">24 bulan (2 thn)</option>
                <option value="36">36 bulan (3 thn)</option>
                <option value="48">48 bulan (4 thn)</option>
                <option value="60" selected>60 bulan (5 thn)</option>
                <option value="72">72 bulan (6 thn)</option>
                <option value="84">84 bulan (7 thn)</option>
                <option value="96">96 bulan (8 thn)</option>
                <option value="120">120 bulan (10 thn)</option>
              </select>
            </div>

            <div class="field">
              <label>Metode Perhitungan Bunga</label>
              <select id="metode">
                <option value="anuitas" selected>Anuitas (cicilan tetap — umum KI)</option>
                <option value="efektif">Efektif (sliding — cicilan menurun)</option>
                <option value="flat">Flat (bunga dari pokok awal)</option>
              </select>
              <p class="hint" style="margin-top:6px">Anuitas: cicilan tetap. Efektif: cicilan menurun. Flat: terlihat murah tapi paling mahal.</p>
            </div>

            <div class="field"><label>Suku Bunga per Tahun</label>
              <div class="input-wrap"><span class="input-suffix">%/thn</span>
                <input type="number" id="bunga" class="has-suffix" value="11" min="5" max="24" step="0.1" /></div>
              <p class="hint" style="margin-top:6px">💡 KI komersial umumnya ~9-13% efektif (BI Rate Juni 2026: 5,75%). Sesuaikan penawaran bank.</p>
            </div>

            <div class="field"><label>Biaya Provisi</label>
              <div class="input-wrap"><span class="input-suffix">% plafon</span>
                <input type="number" id="provisi" class="has-suffix" value="1" min="0" max="5" step="0.1" /></div>
            </div>

            <div class="field"><label>Biaya Administrasi</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="admin" class="has-prefix" value="500.000" inputmode="numeric" /></div>
            </div>

            <div class="field"><label>Masa Tenggang / Grace Period <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-suffix">bln</span>
                <input type="number" id="grace" class="has-suffix" value="0" min="0" step="1" /></div>
              <p class="hint" style="margin-top:6px">🏗️ Bulan awal hanya bayar bunga (saat konstruksi). Pokok dicicil setelahnya, dalam sisa tenor. Isi 0 jika tidak ada.</p>
            </div>

            <div class="field-divider"><span><i class="ti ti-cash-banknote"></i> Simulasi Pelunasan Sebagian <span class="hint">(opsional)</span></span></div>

            <div class="field"><label>Jumlah Pelunasan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="pelJumlah" class="has-prefix" value="0" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Isi 0 jika tidak ada simulasi pelunasan.</p>
            </div>

            <div class="calc-grid-2">
              <div class="field"><label>Di Bulan Ke-</label>
                <div class="input-wrap"><span class="input-suffix">bln</span>
                  <input type="number" id="pelBulan" class="has-suffix" value="24" min="1" step="1" /></div>
              </div>
              <div class="field"><label>Penalti Pelunasan</label>
                <div class="input-wrap"><span class="input-suffix">% dilunasi</span>
                  <input type="number" id="penalti" class="has-suffix" value="2" min="0" max="10" step="0.1" /></div>
              </div>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-building-factory result-placeholder-icon"></i>
              <div class="result-placeholder-title">Simulasi KI akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi plafon, tenor, bunga, metode, lalu klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Angsuran per Bulan</div>
                <div class="result-value" id="angsuran">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="metodeLabel">Anuitas · 11%/thn · 60 bln</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Total Bunga</div><div class="result-item-value result-warn" id="totalBunga">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Bayar (pokok+bunga)</div><div class="result-item-value" id="totalBayar">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Biaya Kredit</div><div class="result-item-value result-warn" id="totalBiaya">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Dana Cair Bersih</div><div class="result-item-value" id="danaCair">Rp 0</div></div>
              </div>

              <div id="effInfo" style="display:none;margin-top:10px;padding:11px 13px;border-radius:12px;background:#FEF3C7;border:1px solid #FDE68A;font-size:12.5px;line-height:1.55;color:#92400E"></div>

              <div id="biayaInfo" style="margin-top:10px;padding:11px 13px;border-radius:12px;background:#F0FDFA;border:1px solid #99F6E4;font-size:12.5px;line-height:1.55;color:#115E59"></div>

              <div id="graceInfo" style="display:none;margin-top:10px;padding:11px 13px;border-radius:12px;background:#FFFBEB;border:1px solid #FDE68A;font-size:12.5px;line-height:1.55;color:#92400E"></div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-list-details"></i>&nbsp; Jadwal Amortisasi (5 Bulan Pertama)</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Bln</th><th class="right">Pokok</th><th class="right">Bunga</th><th class="right">Sisa Pokok</th></tr></thead>
                    <tbody id="amortBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section" id="pelSection" style="display:none">
                <div class="adv-toggle"><span><i class="ti ti-cash-banknote"></i>&nbsp; Hasil Simulasi Pelunasan Sebagian</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content" id="pelBox"></div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
                <button type="button" class="export-btn link" id="exportLink"><i class="ti ti-link" style="color:#0891B2"></i><span style="color:#0891B2">Salin Link</span></button>
              </div>

              <!-- ===== AI COACH KEPUTUSAN (mandiri) ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung sama hasilnya? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu pahami Kredit Investasi-mu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal KI-mu..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hasil hitunganmu, bukan nasihat keuangan berlisensi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Memahami Kredit Investasi (KI) Sebelum Mengajukan</h2>
      <p>Kredit Investasi adalah fasilitas pembiayaan bank untuk barang modal jangka panjang: membeli mesin produksi, membangun pabrik atau gudang, kendaraan operasional, hingga ekspansi usaha. Berbeda dengan Kredit Modal Kerja (KMK) yang membiayai kebutuhan operasional harian, KI bertenor panjang dan berplafon besar. Sebelum ekspansi dengan utang, pastikan arus kas usaha sehat — bandingkan juga dengan <a href="/kalkulator/investasi">simulasi investasi</a> dan siapkan <a href="/kalkulator/dana-darurat">dana darurat</a> usaha.</p>

      <h3>Flat vs Efektif vs Anuitas — Jangan Tertukar</h3>
      <ul>
        <li><strong>Flat</strong>: bunga dihitung dari pokok awal sepanjang tenor. Cicilan tetap, persentase terlihat kecil, tapi biaya riilnya jauh lebih tinggi (flat ~11% bisa setara efektif ~20%).</li>
        <li><strong>Efektif (sliding)</strong>: bunga dari sisa pokok yang menyusut. Cicilan menurun tiap bulan. Lebih adil dan lebih murah.</li>
        <li><strong>Anuitas</strong>: cicilan tetap seperti flat, tapi bunga dihitung efektif dari sisa pokok. Komposisi pokok-bunga berubah (bunga besar di awal). Umum dipakai KI.</li>
      </ul>

      <h3>Biaya-biaya yang Sering Terlupa</h3>
      <ul>
        <li><strong>Provisi</strong> — umumnya 1-2% dari plafon, dipotong di muka saat pencairan.</li>
        <li><strong>Administrasi</strong> — nominal tetap.</li>
        <li><strong>Eksternal</strong> — notaris, appraisal agunan, asuransi, dan pengikatan agunan (APHT). Bisa menambah 2-5% dari plafon.</li>
        <li><strong>Penalti pelunasan dipercepat</strong> — umumnya 1-3% dari sisa pokok, berbeda tiap bank.</li>
      </ul>

      <h3>Pelunasan Sebagian: Perpendek Tenor atau Perkecil Angsuran?</h3>
      <ul>
        <li><strong>Perpendek tenor</strong> — angsuran tetap, kredit lunas lebih cepat. Hemat bunga paling besar. Cocok jika arus kas kuat.</li>
        <li><strong>Perkecil angsuran</strong> — tenor tetap, cicilan bulanan jadi lebih ringan. Cocok jika ingin meringankan beban kas bulanan.</li>
      </ul>

      <div class="cta-box">
        <h3>Disclaimer Penting</h3>
        <p>Kalkulator ini alat bantu simulasi &amp; edukasi. Hasil bersifat estimasi. Suku bunga, provisi, administrasi, penalti, dan ketentuan aktual ditentukan masing-masing bank berdasarkan analisis kelayakan &amp; profil kredit usaha kamu. Simulasi pelunasan sebagian mengasumsikan skema re-amortisasi anuitas (umum dipakai bank). HitungCerdas <strong>tidak berafiliasi</strong> dengan bank manapun dan tidak menerima komisi. Selalu konsultasi langsung ke bank sebelum mengambil keputusan kredit.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Kredit Investasi" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>

  <p class="hc-method-note" style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:680px;line-height:1.6;padding:0 1rem;">
    📅 Diperbarui <strong>Juni 2026</strong> · Cicilan dihitung anuitas/efektif/flat dengan opsi grace period &amp; pelunasan sebagian. Estimasi edukatif; angka final mengikuti kebijakan bank. <strong>Sumber:</strong> <a href="https://www.ojk.go.id/" target="_blank" rel="noopener">OJK</a> &amp; <a href="https://www.bi.go.id/" target="_blank" rel="noopener">Bank Indonesia</a>.
  </p>

<style is:global>
  .field-divider{display:flex;align-items:center;gap:8px;margin:18px 0 4px;font-size:13px;font-weight:700;color:var(--text,#0A2540)}
  .field-divider span{display:flex;align-items:center;gap:7px}
  .field-divider i{color:#0D9488}
  .field-divider::after{content:"";flex:1;height:1px;background:#E5EAF1;margin-left:4px}
  .calc-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  @media (max-width:520px){.calc-grid-2{grid-template-columns:1fr}}
  .pel-opt{padding:12px 13px;border-radius:12px;border:1px solid #E5EAF1;margin-top:10px}
  .pel-opt.a{background:#F0FDF4;border-color:#BBF7D0}
  .pel-opt.b{background:#EFF6FF;border-color:#BFDBFE}
  .pel-opt-hdr{font-size:13px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:6px}
  .pel-opt.a .pel-opt-hdr{color:#15803D}
  .pel-opt.b .pel-opt-hdr{color:#1D4ED8}
  .pel-opt-row{display:flex;justify-content:space-between;font-size:12.5px;line-height:1.7;color:var(--text-mute,#475569)}
  .pel-opt-row b{color:var(--text,#0A2540);font-weight:700}
  .pel-pre{font-size:12.5px;line-height:1.7;color:var(--text-mute,#475569);margin-bottom:4px}
  .pel-pre .pr{display:flex;justify-content:space-between}
  .pel-pre b{color:var(--text,#0A2540)}

  /* ===== AI COACH styles ===== */
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EFF4FF;border:1px solid #C7DBFF;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E4EDFF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#2563EB;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EFF4FF;color:#2563EB;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
