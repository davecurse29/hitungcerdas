  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#8FB4FF}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(37,99,235,.16);color:#8FB4FF;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(37,99,235,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#3B82F6}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
</style>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = {
        plafon: $('plafon'), tenor: $('tenor'), metode: $('metode'), bunga: $('bunga'),
        provisi: $('provisi'), admin: $('admin'), grace: $('grace'),
        pelJumlah: $('pelJumlah'), pelBulan: $('pelBulan'), penalti: $('penalti'),
      };
      [els.plafon, els.admin, els.pelJumlah].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      function calcFlat(pokok, bungaThn, tenor) {
        const bungaBln = bungaThn / 12 / 100;
        const cicilanPokok = pokok / tenor;
        const cicilanBunga = pokok * bungaBln;
        const cicilan = cicilanPokok + cicilanBunga;
        return { cicilan, totalBunga: cicilanBunga * tenor, totalBayar: cicilan * tenor };
      }

      function calcEfektif(pokok, bungaThn, tenor) {
        const bungaBln = bungaThn / 12 / 100;
        const cicilanPokok = pokok / tenor;
        let sisa = pokok, totalBunga = 0, totalBayar = 0, firstCicilan = 0;
        const rows = [];
        for (let i = 1; i <= tenor; i++) {
          const bunga = sisa * bungaBln;
          const cicilan = cicilanPokok + bunga;
          if (i === 1) firstCicilan = cicilan;
          totalBunga += bunga; totalBayar += cicilan;
          rows.push({ bln: i, pokok: cicilanPokok, bunga, sisa: sisa - cicilanPokok });
          sisa -= cicilanPokok;
        }
        return { cicilan: firstCicilan, totalBunga, totalBayar, rows };
      }

      function anuitasCicilan(pokok, bungaBln, tenor) {
        if (bungaBln <= 0) return pokok / tenor;
        return (pokok * bungaBln) / (1 - Math.pow(1 + bungaBln, -tenor));
      }

      function calcAnuitas(pokok, bungaThn, tenor) {
        const bungaBln = bungaThn / 12 / 100;
        const cicilan = anuitasCicilan(pokok, bungaBln, tenor);
        const totalBayar = cicilan * tenor;
        const totalBunga = totalBayar - pokok;
        let sisa = pokok;
        const rows = [];
        for (let i = 1; i <= tenor; i++) {
          const bunga = sisa * bungaBln;
          const cicPokok = cicilan - bunga;
          rows.push({ bln: i, pokok: cicPokok, bunga, sisa: sisa - cicPokok });
          sisa -= cicPokok;
        }
        return { cicilan, totalBunga, totalBayar, rows };
      }

      let lastCalc = null;

      function hitung() {
        const pokok = HC.parseRp(els.plafon.value);
        const tenor = parseInt(els.tenor.value);
        const metode = els.metode.value;
        const bunga = parseFloat(els.bunga.value);
        const provPct = parseFloat(els.provisi.value) || 0;
        const adm = HC.parseRp(els.admin.value);
        const pelJumlah = HC.parseRp(els.pelJumlah.value);
        const pelBulan = parseInt(els.pelBulan.value) || 0;
        const penaltiPct = parseFloat(els.penalti.value) || 0;
        const grace = Math.max(0, parseInt(els.grace.value) || 0);

        if (pokok === 0) { HC.toast('Masukkan plafon pinjaman dulu', 'error'); return; }
        if (!bunga || bunga <= 0) { HC.toast('Masukkan suku bunga', 'error'); return; }
        if (grace >= tenor) { HC.toast('Masa tenggang harus lebih kecil dari tenor', 'error'); return; }

        const amortTenor = tenor - grace;
        let result;
        if (metode === 'flat') result = calcFlat(pokok, bunga, amortTenor);
        else if (metode === 'efektif') result = calcEfektif(pokok, bunga, amortTenor);
        else result = calcAnuitas(pokok, bunga, amortTenor);

        const i = bunga / 12 / 100;
        const graceInterestBln = pokok * i;
        const graceInterestTotal = grace * graceInterestBln;
        const totalBunga = result.totalBunga + graceInterestTotal;
        const totalBayar = pokok + totalBunga;
        const provisi = provPct / 100 * pokok;
        const biayaMuka = provisi + adm;
        const danaCair = pokok - biayaMuka;
        const totalBiayaKredit = biayaMuka + totalBunga;
        const metodeLabel = { flat: 'Flat', efektif: 'Efektif', anuitas: 'Anuitas' }[metode];

        // Hero
        const graceNote = grace > 0 ? ` \u00b7 +${grace} bln grace` : '';
        let heroVal, heroMeta;
        if (metode === 'efektif') {
          const angN = (pokok / amortTenor) + (pokok / amortTenor) * i;
          heroVal = HC.fmt(result.cicilan);
          heroMeta = `${metodeLabel} \u00b7 ${bunga}%/thn \u00b7 ${tenor} bln${graceNote} \u00b7 menurun s/d ${HC.fmt(angN)}`;
        } else {
          heroVal = HC.fmt(result.cicilan);
          heroMeta = `${metodeLabel} \u00b7 ${bunga}%/thn \u00b7 ${tenor} bln${graceNote}`;
        }
        $('angsuran').textContent = heroVal;
        $('metodeLabel').textContent = heroMeta;
        $('totalBunga').textContent = HC.fmt(totalBunga);
        $('totalBayar').textContent = HC.fmt(totalBayar);
        $('totalBiaya').textContent = HC.fmt(totalBiayaKredit);
        $('danaCair').textContent = HC.fmt(danaCair);

        // Metode note
        const effEl = $('effInfo');
        effEl.style.display = '';
        if (metode === 'flat') {
          const efSetara = bunga * 1.8;
          effEl.innerHTML = `\u26a0\ufe0f Bunga <b>${bunga}%/thn flat</b> kira-kira setara <b>~${efSetara.toFixed(1)}% efektif/tahun</b>. Cicilan flat terlihat ringan, tapi bunga dihitung dari pokok awal terus \u2014 biaya riilnya jauh lebih tinggi. Minta bank simulasi versi <b>efektif/anuitas</b> untuk perbandingan adil.`;
        } else if (metode === 'anuitas') {
          effEl.innerHTML = `\u2705 Anuitas: cicilan tetap <b>${HC.fmt(result.cicilan)}/bln</b>, bunga dihitung efektif dari sisa pokok. Metode paling umum untuk Kredit Investasi.`;
        } else {
          effEl.innerHTML = `\u2139\ufe0f Efektif (sliding): bunga dari sisa pokok, cicilan menurun tiap bulan. Beban di awal lebih besar, makin ringan seiring pokok menyusut.`;
        }

        // Biaya info
        $('biayaInfo').innerHTML = `\ud83d\udcb0 Provisi ${provPct}% = <b>${HC.fmt(provisi)}</b> + Admin <b>${HC.fmt(adm)}</b> = biaya muka <b>${HC.fmt(biayaMuka)}</b>. Jika dipotong dari pencairan, dana yang kamu terima \u2248 <b>${HC.fmt(danaCair)}</b>. Belum termasuk notaris, appraisal, asuransi & pengikatan agunan.`;

        // Grace info
        const graceEl = $('graceInfo');
        if (grace > 0) {
          graceEl.style.display = '';
          graceEl.innerHTML = `\ud83c\udfd7\ufe0f Grace period <b>${grace} bln</b>: bayar <b>bunga saja \u2248 ${HC.fmt(graceInterestBln)}/bln</b> (total bunga grace ${HC.fmt(graceInterestTotal)}). Setelah itu pokok dicicil ${amortTenor} bln, angsuran <b>${HC.fmt(result.cicilan)}/bln</b>. Grace meringankan kas awal saat konstruksi, tapi menambah total bunga.`;
        } else {
          graceEl.style.display = 'none';
        }

        // Amortisasi: baris grace (bunga saja) + 5 bln pertama amortisasi pokok
        let amortHtml = '';
        for (let g = 1; g <= Math.min(grace, 3); g++) {
          amortHtml += `<tr style="background:#FFFBEB"><td>G${g}</td><td class="right">Rp 0</td><td class="right">${HC.fmt(graceInterestBln)}</td><td class="right">${HC.fmt(pokok)}</td></tr>`;
        }
        if (grace > 3) amortHtml += `<tr style="background:#FFFBEB"><td colspan="4" style="text-align:center;color:#92400E">\u2026 grace ${grace} bln total (bunga saja) \u2026</td></tr>`;
        if (result.rows) {
          result.rows.slice(0, 5).forEach(r => {
            amortHtml += `<tr><td>${grace + r.bln}</td><td class="right">${HC.fmt(r.pokok)}</td><td class="right">${HC.fmt(r.bunga)}</td><td class="right">${HC.fmt(Math.max(0, r.sisa))}</td></tr>`;
          });
        } else {
          const cicPokok = pokok / amortTenor;
          const cicBunga = pokok * i;
          let sisa = pokok;
          for (let k = 1; k <= Math.min(5, amortTenor); k++) {
            sisa -= cicPokok;
            amortHtml += `<tr><td>${grace + k}</td><td class="right">${HC.fmt(cicPokok)}</td><td class="right">${HC.fmt(cicBunga)}</td><td class="right">${HC.fmt(Math.max(0, sisa))}</td></tr>`;
          }
        }
        $('amortBody').innerHTML = amortHtml;

        // Pelunasan sebagian
        let pel = null;
        if (pelJumlah > 0 && pelBulan >= 1 && pelBulan < amortTenor) {
          let sisaPokok;
          if (result.rows) sisaPokok = Math.max(0, result.rows[pelBulan - 1].sisa);
          else sisaPokok = pokok - pelBulan * (pokok / amortTenor);
          const sisaBln = amortTenor - pelBulan;
          const aCur = anuitasCicilan(sisaPokok, i, sisaBln);
          const Bnew = Math.max(0, sisaPokok - pelJumlah);
          const penalti = penaltiPct / 100 * pelJumlah;

          let nNew = 0;
          if (Bnew > 0) {
            if (i > 0) nNew = Math.ceil(-Math.log(1 - Bnew * i / aCur) / Math.log(1 + i));
            else nNew = Math.ceil(Bnew / aCur);
          }
          const bungaNoPrepay = aCur * sisaBln - sisaPokok;
          const bungaA = Bnew > 0 ? (aCur * nNew - Bnew) : 0;
          const hematBunga = Math.max(0, bungaNoPrepay - bungaA);
          const aNew = Bnew > 0 ? anuitasCicilan(Bnew, i, sisaBln) : 0;

          let html = `<div class="pel-pre">`;
          html += `<div class="pr"><span>Sisa pokok sebelum (akhir bln ${pelBulan})</span><b>${HC.fmt(sisaPokok)}</b></div>`;
          html += `<div class="pr"><span>Jumlah pelunasan</span><b>${HC.fmt(pelJumlah)}</b></div>`;
          html += `<div class="pr"><span>Penalti ${penaltiPct}% \u00d7 pelunasan</span><b>${HC.fmt(penalti)}</b></div>`;
          html += `<div class="pr"><span>Sisa pokok setelah pelunasan</span><b>${HC.fmt(Bnew)}</b></div>`;
          html += `</div>`;
          if (Bnew > 0) {
            html += `<div class="pel-opt a"><div class="pel-opt-hdr"><i class="ti ti-clock-bolt"></i> Opsi A \u2014 Perpendek Tenor</div>`;
            html += `<div class="pel-opt-row"><span>Angsuran (tetap)</span><b>${HC.fmt(aCur)}/bln</b></div>`;
            html += `<div class="pel-opt-row"><span>Sisa tenor</span><b>${nNew} bln</b> <span style="color:#15803D">(dari ${sisaBln} bln)</span></div>`;
            html += `<div class="pel-opt-row"><span>Estimasi hemat bunga</span><b style="color:#15803D">${HC.fmt(hematBunga)}</b></div></div>`;
            html += `<div class="pel-opt b"><div class="pel-opt-hdr"><i class="ti ti-arrow-down"></i> Opsi B \u2014 Perkecil Angsuran</div>`;
            html += `<div class="pel-opt-row"><span>Tenor (tetap)</span><b>${sisaBln} bln</b></div>`;
            html += `<div class="pel-opt-row"><span>Angsuran baru</span><b style="color:#1D4ED8">${HC.fmt(aNew)}/bln</b> <span style="color:#64748b">(dari ${HC.fmt(aCur)})</span></div></div>`;
          } else {
            html += `<div class="pel-opt a"><div class="pel-opt-hdr"><i class="ti ti-circle-check"></i> Kredit LUNAS</div>`;
            html += `<div class="pel-opt-row"><span>Pelunasan menutup seluruh sisa pokok. Total ditebus</span><b>${HC.fmt(sisaPokok + penalti)}</b></div>`;
            html += `<div class="pel-opt-row"><span>(sisa pokok ${HC.fmt(sisaPokok)} + penalti ${HC.fmt(penalti)})</span><b></b></div></div>`;
          }
          html += `<p style="font-size:11px;color:var(--text-mute,#64748b);margin-top:8px;line-height:1.5">Simulasi memakai skema re-amortisasi anuitas. Hemat bunga belum dikurangi penalti ${HC.fmt(penalti)}. Besaran penalti aktual berbeda tiap bank.</p>`;
          $('pelBox').innerHTML = html;
          $('pelSection').style.display = '';
          $('pelSection').classList.add('open');
          pel = { sisaPokok, pelJumlah, penalti, Bnew, sisaBln, aCur, nNew, hematBunga, aNew };
        } else {
          $('pelSection').style.display = 'none';
        }

        // Jadwal lengkap (grace bunga-saja + amortisasi) untuk export Excel
        const amortRows = [];
        for (let _g = 1; _g <= grace; _g++) { amortRows.push({ bln: _g, pokok: 0, bunga: graceInterestBln, sisa: pokok }); }
        if (result.rows) {
          result.rows.forEach(function (r) { amortRows.push({ bln: grace + r.bln, pokok: r.pokok, bunga: r.bunga, sisa: r.sisa }); });
        } else {
          const _cP = pokok / amortTenor, _cB = pokok * i;
          let _s = pokok;
          for (let _k = 1; _k <= amortTenor; _k++) { _s -= _cP; amortRows.push({ bln: grace + _k, pokok: _cP, bunga: _cB, sisa: Math.max(0, _s) }); }
        }

        lastCalc = { pokok, tenor, grace, amortTenor, metode, metodeLabel, bunga, provPct, provisi, adm, biayaMuka, danaCair, graceInterestBln, graceInterestTotal, cicilan: result.cicilan, totalBunga, totalBayar, totalBiayaKredit, pel, amortRows };
        if (HC.history) HC.history.push('kredit-investasi', { inputs: HC.history.capture(['plafon','tenor','metode','bunga','provisi','admin','grace']), summary: 'Plafon ' + HC.fmt(lastCalc.pokok) + ' \u00b7 ' + lastCalc.tenor + ' bln @ ' + lastCalc.bunga + '%', metrics: [{ k: 'Cicilan/bln', v: HC.fmt(lastCalc.cicilan) }, { k: 'Total biaya', v: HC.fmt(lastCalc.totalBiayaKredit) }] });
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Simulasi Kredit Investasi berhasil dihitung!');
      }

      function reset() {
        els.plafon.value = '500.000.000'; els.tenor.value = '60'; els.metode.value = 'anuitas';
        els.bunga.value = '11'; els.provisi.value = '1'; els.admin.value = '500.000';
        els.pelJumlah.value = '0'; els.pelBulan.value = '24'; els.penalti.value = '2';
        els.grace.value = '0';
        var ei = $('effInfo'); if (ei) ei.style.display = 'none';
        var gi = $('graceInfo'); if (gi) gi.style.display = 'none';
        $('pelSection').style.display = 'none';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        let insight = `Metode ${c.metodeLabel}, bunga ${c.bunga}%/thn, tenor ${c.tenor} bln. Total biaya kredit (provisi+admin+bunga) ${HC.fmt(c.totalBiayaKredit)}.`;
        if (c.grace > 0) {
          insight += ` Grace period ${c.grace} bln (bunga saja ${HC.fmt(c.graceInterestBln)}/bln), lalu cicil pokok ${c.amortTenor} bln.`;
        }
        if (c.pel && c.pel.Bnew > 0) {
          insight += ` Pelunasan sebagian ${HC.fmt(c.pel.pelJumlah)}: perpendek tenor jadi ${c.pel.nNew} bln (hemat bunga ~${HC.fmt(c.pel.hematBunga)}) atau perkecil angsuran jadi ${HC.fmt(c.pel.aNew)}/bln.`;
        }
        insight += ' Estimasi \u2014 konfirmasi ke bank.';

        const results = [
          { label: 'Angsuran/bln', value: HC.fmt(c.cicilan), highlight: true },
          { label: 'Total Bunga', value: HC.fmt(c.totalBunga) },
          { label: 'Total Bayar', value: HC.fmt(c.totalBayar) },
          { label: 'Total Biaya Kredit', value: HC.fmt(c.totalBiayaKredit), highlight: true },
          { label: 'Dana Cair Bersih', value: HC.fmt(c.danaCair) },
        ];

        return HC.buildReportCard({
          title: '\ud83c\udfed Simulasi Kredit Investasi',
          color: '#0D9488', color2: '#0F766E',
          heroLabel: 'Angsuran per Bulan',
          heroValue: HC.fmt(c.cicilan),
          heroSubtext: `${c.metodeLabel} \u00b7 ${c.bunga}%/thn \u00b7 ${c.tenor} bln${c.grace > 0 ? ' (+' + c.grace + ' grace)' : ''}`,
          inputs: [
            { label: '\ud83c\udfe6 Plafon', value: HC.fmt(c.pokok) },
            { label: '\ud83d\udcc5 Tenor', value: c.tenor + ' bulan' },
            { label: '\ud83d\udcca Metode', value: c.metodeLabel },
            { label: '\ud83d\udcb0 Provisi+Admin', value: HC.fmt(c.biayaMuka) },
          ],
          results,
          schedule: c.amortRows ? {
            name: 'Jadwal Cicilan',
            header: ['Bulan', 'Total Cicilan', 'Angsuran Pokok', 'Angsuran Bunga', 'Sisa Pokok'],
            rows: c.amortRows.map(function (r) { return [r.bln, Math.round(r.pokok + r.bunga), Math.round(r.pokok), Math.round(r.bunga), Math.round(Math.max(0, r.sisa))]; }),
          } : null,
          insight, slug: 'kredit-investasi',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        const graceLine = c.grace > 0 ? `\nGrace: ${c.grace} bln (bunga saja ${HC.fmt(c.graceInterestBln)}/bln)` : '';
        let t = `\ud83c\udfed *Simulasi Kredit Investasi - HitungCerdas*\n\nPlafon: ${HC.fmt(c.pokok)}\nTenor: ${c.tenor} bulan\nMetode: ${c.metodeLabel}\nBunga: ${c.bunga}%/thn${graceLine}\n\n\ud83d\udcb0 *Angsuran/bln: ${HC.fmt(c.cicilan)}*\n\ud83d\udcca Total Bunga: ${HC.fmt(c.totalBunga)}\n\ud83d\udcb5 Total Bayar: ${HC.fmt(c.totalBayar)}\n\ud83e\uddfe Total Biaya Kredit: ${HC.fmt(c.totalBiayaKredit)}\n\ud83c\udfe6 Dana Cair Bersih: ${HC.fmt(c.danaCair)}`;
        if (c.pel && c.pel.Bnew > 0) {
          t += `\n\n\u2702\ufe0f Pelunasan ${HC.fmt(c.pel.pelJumlah)}:\nA) Perpendek tenor: ${c.pel.nNew} bln (hemat bunga ~${HC.fmt(c.pel.hematBunga)})\nB) Perkecil angsuran: ${HC.fmt(c.pel.aNew)}/bln`;
        }
        t += `\n\nHitung di: https://hitungcerdas.net/kalkulator/kredit-investasi`;
        return t;
      }

            function renderHist() {
        if (HC.history) HC.history.render('kredit-investasi', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      els.metode.addEventListener('change', () => { if (lastCalc) hitung(); });
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'kredit-investasi-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'kredit-investasi'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'kredit-investasi-' + Date.now()); });

      // ── Salin Link Hasil (share via URL) ──
      function buildShareUrl(){
        var p = new URLSearchParams();
        p.set('pf', String(HC.parseRp(els.plafon.value)||0));
        p.set('ad', String(HC.parseRp(els.admin.value)||0));
        p.set('pj', String(HC.parseRp(els.pelJumlah.value)||0));
        p.set('bg', els.bunga.value||'0');
        p.set('pv', els.provisi.value||'0');
        p.set('gr', els.grace.value||'0');
        p.set('pb', els.pelBulan.value||'0');
        p.set('pn', els.penalti.value||'0');
        p.set('tn', els.tenor.value);
        p.set('mt', els.metode.value);
        return location.origin + location.pathname + '?' + p.toString();
      }
      function setNum(el, val){ el.value = val; el.dispatchEvent(new Event('input', {bubbles:true})); }
      function loadFromUrl(){
        var q = new URLSearchParams(location.search);
        if (!q.has('pf')) return false;
        setNum(els.plafon, q.get('pf'));
        if (q.has('ad')) setNum(els.admin, q.get('ad'));
        if (q.has('pj')) setNum(els.pelJumlah, q.get('pj'));
        if (q.has('bg')) els.bunga.value = q.get('bg');
        if (q.has('pv')) els.provisi.value = q.get('pv');
        if (q.has('gr')) els.grace.value = q.get('gr');
        if (q.has('pb')) els.pelBulan.value = q.get('pb');
        if (q.has('pn')) els.penalti.value = q.get('pn');
        if (q.has('tn')) els.tenor.value = q.get('tn');
        if (q.has('mt')) els.metode.value = q.get('mt');
        return true;
      }
      $('exportLink').addEventListener('click', function(){ HC.copyText(buildShareUrl(), 'Link tersalin!'); });
      if (loadFromUrl()) { hitung(); }
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        return {
          angsuran:(($('angsuran')||{}).textContent||'Rp 0'),
          plafon:($('plafon')||{}).value||'',
          tenor:($('tenor')||{}).value||'',
          metode:selText('metode'),
          bunga:($('bunga')||{}).value||'',
          provisi:($('provisi')||{}).value||'',
          admin:($('admin')||{}).value||'',
          grace:($('grace')||{}).value||'0',
          totalBunga:($('totalBunga')||{}).textContent||'',
          totalBayar:($('totalBayar')||{}).textContent||'',
          totalBiaya:($('totalBiaya')||{}).textContent||'',
          danaCair:($('danaCair')||{}).textContent||''
        };
      }

      function renderGround(){
        var d=readData();
        var done = d.angsuran && d.angsuran!=='Rp 0';
        if(!done){ ground.innerHTML='<div class="aic-nogauge">Klik "Hitung Sekarang" dulu supaya Coach bisa baca hasil simulasimu.</div>'; return; }
        var grTxt = (d.grace && d.grace!=='0') ? ' \u00b7 Grace <b>'+esc(d.grace)+' bln</b>' : '';
        ground.innerHTML='<div class="aic-ctx"><i class="ti ti-building-factory"></i> Kredit Investasi \u00b7 Angsuran <b>'+esc(d.angsuran)+'</b>'+grTxt+'</div>'
          +'<div class="aic-ctx" style="margin-top:6px">Total bunga <b>'+esc(d.totalBunga)+'</b> \u00b7 Total biaya kredit <b>'+esc(d.totalBiaya)+'</b></div>'
          +'<div class="aic-nogauge">Catatan: kelayakan KI sangat bergantung arus kas usahamu \u2014 yang tidak dihitung di sini. Tanya Coach untuk bantu menimbang pilihan.</div>';
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Kredit Investasi (KI) \u2014 fasilitas kredit bank untuk barang modal jangka panjang (mesin, pabrik, kendaraan operasional, ekspansi usaha).',
          d.plafon?('Plafon pinjaman: Rp '+d.plafon+'.'):'',
          'Angsuran per bulan: '+d.angsuran+'.',
          'Tenor: '+d.tenor+' bulan. Metode bunga: '+d.metode+'. Bunga: '+d.bunga+'% per tahun.',
          (d.grace && d.grace!=='0')?('Masa tenggang/grace period: '+d.grace+' bulan (saat grace bayar bunga saja, pokok dicicil setelah grace berakhir).'):'',
          'Biaya provisi: '+d.provisi+'% dari plafon. Biaya administrasi: Rp '+d.admin+'.',
          'Total bunga: '+d.totalBunga+'. Total bayar (pokok+bunga): '+d.totalBayar+'.',
          'Total biaya kredit (provisi+admin+bunga): '+d.totalBiaya+'. Dana cair bersih setelah biaya muka: '+d.danaCair+'.',
          'Acuan faktual: BI Rate Juni 2026 = 5,75% (suku bunga acuan Bank Indonesia, bukan bunga KI langsung). Bunga KI komersial umumnya 9-13% efektif (acuan + margin bank). Metode flat jauh lebih mahal dari efektif/anuitas meski angka persennya sama. Provisi umumnya 1-2% plafon, dipotong di muka. Penalti pelunasan dipercepat umumnya 1-3% sisa pokok dan berbeda tiap bank. Kelayakan KI sangat bergantung pada arus kas / proyeksi pendapatan usaha, yang tidak tersedia di kalkulator ini.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Metode bunga mana yang lebih hemat?','Worth it gak ambil grace period?','Biaya & provisi ini wajar gak?','Lebih untung perpendek tenor atau perkecil angsuran?','Total biaya kredit ini berapa?','Penalti pelunasan ngaruh berapa?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Metode bunga mana yang lebih hemat?','Worth it gak ambil grace period?','Biaya & provisi ini wajar gak?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
