<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(function(){ ready(fn); }, 100); }
    ready(function() {
      var $ = function(id){ return document.getElementById(id); };
      var els = { emasGr: $('emasGr'), hutang: $('hutang') };
      els.emasGr.addEventListener('input', function(){ HC.fmtInput.call(this); updateEmasRp(); });
      els.hutang.addEventListener('input', HC.fmtInput);
      $('emasGram').addEventListener('input', updateEmasRp);
      var lastCalc = null;

      function fmtThou(n){ return String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }

      var CATMETA = {
        emas:     { label: 'Emas & Logam Mulia',   color: '#F59E0B' },
        kas:      { label: 'Kas & Tabungan',        color: '#D97706' },
        saham:    { label: 'Saham & Investasi',     color: '#CA8A04' },
        properti: { label: 'Properti & Aset Usaha', color: '#A16207' },
        dagang:   { label: 'Barang Dagangan',       color: '#EAB308' },
        piutang:  { label: 'Piutang',               color: '#B45309' },
        lain:     { label: 'Lainnya',               color: '#92400E' }
      };
      var KAT_ORDER = ['emas', 'kas', 'saham', 'properti', 'dagang', 'piutang', 'lain'];
      var BUILD_KATS = ['kas', 'saham', 'properti', 'dagang', 'piutang', 'lain'];
      var KAT_OPTS = BUILD_KATS.map(function(k){ return '<option value="' + k + '">' + CATMETA[k].label + '</option>'; }).join('');

      function updateEmasRp(){
        var g = parseFloat($('emasGram').value) || 0;
        var p = HC.parseRp(els.emasGr.value);
        $('emasRp').textContent = HC.fmt(g * p);
      }

      // ===== Harta builder =====
      function addRow(d){
        d = d || {};
        var tr = document.createElement('tr'); tr.className = 'zm-row';
        tr.innerHTML = '<td><select class="zm-kat">' + KAT_OPTS + '</select></td>'
          + '<td><input class="zm-ket" type="text" placeholder="keterangan"></td>'
          + '<td><div class="zm-nilai-wrap"><span class="zm-rp">Rp</span><input class="zm-nilai" type="text" inputmode="numeric"></div></td>'
          + '<td><button type="button" class="zm-del" aria-label="Hapus"><i class="ti ti-x"></i></button></td>';
        $('hartaRows').appendChild(tr);
        if (d.kat) tr.querySelector('.zm-kat').value = d.kat;
        tr.querySelector('.zm-ket').value = d.ket || '';
        var n = tr.querySelector('.zm-nilai'); n.value = (d.nilai != null && d.nilai !== '') ? (typeof d.nilai === 'number' ? fmtThou(d.nilai) : d.nilai) : '';
        n.addEventListener('input', HC.fmtInput);
        recalcHarta();
      }
      function recalcHarta(){
        var total = 0, rows = $('hartaRows').querySelectorAll('.zm-row');
        for (var i = 0; i < rows.length; i++) total += HC.parseRp(rows[i].querySelector('.zm-nilai').value);
        $('hartaLainTotal').textContent = HC.fmt(total);
        return total;
      }
      function readRows(){
        var out = [], rows = $('hartaRows').querySelectorAll('.zm-row');
        for (var i = 0; i < rows.length; i++){
          var kat = rows[i].querySelector('.zm-kat').value;
          var ket = rows[i].querySelector('.zm-ket').value.trim();
          var nilai = HC.parseRp(rows[i].querySelector('.zm-nilai').value);
          if (nilai > 0 || ket) out.push({ kat: kat, ket: ket, nilai: nilai });
        }
        return out;
      }
      $('hartaRows').addEventListener('input', recalcHarta);
      $('hartaRows').addEventListener('click', function(ev){
        var del = ev.target.closest('.zm-del'); if (!del) return;
        var rows = $('hartaRows').querySelectorAll('.zm-row');
        if (rows.length <= 1) { var tr = del.closest('.zm-row'); tr.querySelector('.zm-ket').value=''; tr.querySelector('.zm-nilai').value=''; recalcHarta(); return; }
        del.closest('.zm-row').remove(); recalcHarta();
      });
      $('addHarta').addEventListener('click', function(){ addRow({ kat: 'kas' }); });

      function seed(){
        $('emasGram').value = '10';
        $('hartaRows').innerHTML = '';
        addRow({ kat: 'kas', ket: 'Tabungan & deposito', nilai: 150000000 });
        addRow({ kat: 'saham', ket: 'Reksadana & saham', nilai: 80000000 });
        els.hutang.value = '';
        updateEmasRp(); recalcHarta();
      }

      // ===== Donut =====
      function donut(segs){
        var total = 0; segs.forEach(function(s){ total += s.val; });
        if (total <= 0) return '';
        var off = 0, c = '';
        segs.forEach(function(s){ if (s.val <= 0) return; var pct = s.val / total * 100; c += '<circle cx="60" cy="60" r="42" fill="none" stroke="' + s.color + '" stroke-width="16" pathLength="100" stroke-dasharray="' + pct.toFixed(2) + ' ' + (100 - pct).toFixed(2) + '" stroke-dashoffset="' + (-off).toFixed(2) + '" transform="rotate(-90 60 60)"></circle>'; off += pct; });
        return '<svg viewBox="0 0 120 120" class="zm-donut" role="img" aria-label="Komposisi harta">' + c + '<text x="60" y="56" text-anchor="middle" font-size="8.5" fill="#94A3B8">Total Harta</text><text x="60" y="70" text-anchor="middle" font-size="10" font-weight="700" fill="#0F172A">' + HC.fmt(total) + '</text></svg>';
      }

      function hitung() {
        var emasGr = HC.parseRp(els.emasGr.value);
        var gramEmas = parseFloat($('emasGram').value) || 0;
        var emasVal = gramEmas * emasGr;
        var rows = readRows();
        var hartaLain = 0; rows.forEach(function(r){ hartaLain += r.nilai; });
        var total = emasVal + hartaLain;
        var hutang = HC.parseRp(els.hutang.value);

        if (total <= 0) { HC.toast('Masukkan harta yang dimiliki dulu', 'error'); return; }
        if (emasGr <= 0) { HC.toast('Isi harga emas per gram', 'error'); return; }

        var bersih = Math.max(0, total - hutang);
        var nisab = emasGr * 85;
        var wajib = bersih >= nisab && bersih > 0;
        var zakat = wajib ? bersih * 0.025 : 0;
        var selisih = bersih - nisab;

        $('zakatMal').textContent = HC.fmt(zakat);
        $('totalHarta').textContent = HC.fmt(total);
        $('hartaBersih').textContent = HC.fmt(bersih);
        $('nisab').textContent = HC.fmt(nisab);
        $('selisih').textContent = (selisih >= 0 ? '+ ' : '- ') + HC.fmt(Math.abs(selisih));

        var $s = $('status');
        if (wajib) $s.innerHTML = '<div class="kelayakan-status ks-good"><i class="ti ti-circle-check"></i> WAJIB ZAKAT</div><p class="ks-note">Harta bersih melebihi nisab. Bayar <strong>' + HC.fmt(zakat) + '</strong> jika sudah haul 1 tahun.</p>';
        else $s.innerHTML = '<div class="kelayakan-status ks-warn"><i class="ti ti-info-circle"></i> Belum Wajib</div><p class="ks-note">Masih ' + HC.fmt(nisab - bersih) + ' di bawah nisab. Disunnahkan sedekah.</p>';

        // Komposisi
        var catSum = {}; catSum['emas'] = emasVal;
        rows.forEach(function(r){ catSum[r.kat] = (catSum[r.kat] || 0) + r.nilai; });
        var cats = [];
        KAT_ORDER.forEach(function(k){ if (catSum[k] > 0) cats.push({ key: k, label: CATMETA[k].label, color: CATMETA[k].color, val: catSum[k] }); });
        $('kompDonut').innerHTML = donut(cats);
        var bodyHtml = '';
        cats.forEach(function(c){
          var pct = total > 0 ? (c.val / total) * 100 : 0;
          bodyHtml += '<tr><td><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:' + c.color + ';margin-right:6px"></span>' + c.label + '</td><td class="right">' + HC.fmt(c.val) + '</td><td class="right" style="font-weight:700">' + pct.toFixed(1) + '%</td></tr>';
        });
        $('kompBody').innerHTML = bodyHtml;

        lastCalc = { emasGr: emasGr, gramEmas: gramEmas, emasVal: emasVal, hartaLain: hartaLain, total: total, hutang: hutang, bersih: bersih, nisab: nisab, wajib: wajib, zakat: zakat, selisih: selisih, rows: rows, cats: cats };
        window.HCZakat = {
          wajib: wajib, zakatTxt: HC.fmt(zakat), totalTxt: HC.fmt(total), bersihTxt: HC.fmt(bersih), bersihNum: bersih,
          nisabTxt: HC.fmt(nisab), nisabNum: nisab, selisihTxt: HC.fmt(Math.abs(selisih)), emasGrTxt: HC.fmt(emasGr),
          cats: cats.map(function(c){ return { label: c.label, valTxt: HC.fmt(c.val) }; })
        };

        var inputs = { emasGr: els.emasGr.value, emasGram: $('emasGram').value, hutang: els.hutang.value, _rows: JSON.stringify(rows) };
        HC.history.push('zakat-mal', { inputs: inputs, summary: (wajib ? ('Zakat ' + HC.fmt(zakat)) : 'Belum nisab') + ' \u00b7 harta ' + HC.fmt(bersih), metrics: [{ k: 'Harta bersih', v: HC.fmt(bersih) }, { k: 'Status', v: wajib ? 'Wajib' : 'Belum' }] });
        renderHist();

        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Berhasil dihitung!');
      }

      function reset() {
        seed();
        els.emasGr.value = '2.700.000';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; window.HCZakat = null; updateEmasRp(); HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        var c = lastCalc;
        var inputs = [];
        if (c.emasVal > 0) inputs.push({ label: '\ud83e\ude99 Emas (' + c.gramEmas + ' gr)', value: HC.fmt(c.emasVal) });
        c.cats.filter(function(x){ return x.key !== 'emas'; }).slice(0, 5).forEach(function(x){ inputs.push({ label: x.label, value: HC.fmt(x.val) }); });
        if (c.hutang > 0) inputs.push({ label: '\ud83d\udcb3 Hutang JT', value: HC.fmt(c.hutang) });
        return HC.buildReportCard({
          title: '\ud83e\ude99 Zakat Mal', color: '#D97706', color2: '#92400E',
          heroLabel: c.wajib ? 'Zakat Wajib' : 'Status',
          heroValue: c.wajib ? HC.fmt(c.zakat) : 'Belum Nisab',
          heroSubtext: c.wajib ? ('2,5% dari harta bersih ' + HC.fmt(c.bersih)) : ('Masih ' + HC.fmt(c.nisab - c.bersih) + ' di bawah nisab'),
          inputs: inputs,
          results: [
            { label: 'Total Harta', value: HC.fmt(c.total) },
            { label: 'Harta Bersih', value: HC.fmt(c.bersih) },
            { label: 'Nisab (85gr emas)', value: HC.fmt(c.nisab) },
            { label: 'Status', value: c.wajib ? '\u2705 Wajib' : '\u23f8\ufe0f Belum', highlight: c.wajib },
            { label: 'Zakat Wajib', value: HC.fmt(c.zakat), highlight: true }
          ],
          insight: c.wajib ? 'Bayar jika haul 1 tahun terpenuhi, via BAZNAS/LAZ resmi. Disunnahkan di Ramadhan untuk pahala berlipat.' : 'Belum wajib zakat mal. Tetap dianjurkan sedekah & infaq.',
          slug: 'zakat-mal'
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        var c = lastCalc;
        var rin = c.cats.map(function(x){ return '  - ' + x.label + ': ' + HC.fmt(x.val); }).join('\n');
        return '\ud83e\ude99 *Zakat Mal - HitungCerdas*\n\n*Harta:*\n' + rin + '\nHutang: ' + HC.fmt(c.hutang) + '\n\nTotal Harta: ' + HC.fmt(c.total) + '\nHarta Bersih: ' + HC.fmt(c.bersih) + '\nNisab (85gr emas): ' + HC.fmt(c.nisab) + '\n\n' + (c.wajib ? ('\u2705 *Wajib Zakat: ' + HC.fmt(c.zakat) + '*') : '\u23f8\ufe0f Belum capai nisab') + '\n\nHitung: https://hitungcerdas.net/kalkulator/zakat-mal';
      }

      function renderHist() {
        HC.history.render('zakat-mal', $('histBox'), function (e) {
          try { var rows = JSON.parse((e.inputs && e.inputs._rows) || '[]'); if (rows.length) { $('hartaRows').innerHTML = ''; rows.forEach(function(r){ addRow({ kat: r.kat, ket: r.ket, nilai: r.nilai }); }); recalcHarta(); } } catch (err) {}
          updateEmasRp(); hitung();
        });
      }

      // ===== Harga emas LIVE (best-effort, dipertahankan dari versi sebelumnya) =====
      (function loadGoldPrice() {
        var note = $('goldLiveNote'), badge = $('goldLiveBadge');
        var fmtId = function(n){ return new Intl.NumberFormat('id-ID').format(n); };
        fetch('/api/gold', { headers: { 'accept': 'application/json' } })
          .then(function(r){ return r.json(); })
          .then(function(d){
            if (d && d.ok && d.pricePerGram24k > 0) {
              els.emasGr.value = fmtId(d.pricePerGram24k);
              updateEmasRp();
              if (badge) badge.style.display = '';
              if (note) {
                var t = '';
                if (d.ts) { try { t = ' \u00b7 update ' + new Date(d.ts * 1000).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }); } catch (e) {} }
                note.innerHTML = 'Harga emas 24k <strong>live</strong> (spot dunia): Rp ' + fmtId(d.pricePerGram24k) + '/gram' + t + '. Bisa kamu edit \u2014 sebagian ulama pakai harga <strong>Antam</strong> (lebih tinggi, ada premi cetak) sebagai acuan nisab.';
                note.style.color = '#047857';
              }
              if (lastCalc) hitung();
            }
          })
          .catch(function(){});
      })();

      seed();
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      document.querySelectorAll('.adv-toggle').forEach(function(t){ t.addEventListener('click', function(){ t.parentElement.classList.toggle('open'); }); });
      $('exportImg').addEventListener('click', function(){ var r = buildReport(); if (r) HC.exportToImage(r, 'zakat-mal-' + Date.now()); else HC.toast('Hitung dulu', 'error'); });
      $('exportWa').addEventListener('click', function(){ var r = buildReport(); if (r) HC.shareWhatsApp(r, summaryText(), 'zakat-mal'); else HC.toast('Hitung dulu', 'error'); });
      $('exportPdf').addEventListener('click', function(){ if (lastCalc) HC.exportToPDF(); else HC.toast('Hitung dulu', 'error'); });
      $('exportCopy').addEventListener('click', function(){ if (lastCalc) HC.copyText(summaryText(), 'Tersalin!'); else HC.toast('Hitung dulu', 'error'); });
      $('exportExcel').addEventListener('click', function(){ var c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'zakat-mal-' + Date.now()); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function renderGround(){
        var d=window.HCZakat;
        var ctx='<div class="aic-ctx"><i class="ti ti-coins"></i> Zakat Mal</div>';
        if(!d){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat status nisab & zakatmu.</div>'; return; }
        var pct=d.nisabNum>0?Math.min(100,d.bersihNum/d.nisabNum*100):0;
        var bar='<div style="margin:8px 0"><div style="display:flex;justify-content:space-between;font-size:11.5px;margin-bottom:3px"><span>Harta bersih <b>'+esc(d.bersihTxt)+'</b></span><span>Nisab '+esc(d.nisabTxt)+'</span></div><div style="height:9px;border-radius:5px;background:#E5EAF1;overflow:hidden"><div style="height:100%;width:'+pct.toFixed(1)+'%;background:'+(d.wajib?'#16A34A':'#D97706')+'"></div></div></div>';
        var verdict=d.wajib?'<div class="aic-verdict good"><i class="ti ti-circle-check"></i> WAJIB zakat <b>'+esc(d.zakatTxt)+'</b> (bila sudah haul 1 tahun).</div>':'<div class="aic-verdict warn"><i class="ti ti-info-circle"></i> Belum capai nisab, kurang <b>'+esc(d.selisihTxt)+'</b>.</div>';
        ground.innerHTML=ctx+bar+verdict;
      }
      function buildContext(){
        var d=window.HCZakat;
        if(!d) return 'Pengguna belum menghitung zakat mal. Minta mereka mengisi harta (emas, tabungan, investasi, dll) lalu klik Hitung Sekarang.';
        var lines=['Kalkulator: Zakat Mal (zakat harta; tarif 2,5% bila harta capai nisab dan sudah haul 1 tahun).',
          'Total harta: '+d.totalTxt+'. Harta bersih setelah hutang: '+d.bersihTxt+'.',
          'Nisab (85 gram emas, harga '+d.emasGrTxt+'/gram): '+d.nisabTxt+'.'];
        if(d.wajib) lines.push('Status: WAJIB zakat. Zakat = '+d.zakatTxt+' (2,5% dari harta bersih).');
        else lines.push('Status: BELUM wajib zakat, kurang '+d.selisihTxt+' dari nisab.');
        if(d.cats && d.cats.length) lines.push('Rincian harta: '+d.cats.map(function(c){return c.label+' '+c.valTxt;}).join(', ')+'.');
        lines.push('ATURAN UNTUKMU (AI): Gunakan HANYA angka di atas, jangan mengarang. Jelaskan konsep nisab, haul (kepemilikan harta 1 tahun penuh adalah syarat wajib, dan pengguna sendiri yang memastikan ini), tarif 2,5%, serta harta apa yang wajib dan tidak (TIDAK termasuk rumah tinggal, kendaraan pribadi, dan menurut sebagian ulama perhiasan emas yang dipakai sehari-hari). Bila wajib, anjurkan menunaikan via BAZNAS atau Lembaga Amil Zakat (LAZ) resmi. Ini edukasi, BUKAN fatwa. Untuk kasus rumit (mis. zakat saham trading, properti) sarankan konsultasi ke amil/ustadz. Jangan menjawab di luar topik zakat dan harta.');
        return lines.join('\n');
      }
      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Apa itu nisab & haul?','Harta apa yang wajib dizakati?','Emas yang dipakai kena zakat?','Bayar zakat ke mana?','Hutang mengurangi zakat?','Kalau belum 1 tahun gimana?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Jelaskan hasil zakatku','Apa itu nisab & haul?','Bayar zakat ke mana?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
