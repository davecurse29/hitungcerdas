---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('zakat-mal')!;
const related = getRelatedCalculators('zakat-mal', 3);

const faqs = [
  { question: 'Beda zakat mal & fitrah?', answer: '<strong>Mal</strong>: zakat harta yang capai nisab & haul 1 tahun, tarif 2,5%. <strong>Fitrah</strong>: zakat jiwa di Ramadhan, 2,5kg beras/jiwa, tidak ada nisab.' },
  { question: 'Harta apa wajib dizakati?', answer: 'Uang tunai, tabungan, emas/perak, investasi (saham, reksadana, crypto), piutang, aset usaha, properti investasi. TIDAK: rumah tinggal, kendaraan pribadi, perabotan, pakaian.' },
  { question: 'Nisab & haul?', answer: '<strong>Nisab</strong> = 85 gr emas. Nilai rupiahnya mengikuti harga emas terkini — sekitar Rp 205-230jt, tergantung acuan (spot emas dunia atau harga Antam yang lebih tinggi). Kalkulator ini menghitung nisab otomatis dari harga emas yang dipakai. <strong>Haul</strong> = harta dimiliki min 1 tahun. Praktis: tetapkan tanggal patokan (misal Ramadhan) untuk hitung setahun sekali.' },
  { question: 'Hutang mengurangi zakat?', answer: 'YA, hutang jatuh tempo 12 bulan ke depan kurangi harta. Rumus: Zakat = (Harta - Hutang Jangka Pendek) x 2,5%, jika setelahnya masih di atas nisab.' },
  { question: 'Kapan bayar?', answer: 'Saat haul terpenuhi (harta dimiliki 1 tahun). Praktis: tetapkan tanggal patokan tahunan, hitung total harta, bayar 2,5%. Banyak Muslim Indonesia bayar di Ramadhan.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#D97706;--cat-color2:#92400E">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FEF3C7;color:#92400E"><i class="ti ti-coins"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <ellipse cx="100" cy="155" rx="50" ry="8" fill="#B45309"/>
            <ellipse cx="100" cy="135" rx="50" ry="8" fill="#FCD34D" stroke="#B45309" stroke-width="1.5"/>
            <ellipse cx="100" cy="105" rx="50" ry="8" fill="#FCD34D" stroke="#B45309" stroke-width="1.5"/>
            <ellipse cx="100" cy="80" rx="50" ry="8" fill="#FCD34D" stroke="#B45309" stroke-width="1.5"/>
            <text x="100" y="85" text-anchor="middle" font-size="11" font-weight="900" fill="#B45309">2,5%</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#D97706 0%,#92400E 100%)"><i class="ti ti-coins"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Zakat Mal</h2><p class="calc-card-sub">2,5% dari harta yang capai nisab & haul 1 tahun</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="zm-grp">Acuan Emas</div>
            <div class="field"><label>Harga Emas per Gram <span class="hint" id="goldLiveBadge" style="display:none;font-weight:700;color:#047857">🟢 live</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="emasGr" class="has-prefix" value="2.700.000" inputmode="numeric" /></div>
              <p class="field-hint" id="goldLiveNote">Harga emas terisi otomatis (spot terkini). Jika offline, pakai default manual ~Rp 2,7jt/gram (acuan Antam) — bisa kamu edit.</p></div>

            <div class="zm-grp">Emas & Logam Mulia</div>
            <div class="field"><label>Berat Emas Dimiliki <span class="hint">(gram, di luar perhiasan dipakai)</span></label>
              <div class="input-wrap"><input type="number" id="emasGram" value="10" min="0" step="any" inputmode="decimal" /><span class="input-suffix">gram</span></div>
              <p class="field-hint">Senilai <b id="emasRp" style="color:#B45309">Rp 0</b> (otomatis dari harga emas/gram di atas).</p></div>

            <div class="zm-grp">Harta Lain <span class="zm-grp-hint">(tabungan, investasi, dll)</span></div>
            <div class="zm-scroll">
              <table class="zm-table">
                <thead><tr><th>Kategori</th><th>Keterangan</th><th class="r">Nilai</th><th></th></tr></thead>
                <tbody id="hartaRows"></tbody>
              </table>
            </div>
            <button type="button" class="zm-addbtn" id="addHarta"><i class="ti ti-plus"></i> Tambah Harta</button>
            <div class="zm-subtotal"><span><i class="ti ti-wallet"></i> Subtotal Harta Lain</span><b id="hartaLainTotal">Rp 0</b></div>

            <div class="zm-grp">Pengurang</div>
            <div class="field"><label>Hutang Jatuh Tempo 12 Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="hutang" class="has-prefix" placeholder="0" inputmode="numeric" /></div>
              <p class="field-hint">Hanya cicilan/hutang yang jatuh tempo dalam 12 bulan ke depan.</p></div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-coins result-placeholder-icon"></i>
              <div class="result-placeholder-title">Hasil akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi harta yang dimiliki min 1 tahun, lalu klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Zakat Mal Wajib Bayar</div>
                <div class="result-value" id="zakatMal">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="zakatPct">2,5% dari harta bersih</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Total Harta</div><div class="result-item-value" id="totalHarta">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Harta Bersih</div><div class="result-item-value" id="hartaBersih">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Nisab (85gr emas)</div><div class="result-item-value" id="nisab">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Selisih vs Nisab</div><div class="result-item-value" id="selisih">Rp 0</div></div>
              </div>

              <div class="kelayakan-box">
                <div class="kelayakan-hdr"><i class="ti ti-shield-check"></i> <span>Status & Haul</span></div>
                <div id="status"></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-pie"></i>&nbsp; Komposisi Harta</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div class="zm-komp-grid">
                    <div id="kompDonut" class="zm-donut-wrap"></div>
                    <table class="compare-table" style="flex:1;min-width:200px">
                      <thead><tr><th>Jenis Harta</th><th class="right">Nilai</th><th class="right">Porsi</th></tr></thead>
                      <tbody id="kompBody"></tbody>
                    </table>
                  </div>
                </div>
              </div>

              <div class="export-row">
                <button class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>

              <!-- ===== AI COACH ZAKAT ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung nisab/haul? Harta ini kena zakat? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Zakat</strong>
                      <small>Bantu pahami kewajiban zakatmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal zakat & nisab..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Penjelasan edukatif berbasis hitunganmu, bukan fatwa resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Cara Menghitung Zakat Mal yang Benar</h2>
      <p>Zakat mal wajib bagi Muslim yang hartanya capai nisab (85 gr emas — sekitar Rp 205-230jt mengikuti harga emas terkini, tergantung acuan spot emas dunia atau harga Antam) dan sudah dimiliki min 1 tahun. Tarif 2,5% dari harta bersih (setelah dikurangi hutang jatuh tempo). Punya penghasilan rutin? Hitung juga <a href="/kalkulator/zakat-penghasilan">zakat penghasilan</a>. Menjelang Idul Fitri, jangan lupa <a href="/kalkulator/zakat-fitrah">zakat fitrah</a>.</p>
      <div class="cta-box"><h3>Tunaikan Zakat Mal Anda</h3><p>Hitung total harta, kurangi hutang, lalu bayar 2,5% via BAZNAS atau lembaga zakat resmi.</p></div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
  <p style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:600px;">
    Nisab diperbarui <strong>Juni 2026</strong> &middot; Sumber: <a href="https://baznas.go.id/" target="_blank" rel="noopener">BAZNAS</a> & harga emas terkini
  </p>
</Layout>

<style>
  .zm-grp{font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#B45309;margin:16px 0 8px;display:flex;align-items:center;gap:7px}
  .zm-grp:first-child{margin-top:0}
  .zm-grp::before{content:'';width:14px;height:2px;border-radius:2px;background:currentColor;opacity:.55}
  .zm-grp-hint{font-weight:500;text-transform:none;letter-spacing:0;color:var(--text-mute,#94A3B8)}
  .zm-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch}
  .zm-table{width:100%;border-collapse:collapse;font-size:13px;min-width:330px}
  .zm-table thead th{font-size:10px;text-transform:uppercase;letter-spacing:.02em;color:var(--text-mute,#94A3B8);text-align:left;padding:2px 5px 6px;font-weight:600;white-space:nowrap}
  .zm-table thead th.r{text-align:right}
  .zm-row td{padding:3px 4px;vertical-align:middle}
  .zm-row select,.zm-row input{width:100%;border:1px solid var(--border,#E2E8F0);border-radius:8px;padding:7px 8px;font-size:12.5px;font-family:inherit;background:var(--bg,#fff);color:var(--text,#0F172A);outline:none}
  .zm-row select:focus,.zm-row input:focus{border-color:#D97706}
  .zm-row select.zm-kat{min-width:118px}
  .zm-nilai-wrap{display:flex;align-items:center;gap:3px;border:1px solid var(--border,#E2E8F0);border-radius:8px;padding:0 8px;background:var(--bg,#fff)}
  .zm-nilai-wrap:focus-within{border-color:#D97706}
  .zm-nilai-wrap .zm-rp{font-size:11px;color:var(--text-mute,#94A3B8)}
  .zm-nilai-wrap input{border:0;padding:7px 0;width:92px;text-align:right}
  .zm-del{border:0;background:#FEE2E2;color:#DC2626;width:28px;height:28px;border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px}
  .zm-del:hover{background:#FCA5A5}
  .zm-addbtn{margin-top:9px;border:1px dashed #F59E0B;background:#FFFBEB;color:#B45309;border-radius:9px;padding:8px 13px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:6px}
  .zm-addbtn:hover{background:#FEF3C7}
  .zm-subtotal{margin-top:11px;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:10px 13px;background:#FFFBEB;border:1px solid #FDE68A;border-radius:11px;font-size:13px;color:#92400E;font-weight:600}
  .zm-subtotal b{font-size:15px;color:#B45309;white-space:nowrap}
  .zm-komp-grid{display:flex;gap:16px;align-items:center;flex-wrap:wrap}
  .zm-donut-wrap{flex-shrink:0;display:flex;justify-content:center;align-items:center}
  .zm-donut{width:132px;height:132px}
</style>

<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EFF4FF;border:1px solid #C7DBFF;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E4EDFF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#2563EB;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EFF4FF;color:#2563EB;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#2563EB;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#2563EB;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#0891B2;border-color:#0891B2;background:#ECFEFF}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#EFF4FF;color:#2563EB;border:1px solid #D6E4FF;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#E0EBFF}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#2563EB}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#2563EB;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

