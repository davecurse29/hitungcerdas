---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('gaji-bersih')!;
const related = getRelatedCalculators('gaji-bersih', 3);

const faqs = [
  { question: 'Apa itu gaji bersih (take-home pay)?', answer: 'Gaji bersih = uang yang benar-benar masuk rekeningmu setelah semua potongan: BPJS Kesehatan (1%), BPJS JHT (2%), BPJS JP (1%), PPh 21 progresif, dan potongan internal (koperasi, cicilan). Biasanya 70-85% dari gaji bruto.' },
  { question: 'Berapa total potongan BPJS karyawan?', answer: 'Total potongan BPJS karyawan = 4% gaji: <strong>BPJS Kesehatan 1%</strong> (maks Rp 120rb/bln, batas ceiling Rp 12jt), <strong>JHT 2%</strong>, <strong>JP 1%</strong> (maks Rp 110.863/bln, batas ceiling Rp 11,08jt). Perusahaan tambah ~9% dari sisinya untuk JKK, JKM, BPJS Kes.' },
  { question: 'Bagaimana alokasi 50/30/20 yang tepat?', answer: 'Aturan emas alokasi take-home pay: <strong>50% kebutuhan</strong> (sewa/cicilan, listrik, transport, makan), <strong>30% keinginan</strong> (hiburan, hobi, makan di luar), <strong>20% tabungan & investasi</strong> (dana darurat, reksadana, emas).' },
  { question: 'Apakah lembur dan komisi kena PPh?', answer: 'YA, lembur dan komisi termasuk objek PPh 21. Hitungnya ditambahkan ke bruto setahun. Tarifnya progresif sama seperti gaji pokok. Komisi yang besar bisa bikin loncat ke lapisan tarif berikutnya.' },
  { question: 'Kenapa THR/bonus dipotong pajak lebih besar?', answer: 'THR & bonus termasuk <strong>penghasilan tidak teratur</strong>. Pajaknya dihitung sebagai selisih PPh setahun <em>dengan</em> THR dikurangi PPh setahun <em>tanpa</em> THR. Karena menambah total penghasilan tahunan, THR bisa kena tarif lapisan lebih tinggi, sehingga tarif efektifnya terasa lebih besar dari gaji biasa. Sejak 2024 (PMK 168/2023), potongan riil di bulan THR memakai tarif efektif (TER), lalu dikoreksi otomatis di masa pajak Desember.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#059669;--cat-color2:#047857">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#D1FAE5;color:#047857"><i class="ti ti-wallet"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <rect x="50" y="65" width="100" height="70" rx="8" fill="#FFF" stroke="#FBBF24" stroke-width="2"/>
            <circle cx="100" cy="100" r="20" fill="none" stroke="#059669" stroke-width="3"/>
            <text x="100" y="106" text-anchor="middle" font-size="14" font-weight="900" fill="#059669" font-family="Inter">Rp</text>
            <rect x="60" y="75" width="20" height="5" fill="#FBBF24"/>
            <rect x="120" y="75" width="20" height="5" fill="#FBBF24"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#059669 0%,#047857 100%)"><i class="ti ti-wallet"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Gaji Bersih</h2><p class="calc-card-sub">Hitung take-home pay setelah BPJS & PPh 21</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Gaji Pokok</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="gaji" class="has-prefix" value="8.000.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Tunjangan Tetap <span class="hint">(transport, makan)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="tunj" class="has-prefix" value="1.500.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Tunjangan Tidak Tetap <span class="hint">(lembur, komisi)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="tunjVar" class="has-prefix" value="0" inputmode="numeric" /></div></div>

            <div class="field"><label>Status PTKP</label>
              <select id="ptkp">
                <option value="54000000">TK/0 - Lajang</option>
                <option value="58500000">K/0 - Menikah no anak</option>
                <option value="63000000">K/1 - 1 anak</option>
                <option value="67500000">K/2 - 2 anak</option>
                <option value="72000000">K/3 - 3 anak</option>
              </select></div>

            <div class="field"><label>Metode Hitung PPh 21</label>
              <select id="pphMethod">
                <option value="tahunan">Estimasi Tahunan (progresif ÷12)</option>
                <option value="ter">TER Bulanan — sesuai slip 2024+</option>
              </select></div>

            <div class="field"><label>Potongan Lain per Bulan <span class="hint">(koperasi, cicilan internal)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="potLain" class="has-prefix" value="0" inputmode="numeric" /></div></div>

            <div class="field"><label>Iuran DPLK – Karyawan <span class="hint">(% gaji pokok, dipotong dari gajimu)</span></label>
              <div class="input-wrap"><input type="number" id="dplkKaryawan" class="has-suffix" value="0" min="0" max="100" step="0.5" /><span class="input-suffix">%</span></div></div>

            <div class="field"><label>Iuran DPLK – Perusahaan <span class="hint">(% gaji pokok, di luar gajimu)</span></label>
              <div class="input-wrap"><input type="number" id="dplkPerusahaan" class="has-suffix" value="0" min="0" max="100" step="0.5" /><span class="input-suffix">%</span></div></div>
            <p style="font-size:11.5px;color:var(--text-mute);margin:-2px 0 10px;line-height:1.5">💡 Iuran DPLK <strong>karyawan</strong> memotong gaji & mengurangi PPh (pengurang penghasilan bruto, PMK 168/2023). Iuran <strong>perusahaan</strong> di luar gajimu & tidak kena pajak saat disetor.</p>

            <div class="field"><label>THR / Bonus Tahunan <span class="hint">(THR Lebaran, bonus, gratifikasi)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="thrBonus" class="has-prefix" value="0" inputmode="numeric" /></div></div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>

            <div style="margin-top:14px;padding:13px;border:1px dashed var(--border,#CBD5E1);border-radius:12px">
              <div style="font-size:13px;font-weight:700;margin-bottom:8px"><i class="ti ti-arrows-exchange"></i> Kalkulator Balik — target take-home, gaji pokok berapa?</div>
              <div class="field"><label>Target Take-Home Pay yang Diinginkan</label>
                <div class="input-wrap"><span class="input-prefix">Rp</span>
                  <input type="text" id="targetThp" class="has-prefix" value="10.000.000" inputmode="numeric" /></div></div>
              <button type="button" class="btn-reset" id="btnBalik" style="width:100%"><i class="ti ti-arrows-exchange"></i> Hitung Gaji Pokok yang Dibutuhkan</button>
              <div id="balikResult" style="display:none;margin-top:10px;font-size:13px;line-height:1.6"></div>
              <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 Pakai tunjangan, PTKP, DPLK & metode pajak yang sama dengan form di atas. Berguna saat menilai tawaran kerja ("biar take-home Rp X, minta gaji pokok berapa?").</p>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-wallet result-placeholder-icon"></i>
              <div class="result-placeholder-title">Take-Home Pay akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi komponen gaji, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Take-Home Pay (Gaji Bersih)</div>
                <div class="result-value" id="thp">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="thpPct">0% dari bruto</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Gaji Bruto/Bulan</div><div class="result-item-value" id="bruto">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">BPJS Karyawan</div><div class="result-item-value result-warn" id="bpjsTotal">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">PPh 21/Bulan</div><div class="result-item-value result-warn" id="pphBulan">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Potongan Lain</div><div class="result-item-value" id="potLainShow">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">DPLK Karyawan</div><div class="result-item-value result-warn" id="dplkKaryawanShow">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">DPLK Perusahaan <span style="font-weight:400;font-size:10px;opacity:.7">(kantor)</span></div><div class="result-item-value" id="dplkPerusahaanShow">Rp 0</div></div>
              </div>

              <div id="pphMethodInfo" style="font-size:11.5px;color:var(--text-mute);margin:2px 2px 4px;line-height:1.45"></div>

              <div class="adv-section open" id="thrBlock" style="display:none">
                <div class="adv-toggle"><span><i class="ti ti-gift"></i>&nbsp; Rincian THR / Bonus (diterima sekali)</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div class="result-grid">
                    <div class="result-item"><div class="result-item-label">THR / Bonus Bruto</div><div class="result-item-value" id="thrBruto">Rp 0</div></div>
                    <div class="result-item"><div class="result-item-label">PPh 21 atas THR/Bonus</div><div class="result-item-value result-warn" id="thrPphShow">Rp 0</div></div>
                    <div class="result-item"><div class="result-item-label">THR/Bonus Bersih</div><div class="result-item-value result-strong" id="thrNetShow">Rp 0</div></div>
                    <div class="result-item"><div class="result-item-label">Tarif Efektif THR</div><div class="result-item-value" id="thrRateShow">0%</div></div>
                  </div>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 THR/bonus = penghasilan <strong>tidak teratur</strong>. Pajaknya = selisih PPh setahun (dengan vs tanpa THR), jadi tarif efektifnya bisa lebih tinggi dari gaji biasa. Diterima sekali, <strong>terpisah</strong> dari take-home bulanan. Sejak 2024 potongan riil pakai TER di bulan THR, lalu dikoreksi di Desember.</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-building-skyscraper"></i>&nbsp; Total Biaya Perusahaan (CTC)</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Komponen (ditanggung kantor)</th><th class="right">Per Bulan</th></tr></thead>
                    <tbody id="ctcBody"></tbody>
                  </table>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 CTC = total biaya perusahaan untuk mempekerjakanmu (gaji + iuran BPJS sisi kantor + DPLK kantor). Take-home kamu <strong id="ctcRatio">—</strong> dari total ini. Berguna saat negosiasi gaji. (JKK pakai asumsi risiko rendah 0,24%; tarif aktual tergantung sektor usaha.)</p>
                </div>
              </div>

              <div class="adv-section open" id="zakatSection">
                <div class="adv-toggle"><span><i class="ti ti-moon-stars"></i>&nbsp; Zakat Penghasilan (2,5%)</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div id="zakatBody"></div>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 Zakat penghasilan = 2,5% dari penghasilan bruto bila setahun mencapai nisab (85 gr emas). Dibayar via lembaga resmi (mis. BAZNAS) bisa jadi <strong>pengurang PKP</strong>. Nisab pakai harga emas terkini.</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-pie-chart"></i>&nbsp; Alokasi 50/30/20 Take-Home</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Kategori</th><th class="right">% THP</th><th class="right">Nominal/Bulan</th></tr></thead>
                    <tbody id="alokasiBody"></tbody>
                  </table>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 Aturan klasik: <strong>50%</strong> kebutuhan (cicilan, makan, transport), <strong>30%</strong> keinginan (hiburan), <strong>20%</strong> tabungan & investasi.</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-target"></i>&nbsp; Tabungan 20% Selama 5 Tahun</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Tahun</th><th class="right">Tabungan Pokok</th><th class="right">+ Bunga 6%/thn</th></tr></thead>
                    <tbody id="proyeksiBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section" id="scenBlock">
                <div class="adv-toggle"><span><i class="ti ti-columns"></i>&nbsp; Bandingkan Skenario A vs B</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <p style="font-size:12px;color:var(--text-mute);margin:0 0 8px;line-height:1.5">Atur input skenario pertama lalu klik <b>Simpan sbg A</b>. Ubah input, klik <b>Simpan sbg B</b>. Otomatis dihitung ulang saat disimpan — tabel perbandingan muncul sendiri.</p>
                  <div style="display:flex;gap:8px">
                    <button type="button" class="btn-reset" id="btnScenA" style="flex:1"><i class="ti ti-bookmark"></i> Simpan sbg A</button>
                    <button type="button" class="btn-reset" id="btnScenB" style="flex:1"><i class="ti ti-bookmark"></i> Simpan sbg B</button>
                  </div>
                  <div id="scenResult" style="display:none;margin-top:10px"></div>
                  <button type="button" id="btnScenReset" style="margin-top:8px;background:none;border:none;color:var(--text-mute);font-size:12px;cursor:pointer;text-decoration:underline">Reset skenario</button>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn link" id="exportLink"><i class="ti ti-link" style="color:#0891B2"></i><span style="color:#0891B2">Salin Link</span></button>
              </div>

              <div id="nextSteps" style="display:none;margin-top:14px;padding:13px;border:1px dashed var(--border,#CBD5E1);border-radius:12px">
                <div style="font-size:13px;font-weight:700;margin-bottom:8px"><i class="ti ti-route"></i> Langkah Selanjutnya</div>
                <div id="nextStepsBody" style="display:flex;flex-direction:column;gap:8px"></div>
                <p style="font-size:11px;color:var(--text-mute);margin-top:8px;line-height:1.5">Take-home pay-mu otomatis diisi ke kalkulator tujuan.</p>
              </div>

              <!-- ===== AI COACH KEPUTUSAN (mandiri) ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung sama hasilnya? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu pahami gaji bersihmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal gaji bersihmu..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hasil hitunganmu, bukan nasihat keuangan berlisensi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FITUR: BANDINGKAN TAWARAN KERJA ===== -->
  <section class="calc-section" style="padding-top:0">
    <div class="wrap">
      <div class="calc-card jobcmp">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#0EA5E9 0%,#0369A1 100%)"><i class="ti ti-arrows-exchange"></i></div>
          <div><h2 class="calc-card-title">Bandingkan Tawaran Kerja</h2><p class="calc-card-sub">Gaji sekarang vs tawaran baru &mdash; lihat take-home asli &amp; target nego HRD</p></div>
        </div>

        <div class="field"><label>Status PTKP (kamu)</label>
          <select id="jcPtkp">
            <option value="54000000">TK/0 - Lajang</option>
            <option value="58500000">K/0 - Menikah no anak</option>
            <option value="63000000">K/1 - 1 anak</option>
            <option value="67500000">K/2 - 2 anak</option>
            <option value="72000000">K/3 - 3 anak</option>
          </select>
        </div>

        <div class="jc-grid">
          <div class="jc-col jc-now">
            <div class="jc-col-hdr"><i class="ti ti-building"></i> Kantor Sekarang</div>
            <div class="field"><label>Gaji Pokok</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="jcGajiNow" class="has-prefix" value="8.000.000" inputmode="numeric" /></div></div>
            <div class="field" style="margin-bottom:0"><label>Tunjangan Tetap</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="jcTunjNow" class="has-prefix" value="1.500.000" inputmode="numeric" /></div></div>
          </div>
          <div class="jc-vs"><span>VS</span></div>
          <div class="jc-col jc-new">
            <div class="jc-col-hdr"><i class="ti ti-rocket"></i> Tawaran Baru</div>
            <div class="field"><label>Gaji Pokok</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="jcGajiNew" class="has-prefix" value="10.000.000" inputmode="numeric" /></div></div>
            <div class="field" style="margin-bottom:0"><label>Tunjangan Tetap</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="jcTunjNew" class="has-prefix" value="1.500.000" inputmode="numeric" /></div></div>
          </div>
        </div>

        <button type="button" class="btn-hitung" id="jcBtn"><i class="ti ti-arrows-exchange"></i> Bandingkan Take-Home</button>

        <div id="jcResult" class="jc-result" style="display:none;margin-top:16px"></div>

        <p class="jc-note"><i class="ti ti-info-circle"></i> Berdasarkan estimasi tahunan (BPJS + PPh 21, JP cap 2026). THR/bonus &amp; potongan internal belum dihitung. Angka untuk gambaran negosiasi, bukan patokan resmi.</p>
      </div>
    </div>
  </section>
  <!-- ===== /BANDINGKAN TAWARAN KERJA ===== -->

  <section class="content-section">
    <div class="wrap-text">
      <h2>Cara Menghitung Gaji Bersih Karyawan</h2>
      <p>Gaji bersih (take-home pay) = gaji bruto - BPJS Kesehatan 1% - JHT 2% - JP 1% - PPh 21 progresif - potongan lain. Untuk gaji bruto Rp 9,5jt, THP biasanya sekitar Rp 8,8jt (93%). Mau tahu rincian potongan pajaknya? Hitung terpisah di <a href="/kalkulator/pph-21">kalkulator PPh 21</a>. Penghasilanmu sudah capai nisab? Cek juga <a href="/kalkulator/zakat-penghasilan">zakat penghasilan</a>.</p>
      <div class="cta-box"><h3>Coba Sekarang</h3><p>Isi data gaji & potongan, klik "Hitung Sekarang" untuk simulasi lengkap dengan alokasi 50/30/20.</p></div>
    </div>
  </section>

