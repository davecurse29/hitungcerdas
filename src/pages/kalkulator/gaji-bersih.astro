<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { gaji: $('gaji'), tunj: $('tunj'), tunjVar: $('tunjVar'), ptkp: $('ptkp'), pphMethod: $('pphMethod'), potLain: $('potLain'), dplkKaryawan: $('dplkKaryawan'), dplkPerusahaan: $('dplkPerusahaan'), thrBonus: $('thrBonus'), targetThp: $('targetThp') };
      [els.gaji, els.tunj, els.tunjVar, els.potLain, els.thrBonus, els.targetThp].forEach(el => el && el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      const BRACKETS = [
        { max: 60000000, rate: 0.05 }, { max: 250000000, rate: 0.15 },
        { max: 500000000, rate: 0.25 }, { max: 5000000000, rate: 0.30 },
        { max: Infinity, rate: 0.35 },
      ];
      function calcPPh(pkp) {
        if (pkp <= 0) return 0;
        let r = pkp, total = 0, prev = 0;
        for (const b of BRACKETS) { if (r <= 0) break; const s = Math.min(r, b.max - prev); total += s * b.rate; r -= s; prev = b.max; }
        return total;
      }

      // ===== Tabel TER Bulanan PP 58/2023 (resmi). [batas atas bruto/bln, tarif %] =====
      const TER = {
        A: [[5400000,0],[5650000,.25],[5950000,.5],[6300000,.75],[6750000,1],[7500000,1.25],[8550000,1.5],[9650000,1.75],[10050000,2],[10350000,2.25],[10700000,2.5],[11050000,3],[11600000,3.5],[12500000,4],[13750000,5],[15100000,6],[16950000,7],[19750000,8],[24150000,9],[26450000,10],[28000000,11],[30050000,12],[32400000,13],[35400000,14],[39100000,15],[43850000,16],[47800000,17],[51400000,18],[56300000,19],[62200000,20],[68600000,21],[77500000,22],[89000000,23],[103000000,24],[125000000,25],[157000000,26],[206000000,27],[337000000,28],[454000000,29],[550000000,30],[695000000,31],[910000000,32],[1400000000,33],[Infinity,34]],
        B: [[6200000,0],[6500000,.25],[6850000,.5],[7300000,.75],[9200000,1],[10750000,1.5],[11250000,2],[11600000,2.5],[12600000,3],[13600000,4],[14950000,5],[16400000,6],[18450000,7],[21850000,8],[26000000,9],[27700000,10],[29350000,11],[31450000,12],[33950000,13],[37100000,14],[41100000,15],[45800000,16],[49500000,17],[53800000,18],[58500000,19],[64000000,20],[71000000,21],[80000000,22],[93000000,23],[109000000,24],[129000000,25],[163000000,26],[211000000,27],[374000000,28],[459000000,29],[555000000,30],[704000000,31],[957000000,32],[1405000000,33],[Infinity,34]],
        C: [[6600000,0],[6950000,.25],[7350000,.5],[7800000,.75],[8850000,1],[9800000,1.25],[10950000,1.5],[11200000,1.75],[12050000,2],[12950000,3],[14150000,4],[15550000,5],[17050000,6],[19500000,7],[22700000,8],[26600000,9],[28100000,10],[30100000,11],[32600000,12],[35400000,13],[38900000,14],[43000000,15],[47400000,16],[51200000,17],[55800000,18],[60400000,19],[66700000,20],[74500000,21],[83200000,22],[95600000,23],[110000000,24],[134000000,25],[169000000,26],[221000000,27],[390000000,28],[463000000,29],[561000000,30],[709000000,31],[965000000,32],[1419000000,33],[Infinity,34]]
      };
      // PTKP -> kategori TER: A (TK/0, K/0 ≤58,5jt), B (K/1, K/2 ≤67,5jt), C (K/3)
      function terCategory(ptkp){ return ptkp <= 58500000 ? 'A' : (ptkp <= 67500000 ? 'B' : 'C'); }
      function terRate(cat, bruto){ const t = TER[cat]; for (let i=0;i<t.length;i++){ if (bruto <= t[i][0]) return t[i][1]/100; } return t[t.length-1][1]/100; }

      // Fungsi MURNI take-home (dipakai bersama oleh hitung() & Kalkulator Balik). Harus konsisten dgn hitung().
      function coreThp(gaji, tunj, tunjVar, ptkp, potLain, dplkPct, useTer) {
        const dplkKaryawan = gaji * dplkPct / 100;
        const brutoBulan = gaji + tunj + tunjVar;
        const bpjsKes = Math.min(brutoBulan * 0.01, 120000);
        const bpjsJht = brutoBulan * 0.02;
        const bpjsJp = Math.min(brutoBulan * 0.01, 110863);
        const bpjsTotal = bpjsKes + bpjsJht + bpjsJp;
        let pphBulan;
        if (useTer) {
          pphBulan = terRate(terCategory(ptkp), brutoBulan) * brutoBulan;
        } else {
          const bt = brutoBulan * 12;
          const bj = Math.min(bt * 0.05, 6000000);
          const neto = bt - bj - bpjsTotal * 12 - dplkKaryawan * 12;
          pphBulan = calcPPh(Math.max(0, neto - ptkp)) / 12;
        }
        const thp = brutoBulan - bpjsTotal - pphBulan - potLain - dplkKaryawan;
        return { thp, brutoBulan, bpjsTotal, pphBulan, dplkKaryawan };
      }

      // Expose mesin take-home murni untuk fitur "Bandingkan Tawaran Kerja" (single source of truth).
      try { window.HCGaji = { coreThp: coreThp }; } catch (e) {}

      // Harga emas live (untuk nisab zakat penghasilan). Fallback spot 24k ~Rp 2,4jt/gram.
      let goldPerGram = 2400000;
      fetch('/api/gold', { headers: { 'accept': 'application/json' } })
        .then(r => r.json())
        .then(d => { if (d && d.ok && d.pricePerGram24k > 0) goldPerGram = d.pricePerGram24k; })
        .catch(() => {});

      let lastCalc = null;

      function hitung() {
        const gaji = HC.parseRp(els.gaji.value);
        const tunj = HC.parseRp(els.tunj.value);
        const tunjVar = HC.parseRp(els.tunjVar.value);
        const ptkp = parseInt(els.ptkp.value);
        const potLain = HC.parseRp(els.potLain.value);
        const dplkKaryawanPct = Math.max(0, parseFloat(els.dplkKaryawan.value) || 0);
        const dplkPerusahaanPct = Math.max(0, parseFloat(els.dplkPerusahaan.value) || 0);

        if (gaji === 0) { HC.toast('Masukkan gaji pokok dulu', 'error'); return; }

        // DPLK dihitung dari gaji pokok. Iuran KARYAWAN = pengurang penghasilan bruto (PMK 168/2023),
        // memotong take-home & menurunkan PPh. Iuran PERUSAHAAN di luar gaji & bukan objek PPh 21 saat disetor.
        const dplkKaryawan = gaji * dplkKaryawanPct / 100;
        const dplkPerusahaan = gaji * dplkPerusahaanPct / 100;

        const brutoBulan = gaji + tunj + tunjVar;
        // BPJS (with ceiling rules)
        const bpjsKes = Math.min(brutoBulan * 0.01, 120000);
        const bpjsJht = brutoBulan * 0.02;
        const bpjsJp = Math.min(brutoBulan * 0.01, 110863);
        const bpjsTotal = bpjsKes + bpjsJht + bpjsJp;

        // ===== PPh 21: dua metode =====
        const useTer = els.pphMethod.value === 'ter';
        const terCat = terCategory(ptkp);
        const terRt = terRate(terCat, brutoBulan);

        // Metode TAHUNAN (progresif disetahunkan, dibagi 12)
        const brutoTahun = brutoBulan * 12;
        const biayaJabatan = Math.min(brutoTahun * 0.05, 6000000);
        const neto = brutoTahun - biayaJabatan - (bpjsTotal * 12) - (dplkKaryawan * 12);
        const pkp = Math.max(0, neto - ptkp);
        const pphTahun = calcPPh(pkp);
        const pphBulanTahunan = pphTahun / 12;

        // Metode TER BULANAN (Jan–Nov): tarif efektif × bruto bulan ini
        const pphBulanTER = terRt * brutoBulan;

        const pphBulan = useTer ? pphBulanTER : pphBulanTahunan;

        // THR / Bonus = penghasilan tidak teratur (digabung ke bruto bulan diterimanya).
        const thrBonus = HC.parseRp(els.thrBonus.value);
        let thrPph = 0, thrNet = 0, thrRate = 0;
        if (thrBonus > 0) {
          if (useTer) {
            // TER: pajak bulan THR = TER(bruto+THR)×(bruto+THR) − TER(bruto)×bruto
            const rThr = terRate(terCat, brutoBulan + thrBonus);
            thrPph = Math.max(0, rThr * (brutoBulan + thrBonus) - pphBulanTER);
          } else {
            // Tahunan: selisih PPh setahun (dengan vs tanpa THR)
            const brutoTahunTHR = brutoTahun + thrBonus;
            const biayaJabatanTHR = Math.min(brutoTahunTHR * 0.05, 6000000);
            const netoTHR = brutoTahunTHR - biayaJabatanTHR - (bpjsTotal * 12) - (dplkKaryawan * 12);
            thrPph = Math.max(0, calcPPh(Math.max(0, netoTHR - ptkp)) - pphTahun);
          }
          thrNet = thrBonus - thrPph;
          thrRate = (thrPph / thrBonus) * 100;
        }

        // ===== Total Biaya Perusahaan (CTC) — iuran sisi kantor =====
        const empKes = Math.min(brutoBulan, 12000000) * 0.04;   // BPJS Kesehatan kantor 4% (ceiling gaji 12jt)
        const empJht = brutoBulan * 0.037;                       // JHT kantor 3,7%
        const empJp  = Math.min(brutoBulan, 11086300) * 0.02;     // JP kantor 2% (ceiling 11,08jt)
        const empJkk = brutoBulan * 0.0024;                      // JKK 0,24% (asumsi risiko rendah)
        const empJkm = brutoBulan * 0.003;                       // JKM 0,3%
        const empBpjs = empKes + empJht + empJp + empJkk + empJkm;
        const ctc = brutoBulan + empBpjs + dplkPerusahaan;

        const thp = brutoBulan - bpjsTotal - pphBulan - potLain - dplkKaryawan;
        const thpPct = (thp / brutoBulan) * 100;

        $('thp').textContent = HC.fmt(thp);
        $('thpPct').textContent = `${thpPct.toFixed(1)}% dari bruto`;
        $('bruto').textContent = HC.fmt(brutoBulan);
        $('bpjsTotal').textContent = HC.fmt(bpjsTotal);
        $('pphBulan').textContent = HC.fmt(pphBulan);
        $('pphMethodInfo').innerHTML = useTer
          ? `<i class="ti ti-receipt-tax"></i> Metode <strong>TER ${terCat}</strong> · tarif efektif <strong>${(terRt*100).toFixed(2)}%</strong> × bruto (potongan riil slip Jan–Nov). Desember dikoreksi ke total tahunan.`
          : `<i class="ti ti-calculator"></i> Metode <strong>estimasi tahunan</strong> (progresif disetahunkan ÷12). Pilih <strong>TER</strong> untuk angka sesuai slip gaji 2024+.`;
        $('potLainShow').textContent = HC.fmt(potLain);
        $('dplkKaryawanShow').textContent = HC.fmt(dplkKaryawan);
        $('dplkPerusahaanShow').textContent = HC.fmt(dplkPerusahaan);

        $('ctcBody').innerHTML =
          `<tr><td>Gaji bruto (yang kamu lihat)</td><td class="right">${HC.fmt(brutoBulan)}</td></tr>`
          + `<tr><td>BPJS Kesehatan (4%)</td><td class="right">${HC.fmt(empKes)}</td></tr>`
          + `<tr><td>JHT (3,7%)</td><td class="right">${HC.fmt(empJht)}</td></tr>`
          + `<tr><td>JP (2%)</td><td class="right">${HC.fmt(empJp)}</td></tr>`
          + `<tr><td>JKK (0,24%, risiko rendah)</td><td class="right">${HC.fmt(empJkk)}</td></tr>`
          + `<tr><td>JKM (0,3%)</td><td class="right">${HC.fmt(empJkm)}</td></tr>`
          + (dplkPerusahaan > 0 ? `<tr><td>DPLK perusahaan</td><td class="right">${HC.fmt(dplkPerusahaan)}</td></tr>` : '')
          + `<tr class="active"><td><strong>Total Biaya Perusahaan</strong></td><td class="right"><strong>${HC.fmt(ctc)}</strong></td></tr>`;
        $('ctcRatio').textContent = `${(thp / ctc * 100).toFixed(0)}%`;

        // ===== Zakat penghasilan (2,5%) — nisab 85 gr emas (harga emas live) =====
        const brutoSetahun = brutoBulan * 12 + thrBonus;
        const nisabTahun = 85 * goldPerGram;
        const wajibZakat = brutoSetahun >= nisabTahun;
        const zakatBulan = brutoBulan * 0.025;
        const zakatTahun = brutoSetahun * 0.025;
        $('zakatBody').innerHTML =
          `<div class="result-grid">`
          + `<div class="result-item"><div class="result-item-label">Bruto / Tahun</div><div class="result-item-value">${HC.fmt(brutoSetahun)}</div></div>`
          + `<div class="result-item"><div class="result-item-label">Nisab (85gr emas)</div><div class="result-item-value">${HC.fmt(nisabTahun)}</div></div>`
          + `<div class="result-item"><div class="result-item-label">Zakat 2,5% / Bulan</div><div class="result-item-value result-strong">${wajibZakat ? HC.fmt(zakatBulan) : '—'}</div></div>`
          + `<div class="result-item"><div class="result-item-label">Zakat 2,5% / Tahun</div><div class="result-item-value">${wajibZakat ? HC.fmt(zakatTahun) : '—'}</div></div>`
          + `</div>`
          + `<div style="margin-top:8px;font-weight:600;font-size:13px;color:${wajibZakat ? 'var(--green-dark,#047857)' : 'var(--text-mute)'}">`
          + (wajibZakat ? '✅ Penghasilanmu sudah mencapai nisab — zakat penghasilan berlaku.' : ('ℹ️ Belum mencapai nisab setahun (' + HC.fmt(nisabTahun) + '). Disunnahkan sedekah.'))
          + `</div>`;

        if (thrBonus > 0) {
          $('thrBlock').style.display = '';
          $('thrBlock').classList.add('open');
          $('thrBruto').textContent = HC.fmt(thrBonus);
          $('thrPphShow').textContent = HC.fmt(thrPph);
          $('thrNetShow').textContent = HC.fmt(thrNet);
          $('thrRateShow').textContent = `${thrRate.toFixed(1)}%`;
        } else {
          $('thrBlock').style.display = 'none';
        }

        $('alokasiBody').innerHTML = `
          <tr><td>🏠 Kebutuhan (50%)</td><td class="right">50%</td><td class="right">${HC.fmt(thp * 0.5)}</td></tr>
          <tr><td>🎮 Keinginan (30%)</td><td class="right">30%</td><td class="right">${HC.fmt(thp * 0.3)}</td></tr>
          <tr class="active"><td>💰 Tabungan (20%)</td><td class="right">20%</td><td class="right">${HC.fmt(thp * 0.2)}</td></tr>`;

        // Projection
        const monthly = thp * 0.2;
        const r = 0.06 / 12;
        let html = '';
        for (let y = 1; y <= 5; y++) {
          const months = y * 12;
          const pokok = monthly * months;
          const fv = monthly * ((Math.pow(1 + r, months) - 1) / r);
          html += `<tr><td>Tahun ${y}</td><td class="right">${HC.fmt(pokok)}</td><td class="right" style="color:var(--green-dark);font-weight:700">${HC.fmt(fv)}</td></tr>`;
        }
        $('proyeksiBody').innerHTML = html;

        lastCalc = { gaji, tunj, tunjVar, ptkpLabel: els.ptkp.options[els.ptkp.selectedIndex].text, useTer, terCat, terRt, pphBulanTahunan, pphBulanTER, ctc, empBpjs, potLain, dplkKaryawan, dplkPerusahaan, dplkKaryawanPct, dplkPerusahaanPct, thrBonus, thrPph, thrNet, thrRate, brutoBulan, bpjsTotal, pphBulan, thp, thpPct };
        HC.history.push('gaji-bersih', { inputs: HC.history.capture(['gaji','tunj','tunjVar','ptkp','pphMethod','potLain','dplkKaryawan','dplkPerusahaan','thrBonus']), summary: 'Gaji ' + HC.fmt(lastCalc.gaji) + ' \u00b7 ' + lastCalc.ptkpLabel, metrics: [{ k: 'Take-home', v: HC.fmt(lastCalc.thp) }, { k: 'PPh/bln', v: HC.fmt(lastCalc.pphBulan) }] });
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('nextSteps').style.display = '';
        $('nextStepsBody').innerHTML =
          `<a href="/kalkulator/kpr?gaji=${Math.round(thp)}" class="btn-hitung" style="text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px"><i class="ti ti-home"></i> Cek KPR yang sanggup kamu cicil</a>`
          + `<a href="/kalkulator/investasi?topup=${Math.round(thp * 0.2)}" class="btn-reset" style="text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px"><i class="ti ti-trending-up"></i> Investasikan 20% (${HC.fmt(thp * 0.2)}/bln)</a>`;
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Gaji bersih berhasil dihitung!');
      }


      // ===== Skenario A vs B =====
      let scenA = null, scenB = null;
      function scenFmt(v, t) { return t === 'pct' ? v.toFixed(1) + '%' : HC.fmt(v); }
      function buildSnap() { var c = lastCalc; return { label: HC.fmt(c.brutoBulan) + ' bruto', rows: [ {k:'Take-Home', v:c.thp, t:'rp'}, {k:'Bruto/bln', v:c.brutoBulan, t:'rp'}, {k:'Total Potongan', v:(c.brutoBulan - c.thp), t:'rp'}, {k:'PPh 21/bln', v:c.pphBulan, t:'rp'} ] }; }
      function snapScenario(slot) {
        hitung(); // refresh dari input terkini agar snapshot selalu akurat (anti lupa klik Hitung)
        if (!lastCalc) { HC.toast('Isi data dulu sebelum simpan skenario', 'error'); return; }
        var snap = buildSnap();
        if (slot === 'A') scenA = snap; else scenB = snap;
        HC.toast('Tersimpan sebagai Skenario ' + slot + ' (' + snap.label + ')');
        renderScenario();
        var _sb = $('scenResult'); if (_sb) _sb.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      function renderScenario() {
        var box = $('scenResult');
        if (!scenA && !scenB) { box.style.display = 'none'; return; }
        box.style.display = '';
        var ref = scenA || scenB, both = scenA && scenB;
        var html = '<table class="compare-table"><thead><tr><th>Metrik</th>'
          + '<th class="right">A' + (scenA ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenA.label + '</span>' : '') + '</th>'
          + '<th class="right">B' + (scenB ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenB.label + '</span>' : '') + '</th>'
          + (both ? '<th class="right">Selisih</th>' : '') + '</tr></thead><tbody>';
        for (var i = 0; i < ref.rows.length; i++) {
          var k = ref.rows[i].k, t = ref.rows[i].t;
          var av = scenA ? scenFmt(scenA.rows[i].v, t) : '—';
          var bv = scenB ? scenFmt(scenB.rows[i].v, t) : '—';
          var sel = '';
          if (both) { var d = scenB.rows[i].v - scenA.rows[i].v; sel = '<td class="right">' + (Math.abs(d) < 0.005 ? '—' : (d > 0 ? '+' : '\u2212') + scenFmt(Math.abs(d), t)) + '</td>'; }
          html += '<tr' + (i === 0 ? ' class="active"' : '') + '><td>' + k + '</td><td class="right">' + av + '</td><td class="right">' + bv + '</td>' + sel + '</tr>';
        }
        html += '</tbody></table>';
        if (both) {
          var lower = false, d = scenB.rows[0].v - scenA.rows[0].v, pk = scenA.rows[0].k, t0 = scenA.rows[0].t;
          var msg;
          if (Math.abs(d) < 0.005) msg = 'Kedua skenario setara di ' + pk + '.';
          else { var bBetter = lower ? d < 0 : d > 0; msg = 'Skenario ' + (bBetter ? 'B' : 'A') + ' lebih ' + (lower ? 'hemat' : 'unggul') + ' \u2014 ' + pk + ' selisih ' + scenFmt(Math.abs(d), t0) + '.'; }
          html += '<p style="font-size:13px;margin-top:8px;font-weight:600;color:var(--green-dark,#047857)">' + msg + '</p>';
        }
        box.innerHTML = html;
        box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      var bSA = $('btnScenA'); if (bSA) bSA.addEventListener('click', function () { snapScenario('A'); });
      var bSB = $('btnScenB'); if (bSB) bSB.addEventListener('click', function () { snapScenario('B'); });
      var bSR = $('btnScenReset'); if (bSR) bSR.addEventListener('click', function () { scenA = null; scenB = null; renderScenario(); HC.toast('Skenario direset', 'info'); });

      function reset() {
        scenA = null; scenB = null; var _sr=$('scenResult'); if(_sr) _sr.style.display='none';
        els.gaji.value = '8.000.000'; els.tunj.value = '1.500.000'; els.tunjVar.value = '0';
        els.ptkp.value = '54000000'; els.pphMethod.value = 'tahunan'; els.potLain.value = '0'; els.dplkKaryawan.value = '0'; els.dplkPerusahaan.value = '0'; els.thrBonus.value = '0';
        var br=$('balikResult'); if(br) br.style.display='none';
        var ns=$('nextSteps'); if(ns) ns.style.display='none';
        $('thrBlock').style.display = 'none';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.thpPct >= 90
          ? `Take-Home Pay ${c.thpPct.toFixed(1)}% dari bruto — sangat efisien! Maksimalkan alokasi 20% untuk tabungan & investasi.`
          : `Take-Home Pay ${c.thpPct.toFixed(1)}% dari bruto. PPh 21 cukup besar — pertimbangkan zakat via lembaga resmi untuk kurangi PKP.`;

        return HC.buildReportCard({
          title: '💰 Gaji Bersih (Take-Home Pay)',
          color: '#059669', color2: '#047857',
          heroLabel: 'Take-Home Pay/Bulan',
          heroValue: HC.fmt(c.thp),
          heroSubtext: `${c.thpPct.toFixed(1)}% dari bruto · ${c.ptkpLabel}`,
          inputs: [
            { label: '💼 Gaji Pokok', value: HC.fmt(c.gaji) },
            { label: '➕ Tunjangan Tetap', value: HC.fmt(c.tunj) },
            { label: '⚡ Tunj. Tidak Tetap', value: HC.fmt(c.tunjVar) },
            { label: '👨‍👩‍👧 Status PTKP', value: c.ptkpLabel },
          ],
          results: [
            { label: 'Take-Home Pay', value: HC.fmt(c.thp), highlight: true },
            { label: 'Bruto/Bulan', value: HC.fmt(c.brutoBulan) },
            { label: 'BPJS Karyawan (4%)', value: HC.fmt(c.bpjsTotal) },
            { label: 'PPh 21/Bulan', value: HC.fmt(c.pphBulan) },
            ...(c.dplkKaryawan > 0 ? [{ label: `DPLK Karyawan (${c.dplkKaryawanPct}%)`, value: HC.fmt(c.dplkKaryawan) }] : []),
            ...(c.dplkPerusahaan > 0 ? [{ label: `DPLK Perusahaan (${c.dplkPerusahaanPct}%)`, value: HC.fmt(c.dplkPerusahaan) }] : []),
            ...(c.thrBonus > 0 ? [{ label: '🎁 THR/Bonus Bruto', value: HC.fmt(c.thrBonus) }, { label: 'PPh atas THR/Bonus', value: HC.fmt(c.thrPph) }, { label: 'THR/Bonus Bersih', value: HC.fmt(c.thrNet), highlight: true }] : []),
            { label: 'Untuk Kebutuhan (50%)', value: HC.fmt(c.thp * 0.5) },
            { label: 'Untuk Tabungan (20%)', value: HC.fmt(c.thp * 0.2), highlight: true },
          ],
          insight, slug: 'gaji-bersih',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        const dplkLine = c.dplkKaryawan > 0 ? `\nDPLK (karyawan): ${HC.fmt(c.dplkKaryawan)}` : '';
        const thrLine = c.thrBonus > 0 ? `\n\n🎁 *THR/Bonus: ${HC.fmt(c.thrBonus)}*\nPPh THR: ${HC.fmt(c.thrPph)} (${c.thrRate.toFixed(1)}%)\nTHR Bersih: ${HC.fmt(c.thrNet)}` : '';
        return `💰 *Gaji Bersih - HitungCerdas*\n\nBruto: ${HC.fmt(c.brutoBulan)}/bln\nBPJS: ${HC.fmt(c.bpjsTotal)}\nPPh 21: ${HC.fmt(c.pphBulan)}${dplkLine}\n\n💵 *Take-Home Pay: ${HC.fmt(c.thp)}/bulan*\n📊 ${c.thpPct.toFixed(1)}% dari bruto${thrLine}\n\nAlokasi 50/30/20:\n• Kebutuhan: ${HC.fmt(c.thp * 0.5)}\n• Keinginan: ${HC.fmt(c.thp * 0.3)}\n• Tabungan: ${HC.fmt(c.thp * 0.2)}\n\nHitung di: https://hitungcerdas.net/kalkulator/gaji-bersih`;
      }

      function hitungBalik() {
        const target = HC.parseRp(els.targetThp.value);
        if (target <= 0) { HC.toast('Masukkan target take-home dulu', 'error'); return; }
        const tunj = HC.parseRp(els.tunj.value), tunjVar = HC.parseRp(els.tunjVar.value);
        const ptkp = parseInt(els.ptkp.value), potLain = HC.parseRp(els.potLain.value);
        const dplkPct = Math.max(0, parseFloat(els.dplkKaryawan.value) || 0);
        const useTer = els.pphMethod.value === 'ter';
        const box = $('balikResult');
        box.style.display = '';
        // Kalau tunjangan saja sudah bikin take-home >= target tanpa gaji pokok
        if (coreThp(0, tunj, tunjVar, ptkp, potLain, dplkPct, useTer).thp >= target) {
          box.innerHTML = `Dengan tunjangan saat ini (${HC.fmt(tunj + tunjVar)}/bln), take-home kamu sudah mencapai <b>${HC.fmt(target)}</b> tanpa perlu gaji pokok. Coba turunkan target atau tunjangan.`;
          return;
        }
        let lo = 0, hi = Math.max(target * 5, 1000000);
        for (let k = 0; k < 80 && coreThp(hi, tunj, tunjVar, ptkp, potLain, dplkPct, useTer).thp < target; k++) hi *= 1.5;
        for (let k = 0; k < 100; k++) { const mid = (lo + hi) / 2; if (coreThp(mid, tunj, tunjVar, ptkp, potLain, dplkPct, useTer).thp < target) lo = mid; else hi = mid; }
        const gajiNeeded = Math.round((lo + hi) / 2);
        const r = coreThp(gajiNeeded, tunj, tunjVar, ptkp, potLain, dplkPct, useTer);
        box.innerHTML = `🎯 Untuk take-home <b>${HC.fmt(target)}</b>/bulan, gaji pokok kamu perlu sekitar <b style="color:var(--green-dark)">${HC.fmt(gajiNeeded)}</b>/bulan.<br><span style="color:var(--text-mute);font-size:12px">Bruto ${HC.fmt(r.brutoBulan)} · BPJS ${HC.fmt(r.bpjsTotal)} · PPh ${HC.fmt(r.pphBulan)}/bln. Pakai tunjangan/PTKP/metode yang sama dengan form di atas.</span>`;
      }

            function renderHist() {
        HC.history.render('gaji-bersih', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      var btnBalik = $('btnBalik'); if (btnBalik) btnBalik.addEventListener('click', hitungBalik);
      els.pphMethod.addEventListener('change', () => { if (lastCalc) hitung(); });
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'gaji-bersih-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'gaji-bersih'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });

      // ── Salin Link Hasil (share via URL) ──
      function buildShareUrl(){
        var p = new URLSearchParams();
        p.set('g',  String(HC.parseRp(els.gaji.value)||0));
        p.set('t',  String(HC.parseRp(els.tunj.value)||0));
        p.set('tv', String(HC.parseRp(els.tunjVar.value)||0));
        p.set('pl', String(HC.parseRp(els.potLain.value)||0));
        p.set('tb', String(HC.parseRp(els.thrBonus.value)||0));
        p.set('dk', els.dplkKaryawan.value||'0');
        p.set('dp', els.dplkPerusahaan.value||'0');
        p.set('pt', els.ptkp.value);
        p.set('m',  els.pphMethod.value);
        return location.origin + location.pathname + '?' + p.toString();
      }
      function setNum(el, val){ el.value = val; el.dispatchEvent(new Event('input', {bubbles:true})); }
      function loadFromUrl(){
        var q = new URLSearchParams(location.search);
        if (!q.has('g')) return false;
        setNum(els.gaji, q.get('g'));
        if (q.has('t'))  setNum(els.tunj, q.get('t'));
        if (q.has('tv')) setNum(els.tunjVar, q.get('tv'));
        if (q.has('pl')) setNum(els.potLain, q.get('pl'));
        if (q.has('tb')) setNum(els.thrBonus, q.get('tb'));
        if (q.has('dk')) els.dplkKaryawan.value = q.get('dk');
        if (q.has('dp')) els.dplkPerusahaan.value = q.get('dp');
        if (q.has('pt')) els.ptkp.value = q.get('pt');
        if (q.has('m'))  els.pphMethod.value = q.get('m');
        return true;
      }
      $('exportLink').addEventListener('click', function(){ HC.copyText(buildShareUrl(), 'Link tersalin!'); });
      if (loadFromUrl()) { hitung(); }
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function readData(){
        var thpTxt=($('thp')||{}).textContent||'Rp 0';
        var brutoTxt=($('bruto')||{}).textContent||'Rp 0';
        var bpjsTxt=($('bpjsTotal')||{}).textContent||'Rp 0';
        var pphTxt=($('pphBulan')||{}).textContent||'Rp 0';
        var pct=parseFloat(String(($('thpPct')||{}).textContent||'').replace(',','.')); if(!isFinite(pct)) pct=null;
        return { thpTxt:thpTxt, thpNum:num(thpTxt), brutoTxt:brutoTxt, brutoNum:num(brutoTxt),
          bpjsTxt:bpjsTxt, pphTxt:pphTxt, pct:pct,
          dplkKaryawanTxt:($('dplkKaryawanShow')||{}).textContent||'', dplkPerusahaanTxt:($('dplkPerusahaanShow')||{}).textContent||'',
          dplkKaryawanPct:($('dplkKaryawan')||{}).value||'0', dplkPerusahaanPct:($('dplkPerusahaan')||{}).value||'0',
          thrBonus:($('thrBonus')||{}).value||'0', thrPphTxt:($('thrPphShow')||{}).textContent||'', thrNetTxt:($('thrNetShow')||{}).textContent||'', thrRateTxt:($('thrRateShow')||{}).textContent||'',
          gaji:($('gaji')||{}).value||'', tunj:($('tunj')||{}).value||'', tunjVar:($('tunjVar')||{}).value||'',
          ptkp:selText('ptkp'), potLain:($('potLain')||{}).value||'',
          pphMethod:selText('pphMethod'), ctcRatio:($('ctcRatio')||{}).textContent||'' };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-wallet"></i> Gaji Bersih \u00b7 Take-home <b>'+esc(d.thpTxt)+'</b></div>';
        if(!d.brutoNum || !d.thpNum){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat komposisi gaji yang sampai ke kantong.</div>'; return; }
        var pct=d.pct!=null?d.pct:(d.thpNum/d.brutoNum*100); pct=Math.max(0,Math.min(100,pct));
        var cut=Math.max(0,100-pct); var potTxt=HC.fmt(Math.max(0,d.brutoNum-d.thpNum));
        var vc=pct>=85?'good':(pct>=75?'warn':'bad');
        var vi=pct>=85?'ti-circle-check':'ti-alert-triangle';
        var vt=pct>=85?('Efisien \u2014 '+pct.toFixed(0)+'% gajimu sampai ke kantong'):('Potongan cukup besar \u2014 hanya '+pct.toFixed(0)+'% yang jadi take-home');
        ground.innerHTML=ctx
          +'<div class="aic-stack"><div class="seg s-green" style="width:'+pct.toFixed(1)+'%"><span class="seg-lbl">Diterima</span></div><div class="seg s-amber" style="width:'+cut.toFixed(1)+'%"><span class="seg-lbl">Potongan</span></div></div>'
          +'<div class="aic-legend"><span><span class="dot" style="background:#10B981"></span>Diterima: <b>'+esc(d.thpTxt)+'</b></span><span><span class="dot" style="background:#FDE68A"></span>Potongan: <b>'+esc(potTxt)+'</b></span></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var pct=d.pct!=null?d.pct:(d.brutoNum?d.thpNum/d.brutoNum*100:null);
        var p=[
          'Kalkulator: Gaji Bersih (take-home pay setelah BPJS dan PPh 21).',
          d.gaji?('Gaji pokok: Rp '+d.gaji+'.'):'',
          (d.tunj && d.tunj!=='0')?('Tunjangan tetap: Rp '+d.tunj+'.'):'',
          (d.tunjVar && d.tunjVar!=='0')?('Tunjangan tidak tetap (lembur/komisi): Rp '+d.tunjVar+'.'):'',
          d.ptkp?('Status PTKP: '+d.ptkp+'.'):'',
          d.pphMethod?('Metode hitung PPh 21 yang dipilih: '+d.pphMethod+'. (TER = tarif efektif bulanan PP 58/2023 untuk masa Jan-Nov, dikoreksi Desember; Estimasi Tahunan = progresif disetahunkan dibagi 12.)'):'',
          (d.ctcRatio)?('Total Biaya Perusahaan (CTC) = gaji bruto + iuran BPJS sisi kantor (Kes 4%, JHT 3,7%, JP 2%, JKK ~0,24%, JKM 0,3%) + DPLK kantor. Take-home karyawan sekitar '+d.ctcRatio+' dari CTC.'):'',
          'Gaji bruto per bulan: '+d.brutoTxt+'.',
          'Potongan BPJS karyawan: '+d.bpjsTxt+'. PPh 21 per bulan: '+d.pphTxt+'.',
          (d.potLain && d.potLain!=='0')?('Potongan lain per bulan: Rp '+d.potLain+'.'):'',
          (d.dplkKaryawanPct && d.dplkKaryawanPct!=='0')?('Iuran DPLK karyawan: '+d.dplkKaryawanPct+'% dari gaji pokok ('+d.dplkKaryawanTxt+'/bln) \u2014 dipotong dari gaji & jadi pengurang penghasilan bruto sehingga PPh ikut turun (PMK 168/2023).'):'',
          (d.dplkPerusahaanPct && d.dplkPerusahaanPct!=='0')?('Iuran DPLK perusahaan: '+d.dplkPerusahaanPct+'% dari gaji pokok ('+d.dplkPerusahaanTxt+'/bln) \u2014 ditanggung kantor, di luar gaji karyawan & bukan objek PPh 21 saat disetor.'):'',
          (d.thrBonus && d.thrBonus!=='0')?('THR/Bonus tahunan: Rp '+d.thrBonus+'. PPh atas THR/bonus: '+d.thrPphTxt+' (tarif efektif '+d.thrRateTxt+'). THR/bonus bersih: '+d.thrNetTxt+'. Catatan: THR/bonus = penghasilan tidak teratur, pajaknya = selisih PPh setahun dengan vs tanpa THR (jadi tarif efektifnya bisa lebih tinggi dari gaji bulanan), diterima sekali & terpisah dari take-home bulanan. Sejak 2024 potongan riil pakai TER di bulan THR lalu dikoreksi Desember.'):'',
          'Take-home pay (gaji bersih) per bulan: '+d.thpTxt+(pct!=null?(' ('+pct.toFixed(1)+'% dari bruto)'):'')+'.',
          'Acuan: alokasi sehat 50% kebutuhan, 30% keinginan, 20% tabungan/investasi. Take-home pay umumnya 70-85% dari bruto. Iuran pensiun (DPLK/JHT/JP) yang dibayar karyawan adalah pengurang penghasilan bruto untuk PPh 21.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Take-home segini wajar gak?','Cara atur 50/30/20 dari gaji ini?','Kenapa potongannya segini?','BPJS-ku motong berapa?','Berapa idealnya aku nabung?','DPLK ngaruh berapa ke pajak?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Take-home segini wajar gak?','Cara atur 50/30/20 dari gaji ini?','Kenapa potongannya segini?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>

<style is:global>
  .jobcmp .jc-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:12px;align-items:stretch;margin:6px 0 14px}
  .jobcmp .jc-col{padding:14px;border-radius:14px;border:1px solid var(--border,#E2E8F0)}
  .jobcmp .jc-now{background:var(--bg-soft,#F8FAFC)}
  .jobcmp .jc-new{background:#ECFDF5;border-color:#A7F3D0}
  .jobcmp .jc-col-hdr{font-weight:800;font-size:13.5px;margin-bottom:12px;display:flex;align-items:center;gap:6px}
  .jobcmp .jc-now .jc-col-hdr{color:#475569}
  .jobcmp .jc-new .jc-col-hdr{color:#047857}
  .jobcmp .jc-vs{align-self:center;display:flex;justify-content:center}
  .jobcmp .jc-vs span{display:inline-flex;width:36px;height:36px;border-radius:50%;background:#fff;border:1px solid var(--border,#E2E8F0);align-items:center;justify-content:center;font-weight:800;font-size:12px;color:var(--text-mute,#94A3B8)}
  .jobcmp .jc-twin{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
  .jobcmp .jc-thp{padding:12px;border-radius:12px;text-align:center}
  .jobcmp .jc-thp.now{background:var(--bg-soft,#F8FAFC)}
  .jobcmp .jc-thp.new{background:#ECFDF5}
  .jobcmp .jc-thp .l{font-size:11.5px;color:var(--text-mute,#64748B);font-weight:600}
  .jobcmp .jc-thp .v{font-size:19px;font-weight:800;margin-top:3px;color:var(--text,#0F172A)}
  .jobcmp .jc-delta{padding:11px 14px;border-radius:12px;font-weight:700;text-align:center;margin-bottom:12px;font-size:14px;display:flex;align-items:center;justify-content:center;gap:7px}
  .jobcmp .jc-delta.up{background:#D1FAE5;color:#047857}
  .jobcmp .jc-delta.down{background:#FEE2E2;color:#B91C1C}
  .jobcmp .jc-delta.flat{background:var(--bg-soft,#F1F5F9);color:#475569}
  .jobcmp .jc-nego{padding:14px;border-radius:12px;background:#FEF9C3;border:1px solid #FDE68A;margin-bottom:10px}
  .jobcmp .jc-nego .t{font-weight:800;font-size:13px;margin-bottom:4px;display:flex;align-items:center;gap:6px;color:#854D0E}
  .jobcmp .jc-nego .big{font-size:20px;font-weight:800;color:#0F172A;margin:2px 0 6px}
  .jobcmp .jc-nego p{font-size:12.5px;color:#475569;line-height:1.55;margin:0}
  .jobcmp .jc-sentence{margin-top:10px;padding:12px;border-radius:10px;background:#fff;border:1px dashed #CBD5E1;font-size:12.5px;color:#334155;line-height:1.6;font-style:italic}
  .jobcmp .jc-copy{margin-top:8px;display:inline-flex;align-items:center;gap:6px;background:#0EA5E9;color:#fff;border:none;border-radius:9px;padding:8px 14px;font-size:12.5px;font-weight:700;cursor:pointer}
  .jobcmp .jc-copy:hover{background:#0284C7}
  .jobcmp .jc-note{font-size:11px;color:var(--text-mute,#94A3B8);line-height:1.5;margin-top:12px;display:flex;gap:6px;align-items:flex-start}
  @media(max-width:560px){ .jobcmp .jc-grid{grid-template-columns:1fr} .jobcmp .jc-vs{margin:2px 0} .jobcmp .jc-vs span{width:30px;height:30px} }
</style>

<script is:inline>
  (function(){
    function ready(fn){ if(window.HC && window.HCGaji && window.HCGaji.coreThp){ fn(); } else { setTimeout(function(){ ready(fn); }, 120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var btn=$('jcBtn'); if(!btn) return;
      function parseRp(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return parseInt(String(v||'').replace(/\D/g,''),10)||0; } }
      function fmt(n){ try{ return HC.fmt(n); }catch(e){ return 'Rp '+Math.round(n).toLocaleString('id-ID'); } }
      function grp(v){ v=String(v).replace(/\D/g,''); return v.replace(/\B(?=(\d{3})+(?!\d))/g,'.'); }
      ['jcGajiNow','jcTunjNow','jcGajiNew','jcTunjNew'].forEach(function(id){ var el=$(id); if(el){ el.addEventListener('input', function(){ el.value=grp(el.value); }); } });

      var C=window.HCGaji.coreThp;
      function thp(g,t,p){ return C(g,t,0,p,0,0,false).thp; }
      function reqGaji(target,t,p){
        if(thp(0,t,p)>=target) return 0;
        var lo=0,hi=1000000,k;
        for(k=0;k<80 && thp(hi,t,p)<target;k++) hi*=1.5;
        for(k=0;k<100;k++){ var mid=(lo+hi)/2; if(thp(mid,t,p)<target) lo=mid; else hi=mid; }
        return (lo+hi)/2;
      }
      function round1k(n){ return Math.ceil(n/1000)*1000; }

      function run(){
        var p=parseInt(($('jcPtkp')||{}).value||'54000000',10);
        var gNow=parseRp($('jcGajiNow').value), tNow=parseRp($('jcTunjNow').value);
        var gNew=parseRp($('jcGajiNew').value), tNew=parseRp($('jcTunjNew').value);
        if(gNow<=0 || gNew<=0){ try{HC.toast('Isi gaji pokok kedua kolom dulu','error');}catch(e){} return; }
        var thpNow=thp(gNow,tNow,p), thpNew=thp(gNew,tNew,p);
        var dBln=thpNew-thpNow, dThn=dBln*12;
        var pct= thpNow>0 ? (dBln/thpNow*100) : 0;
        var be=round1k(reqGaji(thpNow,tNew,p)); var gap=be-gNew;

        var dCls = Math.abs(dBln)<5000 ? 'flat' : (dBln>0?'up':'down');
        var dIcon = dCls==='up'?'ti-trending-up':(dCls==='down'?'ti-trending-down':'ti-equal');
        var dTxt = dCls==='flat' ? 'Take-home praktis setara'
          : ((dBln>0?'+':'\u2212')+fmt(Math.abs(dBln))+'/bln ('+(dBln>0?'+':'\u2212')+Math.abs(pct).toFixed(1)+'%) '+(dBln>0?'lebih tinggi':'lebih rendah'));

        var negoHtml;
        if(gap>5000){
          negoHtml='<div class="jc-nego"><div class="t"><i class="ti ti-target-arrow"></i> Target nego HRD</div>'
            +'<div class="big">Gaji pokok min. '+fmt(be)+'</div>'
            +'<p>Dengan tunjangan '+fmt(tNew)+', tawaran sekarang ('+fmt(gNew)+') memberi take-home '+fmt(thpNew)+'/bln \u2014 masih <b>'+fmt(Math.abs(dBln))+' di bawah</b> posisimu sekarang. Untuk minimal setara, dorong gaji pokok naik ~<b>'+fmt(gap)+'</b> jadi '+fmt(be)+'.</p></div>';
        } else if(gap<-5000){
          negoHtml='<div class="jc-nego" style="background:#ECFDF5;border-color:#A7F3D0"><div class="t" style="color:#047857"><i class="ti ti-circle-check"></i> Tawaran sudah unggul</div>'
            +'<div class="big">Surplus +'+fmt(thpNew-thpNow)+'/bln</div>'
            +'<p>Take-home tawaran baru sudah di atas posisimu sekarang. Titik impas ada di gaji pokok '+fmt(be)+' \u2014 tawaran ('+fmt(gNew)+') sudah <b>'+fmt(Math.abs(gap))+' di atas</b> itu. Posisi nego kamu kuat; bisa dorong lebih atau amankan benefit lain.</p></div>';
        } else {
          negoHtml='<div class="jc-nego" style="background:#F1F5F9;border-color:#CBD5E1"><div class="t" style="color:#475569"><i class="ti ti-equal"></i> Nyaris setara</div>'
            +'<div class="big">Impas di gaji pokok '+fmt(be)+'</div>'
            +'<p>Take-home dua posisi praktis sama. Timbang faktor non-gaji: jarak, jenjang karier, kultur, benefit kesehatan, dan bonus/THR yang belum dihitung di sini.</p></div>';
        }

        var sentence='Berdasarkan perhitungan take-home pay (setelah BPJS & PPh 21), penghasilan bersih saya saat ini sekitar '+fmt(thpNow)+'/bulan. Agar penghasilan bersih di posisi baru setara atau lebih baik, saya mengusulkan gaji pokok minimal '+fmt(be)+' (dengan tunjangan '+fmt(tNew)+').';

        var html='<div class="jc-twin">'
          +'<div class="jc-thp now"><div class="l">Take-home Sekarang</div><div class="v">'+fmt(thpNow)+'</div></div>'
          +'<div class="jc-thp new"><div class="l">Take-home Tawaran Baru</div><div class="v">'+fmt(thpNew)+'</div></div></div>'
          +'<div class="jc-delta '+dCls+'"><i class="ti '+dIcon+'"></i> '+dTxt+'</div>'
          +(dCls!=='flat'?('<div style="font-size:12px;color:var(--text-mute,#64748B);text-align:center;margin:-6px 0 12px">Selisih setahun: '+(dBln>0?'+':'\u2212')+fmt(Math.abs(dThn))+'</div>'):'')
          +negoHtml
          +'<div class="jc-sentence">\u201c'+sentence+'\u201d</div>'
          +'<button type="button" class="jc-copy" id="jcCopy"><i class="ti ti-copy"></i> Salin kalimat nego</button>';

        var box=$('jcResult'); box.innerHTML=html; box.style.display='block';
        var cp=$('jcCopy'); if(cp){ cp.addEventListener('click', function(){ try{ HC.copyText(sentence,'Kalimat nego tersalin!'); }catch(e){ try{ navigator.clipboard.writeText(sentence); }catch(_){} } }); }
        try{ box.scrollIntoView({behavior:'smooth',block:'nearest'}); }catch(e){}
      }
      btn.addEventListener('click', run);
    });
  })();
</script>
