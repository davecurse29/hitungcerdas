---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('pensiun')!;
const related = getRelatedCalculators('pensiun', 3);

const faqs = [
  { question: 'Berapa dana pensiun ideal?', answer: 'Tergantung gaya hidup, usia pensiun, dan berapa lama masa pensiun. Patokan kasar: dana pensiun idealnya cukup membiayai 70-80% pengeluaranmu sekarang (disesuaikan inflasi) selama masa pensiun. Kalkulator ini menghitungnya dengan metode <strong>return riil</strong> (return dikurangi inflasi) agar daya beli tetap terjaga, bukan sekadar angka nominal besar.' },
  { question: 'Apakah BPJS cukup untuk pensiun?', answer: 'Umumnya <strong>tidak cukup kalau hanya mengandalkan BPJS</strong>. Jaminan Pensiun (JP) BPJS memberi manfaat bulanan tapi nilainya relatif kecil dibanding kebutuhan hidup, dan Jaminan Hari Tua (JHT) sifatnya lump sum sekali cair. Jadikan BPJS sebagai pelengkap, bukan satu-satunya sumber. Sisanya perlu kamu tabung & investasikan sendiri (reksadana, saham, emas, DPLK, properti).' },
  { question: 'Apa beda JHT dan JP?', answer: '<strong>JHT (Jaminan Hari Tua)</strong> adalah tabungan yang dibayarkan <strong>sekaligus (lump sum)</strong>, umumnya bisa dicairkan mulai usia 56 tahun. <strong>JP (Jaminan Pensiun)</strong> adalah manfaat <strong>bulanan</strong> yang diterima jika masa iur minimal 15 tahun; kalau kurang dari 15 tahun, dibayarkan sekaligus. Keduanya program BPJS Ketenagakerjaan.' },
  { question: 'Berapa usia pensiun BPJS?', answer: 'Usia pensiun program Jaminan Pensiun (JP) BPJS Ketenagakerjaan pada 2026 adalah <strong>59 tahun</strong>, dan naik 1 tahun setiap 3 tahun hingga maksimal 65 tahun. Namun banyak perusahaan menetapkan usia pensiun internal sendiri (mis. 55 tahun), jadi field usia pensiun di kalkulator ini bisa kamu ubah sesuai rencanamu.' },
  { question: 'Apa itu inflasi dan return riil?', answer: '<strong>Inflasi</strong> adalah kenaikan harga barang/jasa tiap tahun — membuat Rp 10 juta hari ini tidak sama nilainya dengan 20 tahun lagi. <strong>Return riil</strong> = (1 + return investasi) ÷ (1 + inflasi) − 1, yaitu keuntungan investasi setelah dipotong inflasi. Inilah angka yang benar-benar menambah daya belimu. Kalau return investasi lebih rendah dari inflasi, daya beli danamu justru menyusut.' },
  { question: 'Bagaimana cara mengejar kekurangan dana pensiun?', answer: 'Ada 5 tuas utama: <strong>(1)</strong> tambah setoran bulanan, <strong>(2)</strong> tunda usia pensiun beberapa tahun, <strong>(3)</strong> turunkan target gaya hidup pensiun, <strong>(4)</strong> alokasikan THR/bonus tahunan ke investasi pensiun, dan <strong>(5)</strong> tambah sumber penghasilan pasif (sewa, dividen, usaha). Yang paling berdampak biasanya kombinasi menabung lebih dini + return investasi yang memadai (efek bunga majemuk).' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#4F46E5;--cat-color2:#3730A3">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#E0E7FF;color:#3730A3"><i class="ti ti-beach"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M55 150C55 120 75 105 100 105C125 105 145 120 145 150" fill="#FFF" stroke="#A5B4FC" stroke-width="3" stroke-linejoin="round"/>
            <circle cx="100" cy="80" r="24" fill="#FFF" stroke="#A5B4FC" stroke-width="3"/>
            <path d="M40 150H160" stroke="#C7D2FE" stroke-width="4" stroke-linecap="round"/>
            <path d="M70 128L88 110L100 122L130 92" stroke="#34D399" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <path d="M130 92H120M130 92V102" stroke="#34D399" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
            <text x="100" y="86" text-anchor="middle" font-size="16" font-weight="900" fill="#4F46E5" font-family="Inter">Rp</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#4F46E5 0%,#3730A3 100%)"><i class="ti ti-beach"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Dana Pensiun</h2><p class="calc-card-sub">Target · proyeksi · setoran ideal · skor kesiapan</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field-row">
              <div class="field"><label>Usia Sekarang</label>
                <div class="input-wrap"><input type="number" id="usiaNow" value="30" min="15" max="80" /><span class="input-suffix">thn</span></div>
              </div>
              <div class="field"><label>Usia Pensiun</label>
                <div class="input-wrap"><input type="number" id="usiaPensiun" value="59" min="40" max="75" /><span class="input-suffix">thn</span></div>
              </div>
            </div>
            <p class="hint" style="margin-top:-4px">Usia pensiun BPJS 2026 = 59 (bisa diubah sesuai rencanamu).</p>

            <div class="field"><label>Usia Harapan Hidup (rencana)</label>
              <div class="input-wrap"><input type="number" id="usiaHarapan" value="80" min="60" max="100" /><span class="input-suffix">thn</span></div>
              <p class="hint" style="margin-top:6px">Dana dirancang cukup sampai usia ini.</p>
            </div>

            <div class="field"><label>Pengeluaran per Bulan Sekarang</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="pengeluaran" class="has-prefix" value="8.000.000" inputmode="numeric" /></div>
            </div>

            <div class="field"><label>Gaya Hidup Saat Pensiun</label>
              <div class="input-wrap"><input type="number" id="lifestyle" value="75" min="30" max="120" /><span class="input-suffix">%</span></div>
              <p class="hint" style="margin-top:6px">% dari pengeluaran sekarang. Umumnya turun jadi 70-80% (anak mandiri, cicilan lunas).</p>
            </div>

            <div class="field"><label>Perkiraan Pensiun/Penghasilan Pasif Bulanan <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="pensiunBulanan" class="has-prefix" value="0" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Estimasi pemasukan bulanan saat pensiun: BPJS JP, DPLK, pensiun kantor, atau sewa properti. Mengurangi kebutuhan dari tabungan.</p>
            </div>

            <div class="field"><label>Tabungan/Investasi Pensiun Saat Ini</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="tabunganNow" class="has-prefix" value="0" inputmode="numeric" /></div>
            </div>

            <div class="field"><label>Nabung/Setor per Bulan Saat Ini</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="setoranNow" class="has-prefix" value="1.000.000" inputmode="numeric" /></div>
            </div>

            <div class="field-row">
              <div class="field"><label>Return Sebelum Pensiun</label>
                <div class="input-wrap"><input type="number" id="returnPra" value="8" min="0" max="30" step="0.5" /><span class="input-suffix">%/th</span></div>
              </div>
              <div class="field"><label>Return Saat Pensiun</label>
                <div class="input-wrap"><input type="number" id="returnPensiun" value="5" min="0" max="30" step="0.5" /><span class="input-suffix">%/th</span></div>
              </div>
            </div>
            <p class="hint" style="margin-top:-4px">Sebelum pensiun bisa lebih agresif (reksadana campuran/saham ~6-10%); saat pensiun lebih konservatif (~4-6%).</p>

            <div class="field"><label>Inflasi per Tahun</label>
              <div class="input-wrap"><input type="number" id="inflasi" value="4" min="0" max="20" step="0.5" /><span class="input-suffix">%/th</span></div>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-beach result-placeholder-icon"></i>
              <div class="result-placeholder-title">Rencana pensiunmu akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi usia, pengeluaran & tabungan, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="view-toggle" id="viewToggle">
                <button type="button" data-view="future" class="active">Nominal Masa Depan</button>
                <button type="button" data-view="today">Nilai Hari Ini</button>
              </div>

              <div class="result-main">
                <div class="result-label">Setoran Ideal per Bulan</div>
                <div class="result-value" id="setoranIdeal">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="heroMeta">—</span></div>
              </div>

              <div class="warn-box" id="warnBox" style="display:none"></div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Target Dana Pensiun</div><div class="result-item-value" id="targetDana">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Proyeksi Dana Kamu</div><div class="result-item-value" id="proyeksiDana">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label" id="gapLabel">Kekurangan</div><div class="result-item-value result-warn" id="kekurangan">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Pengeluaran/bln Saat Pensiun</div><div class="result-item-value" id="pengeluaranPensiun">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Dana Cukup Sampai Usia</div><div class="result-item-value" id="cukupSampai">—</div></div>
                <div class="result-item"><div class="result-item-label">Skor Kesiapan</div><div class="result-item-value" id="readiness">0%</div></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-area-line"></i>&nbsp; Grafik Gunung Pensiun & Proyeksi Tahunan</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div id="mountainChart" class="mountain-wrap"></div>
                  <table class="compare-table">
                    <thead><tr><th>Usia</th><th>Fase</th><th class="right">Proyeksi Saldo</th></tr></thead>
                    <tbody id="yearlyBody"></tbody>
                  </table>
                  <p class="adv-note">Saldo naik selama menabung (akumulasi), memuncak saat pensiun (usia <span id="mtPeakAge">—</span>), lalu menurun karena dipakai (dekumulasi). Ditandai tiap 5 tahun. Nilai nominal masa depan.</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-calendar-stats"></i>&nbsp; Skenario Usia Pensiun</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Pensiun Usia</th><th class="right">Target</th><th class="right">Setoran Ideal</th><th class="right">Kesiapan</th></tr></thead>
                    <tbody id="skenarioBody"></tbody>
                  </table>
                  <p class="adv-note">Menunda pensiun beberapa tahun bisa memangkas setoran bulanan drastis (lebih lama menabung, lebih singkat masa pensiun). Baris ★ = pilihanmu.</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-adjustments-alt"></i>&nbsp; Uji Sensitivitas Asumsi</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Skenario</th><th class="right">Target Dana</th><th class="right">Setoran Ideal/bln</th></tr></thead>
                    <tbody id="sensBody"></tbody>
                  </table>
                  <p class="adv-note">Pensiun sangat sensitif ke asumsi jangka panjang. ▲ merah = butuh setoran lebih besar; ▼ hijau = lebih ringan.</p>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
                <button type="button" class="export-btn link" id="exportLink"><i class="ti ti-link" style="color:#4F46E5"></i><span style="color:#4F46E5">Salin Link</span></button>
              </div>
              <!-- ===== AI COACH PENSIUN ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Dana pensiunku cukup? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Pensiun</strong>
                      <small>Bantu pahami kesiapan pensiunmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal dana pensiun..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Penjelasan edukatif berbasis hitunganmu, bukan nasihat keuangan/investasi resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-content">
    <div class="wrap prose">
      <h2>Cara Menghitung Dana Pensiun yang Benar</h2>
      <p>Merencanakan pensiun bukan soal menabung asal banyak, tapi soal <strong>menutup selisih antara kebutuhan dan yang kamu punya</strong>. Kalkulator ini bekerja dalam dua fase: <strong>akumulasi</strong> (sekarang sampai pensiun, saat dana bertumbuh) dan <strong>dekumulasi</strong> (saat pensiun, ketika dana dipakai). Kuncinya memakai <strong>return riil</strong> agar daya beli — bukan sekadar angka nominal — yang dijaga.</p>

      <h3>Rumus Inti</h3>
      <p>Pengeluaran saat pensiun = pengeluaran sekarang × % gaya hidup × (1 + inflasi)<sup>tahun ke pensiun</sup>. Return riil = (1 + return) ÷ (1 + inflasi) − 1. Target dana = nilai kini (present value) dari kebutuhan tahunan selama masa pensiun, didiskon di return riil. Proyeksi dana = nilai masa depan tabungan sekarang + nilai masa depan setoran bulanan. Kekurangan = target − proyeksi, lalu diubah balik menjadi setoran ideal per bulan.</p>

      <h3>Jangan Andalkan BPJS Saja</h3>
      <p>Jaminan Pensiun (JP) BPJS memberi manfaat bulanan, tapi biasanya jauh dari cukup untuk menutup seluruh kebutuhan hidup. Jaminan Hari Tua (JHT) berupa lump sum. Anggap keduanya sebagai pelengkap. Kekuatan terbesarmu adalah <strong>mulai menabung sedini mungkin</strong> supaya bunga majemuk bekerja maksimal, lalu diversifikasi ke reksadana, saham, emas, DPLK, atau properti sewa.</p>

      <div class="cta-box"><h3>Mulai Rencanakan Pensiunmu</h3><p>Isi usia & pengeluaran, lihat target dana pensiun dan berapa idealnya kamu menabung tiap bulan.</p></div>
    </div>
  </section>

  <AdSlot format="rectangle" />

  <FAQ title="Pertanyaan Seputar Dana Pensiun" items={faqs} />

  <section class="calc-related">
    <div class="wrap">
      <h2 class="calc-related-title">Kalkulator Lainnya</h2>
      <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
    </div>
  </section>

  <div class="wrap">
    <p class="calc-note">📅 Diperbarui Juli 2026 · Target dana pensiun memakai metode nilai kini (present value) atas return riil = (1+return)÷(1+inflasi)−1. Estimasi edukatif untuk perencanaan, bukan nasihat keuangan atau produk investasi. Angka BPJS/JP/JHT bersifat estimasi, bukan angka resmi. Usia pensiun JP BPJS 2026 = 59 tahun. Sumber: BPJS Ketenagakerjaan, prinsip perencanaan keuangan.</p>
  </div>
</Layout>

<style is:global>
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .view-toggle { display:flex; gap:4px; padding:4px; background:var(--surface-2,#F1F5F9); border-radius:12px; margin-bottom:14px; }
  .view-toggle button { flex:1; padding:8px 10px; border:none; background:transparent; border-radius:9px; font-size:12.5px; font-weight:600; color:var(--text-soft,#64748B); cursor:pointer; transition:all .15s; }
  .view-toggle button.active { background:#fff; color:#4F46E5; box-shadow:0 1px 3px rgba(0,0,0,.08); }
  .warn-box { background:#FFFBEB; border:1px solid #FDE68A; color:#92400E; border-radius:12px; padding:11px 13px; font-size:12.5px; line-height:1.55; margin-bottom:14px; }
  .warn-box .warn-item { display:flex; gap:7px; align-items:flex-start; }
  .warn-box .warn-item + .warn-item { margin-top:6px; }
  .result-item-value.result-good { color:var(--green-dark,#047857); }
  html.dark .view-toggle { background:#1E293B; }
  html.dark .view-toggle button.active { background:#0F172A; color:#A5B4FC; }
  html.dark .warn-box { background:rgba(180,120,10,.12); border-color:rgba(251,191,36,.3); color:#FCD34D; }
  .mountain-wrap { width:100%; margin-bottom:10px; }
  .mountain-wrap svg { width:100%; height:auto; display:block; border-radius:8px; }
  .adv-note { font-size:11.5px; color:var(--text-mute); margin-top:8px; line-height:1.5; }
</style>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = {
        usiaNow: $('usiaNow'), usiaPensiun: $('usiaPensiun'), usiaHarapan: $('usiaHarapan'),
        pengeluaran: $('pengeluaran'), lifestyle: $('lifestyle'), pensiunBulanan: $('pensiunBulanan'),
        tabunganNow: $('tabunganNow'), setoranNow: $('setoranNow'),
        returnPra: $('returnPra'), returnPensiun: $('returnPensiun'), inflasi: $('inflasi')
      };
      [els.pengeluaran, els.pensiunBulanan, els.tabunganNow, els.setoranNow].forEach(el => el.addEventListener('input', HC.fmtInput));

      let lastCalc = null;
      let viewMode = 'future';

      function num(el, def) { var v = parseFloat(String(el.value).replace(',', '.')); return isFinite(v) ? v : def; }

      // ===== V2: sensitivitas, skenario usia, proyeksi tahunan, grafik =====
      function calcTargetX(pengeluaran, lifestyle, inflasi, returnPensiun, ytr, mp, pensiunBulanan){
        var inflF=Math.pow(1+inflasi,ytr);
        var pengP=pengeluaran*lifestyle*inflF;
        var kebT=Math.max(0,pengP-pensiunBulanan)*12;
        var rr=(1+returnPensiun)/(1+inflasi)-1;
        return Math.abs(rr)<1e-9 ? kebT*mp : kebT*(1-Math.pow(1+rr,-mp))/rr;
      }
      function calcProyX(tabunganNow, setoranNow, returnPra, ytr){
        var rMon=returnPra/12, nMon=ytr*12;
        var fvTab=tabunganNow*Math.pow(1+returnPra,ytr);
        var fvSet=(setoranNow>0&&rMon>0)?setoranNow*((Math.pow(1+rMon,nMon)-1)/rMon):setoranNow*nMon;
        return {proyeksi:fvTab+fvSet, fvTab:fvTab, rMon:rMon, nMon:nMon};
      }
      function calcSetoranX(target, fvTab, rMon, nMon){
        var sisa=target-fvTab; if(sisa<=0) return 0;
        return rMon>0 ? sisa*rMon/(Math.pow(1+rMon,nMon)-1) : sisa/nMon;
      }
      function deltaTd(base, val){
        if(base<=0) return '<td class="right">'+HC.fmt(val)+'</td>';
        var d=(val-base)/base*100;
        var col = d>0.5?'#DC2626':(d<-0.5?'#059669':'var(--text-soft)');
        var arr = d>0.5?'\u25b2':(d<-0.5?'\u25bc':'\u2022');
        return '<td class="right">'+HC.fmt(val)+' <span style="color:'+col+';font-weight:700;font-size:10.5px">'+arr+Math.abs(d).toFixed(0)+'%</span></td>';
      }
      function renderSensitivity(c){
        var base=c.setoranIdeal;
        var rows=[
          {n:'Asumsimu (base)', rp:c.returnPra, rq:c.returnPensiun, inf:c.inflasi, uh:c.usiaHarapan},
          {n:'Return \u22122%', rp:Math.max(0,c.returnPra-0.02), rq:Math.max(0,c.returnPensiun-0.02), inf:c.inflasi, uh:c.usiaHarapan},
          {n:'Return +2%', rp:c.returnPra+0.02, rq:c.returnPensiun+0.02, inf:c.inflasi, uh:c.usiaHarapan},
          {n:'Inflasi +1%', rp:c.returnPra, rq:c.returnPensiun, inf:c.inflasi+0.01, uh:c.usiaHarapan},
          {n:'Umur +10 thn', rp:c.returnPra, rq:c.returnPensiun, inf:c.inflasi, uh:c.usiaHarapan+10}
        ];
        var html='';
        rows.forEach(function(r,i){
          var mp=r.uh-c.usiaPensiun;
          var t=calcTargetX(c.pengeluaran,c.lifestyle,r.inf,r.rq,c.tahunKePensiun,mp,c.pensiunBulanan);
          var pr=calcProyX(c.tabunganNow,c.setoranNow,r.rp,c.tahunKePensiun);
          var si=calcSetoranX(t,pr.fvTab,pr.rMon,pr.nMon);
          html+='<tr'+(i===0?' class="active"':'')+'><td>'+r.n+'</td><td class="right">'+HC.fmt(t)+'</td>'+(i===0?('<td class="right"><b>'+HC.fmt(si)+'</b></td>'):deltaTd(base,si))+'</tr>';
        });
        $('sensBody').innerHTML=html;
      }
      function renderSkenario(c){
        var ages=[55,59,65]; if(ages.indexOf(c.usiaPensiun)<0) ages.push(c.usiaPensiun);
        ages.sort(function(a,b){return a-b;});
        var html='';
        ages.forEach(function(age){
          if(age<=c.usiaNow || age>=c.usiaHarapan) return;
          var ytr=age-c.usiaNow, mp=c.usiaHarapan-age;
          var t=calcTargetX(c.pengeluaran,c.lifestyle,c.inflasi,c.returnPensiun,ytr,mp,c.pensiunBulanan);
          var pr=calcProyX(c.tabunganNow,c.setoranNow,c.returnPra,ytr);
          var si=calcSetoranX(t,pr.fvTab,pr.rMon,pr.nMon);
          var rd=t>0?Math.min(999,pr.proyeksi/t*100):0;
          var mine=age===c.usiaPensiun;
          html+='<tr'+(mine?' class="active"':'')+'><td>'+(mine?'\u2605 ':'')+age+' thn</td><td class="right">'+HC.fmt(t)+'</td><td class="right">'+HC.fmt(si)+'</td><td class="right" style="font-weight:700;color:'+(rd>=90?'#059669':rd>=50?'#D97706':'#DC2626')+'">'+rd.toFixed(0)+'%</td></tr>';
        });
        $('skenarioBody').innerHTML=html;
      }
      function buildYearly(c){
        var arr=[]; var saldo=c.tabunganNow; var setTahun=c.setoranNow*12;
        for(var usia=c.usiaNow; usia<=c.usiaHarapan; usia++){
          var phase=usia<c.usiaPensiun?'akum':'pensiun';
          arr.push({usia:usia, saldo:Math.max(0,saldo), phase:phase});
          if(usia<c.usiaPensiun){ saldo=saldo*(1+c.returnPra)+setTahun; }
          else {
            var yfn=usia-c.usiaNow+1;
            var pengY=c.pengeluaran*c.lifestyle*Math.pow(1+c.inflasi,yfn);
            var wd=Math.max(0,(pengY-c.pensiunBulanan))*12;
            saldo=saldo*(1+c.returnPensiun)-wd; if(saldo<0) saldo=0;
          }
        }
        return arr;
      }
      function renderYearly(c, yearly){
        var html='';
        yearly.forEach(function(pt){
          var show=(pt.usia%5===0)||pt.usia===c.usiaPensiun||pt.usia===c.usiaHarapan||pt.usia===c.usiaNow;
          if(!show) return;
          var peak=pt.usia===c.usiaPensiun;
          var fase=pt.phase==='akum'?'Menabung':'Pensiun';
          html+='<tr'+(peak?' class="active"':'')+'><td>'+(peak?'\u2605 ':'')+pt.usia+' thn</td><td>'+fase+'</td><td class="right">'+HC.fmt(pt.saldo)+'</td></tr>';
        });
        $('yearlyBody').innerHTML=html;
      }
      function renderMountain(c, yearly){
        var W=340,H=150,padL=8,padR=8,padT=16,padB=18;
        var maxS=0; yearly.forEach(function(pt){if(pt.saldo>maxS)maxS=pt.saldo;}); if(maxS<=0)maxS=1;
        var span=(c.usiaHarapan-c.usiaNow)||1;
        var xOf=function(u){return padL+(u-c.usiaNow)/span*(W-padL-padR);};
        var yOf=function(sv){return H-padB-(sv/maxS)*(H-padT-padB);};
        var line=''; yearly.forEach(function(pt,i){ line+=(i===0?'M':'L')+xOf(pt.usia).toFixed(1)+','+yOf(pt.saldo).toFixed(1)+' '; });
        var area='M'+xOf(c.usiaNow).toFixed(1)+','+(H-padB)+' '+line.replace(/^M/,'L')+'L'+xOf(c.usiaHarapan).toFixed(1)+','+(H-padB)+' Z';
        var peakFrac=(c.usiaPensiun-c.usiaNow)/span*100;
        var px=xOf(c.usiaPensiun);
        var svg='<svg viewBox="0 0 '+W+' '+H+'" xmlns="http://www.w3.org/2000/svg">'
          +'<defs><linearGradient id="mtG'+c.usiaPensiun+'" x1="0" y1="0" x2="1" y2="0">'
          +'<stop offset="0%" stop-color="#10B981" stop-opacity=".8"/>'
          +'<stop offset="'+peakFrac.toFixed(0)+'%" stop-color="#34D399" stop-opacity=".65"/>'
          +'<stop offset="'+Math.min(100,peakFrac+1).toFixed(0)+'%" stop-color="#FBBF24" stop-opacity=".6"/>'
          +'<stop offset="100%" stop-color="#F59E0B" stop-opacity=".5"/>'
          +'</linearGradient></defs>'
          +'<path d="'+area+'" fill="url(#mtG'+c.usiaPensiun+')"/>'
          +'<path d="'+line+'" fill="none" stroke="#4F46E5" stroke-width="2" stroke-linejoin="round"/>'
          +'<line x1="'+px.toFixed(1)+'" y1="'+padT+'" x2="'+px.toFixed(1)+'" y2="'+(H-padB)+'" stroke="#3730A3" stroke-width="1.1" stroke-dasharray="3 3"/>'
          +'<text x="'+px.toFixed(1)+'" y="'+(padT-5)+'" text-anchor="middle" font-size="9" font-weight="700" fill="#4F46E5" font-family="Inter">Pensiun '+c.usiaPensiun+'</text>'
          +'<text x="'+padL+'" y="'+(H-5)+'" font-size="8.5" fill="#94A3B8" font-family="Inter">'+c.usiaNow+' th</text>'
          +'<text x="'+(W-padR)+'" y="'+(H-5)+'" text-anchor="end" font-size="8.5" fill="#94A3B8" font-family="Inter">'+c.usiaHarapan+' th</text>'
          +'<text x="'+padL+'" y="'+(padT-5)+'" font-size="8.5" fill="#94A3B8" font-family="Inter">puncak '+HC.fmt(maxS)+'</text>'
          +'</svg>';
        $('mountainChart').innerHTML=svg;
        var pa=$('mtPeakAge'); if(pa) pa.textContent=c.usiaPensiun;
      }
      function renderAdv(){
        var c=lastCalc; if(!c) return;
        var yearly=buildYearly(c);
        renderMountain(c, yearly);
        renderYearly(c, yearly);
        renderSkenario(c);
        renderSensitivity(c);
      }

      function hitung() {
        const usiaNow = num(els.usiaNow, 30);
        const usiaPensiun = num(els.usiaPensiun, 59);
        const usiaHarapan = num(els.usiaHarapan, 80);
        const pengeluaran = HC.parseRp(els.pengeluaran.value);
        const lifestyle = num(els.lifestyle, 75) / 100;
        const pensiunBulanan = HC.parseRp(els.pensiunBulanan.value);
        const tabunganNow = HC.parseRp(els.tabunganNow.value);
        const setoranNow = HC.parseRp(els.setoranNow.value);
        const returnPra = num(els.returnPra, 8) / 100;
        const returnPensiun = num(els.returnPensiun, 5) / 100;
        const inflasi = num(els.inflasi, 4) / 100;

        // Validasi
        if (pengeluaran === 0) { HC.toast('Masukkan pengeluaran bulanan dulu', 'error'); return; }
        if (usiaNow >= usiaPensiun) { HC.toast('Usia sekarang harus lebih kecil dari usia pensiun', 'error'); return; }
        if (usiaPensiun >= usiaHarapan) { HC.toast('Usia pensiun harus lebih kecil dari usia harapan hidup', 'error'); return; }

        const tahunKePensiun = usiaPensiun - usiaNow;
        const masaPensiun = usiaHarapan - usiaPensiun;
        const inflFactor = Math.pow(1 + inflasi, tahunKePensiun);

        const pengeluaranPensiun = pengeluaran * lifestyle * inflFactor; // bulanan, nominal masa depan
        const kebutuhanBersihBulanan = Math.max(0, pengeluaranPensiun - pensiunBulanan);
        const kebutuhanTahunan = kebutuhanBersihBulanan * 12;
        const rr = (1 + returnPensiun) / (1 + inflasi) - 1; // return riil saat pensiun

        // Target dana = PV anuitas kebutuhan tahunan selama masaPensiun @ return riil
        let targetDana;
        if (Math.abs(rr) < 1e-9) targetDana = kebutuhanTahunan * masaPensiun;
        else targetDana = kebutuhanTahunan * (1 - Math.pow(1 + rr, -masaPensiun)) / rr;

        // Proyeksi dana saat pensiun
        const rMon = returnPra / 12;
        const nMon = tahunKePensiun * 12;
        const fvTabungan = tabunganNow * Math.pow(1 + returnPra, tahunKePensiun);
        const fvSetoran = (setoranNow > 0 && rMon > 0) ? setoranNow * ((Math.pow(1 + rMon, nMon) - 1) / rMon) : setoranNow * nMon;
        const proyeksiDana = fvTabungan + fvSetoran;

        const kekurangan = targetDana - proyeksiDana; // >0 kurang, <0 surplus
        const surplus = kekurangan < 0;

        // Setoran ideal per bulan (total) untuk capai target
        let setoranIdeal;
        const sisaTarget = targetDana - fvTabungan;
        if (sisaTarget <= 0) setoranIdeal = 0;
        else if (rMon > 0) setoranIdeal = sisaTarget * rMon / (Math.pow(1 + rMon, nMon) - 1);
        else setoranIdeal = sisaTarget / nMon;

        // Dana cukup sampai usia berapa (dekumulasi proyeksi)
        let cukupSampaiUsia, seumurHidup = false;
        if (kebutuhanTahunan <= 0) { cukupSampaiUsia = usiaHarapan; seumurHidup = true; }
        else if (Math.abs(rr) < 1e-9) { cukupSampaiUsia = usiaPensiun + Math.floor(proyeksiDana / kebutuhanTahunan); }
        else {
          const ratio = 1 - proyeksiDana * rr / kebutuhanTahunan;
          if (ratio <= 0) { cukupSampaiUsia = 999; seumurHidup = true; }
          else cukupSampaiUsia = usiaPensiun + Math.floor(-Math.log(ratio) / Math.log(1 + rr));
        }

        const readiness = targetDana > 0 ? Math.min(999, proyeksiDana / targetDana * 100) : 0;
        const status = readiness >= 90 ? 'On track' : readiness >= 50 ? 'Menuju cukup' : 'Perlu dikejar';

        // Warnings
        const warns = [];
        if (inflasi >= returnPensiun) warns.push('Inflasi ' + (inflasi * 100).toFixed(1) + '% ≥ return saat pensiun — daya beli dana bisa menyusut. Pertimbangkan instrumen dengan return lebih tinggi atau turunkan asumsi inflasi.');
        if (masaPensiun > 30) warns.push('Masa pensiun ' + masaPensiun + ' tahun cukup panjang (longevity risk) — target dana jadi besar. Pastikan asumsi return realistis & pertimbangkan anuitas seumur hidup.');
        if (setoranIdeal > pengeluaran && setoranIdeal > 0) warns.push('Setoran ideal (' + HC.fmt(setoranIdeal) + '/bln) melebihi pengeluaran bulananmu — target mungkin terlalu berat. Pertimbangkan tunda usia pensiun atau turunkan gaya hidup pensiun.');

        lastCalc = {
          usiaNow, usiaPensiun, usiaHarapan, tahunKePensiun, masaPensiun, inflFactor,
          pengeluaran, lifestyle, pensiunBulanan, tabunganNow, setoranNow,
          returnPra, returnPensiun, inflasi,
          pengeluaranPensiun, targetDana, proyeksiDana, kekurangan, surplus,
          setoranIdeal, cukupSampaiUsia, seumurHidup, readiness, status, warns
        };

        if (HC.history) HC.history.push('pensiun', {
          inputs: HC.history.capture(['usiaNow','usiaPensiun','usiaHarapan','pengeluaran','lifestyle','pensiunBulanan','tabunganNow','setoranNow','returnPra','returnPensiun','inflasi']),
          summary: 'Pensiun usia ' + usiaPensiun + ' · target ' + HC.fmt(targetDana),
          metrics: [{ k: 'Setoran ideal', v: HC.fmt(setoranIdeal) + '/bln' }, { k: 'Kesiapan', v: readiness.toFixed(0) + '%' }]
        });
        renderHist();

        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        render();
        renderAdv();
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Rencana pensiun berhasil dihitung!');
      }

      function fvFmt(val) {
        // format nilai masa depan; kalau viewMode 'today', diskon ke daya beli sekarang
        if (viewMode === 'today' && lastCalc) return HC.fmt(val / lastCalc.inflFactor);
        return HC.fmt(val);
      }

      function render() {
        const c = lastCalc; if (!c) return;
        // hero (setoran ideal selalu nominal — keputusan hari ini)
        $('setoranIdeal').textContent = HC.fmt(c.setoranIdeal) + '/bln';
        const gapTxt = c.surplus
          ? 'surplus ' + fvFmt(Math.abs(c.kekurangan))
          : 'kurang ' + fvFmt(c.kekurangan);
        $('heroMeta').textContent = 'Pensiun usia ' + c.usiaPensiun + ' (' + c.tahunKePensiun + ' thn lagi) · nabung sekarang ' + HC.fmt(c.setoranNow) + '/bln · ' + gapTxt;

        $('targetDana').textContent = fvFmt(c.targetDana);
        $('proyeksiDana').textContent = fvFmt(c.proyeksiDana);
        $('gapLabel').textContent = c.surplus ? 'Surplus' : 'Kekurangan';
        const kEl = $('kekurangan');
        kEl.textContent = fvFmt(Math.abs(c.kekurangan));
        kEl.classList.toggle('result-warn', !c.surplus);
        kEl.classList.toggle('result-good', c.surplus);
        $('pengeluaranPensiun').textContent = fvFmt(c.pengeluaranPensiun);
        $('cukupSampai').textContent = c.seumurHidup ? 'Seumur hidup ✅'
          : (c.cukupSampaiUsia >= c.usiaHarapan ? ('Usia ' + c.usiaHarapan + '+ ✅') : ('Usia ' + c.cukupSampaiUsia));
        $('readiness').textContent = Math.min(999, c.readiness).toFixed(0) + '% · ' + c.status;

        const wb = $('warnBox');
        if (c.warns.length) { wb.style.display = ''; wb.innerHTML = c.warns.map(w => '<div class="warn-item"><i class="ti ti-alert-triangle"></i><span>' + w + '</span></div>').join(''); }
        else wb.style.display = 'none';
      }

      function reset() {
        els.usiaNow.value = '30'; els.usiaPensiun.value = '59'; els.usiaHarapan.value = '80';
        els.pengeluaran.value = '8.000.000'; els.lifestyle.value = '75'; els.pensiunBulanan.value = '0';
        els.tabunganNow.value = '0'; els.setoranNow.value = '1.000.000';
        els.returnPra.value = '8'; els.returnPensiun.value = '5'; els.inflasi.value = '4';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.readiness >= 90
          ? `🎉 Kesiapan pensiunmu ${c.readiness.toFixed(0)}% — On track! Jaga konsistensi, kelola risiko investasi, dan review tiap tahun.`
          : c.readiness >= 50
          ? `Kesiapan ${c.readiness.toFixed(0)}% — menuju cukup. Naikkan setoran ke ${HC.fmt(c.setoranIdeal)}/bln atau tunda pensiun sedikit untuk menutup gap.`
          : `Kesiapan baru ${c.readiness.toFixed(0)}%. Gap masih besar — mulai naikkan setoran, alokasikan bonus/THR, dan pertimbangkan return investasi yang memadai. Mulai lebih dini = lebih ringan.`;
        return HC.buildReportCard({
          title: '🏖️ Rencana Dana Pensiun',
          color: '#4F46E5', color2: '#3730A3',
          heroLabel: 'Setoran Ideal per Bulan',
          heroValue: HC.fmt(c.setoranIdeal) + '/bln',
          heroSubtext: `Pensiun usia ${c.usiaPensiun} · kesiapan ${c.readiness.toFixed(0)}% (${c.status})`,
          inputs: [
            { label: '🎂 Usia', value: c.usiaNow + ' → ' + c.usiaPensiun + ' thn' },
            { label: '💸 Pengeluaran/bln', value: HC.fmt(c.pengeluaran) },
            { label: '💰 Tabungan kini', value: HC.fmt(c.tabunganNow) },
            { label: '📈 Return', value: (c.returnPra*100).toFixed(0) + '% / ' + (c.returnPensiun*100).toFixed(0) + '%' },
          ],
          results: [
            { label: 'Target Dana Pensiun', value: HC.fmt(c.targetDana), highlight: true },
            { label: 'Proyeksi Dana Kamu', value: HC.fmt(c.proyeksiDana) },
            { label: c.surplus ? 'Surplus' : 'Kekurangan', value: HC.fmt(Math.abs(c.kekurangan)) },
            { label: 'Pengeluaran/bln saat pensiun', value: HC.fmt(c.pengeluaranPensiun) },
            { label: 'Dana cukup sampai usia', value: c.seumurHidup ? 'Seumur hidup' : (c.cukupSampaiUsia >= c.usiaHarapan ? c.usiaHarapan + '+' : String(c.cukupSampaiUsia)) },
            { label: 'Setoran ideal/bln', value: HC.fmt(c.setoranIdeal), highlight: true },
          ],
          insight, slug: 'pensiun',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🏖️ *Dana Pensiun - HitungCerdas*\n\nUsia ${c.usiaNow} → pensiun ${c.usiaPensiun} (${c.tahunKePensiun} thn lagi)\nPengeluaran: ${HC.fmt(c.pengeluaran)}/bln\n\n🎯 *Target dana: ${HC.fmt(c.targetDana)}*\n📊 Proyeksi kamu: ${HC.fmt(c.proyeksiDana)}\n${c.surplus ? '✅ Surplus' : '⚠️ Kurang'}: ${HC.fmt(Math.abs(c.kekurangan))}\n💰 *Setoran ideal: ${HC.fmt(c.setoranIdeal)}/bln*\n🧭 Kesiapan: ${c.readiness.toFixed(0)}% (${c.status})\n\nHitung di: https://hitungcerdas.net/kalkulator/pensiun`;
      }

      function renderHist() {
        if (HC.history) HC.history.render('pensiun', $('histBox'), function () { hitung(); });
      }
      renderHist();
      document.querySelectorAll('.adv-toggle').forEach(function(t){ t.addEventListener('click', function(){ t.parentElement.classList.toggle('open'); }); });

      // view toggle
      $('viewToggle').querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
        viewMode = btn.getAttribute('data-view');
        $('viewToggle').querySelectorAll('button').forEach(b => b.classList.toggle('active', b === btn));
        render();
      }));

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'pensiun-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'pensiun'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'pensiun-' + Date.now()); });

      function buildShareUrl() {
        var p = new URLSearchParams();
        p.set('un', els.usiaNow.value); p.set('up', els.usiaPensiun.value); p.set('uh', els.usiaHarapan.value);
        p.set('pg', String(HC.parseRp(els.pengeluaran.value) || 0));
        p.set('ls', els.lifestyle.value); p.set('pb', String(HC.parseRp(els.pensiunBulanan.value) || 0));
        p.set('tb', String(HC.parseRp(els.tabunganNow.value) || 0)); p.set('sn', String(HC.parseRp(els.setoranNow.value) || 0));
        p.set('ra', els.returnPra.value); p.set('rp', els.returnPensiun.value); p.set('if', els.inflasi.value);
        return location.origin + location.pathname + '?' + p.toString();
      }
      function setNum(el, val) { el.value = val; el.dispatchEvent(new Event('input', { bubbles: true })); }
      function loadFromUrl() {
        var q = new URLSearchParams(location.search);
        if (!q.has('pg')) return false;
        if (q.has('un')) els.usiaNow.value = q.get('un');
        if (q.has('up')) els.usiaPensiun.value = q.get('up');
        if (q.has('uh')) els.usiaHarapan.value = q.get('uh');
        setNum(els.pengeluaran, q.get('pg'));
        if (q.has('ls')) els.lifestyle.value = q.get('ls');
        if (q.has('pb')) setNum(els.pensiunBulanan, q.get('pb'));
        if (q.has('tb')) setNum(els.tabunganNow, q.get('tb'));
        if (q.has('sn')) setNum(els.setoranNow, q.get('sn'));
        if (q.has('ra')) els.returnPra.value = q.get('ra');
        if (q.has('rp')) els.returnPensiun.value = q.get('rp');
        if (q.has('if')) els.inflasi.value = q.get('if');
        return true;
      }
      $('exportLink').addEventListener('click', function () { HC.copyText(buildShareUrl(), 'Link tersalin!'); });
      if (loadFromUrl()) { hitung(); }
    });
  })();
</script>
<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EEF2FF;border:1px solid #C7D2FE;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E0E7FF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#4F46E5;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EEF2FF;color:#4F46E5;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EEF2FF;color:#4F46E5;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl>span{flex:1 1 0}
  .aic-gauge-lbl>span:first-child{text-align:left}
  .aic-gauge-lbl>span:nth-child(2){text-align:center}
  .aic-gauge-lbl>span:last-child{text-align:right}
  .aic-gauge-lbl .g{color:#059669}
  .aic-gauge-lbl .a{color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#EEF2FF;color:#4F46E5;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#4F46E5;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#4F46E5;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#3730A3;border-color:#3730A3;background:#EEF2FF}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#EEF2FF;color:#4F46E5;border:1px solid #C7D2FE;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#E0E7FF}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#4F46E5}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#4F46E5;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#A5B4FC}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#A5B4FC}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#A5B4FC}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#A5B4FC}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(79,70,229,.16);color:#A5B4FC;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(79,70,229,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#6366F1}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}
</style>
<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        var v=function(id){ return ((($(id)||{}).textContent)||'').trim(); };
        var val=function(id){ return ($(id)||{}).value||''; };
        var rdTxt=v('readiness');
        var rd=parseFloat(rdTxt); if(!isFinite(rd)) rd=null;
        var status=(rdTxt.split('\u00b7')[1]||'').trim();
        return {
          setoran:v('setoranIdeal'), target:v('targetDana'), proyeksi:v('proyeksiDana'),
          kekurangan:v('kekurangan'), gapLabel:v('gapLabel')||'Kekurangan', pengPensiun:v('pengeluaranPensiun'),
          cukup:v('cukupSampai'), readiness:rd, status:status,
          usiaNow:val('usiaNow'), usiaPensiun:val('usiaPensiun'), usiaHarapan:val('usiaHarapan'),
          pengeluaran:val('pengeluaran'), lifestyle:val('lifestyle'), pensiunBulanan:val('pensiunBulanan'),
          tabunganNow:val('tabunganNow'), setoranNow:val('setoranNow'),
          returnPra:val('returnPra'), returnPensiun:val('returnPensiun'), inflasi:val('inflasi'),
          hasResult:(rd!=null)
        };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-beach"></i> Dana Pensiun'+(d.readiness!=null?' \u00b7 Kesiapan <b>'+d.readiness.toFixed(0)+'%</b>':'')+'</div>';
        if(d.readiness==null){ ground.innerHTML=ctx+'<div class="aic-nogauge">Klik "Hitung Sekarang" dulu untuk lihat skor kesiapan pensiunmu.</div>'; return; }
        var rd=Math.max(0,Math.min(d.readiness,120)); var pos=rd/120*100;
        var vc=d.readiness>=90?'good':(d.readiness>=50?'warn':'bad');
        var vi=d.readiness>=90?'ti-circle-check':(d.readiness>=50?'ti-alert-triangle':'ti-alert-circle');
        var vt=d.readiness>=90?'On track \u2014 danamu terproyeksi cukup':(d.readiness>=50?'Menuju cukup \u2014 tinggal dikejar sedikit':'Perlu dikejar \u2014 gap masih besar');
        ground.innerHTML=ctx
          +'<div class="aic-gauge"><div class="aic-gauge-mark" style="left:'+pos.toFixed(1)+'%"><span>kamu \u00b7 '+d.readiness.toFixed(0)+'%</span></div>'
          +'<div class="aic-gauge-bar"><div class="z-red" style="flex:50"></div><div class="z-amber" style="flex:40"></div><div class="z-green" style="flex:30"></div></div>'
          +'<div class="aic-gauge-lbl"><span class="r">Perlu dikejar</span><span class="a">Menuju cukup</span><span class="g">On track</span></div></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Dana Pensiun (perencanaan pensiun jangka panjang).',
          'Input: usia sekarang '+d.usiaNow+', usia pensiun '+d.usiaPensiun+', usia harapan hidup '+d.usiaHarapan+', pengeluaran sekarang Rp '+d.pengeluaran+'/bln, gaya hidup saat pensiun '+d.lifestyle+'% dari pengeluaran, pensiun/penghasilan pasif Rp '+d.pensiunBulanan+'/bln, tabungan pensiun kini Rp '+d.tabunganNow+', nabung sekarang Rp '+d.setoranNow+'/bln, return sebelum pensiun '+d.returnPra+'%/th, return saat pensiun '+d.returnPensiun+'%/th, inflasi '+d.inflasi+'%/th.',
          'Hasil: target dana pensiun '+d.target+', proyeksi dana '+d.proyeksi+', '+d.gapLabel.toLowerCase()+' '+d.kekurangan+', pengeluaran bulanan saat pensiun '+d.pengPensiun+', dana proyeksi cukup sampai '+d.cukup+', skor kesiapan '+(d.readiness!=null?d.readiness.toFixed(0)+'%':'-')+' ('+d.status+'). Setoran ideal per bulan '+d.setoran+'.',
          'Acuan untuk jawabanmu: Skor kesiapan = proyeksi dana \u00f7 target dana \u00d7 100%. <50% Perlu dikejar, 50-90% Menuju cukup, \u226590% On track. Target dihitung metode nilai kini (present value) atas RETURN RIIL = (1+return)\u00f7(1+inflasi)\u22121, agar daya beli terjaga (bukan sekadar nominal). Fakta BPJS Ketenagakerjaan 2026: usia pensiun program Jaminan Pensiun (JP) = 59 tahun, naik 1 tahun tiap 3 tahun hingga maksimal 65. JP memberi manfaat BULANAN bila masa iur minimal 15 tahun (kalau kurang, dibayar sekaligus); iuran JP 3% dari upah (2% pemberi kerja + 1% pekerja); batas upah JP 2026 Rp 10.547.400. JHT (Jaminan Hari Tua) berupa LUMP SUM, umumnya cair mulai usia 56. JANGAN andalkan BPJS saja \u2014 manfaat JP relatif kecil dibanding kebutuhan hidup; jadikan pelengkap, sisanya tabung & investasikan sendiri. Lima tuas menutup kekurangan: (1) tambah setoran bulanan, (2) tunda usia pensiun, (3) turunkan gaya hidup pensiun, (4) alokasikan THR/bonus, (5) tambah penghasilan pasif. Kekuatan terbesar: mulai sedini mungkin (bunga majemuk) + diversifikasi (reksadana, saham, emas, DPLK, properti sewa). Semua angka BPJS bersifat estimasi, bukan angka resmi. Pakai sapaan "kamu", jawab ringkas & hangat, JANGAN mengarang angka di luar data. Ini edukasi, bukan nasihat keuangan/investasi resmi.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var bl=t.match(/^[-*\u2022]\s+(.*)$/); if(bl){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(bl[1]))+'</span></div>');continue;} var nn=t.match(/^(\d+)[.)]\s+(.*)$/); if(nn){out.push('<div class="aic-li"><span class="aic-mk">'+nn[1]+'.</span><span>'+mdInline(esc(nn[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function typeInto(bubble, text, done){ var n=0, len=text.length, step=Math.max(2, Math.round(len/90)); var t=setInterval(function(){ n=Math.min(len, n+step); bubble.innerHTML=mdToHtml(text.slice(0,n)); msgs.scrollTop=msgs.scrollHeight; if(n>=len){ clearInterval(t); done&&done(); } }, 18); }
      function mkCopyBtn(text){ var b=document.createElement('button'); b.type='button'; b.className='aic-copy'; b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>'; b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); }); return b; }
      function addMsgTyped(text){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); }); return row; }
      var FOLLOWUPS=['Dana pensiunku cukup gak?','BPJS aja cukup gak?','Gimana cara nutup kekurangannya?','Kenapa targetnya semiliar-an?','Return riil itu apa?','Mulai investasi dari mana?','Kenapa harus mulai sekarang?','Beda JHT dan JP apa?'];
      function renderFollowups(){ chips.innerHTML=''; var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;}); var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;}); pool.slice(0,3).forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b); }); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Dana pensiunku cukup gak?','BPJS aja cukup gak?','Gimana cara nutup kekurangannya?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },800); }); }
    });
  })();
</script>
