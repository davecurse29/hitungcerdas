---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('kpr')!;
const related = getRelatedCalculators('kpr', 3);

const faqs = [
  { question: 'Bagaimana rumus menghitung cicilan KPR yang benar?', answer: 'Cicilan KPR menggunakan rumus <strong>anuitas</strong>: M = P × (i × (1+i)<sup>n</sup>) / ((1+i)<sup>n</sup> - 1). Cicilan bulanan tetap sama tiap bulan, tapi komposisi bunga vs pokok berubah — di awal lebih banyak bunga, di akhir lebih banyak pokok.' },
  { question: 'Apa beda bunga fixed dan floating? Mana yang harus saya pilih?', answer: '<strong>Fixed</strong>: bunga TETAP selama periode tertentu (biasanya 1-5 tahun pertama). Predictable, aman dari kenaikan BI Rate.<br><br><strong>Floating</strong>: bunga mengikuti BI Rate, bisa naik/turun setiap 3-6 bulan. Berisiko tapi bisa lebih murah saat bunga turun.<br><br><strong>Combo (Fixed+Floating)</strong>: Bank Indonesia umumnya pakai sistem ini. Misal: Fixed 5% selama 3 tahun, lalu Floating ~9-11% sisa tenor. Mode ini PALING REALISTIS untuk simulasi KPR di Indonesia.' },
  { question: 'Pelunasan dipercepat, untung gak sih?', answer: 'SANGAT UNTUNG! Misal: KPR Rp 640jt, tenor 15 thn, bunga 7.5%. Cicilan Rp 5.93jt/bln. Total bunga: Rp 426jt.<br><br>Kalau di tahun ke-3 kamu lunasi extra Rp 100 juta:<br>• Tenor jadi 11 tahun (lebih cepat 4 tahun!)<br>• Hemat total bunga: Rp 145 juta!<br><br>Tips: gunakan bonus tahunan, THR, atau dapat warisan untuk lunasi sebagian. Bank wajib terima pelunasan dipercepat sesuai POJK.' },
  { question: 'Apa saja biaya KPR di luar cicilan?', answer: 'Biaya yang HARUS disiapkan saat KPR (di luar DP):<br>• <strong>BPHTB</strong>: 5% dari (harga - NJOPTKP)<br>• <strong>AJB (Akta Jual Beli)</strong>: 1% dari harga<br>• <strong>BBN (Balik Nama Sertifikat)</strong>: 2% dari harga<br>• <strong>Provisi Bank</strong>: 1% dari pokok pinjaman<br>• <strong>Biaya Notaris</strong>: Rp 2-5 juta<br>• <strong>Appraisal/Survey</strong>: Rp 500rb-2jt<br>• <strong>Administrasi Bank</strong>: Rp 250rb-1jt<br>• <strong>Asuransi KPR Life + Property</strong>: 0.3-0.5%/thn dari pokok<br><br>Total biaya awal biasanya 5-7% dari harga rumah. Untuk rumah Rp 800jt, siapkan Rp 40-56 juta DI LUAR DP.' },
  { question: 'Mengapa inflasi mempengaruhi bunga KPR?', answer: 'Bunga KPR dipengaruhi <strong>BI Rate</strong>, yang naik saat inflasi tinggi untuk menjaga daya beli Rupiah (Fisher Equation). Saat inflasi tinggi (>5%), BI Rate naik, bank juga naikkan bunga KPR floating. Mode Inflasi kami simulasikan dampak skenario inflasi terhadap cicilan untuk perencanaan jangka panjang.' },
  { question: 'Berapa cicilan KPR yang aman dari gaji?', answer: 'Aturan emas: <strong>cicilan KPR maksimal 30% dari gaji bulanan</strong> (Debt-to-Income Ratio max 30%). Bank approve sampai 40%, tapi itu zona berisiko. Sisakan margin untuk pajak (PBB), maintenance, asuransi, dan dana darurat 6 bulan cicilan.' },
  { question: 'Bank mana yang punya bunga KPR paling murah?', answer: 'Bunga KPR fluktuatif per bulan. Pada 2026, kisaran bunga fixed 1-3 tahun di bank besar Indonesia: BCA (~5.25%), Mandiri (~5.50%), BNI (~5.99%), BRI (~6.25%), CIMB Niaga (~5.49%). Untuk KPR Subsidi (FLPP) di BTN: bunga flat 5% selama 20 tahun. CEK LANGSUNG ke website bank untuk angka terbaru karena bunga sering berubah.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": calc.shortTitle,
  "description": calc.metaDescription,
  "applicationCategory": "FinanceApplication",
  "url": `https://hitungcerdas.net/kalkulator/${calc.slug}`,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "IDR" },
};
---

<Layout
  title={calc.title}
  description={calc.metaDescription}
  keywords={calc.keywords}
  canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}
  jsonLd={jsonLd}
>
  <section class="calc-hero" style="--cat-color:#2563EB;--cat-color2:#1E40AF">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#DBEAFE;color:#1E40AF">
            <i class="ti ti-home" aria-hidden="true"></i>
            {calc.categoryLabel}
          </div>
          <h1 class="calc-hero-title">Kalkulator KPR Indonesia 2026 — Premium</h1>
          <p class="calc-hero-sub">{calc.introText} Sekarang dilengkapi <strong>simulasi bunga fixed+floating, pelunasan dipercepat, biaya KPR lengkap, visual charts, dan perbandingan 6 bank besar Indonesia</strong>.</p>
          <ul class="calc-hero-benefits">
            <li><i class="ti ti-check"></i> Bunga fixed+floating realistis</li>
            <li><i class="ti ti-check"></i> Simulasi pelunasan dipercepat</li>
            <li><i class="ti ti-check"></i> Biaya KPR lengkap (BPHTB, AJB, dll)</li>
            <li><i class="ti ti-check"></i> Visual charts (donut + line)</li>
            <li><i class="ti ti-check"></i> Bandingkan 6 bank Indonesia</li>
          </ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/>
            <circle cx="100" cy="100" r="65" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.15)" stroke-width="1"/>
            <g transform="translate(60 70)">
              <path d="M0 40L40 5L80 40" fill="#FBBF24" stroke="#FFF" stroke-width="2" stroke-linejoin="round"/>
              <rect x="8" y="40" width="64" height="42" fill="#FFF" stroke="#FBBF24" stroke-width="2"/>
              <rect x="30" y="55" width="20" height="27" fill="#1E4475"/>
              <rect x="15" y="48" width="10" height="10" fill="#DBEAFE" stroke="#1E4475" stroke-width="1.5"/>
              <rect x="55" y="48" width="10" height="10" fill="#DBEAFE" stroke="#1E4475" stroke-width="1.5"/>
              <rect x="50" y="12" width="6" height="14" fill="#DC2626"/>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic"><i class="ti ti-home-dollar"></i></div>
          <div>
            <h2 class="calc-card-title">Kalkulator KPR Premium</h2>
            <p class="calc-card-sub">Anuitas + Combo Fixed-Floating + Pelunasan Dipercepat + Charts + Bank Compare</p>
          </div>
        </div>

        <div class="calc-grid">
          {/* ─── INPUT FORM ─── */}
          <div class="calc-input">
            <div class="field">
              <label for="hargaRumah">Harga Rumah <span class="hint">(Rupiah)</span></label>
              <div class="input-wrap">
                <span class="input-prefix">Rp</span>
                <input type="text" id="hargaRumah" class="has-prefix" placeholder="800.000.000" value="800.000.000" inputmode="numeric" />
              </div>
            </div>

            <div class="field">
              <label for="dpPersen">DP (Down Payment) <span class="hint">(%)</span></label>
              <div class="input-wrap">
                <input type="number" id="dpPersen" class="has-suffix" placeholder="20" value="20" step="1" min="0" max="100" />
                <span class="input-suffix">%</span>
              </div>
              <div class="quick-btns">
                <button type="button" data-dp="10">10%</button>
                <button type="button" data-dp="20">20%</button>
                <button type="button" data-dp="30">30%</button>
                <button type="button" data-dp="40">40%</button>
                <button type="button" data-dp="50">50%</button>
              </div>
            </div>

            <div class="field">
              <label for="bunga">Suku Bunga <span class="hint">(per tahun)</span></label>
              <div class="input-wrap">
                <input type="number" id="bunga" class="has-suffix" placeholder="7.5" value="7.5" step="0.1" min="0" />
                <span class="input-suffix">%</span>
              </div>
              <p class="field-hint">Bunga KPR bank Indonesia: 5-12% per tahun</p>
            </div>

            <div class="field">
              <label for="tenor">Tenor (Lama Cicilan)</label>
              <select id="tenor">
                <option value="5">5 tahun</option>
                <option value="10">10 tahun</option>
                <option value="15" selected>15 tahun</option>
                <option value="20">20 tahun</option>
                <option value="25">25 tahun</option>
                <option value="30">30 tahun</option>
              </select>
            </div>

            <div class="field">
              <label for="gajiCheck">Gaji Bulanan <span class="hint">(untuk cek kelayakan)</span></label>
              <div class="input-wrap">
                <span class="input-prefix">Rp</span>
                <input type="text" id="gajiCheck" class="has-prefix" placeholder="15.000.000" value="15.000.000" inputmode="numeric" />
              </div>
            </div>

            {/* ─── FEATURE 1: COMBO BUNGA FIXED + FLOATING ─── */}
            <div class="combo-bunga-box" id="comboBox">
              <label class="combo-bunga-toggle">
                <input type="checkbox" id="comboToggle" />
                <span>🎯 Aktifkan Bunga Combo (Fixed → Floating)</span>
              </label>
              <div class="combo-bunga-options">
                <p class="combo-note">
                  <strong>Skenario realistis bank Indonesia:</strong> Bunga FIXED untuk beberapa tahun pertama, lalu FLOATING mengikuti BI Rate.
                </p>
                <div class="combo-bunga-grid">
                  <div class="field">
                    <label for="bungaFixed">Bunga Fixed (%)</label>
                    <div class="input-wrap">
                      <input type="number" id="bungaFixed" class="has-suffix" value="5" step="0.1" min="0" />
                      <span class="input-suffix">%</span>
                    </div>
                  </div>
                  <div class="field">
                    <label for="durasiFixed">Selama (tahun)</label>
                    <select id="durasiFixed">
                      <option value="1">1 tahun</option>
                      <option value="2">2 tahun</option>
                      <option value="3" selected>3 tahun</option>
                      <option value="5">5 tahun</option>
                    </select>
                  </div>
                </div>
                <div class="combo-bunga-grid">
                  <div class="field" style="grid-column:1 / -1">
                    <label for="bungaFloating">Estimasi Bunga Floating (%)</label>
                    <div class="input-wrap">
                      <input type="number" id="bungaFloating" class="has-suffix" value="10" step="0.1" min="0" />
                      <span class="input-suffix">%</span>
                    </div>
                  </div>
                </div>
                <p class="combo-note" style="margin-top:10px">
                  💡 <strong>Tip realistis</strong>: Bunga floating sering naik 4-6% di atas fixed. Hitung skenario terburuk.
                </p>
              </div>
            </div>

            {/* ─── FEATURE 2: PREPAYMENT (PELUNASAN DIPERCEPAT) ─── */}
            <div class="prepayment-box" id="prepayBox">
              <label class="prepayment-toggle">
                <input type="checkbox" id="prepayToggle" />
                <span>💸 Aktifkan Pelunasan Dipercepat</span>
              </label>
              <div class="prepayment-options">
                <p class="combo-note" style="color:#065F46">
                  Punya bonus/THR/warisan? Lunasi sebagian KPR untuk hemat bunga besar!
                </p>
                <div class="prepayment-row">
                  <div class="field">
                    <label for="prepayAmount">Pelunasan (Rp)</label>
                    <div class="input-wrap">
                      <span class="input-prefix">Rp</span>
                      <input type="text" id="prepayAmount" class="has-prefix" value="100.000.000" inputmode="numeric" />
                    </div>
                  </div>
                  <div class="field">
                    <label for="prepayYear">Di Tahun Ke-</label>
                    <select id="prepayYear">
                      <option value="1">Tahun 1</option>
                      <option value="2">Tahun 2</option>
                      <option value="3" selected>Tahun 3</option>
                      <option value="4">Tahun 4</option>
                      <option value="5">Tahun 5</option>
                      <option value="7">Tahun 7</option>
                      <option value="10">Tahun 10</option>
                    </select>
                  </div>
                </div>
              </div>
            </div>

            {/* ─── FEATURE 3: INFLASI MODE (existing) ─── */}
            <div class="inflation-box" id="inflationBox">
              <label class="inflation-toggle">
                <input type="checkbox" id="inflasiToggle" />
                <span>🔥 Aktifkan Mode Skenario Inflasi</span>
              </label>
              <div class="inflation-options">
                <label>Skenario Inflasi:</label>
                <select id="inflasiSkenario">
                  <option value="rendah">📉 Rendah (3.0%) — Optimis</option>
                  <option value="normal" selected>📊 Normal (4.5%) — Rata-rata historis</option>
                  <option value="tinggi">📈 Tinggi (6.0%) — Hati-hati</option>
                  <option value="krisis">⚠️ Krisis (8.0%) — Skenario terburuk</option>
                </select>
                <p class="inflation-note">
                  Saat inflasi naik, BI Rate naik → bunga KPR naik. Mode ini auto-adjust suku bunga sesuai skenario inflasi (Fisher Equation).
                </p>
              </div>
            </div>

            {/* ─── ACTION BUTTONS ─── */}
            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung">
                <i class="ti ti-calculator"></i> Hitung Sekarang
              </button>
              <button type="button" class="btn-reset" id="btnReset">
                <i class="ti ti-refresh"></i> Reset
              </button>
            </div>
          </div>

          {/* ─── OUTPUT PANEL ─── */}
          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-calculator result-placeholder-icon"></i>
              <div class="result-placeholder-title">Hasil akan muncul di sini</div>
              <div class="result-placeholder-desc">
                Isi data di sebelah kiri, lalu klik tombol <strong>"Hitung Sekarang"</strong> untuk simulasi cicilan KPR lengkap dengan charts.
              </div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Cicilan Per Bulan</div>
                <div class="result-value" id="cicilanBulan">Rp 0</div>
                <div class="result-meta">
                  <span><i class="ti ti-info-circle"></i> <span id="metaInfo">Anuitas tetap</span></span>
                </div>
              </div>

              <div class="result-grid">
                <div class="result-item">
                  <div class="result-item-label">DP Dibayar</div>
                  <div class="result-item-value" id="totalDP">Rp 0</div>
                </div>
                <div class="result-item">
                  <div class="result-item-label">Pokok Pinjaman</div>
                  <div class="result-item-value" id="pokokPinjaman">Rp 0</div>
                </div>
                <div class="result-item">
                  <div class="result-item-label">Total Bunga</div>
                  <div class="result-item-value result-warn" id="totalBunga">Rp 0</div>
                </div>
                <div class="result-item">
                  <div class="result-item-label">Total Bayar</div>
                  <div class="result-item-value result-strong" id="totalBayar">Rp 0</div>
                </div>
              </div>

              {/* COMBO BUNGA RESULT (only shown if combo active) */}
              <div class="combo-bunga-box" id="comboResult" style="display:none">
                <h4 style="font-size:13px;font-weight:700;color:#1E40AF;margin:0 0 10px;display:flex;align-items:center;gap:6px">
                  <i class="ti ti-arrow-bar-up"></i> Cicilan Bertingkat (Fixed → Floating)
                </h4>
                <table style="width:100%;font-size:12.5px;border-collapse:collapse;color:#1E3A8A">
                  <tr><td style="padding:5px 0">Cicilan periode Fixed</td><td style="text-align:right;font-weight:700" id="cicilanFixedShow">-</td></tr>
                  <tr><td style="padding:5px 0">Cicilan periode Floating</td><td style="text-align:right;font-weight:700" id="cicilanFloatingShow">-</td></tr>
                  <tr style="border-top:1px dashed #2563EB"><td style="padding:8px 0;font-weight:700">Selisih Cicilan</td><td style="text-align:right;font-weight:800;color:#1E40AF" id="selisihCicilan">-</td></tr>
                </table>
                <p class="combo-note" style="margin-top:8px">⚠️ Pastikan kamu mampu cicilan FLOATING (yang lebih tinggi) sebelum ambil KPR.</p>
              </div>

              {/* PREPAYMENT RESULT (only shown if prepay active) */}
              <div class="prepayment-result" id="prepayResultBox" style="display:none">
                <h4 style="font-size:13px;font-weight:700;color:#065F46;margin:0 0 10px;display:flex;align-items:center;gap:6px">
                  <i class="ti ti-discount"></i> Hasil Pelunasan Dipercepat
                </h4>
                <div class="pr-row">
                  <span>Tenor SEBELUM pelunasan</span>
                  <span id="tenorBefore">-</span>
                </div>
                <div class="pr-row">
                  <span>Tenor SETELAH pelunasan</span>
                  <span id="tenorAfter">-</span>
                </div>
                <div class="pr-row">
                  <span>Hemat Waktu</span>
                  <span id="hematWaktu" style="color:#065F46;font-weight:700">-</span>
                </div>
                <div class="pr-row highlight">
                  <span>💰 Hemat Total Bunga</span>
                  <span id="hematBunga">-</span>
                </div>
              </div>

              {/* KELAYAKAN VS GAJI */}
              <div class="kelayakan-box" id="kelayakanBox">
                <div class="kelayakan-hdr">
                  <i class="ti ti-shield-check"></i>
                  <span>Cek Kelayakan vs Gaji</span>
                </div>
                <div id="kelayakanBody"></div>
              </div>

              {/* FEATURE 4: VISUAL CHARTS */}
              <div class="chart-section" id="chartSection" style="display:none">
                <h4><i class="ti ti-chart-pie"></i> Visualisasi Data</h4>
                <div class="chart-grid">
                  <div class="chart-wrap">
                    <h5>🍩 Komposisi Total Bayar</h5>
                    <div class="chart-canvas-wrap">
                      <canvas id="donutChart"></canvas>
                    </div>
                  </div>
                  <div class="chart-wrap">
                    <h5>📉 Sisa Pinjaman per Tahun</h5>
                    <div class="chart-canvas-wrap">
                      <canvas id="lineChart"></canvas>
                    </div>
                  </div>
                </div>
              </div>

              {/* FEATURE 5: BANK COMPARISON */}
              <div class="adv-section">
                <div class="adv-toggle">
                  <span><i class="ti ti-building-bank"></i>&nbsp; Bandingkan 6 Bank Indonesia</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <div id="bankCompareBody" class="bank-compare-box"></div>
                  <p class="bank-disclaimer">
                    ⚠️ <strong>Disclaimer</strong>: Data bunga adalah <em>indikatif</em> per Juni 2026 berdasarkan publikasi terbuka. Bunga riil bisa berbeda tergantung profil debitur (gaji, BI Checking, durasi kerja). <strong>Selalu cek langsung ke bank</strong> untuk angka final yang berlaku.
                  </p>
                </div>
              </div>

              {/* BIAYA KPR LENGKAP */}
              <div class="adv-section">
                <div class="adv-toggle">
                  <span><i class="ti ti-receipt"></i>&nbsp; Biaya KPR Lengkap (di luar DP)</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <div class="biaya-detail-box">
                    <h4><i class="ti ti-file-invoice"></i> Estimasi Biaya yang Harus Disiapkan</h4>
                    <ul class="biaya-detail-list" id="biayaList"></ul>
                  </div>
                  <p class="bank-disclaimer">
                    💡 Biaya ini DI LUAR DP. Biasanya 5-7% dari harga rumah. Bank kadang memasukkan beberapa biaya ini ke pokok pinjaman (top-up), tapi pastikan tanya dengan jelas.
                  </p>
                </div>
              </div>

              {/* TENOR COMPARISON */}
              <div class="adv-section">
                <div class="adv-toggle">
                  <span><i class="ti ti-chart-bar"></i>&nbsp; Bandingkan Semua Tenor</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead>
                      <tr><th>Tenor</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bunga</th><th class="right">Total Bayar</th></tr>
                    </thead>
                    <tbody id="tenorCompareBody"></tbody>
                  </table>
                </div>
              </div>

              {/* AMORTISASI */}
              <div class="adv-section">
                <div class="adv-toggle">
                  <span><i class="ti ti-table"></i>&nbsp; Tabel Amortisasi Per Tahun</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead>
                      <tr><th>Tahun</th><th class="right">Pokok</th><th class="right">Bunga</th><th class="right">Sisa Pinjaman</th></tr>
                    </thead>
                    <tbody id="amortBody"></tbody>
                  </table>
                </div>
              </div>

              {/* INFLASI COMPARE (if active) */}
              <div class="adv-section" id="advInflasi" style="display:none">
                <div class="adv-toggle">
                  <span><i class="ti ti-trending-up"></i>&nbsp; Dampak Inflasi terhadap Bunga & Cicilan</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead>
                      <tr><th>Skenario</th><th class="right">Bunga</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bayar</th></tr>
                    </thead>
                    <tbody id="inflasiCompareBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section open" id="stressBlock">
                <div class="adv-toggle">
                  <span><i class="ti ti-flame"></i>&nbsp; Stress Test: Kalau Bunga Floating Naik</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <div class="field" style="margin-bottom:10px"><label>Bunga floating naik ke (%)</label>
                    <div class="input-wrap"><input type="number" id="stressBunga" class="has-suffix" value="12" step="0.5" min="0" /><span class="input-suffix">%</span></div></div>
