      }

      function renderLine(amortRows, prepayInfo) {
        const ctx = $('lineChart').getContext('2d');
        if (lineChart) lineChart.destroy();
        const labels = amortRows.map(r => `Thn ${r.tahun}`);
        const dataNormal = amortRows.map(r => r.sisa);

        const datasets = [{
          label: 'Sisa Pinjaman (Normal)',
          data: dataNormal,
          borderColor: '#2563EB',
          backgroundColor: 'rgba(37,99,235,.1)',
          borderWidth: 2,
          tension: .25,
          fill: true,
        }];

        // If prepayment data exists, add overlay line
        if (prepayInfo) {
          datasets.push({
            label: 'Sisa (Dengan Pelunasan Dipercepat)',
            data: prepayInfo.sisaPerTahun,
            borderColor: '#10B981',
            backgroundColor: 'rgba(16,185,129,.05)',
            borderWidth: 2,
            borderDash: [5, 5],
            tension: .25,
            fill: false,
          });
        }

        lineChart = new Chart(ctx, {
          type: 'line',
          data: { labels, datasets },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom', labels: { font: { size: 10 }, padding: 6 } },
              tooltip: {
                callbacks: {
                  label: (ctx) => `${ctx.dataset.label}: Rp ${(ctx.parsed.y / 1e6).toFixed(0)}jt`,
                },
              },
            },
            scales: {
              y: {
                ticks: { callback: (val) => 'Rp ' + (val / 1e6).toFixed(0) + 'jt', font: { size: 10 } },
              },
              x: { ticks: { font: { size: 9 } } },
            },
          },
        });
      }

      // Build prepayment amort for chart overlay
      function buildPrepayAmortYearly(pokok, bungaTahun, tenorTahun, cicilan, prepayAmt, prepayYear) {
        const bungaBulan = bungaTahun / 100 / 12;
        let saldo = pokok;
        const prepayMonth = prepayYear * 12;
        const sisaPerTahun = [];

        for (let t = 1; t <= tenorTahun; t++) {
          for (let m = 1; m <= 12; m++) {
            const monthGlobal = (t - 1) * 12 + m;
            if (saldo <= 0.01) {
              saldo = 0;
              break;
            }
            const bgn = saldo * bungaBulan;
            let pkk = cicilan - bgn;
            if (monthGlobal === prepayMonth) pkk += prepayAmt;
            if (pkk > saldo) { saldo = 0; break; }
            saldo -= pkk;
          }
          sisaPerTahun.push(Math.max(0, saldo));
        }
        return { sisaPerTahun };
      }

      let lastCalc = null;

      function hitung() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        let bunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value) || 1;
        const gaji = HC.parseRp(els.gaji.value);

        if (harga === 0) { HC.toast('Masukkan harga rumah dulu', 'error'); return; }

        // FEATURE 3: Inflation adjustment
        const useInflasi = els.inflasiToggle.checked;
        let bungaOriginal = bunga;
        let skenario = null;
        if (useInflasi) {
          skenario = els.inflasiSkenario.value;
          bunga = HC.adjustInterestRate(bunga, skenario);
        }

        const dpAmt = harga * (dpPct / 100);
        const pokok = harga - dpAmt;
        const bungaBulanan = bunga / 100 / 12;
        const totalBulan = tenor * 12;

        // FEATURE 1: Combo Bunga
        const useCombo = els.comboToggle.checked;
        let comboData = null;
        let cicilan, totalBunga, totalBayar;

        if (useCombo) {
          const bFixed = parseFloat(els.bungaFixed.value) || 5;
          const dFixed = parseInt(els.durasiFixed.value) || 3;
          const bFloating = parseFloat(els.bungaFloating.value) || 10;
          comboData = calcCombo(pokok, bFixed, dFixed, bFloating, tenor);
          cicilan = comboData.cicilanFixed; // Display as primary cicilan
          totalBunga = comboData.totalBunga;
          totalBayar = dpAmt + comboData.totalBayar;

          // Show combo result
          $('comboResult').style.display = '';
          $('cicilanFixedShow').textContent = `${HC.fmt(comboData.cicilanFixed)} (${dFixed} thn, bunga ${bFixed}%)`;
          $('cicilanFloatingShow').textContent = `${HC.fmt(comboData.cicilanFloating)} (sisa ${tenor - dFixed} thn, bunga ${bFloating}%)`;
          $('selisihCicilan').textContent = `+${HC.fmt(comboData.cicilanFloating - comboData.cicilanFixed)} per bulan`;
        } else {
          cicilan = ann(pokok, bungaBulanan, totalBulan);
          totalBunga = cicilan * totalBulan - pokok;
          totalBayar = dpAmt + cicilan * totalBulan;
          $('comboResult').style.display = 'none';
        }

        // Display main results
        $('cicilanBulan').textContent = HC.fmt(cicilan);
        const metaText = useCombo
          ? `Combo: ${parseFloat(els.bungaFixed.value)}% fixed → ${parseFloat(els.bungaFloating.value)}% floating, ${tenor} thn`
          : `${tenor} tahun · Bunga ${bunga.toFixed(2)}%${useInflasi ? ' (inflasi-adjusted)' : ''}`;
        $('metaInfo').textContent = metaText;
        $('totalDP').textContent = HC.fmt(dpAmt);
        $('pokokPinjaman').textContent = HC.fmt(pokok);
        $('totalBunga').textContent = HC.fmt(totalBunga);
        $('totalBayar').textContent = HC.fmt(totalBayar);

        // FEATURE 2: Prepayment
        const usePrepay = els.prepayToggle.checked;
        let prepayResult = null;
        let prepayAmortChart = null;
        if (usePrepay) {
          const pAmt = HC.parseRp(els.prepayAmount.value);
          const pYear = parseInt(els.prepayYear.value);
          if (pAmt > 0 && pAmt < pokok) {
            prepayResult = calcPrepay(pokok, bunga, tenor, cicilan, pAmt, pYear);
            const hematBunga = totalBunga - prepayResult.totalBungaBaru;
            const tenorBaruTahun = prepayResult.tenorBaruTahun;
            const hematBulan = totalBulan - prepayResult.tenorBaruBulan;
            $('prepayResultBox').style.display = '';
            $('tenorBefore').textContent = `${tenor} tahun (${totalBulan} bulan)`;
            $('tenorAfter').textContent = `${tenorBaruTahun.toFixed(1)} tahun (${prepayResult.tenorBaruBulan} bulan)`;
            $('hematWaktu').textContent = `${(hematBulan / 12).toFixed(1)} tahun (${hematBulan} bulan)`;
            $('hematBunga').textContent = HC.fmt(hematBunga);
            prepayAmortChart = buildPrepayAmortYearly(pokok, bunga, tenor, cicilan, pAmt, pYear);
          } else {
            $('prepayResultBox').style.display = 'none';
          }
        } else {
          $('prepayResultBox').style.display = 'none';
        }

        // Kelayakan vs gaji
        const $kb = $('kelayakanBody');
        if (gaji > 0) {
          const ratio = (cicilan / gaji) * 100;
          let html = '';
          if (ratio <= 30) html = `<div class="kelayakan-status ks-good"><i class="ti ti-circle-check"></i> Sangat aman — cicilan ${ratio.toFixed(1)}% dari gaji</div><p class="ks-note">Masih di bawah batas aman 30%. Ada ruang untuk maintenance & tabungan.</p>`;
          else if (ratio <= 40) html = `<div class="kelayakan-status ks-warn"><i class="ti ti-alert-triangle"></i> Cukup berat — cicilan ${ratio.toFixed(1)}% dari gaji</div><p class="ks-note">Sudah melewati zona aman 30%. Pastikan ada dana darurat 6 bulan & sumber penghasilan tambahan.</p>`;
          else html = `<div class="kelayakan-status ks-bad"><i class="ti ti-alert-circle"></i> Terlalu berat — cicilan ${ratio.toFixed(1)}% dari gaji</div><p class="ks-note">Cicilan terlalu besar. Pertimbangkan: tambah DP, perpanjang tenor, atau cari rumah lebih murah.</p>`;
          $kb.innerHTML = html;
        } else {
          $kb.innerHTML = '<p style="font-size:12px;color:var(--text-mute);padding:8px 0">Isi "Gaji Bulanan" untuk cek kelayakan otomatis</p>';
        }

        // FEATURE 4: VISUAL CHARTS
        $('chartSection').style.display = '';
        renderDonut(dpAmt, pokok, totalBunga);
        const amort = buildAmort(pokok, bunga, tenor, cicilan);
        renderLine(amort, prepayAmortChart);

        // FEATURE 5: BANK COMPARISON
        const bankHtml = BANK_DATA.map(b => {
          const c = ann(pokok, b.rate / 100 / 12, totalBulan);
          const total = c * totalBulan + dpAmt;
          const isActive = Math.abs(b.rate - bungaOriginal) < 0.3;
          return `
            <div class="bank-card ${isActive ? 'active' : ''}">
              <div class="bank-info">
                <div class="bank-name">🏦 ${b.name}</div>
                <div class="bank-rate">${b.rate}% · ${b.label}</div>
              </div>
              <div class="bank-result">
                <div class="bank-cicilan">${HC.fmt(c)}</div>
                <div class="bank-total">Total ${HC.fmt(total).replace('Rp ', 'Rp ')}</div>
              </div>
            </div>
          `;
        }).join('');
        $('bankCompareBody').innerHTML = bankHtml;

        // FEATURE 3: BIAYA KPR LENGKAP
        const bphtb = Math.max(0, (harga - 60000000)) * 0.05; // BPHTB 5% setelah NJOPTKP 60jt
        const ajb = harga * 0.01;
        const bbn = harga * 0.02;
        const provisi = pokok * 0.01;
        const notaris = harga > 500000000 ? 5000000 : 3000000;
        const appraisal = harga > 1000000000 ? 2000000 : 800000;
        const admin = 500000;
        const asuransiThn1 = pokok * 0.005; // estimate
        const totalBiaya = bphtb + ajb + bbn + provisi + notaris + appraisal + admin + asuransiThn1;

        $('biayaList').innerHTML = `
          <li><span class="label">BPHTB (5% dari harga - NJOPTKP 60jt)</span><span class="value">${HC.fmt(bphtb)}</span></li>
          <li><span class="label">AJB / Akta Jual Beli (1%)</span><span class="value">${HC.fmt(ajb)}</span></li>
          <li><span class="label">BBN / Balik Nama (2%)</span><span class="value">${HC.fmt(bbn)}</span></li>
          <li><span class="label">Provisi Bank (1% dari pokok)</span><span class="value">${HC.fmt(provisi)}</span></li>
          <li><span class="label">Biaya Notaris</span><span class="value">${HC.fmt(notaris)}</span></li>
          <li><span class="label">Appraisal / Survey Bank</span><span class="value">${HC.fmt(appraisal)}</span></li>
          <li><span class="label">Administrasi Bank</span><span class="value">${HC.fmt(admin)}</span></li>
          <li><span class="label">Asuransi KPR Tahun Pertama (0.5%)</span><span class="value">${HC.fmt(asuransiThn1)}</span></li>
          <li><span class="label">📦 TOTAL BIAYA AWAL (di luar DP)</span><span class="value">${HC.fmt(totalBiaya)}</span></li>
        `;

        // Tenor comparison
        const tenorComp = [5, 10, 15, 20, 25, 30];
        $('tenorCompareBody').innerHTML = tenorComp.map(t => {
          const c = ann(pokok, bungaBulanan, t * 12);
          const tb = c * t * 12 - pokok;
          const tot = c * t * 12 + dpAmt;
          return `<tr class="${t === tenor ? 'active' : ''}"><td>${t} tahun</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(tb)}</td><td class="right">${HC.fmt(tot)}</td></tr>`;
        }).join('');

        // Amortization
        $('amortBody').innerHTML = amort.map(r =>
          `<tr><td>Tahun ${r.tahun}</td><td class="right">${HC.fmt(r.pokok)}</td><td class="right" style="color:var(--red)">${HC.fmt(r.bunga)}</td><td class="right">${HC.fmt(r.sisa)}</td></tr>`
        ).join('');

        // Inflation comparison
        if (useInflasi) {
          els.advInflasi.style.display = '';
          const scenarios = ['rendah', 'normal', 'tinggi', 'krisis'];
          const labels = { rendah: 'Rendah (3.0%)', normal: 'Normal (4.5%)', tinggi: 'Tinggi (6.0%)', krisis: 'Krisis (8.0%)' };
          $('inflasiCompareBody').innerHTML = scenarios.map(s => {
            const b = HC.adjustInterestRate(bungaOriginal, s);
            const c = ann(pokok, b / 100 / 12, totalBulan);
            const tot = c * totalBulan + dpAmt;
            return `<tr class="${s === skenario ? 'active' : ''}"><td>${labels[s]}</td><td class="right">${b.toFixed(2)}%</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(tot)}</td></tr>`;
          }).join('');
        } else {
          els.advInflasi.style.display = 'none';
        }

        lastCalc = {
          harga, dpPct, dpAmt, pokok, bunga, bungaOriginal, tenor, gaji,
          cicilan, totalBunga, totalBayar, useInflasi, skenario,
          useCombo, comboData, usePrepay, prepayResult,
          totalBiaya, bphtb, ajb, bbn, provisi,
          ratio: gaji > 0 ? (cicilan / gaji) * 100 : 0,
        };

        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Berhasil dihitung! 🎉');
      }


      // ===== Skenario A vs B =====
      let scenA = null, scenB = null;
      function scenFmt(v, t) { return t === 'pct' ? v.toFixed(1) + '%' : HC.fmt(v); }
      function buildSnap() { var c = lastCalc; return { label: c.tenor + 'thn @ ' + c.bunga.toFixed(1) + '%', rows: [ {k:'Cicilan/bln', v:c.cicilan, t:'rp'}, {k:'Total Bunga', v:c.totalBunga, t:'rp'}, {k:'Total Bayar', v:c.totalBayar, t:'rp'}, {k:'DTI (% gaji)', v:c.ratio, t:'pct'} ] }; }
      function snapScenario(slot) {
        if (!lastCalc) { HC.toast('Hitung dulu sebelum simpan skenario', 'error'); return; }
        var snap = buildSnap();
        if (slot === 'A') scenA = snap; else scenB = snap;
        HC.toast('Tersimpan sebagai Skenario ' + slot + ' (' + snap.label + ')');
        renderScenario();
      }
      function renderScenario() {
        var box = $('scenResult');
        if (!scenA && !scenB) { box.style.display = 'none'; return; }
        box.style.display = '';
        var ref = scenA || scenB, both = scenA && scenB;
        var html = '<table class="compare-table"><thead><tr><th>Metrik</th>'
          + '<th class="right">A' + (scenA ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenA.label + '</span>' : '') + '</th>'
          + '<th class="right">B' + (scenB ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenB.label + '</span>' : '') + '</th>'
          + (both ? '<th class="right">Selisih</th>' : '') + '</tr></thead><tbody>';
        for (var i = 0; i < ref.rows.length; i++) {
          var k = ref.rows[i].k, t = ref.rows[i].t;
          var av = scenA ? scenFmt(scenA.rows[i].v, t) : '—';
          var bv = scenB ? scenFmt(scenB.rows[i].v, t) : '—';
          var sel = '';
          if (both) { var d = scenB.rows[i].v - scenA.rows[i].v; sel = '<td class="right">' + (Math.abs(d) < 0.005 ? '—' : (d > 0 ? '+' : '\u2212') + scenFmt(Math.abs(d), t)) + '</td>'; }
          html += '<tr' + (i === 0 ? ' class="active"' : '') + '><td>' + k + '</td><td class="right">' + av + '</td><td class="right">' + bv + '</td>' + sel + '</tr>';
        }
        html += '</tbody></table>';
        if (both) {
          var lower = true, d = scenB.rows[0].v - scenA.rows[0].v, pk = scenA.rows[0].k, t0 = scenA.rows[0].t;
          var msg;
          if (Math.abs(d) < 0.005) msg = 'Kedua skenario setara di ' + pk + '.';
          else { var bBetter = lower ? d < 0 : d > 0; msg = 'Skenario ' + (bBetter ? 'B' : 'A') + ' lebih ' + (lower ? 'hemat' : 'unggul') + ' \u2014 ' + pk + ' selisih ' + scenFmt(Math.abs(d), t0) + '.'; }
          html += '<p style="font-size:13px;margin-top:8px;font-weight:600;color:var(--green-dark,#047857)">' + msg + '</p>';
        }
        box.innerHTML = html;
      }
      var bSA = $('btnScenA'); if (bSA) bSA.addEventListener('click', function () { snapScenario('A'); });
      var bSB = $('btnScenB'); if (bSB) bSB.addEventListener('click', function () { snapScenario('B'); });
      var bSR = $('btnScenReset'); if (bSR) bSR.addEventListener('click', function () { scenA = null; scenB = null; renderScenario(); HC.toast('Skenario direset', 'info'); });

      function reset() {
        scenA = null; scenB = null; var _sr=$('scenResult'); if(_sr) _sr.style.display='none';
        els.harga.value = '800.000.000';
        els.dp.value = '20';
        els.bunga.value = '7.5';
        els.tenor.value = '15';
        els.gaji.value = '15.000.000';
        els.inflasiToggle.checked = false;
        els.inflasiBox.classList.remove('active');
        els.comboToggle.checked = false;
        els.comboBox.classList.remove('active');
        els.prepayToggle.checked = false;
        els.prepayBox.classList.remove('active');
        $('placeholder').style.display = '';
        $('results').classList.remove('show');
        if (donutChart) { donutChart.destroy(); donutChart = null; }
        if (lineChart) { lineChart.destroy(); lineChart = null; }
        lastCalc = null;
        HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        let insight = '';
        if (c.gaji > 0) {
          if (c.ratio <= 30) insight = `Cicilan ${c.ratio.toFixed(1)}% dari gaji — AMAN. ${c.usePrepay && c.prepayResult ? `Pelunasan dipercepat hemat ${HC.fmt(c.totalBunga - c.prepayResult.totalBungaBaru)} bunga!` : 'Pertimbangkan pelunasan dipercepat saat dapat bonus.'}`;
          else if (c.ratio <= 40) insight = `Cicilan ${c.ratio.toFixed(1)}% dari gaji — BERAT. Siapkan dana darurat 6 bulan cicilan + waspada combo floating.`;
          else insight = `Cicilan ${c.ratio.toFixed(1)}% dari gaji — BERAT BANGET. Pertimbangkan tambah DP atau cari rumah lebih murah.`;
        } else {
          insight = `Bunga total ${HC.fmtPct(c.totalBunga / c.pokok * 100, 0)} dari pokok. Biaya awal (di luar DP): ${HC.fmt(c.totalBiaya)}.`;
        }

        const inputs = [
          { label: '🏠 Harga Rumah', value: HC.fmt(c.harga) },
          { label: '💰 DP', value: `${c.dpPct}% (${HC.fmt(c.dpAmt)})` },
          { label: '📊 Suku Bunga', value: c.useCombo ? `Combo: ${parseFloat(els.bungaFixed.value)}%→${parseFloat(els.bungaFloating.value)}%` : `${c.bunga.toFixed(2)}%${c.useInflasi ? ' (inflasi)' : ''}` },
          { label: '📅 Tenor', value: `${c.tenor} tahun` },
        ];
        if (c.gaji > 0) inputs.push({ label: '💵 Gaji Bulanan', value: HC.fmt(c.gaji) });
        if (c.usePrepay && c.prepayResult) inputs.push({ label: '💸 Pelunasan Dipercepat', value: `${HC.fmt(HC.parseRp(els.prepayAmount.value))} di thn ${els.prepayYear.value}` });

        const results = [
          { label: 'Cicilan/Bulan', value: HC.fmt(c.cicilan), highlight: true },
          { label: 'Pokok Pinjaman', value: HC.fmt(c.pokok) },
          { label: 'Total Bunga', value: HC.fmt(c.totalBunga) },
          { label: 'Total Bayar', value: HC.fmt(c.totalBayar), highlight: true },
          { label: 'Biaya Awal (BPHTB+AJB+dll)', value: HC.fmt(c.totalBiaya) },
        ];
        if (c.usePrepay && c.prepayResult) {
          results.push({ label: 'Hemat Bunga (Prepay)', value: HC.fmt(c.totalBunga - c.prepayResult.totalBungaBaru), highlight: true });
        }
        if (c.useCombo && c.comboData) {
          results.push({ label: 'Cicilan Floating Period', value: HC.fmt(c.comboData.cicilanFloating) });
        }

        return HC.buildReportCard({
          title: '🏠 Simulasi KPR Premium',
          color: '#2563EB',
          color2: '#1E40AF',
          heroLabel: 'Cicilan Per Bulan',
          heroValue: HC.fmt(c.cicilan),
          heroSubtext: c.useCombo ? `Combo Fixed→Floating · ${c.tenor} tahun` : `${c.tenor} tahun · Bunga ${c.bunga.toFixed(2)}%`,
          inputs, results, insight,
          slug: 'kpr',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        let txt = `🏠 *Simulasi KPR Premium - HitungCerdas*\n\n`;
        txt += `Harga Rumah: ${HC.fmt(c.harga)}\nDP ${c.dpPct}%: ${HC.fmt(c.dpAmt)}\n`;
        txt += c.useCombo ? `Bunga: Combo Fixed→Floating\n` : `Bunga: ${c.bunga.toFixed(2)}%${c.useInflasi ? ' (inflasi)' : ''}\n`;
        txt += `Tenor: ${c.tenor} tahun\n\n`;
        txt += `💰 *Cicilan/Bulan: ${HC.fmt(c.cicilan)}*\n`;
        txt += `📊 Total Bunga: ${HC.fmt(c.totalBunga)}\n`;
        txt += `💵 Total Bayar: ${HC.fmt(c.totalBayar)}\n`;
        txt += `📋 Biaya Awal Lain: ${HC.fmt(c.totalBiaya)}\n`;
        if (c.usePrepay && c.prepayResult) {
          txt += `\n💸 *Pelunasan Dipercepat:*\n`;
          txt += `Hemat Bunga: ${HC.fmt(c.totalBunga - c.prepayResult.totalBungaBaru)}\n`;
          txt += `Hemat Waktu: ${((c.tenor * 12 - c.prepayResult.tenorBaruBulan) / 12).toFixed(1)} tahun\n`;
        }
        txt += `\nHitung sendiri di: https://hitungcerdas.net/kalkulator/kpr`;
        return txt;
      }

      // Event listeners
      function hitungStress() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        const baseBunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value) || 1;
        const gaji = HC.parseRp(els.gaji.value);
        const stressBunga = parseFloat($('stressBunga').value) || 0;
        if (harga === 0) { HC.toast('Hitung KPR dulu', 'error'); return; }
        const pokok = harga - harga * (dpPct / 100);
        const n = tenor * 12;
        const cicBase = ann(pokok, baseBunga / 100 / 12, n);
        const cicStress = ann(pokok, stressBunga / 100 / 12, n);
        const selisih = cicStress - cicBase;
        let dtiHtml = '';
        if (gaji > 0) {
          const dtiBase = cicBase / gaji * 100, dtiStress = cicStress / gaji * 100;
          const col = dtiStress <= 30 ? 'var(--green-dark,#047857)' : (dtiStress <= 40 ? '#B45309' : 'var(--red,#DC2626)');
          dtiHtml = `<div style="margin-top:8px;font-size:13px;font-weight:600;color:${col}"><i class="ti ti-percentage"></i> DTI: ${dtiBase.toFixed(1)}% &rarr; ${dtiStress.toFixed(1)}% dari gaji${dtiStress > 40 ? ' (lewat batas aman!)' : ''}</div>`;
        }
        $('stressResult').style.display = '';
        $('stressResult').innerHTML = `
          <table class="compare-table">
            <thead><tr><th>Skenario</th><th class="right">Bunga</th><th class="right">Cicilan/Bulan</th></tr></thead>
            <tbody>
              <tr><td>Sekarang</td><td class="right">${baseBunga.toFixed(1)}%</td><td class="right">${HC.fmt(cicBase)}</td></tr>
              <tr class="active"><td>Stress (naik)</td><td class="right">${stressBunga.toFixed(1)}%</td><td class="right">${HC.fmt(cicStress)}</td></tr>
            </tbody>
          </table>
          <p style="font-size:12.5px;margin-top:8px;line-height:1.5">⚠️ Kalau bunga naik ke <strong>${stressBunga.toFixed(1)}%</strong>, cicilanmu naik <strong style="color:var(--red,#DC2626)">+${HC.fmt(selisih)}/bulan</strong> (≈ +${HC.fmt(selisih * 12)}/tahun).</p>${dtiHtml}`;
      }

      $('btnHitung').addEventListener('click', hitung);
      // Smart-link: terima ?gaji= dari Gaji Bersih, auto-isi & hitung
      (function(){ try {
        var g = new URLSearchParams(location.search).get('gaji');
        if (g && !isNaN(+g) && +g > 0) {
          els.gaji.value = Number(g).toLocaleString('id-ID');
          hitung();
          HC.toast('Gaji Rp ' + Number(g).toLocaleString('id-ID') + ' diisi dari Gaji Bersih');
        }
      } catch(e){} })();
      $('btnReset').addEventListener('click', reset);
      $('btnStress').addEventListener('click', hitungStress);

      // ===== Sewa vs Beli =====
      function hitungSewaBeli() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        const bunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value) || 1;
        if (harga === 0) { HC.toast('Hitung KPR dulu', 'error'); return; }
        const sewa0 = HC.parseRp($('sbSewa').value);
        const H = Math.max(1, parseInt($('sbTahun').value) || 10);
        const apr = (parseFloat($('sbApresiasi').value) || 0) / 100;
        const naik = (parseFloat($('sbKenaikan').value) || 0) / 100;
        const ret = (parseFloat($('sbReturn').value) || 0) / 100;

        const dpAmt = harga * dpPct / 100;
        const pokok = harga - dpAmt;
        const i = bunga / 100 / 12, n = tenor * 12;
        const cicilan = ann(pokok, i, n);
        const hM = Math.min(H * 12, n);

        // BELI
        const totalCicilanH = cicilan * hM;
        const maintenance = harga * 0.01 * H;
        let sisa;
        if (i === 0) sisa = Math.max(0, pokok - cicilan * hM);
        else sisa = Math.max(0, pokok * Math.pow(1 + i, hM) - cicilan * ((Math.pow(1 + i, hM) - 1) / i));
        if (hM >= n) sisa = 0;
        const nilaiRumah = harga * Math.pow(1 + apr, H);
        const ekuitas = nilaiRumah - sisa;
        const beliCashOut = dpAmt + totalCicilanH + maintenance;
        const beliNet = beliCashOut - ekuitas;

        // SEWA
        let rent = sewa0, totalSewa = 0;
        for (let y = 0; y < H; y++) { totalSewa += rent * 12; rent *= (1 + naik); }
        const dpInvestGain = dpAmt * (Math.pow(1 + ret, H) - 1);
        const sewaNet = totalSewa - dpInvestGain;

        const beliMenang = beliNet <= sewaNet;
        const selisih = Math.abs(beliNet - sewaNet);
        const col = beliMenang ? 'var(--green-dark,#047857)' : '#B45309';

        $('sewaBeliResult').style.display = '';
        $('sewaBeliResult').innerHTML =
          `<table class="compare-table">`
          + `<thead><tr><th>Selama ${H} tahun</th><th class="right">🏠 Beli (KPR)</th><th class="right">🔑 Sewa</th></tr></thead>`
          + `<tbody>`
          + `<tr><td>Uang keluar</td><td class="right">${HC.fmt(beliCashOut)}</td><td class="right">${HC.fmt(totalSewa)}</td></tr>`
          + `<tr><td>Nilai dipegang akhir</td><td class="right" style="color:var(--green-dark)">${HC.fmt(ekuitas)}<br><span style="font-size:10px;color:var(--text-mute)">ekuitas rumah</span></td><td class="right" style="color:var(--green-dark)">${HC.fmt(dpInvestGain)}<br><span style="font-size:10px;color:var(--text-mute)">hasil invest DP</span></td></tr>`
          + `<tr class="active"><td><b>Net biaya</b></td><td class="right"><b>${HC.fmt(beliNet)}</b></td><td class="right"><b>${HC.fmt(sewaNet)}</b></td></tr>`
          + `</tbody></table>`
          + `<p style="font-size:13px;margin-top:8px;font-weight:600;color:${col}">${beliMenang ? '🏠 Beli' : '🔑 Sewa'} lebih hemat ${HC.fmt(selisih)} dalam ${H} tahun (asumsi apresiasi ${(apr*100).toFixed(1)}%/thn, return invest ${(ret*100).toFixed(1)}%/thn).</p>`
          + `<p style="font-size:11px;color:var(--text-mute);margin-top:4px;line-height:1.5">Net negatif = nilai aset yang kamu pegang di akhir melebihi total uang keluar (alias untung). Hasil sangat sensitif pada apresiasi rumah & return investasi: Beli unggul kalau rumah cepat naik & kamu tinggal lama; Sewa unggul kalau horizon pendek atau dana DP bisa diinvestasikan return tinggi.</p>`;
      }

      // ===== KPR Syariah (Murabahah) vs Konvensional =====
      function hitungSyariah() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        const bunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value) || 1;
        if (harga === 0) { HC.toast('Hitung KPR dulu', 'error'); return; }
        const margin = parseFloat($('syrMargin').value) || 0;
        const pokok = harga - harga * dpPct / 100;
        const n = tenor * 12;

        // Konvensional (anuitas / bunga efektif)
        const cicKonv = ann(pokok, bunga / 100 / 12, n);
        const totalKonv = cicKonv * n;

        // Murabahah (margin flat, cicilan tetap)
        const marginTotal = pokok * (margin / 100) * tenor;
        const totalJual = pokok + marginTotal;
        const cicSyr = totalJual / n;
        const totalSyr = totalJual;

        // Setara bunga efektif (IRR bulanan) dari cicilan tetap murabahah
        let lo = 0, hi = 1;
        for (let k = 0; k < 100; k++) { const m = (lo + hi) / 2; if (ann(pokok, m, n) < cicSyr) lo = m; else hi = m; }
        const effSyr = (lo + hi) / 2 * 12 * 100;

        const selisihTotal = totalSyr - totalKonv;
        const syrLebihMahal = selisihTotal > 0;

        $('syariahResult').style.display = '';
        $('syariahResult').innerHTML =
          `<table class="compare-table">`
          + `<thead><tr><th>Pembiayaan ${tenor} thn</th><th class="right">Konvensional</th><th class="right">Syariah (Murabahah)</th></tr></thead>`
          + `<tbody>`
          + `<tr><td>Dasar</td><td class="right">Bunga efektif ${bunga.toFixed(1)}%</td><td class="right">Margin flat ${margin.toFixed(1)}%<br><span style="font-size:10px;color:var(--text-mute)">≈ ${effSyr.toFixed(1)}% efektif</span></td></tr>`
          + `<tr><td>Cicilan/bulan</td><td class="right">${HC.fmt(cicKonv)}<br><span style="font-size:10px;color:var(--text-mute)">bisa floating</span></td><td class="right" style="color:var(--green-dark)">${HC.fmt(cicSyr)}<br><span style="font-size:10px;color:var(--text-mute)">tetap</span></td></tr>`
          + `<tr class="active"><td><b>Total bayar</b></td><td class="right"><b>${HC.fmt(totalKonv)}</b></td><td class="right"><b>${HC.fmt(totalSyr)}</b></td></tr>`
          + `</tbody></table>`
          + `<p style="font-size:12.5px;margin-top:8px;line-height:1.55">${syrLebihMahal
              ? `Dengan margin ${margin.toFixed(1)}% flat, total Murabahah <strong style="color:#B45309">lebih mahal ${HC.fmt(selisihTotal)}</strong> dari konvensional ${bunga.toFixed(1)}% efektif — tapi cicilan <strong>tetap</strong> (bebas risiko bunga naik).`
              : `Dengan margin ${margin.toFixed(1)}% flat, total Murabahah <strong style="color:var(--green-dark)">lebih murah ${HC.fmt(-selisihTotal)}</strong> dari konvensional — plus cicilan tetap. Menarik!`}</p>`;
      }

      var sbS=$('sbSewa'); if(sbS) sbS.addEventListener('input', HC.fmtInput);
      var btnSB=$('btnSewaBeli'); if(btnSB) btnSB.addEventListener('click', hitungSewaBeli);
      var btnSyr=$('btnSyariah'); if(btnSyr) btnSyr.addEventListener('click', hitungSyariah);

      $('exportImg').addEventListener('click', () => {
        const card = buildReport();
        if (!card) { HC.toast('Hitung dulu sebelum export', 'error'); return; }
        HC.exportToImage(card, 'kpr-premium-' + Date.now());
      });

      $('exportWa').addEventListener('click', () => {
        const card = buildReport();
        if (!card) { HC.toast('Hitung dulu sebelum share', 'error'); return; }
        HC.shareWhatsApp(card, summaryText(), 'kpr');
      });

      $('exportPdf').addEventListener('click', () => {
        if (!lastCalc) { HC.toast('Hitung dulu sebelum print', 'error'); return; }
        HC.exportToPDF();
      });

      $('exportCopy').addEventListener('click', () => {
        if (!lastCalc) { HC.toast('Hitung dulu sebelum copy', 'error'); return; }
        HC.copyText(summaryText(), 'Hasil tersalin!');
      });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10; // batas pertanyaan gratis / hari (client-side)
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }

    ready(function(){
      var wrap = $('aicWrap'); if(!wrap) return;
      var trigger = $('aicTrigger'), panel = $('aicPanel');
      var ground = $('aicGround'), msgs = $('aicMsgs'), chips = $('aicChips');
      var input = $('aicText'), send = $('aicSend'), limitEl = $('aicLimit');
      var history = [];

      /* ---------- dark mode mandiri ---------- */
      function isDark(){
        var de = document.documentElement;
        return de.classList.contains('dark')
            || de.getAttribute('data-theme') === 'dark'
            || (function(){ try{ return localStorage.getItem('hc-theme')==='dark'; }catch(e){ return false; } })();
      }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement, {attributes:true, attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });

      /* ---------- baca hasil dari layar ---------- */
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function readData(){
        var cicilanTxt = ($('cicilanBulan')||{}).textContent || 'Rp 0';
        var gajiVal = ($('gajiCheck')||{}).value || '';
        var cic = num(cicilanTxt), gaji = num(gajiVal);
        var ratio = gaji > 0 ? (cic/gaji*100) : null;
        return {
          cicilanTxt: cicilanTxt,
          ratio: ratio,
          gaji: gajiVal,
          harga: ($('hargaRumah')||{}).value || '',
          tenor: ($('tenor')||{}).value || '',
          bunga: ($('bunga')||{}).value || '',
          totalBunga: ($('totalBunga')||{}).textContent || '',
          totalBayar: ($('totalBayar')||{}).textContent || '',
          totalDP: ($('totalDP')||{}).textContent || '',
          pokok: ($('pokokPinjaman')||{}).textContent || ''
        };
      }

      /* ---------- gauge + grounding ---------- */
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
      function renderGround(){
        var d = readData();
        var ctx = '<div class="aic-ctx"><i class="ti ti-home"></i> KPR · Cicilan <b>'+esc(d.cicilanTxt)+'</b>'
                + (d.ratio!=null ? ' · <b>'+d.ratio.toFixed(1)+'% gaji</b>' : '') + '</div>';
        if(d.ratio==null){
          ground.innerHTML = ctx + '<div class="aic-nogauge">Isi "Gaji Bulanan" lalu hitung ulang untuk lihat gauge risiko.</div>';
          return;
        }
        var pos = Math.max(0, Math.min(d.ratio, 50)) / 50 * 100;
        var vClass = d.ratio<=30 ? 'good' : (d.ratio<=40 ? 'warn' : 'bad');
        var vIcon  = d.ratio<=30 ? 'ti-circle-check' : (d.ratio<=40 ? 'ti-alert-triangle' : 'ti-alert-circle');
        var vText  = d.ratio<=30 ? 'Aman — di bawah batas 30%' : (d.ratio<=40 ? 'Agak ketat — tapi bisa diatur' : 'Cukup berat — perlu disiasati');
        ground.innerHTML = ctx
          + '<div class="aic-gauge">'
          +   '<div class="aic-gauge-mark" style="left:'+pos.toFixed(1)+'%"><span>kamu · '+d.ratio.toFixed(0)+'%</span></div>'
          +   '<div class="aic-gauge-bar"><div class="z-green"></div><div class="z-amber"></div><div class="z-red"></div></div>'
          +   '<div class="aic-gauge-lbl"><span class="g">Aman &le;30%</span><span class="a">Hati-hati</span><span class="r">Risiko &ge;40%</span></div>'
          + '</div>'
          + '<div class="aic-verdict '+vClass+'"><i class="ti '+vIcon+'"></i> '+vText+'</div>';
      }

      /* ---------- konteks untuk AI (grounding) ---------- */
      function buildContext(){
        var d = readData();
        var p = [
          'Kalkulator: KPR (Kredit Pemilikan Rumah).',
          d.harga ? ('Harga rumah: Rp ' + d.harga + '.') : '',
          'Cicilan per bulan: ' + d.cicilanTxt + '.',
          d.gaji ? ('Gaji bulanan: Rp ' + d.gaji + '.') : '',
          d.ratio!=null ? ('Rasio cicilan terhadap gaji (DTI): ' + d.ratio.toFixed(1) + '%.') : 'Gaji belum diisi, rasio DTI tidak tersedia.',
          'Tenor: ' + d.tenor + ' tahun. Bunga: ' + d.bunga + '% per tahun.',
          'Total bunga: ' + d.totalBunga + '. Total yang dibayar: ' + d.totalBayar + '.',
          'DP: ' + d.totalDP + '. Pokok pinjaman: ' + d.pokok + '.',
          'Acuan: batas aman DTI 30%; bank umumnya approve hingga 40% (zona berisiko).'
        ];
        return p.filter(Boolean).join('\n');
      }

      /* ---------- pesan UI ---------- */
      function mdInline(t){
        t = t.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        t = t.replace(/__([^_]+)__/g, '<strong>$1</strong>');
        t = t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g, '$1<em>$2</em>');
        t = t.replace(/`([^`]+)`/g, '<code>$1</code>');
        return t;
      }
      function mdToHtml(raw){
        var lines = String(raw).replace(/\r/g,'').split('\n');
        var out = [];
        for(var i=0;i<lines.length;i++){
          var t = lines[i].trim();
          if(t === '') continue;
          if(/^([-*_]\s*){3,}$/.test(t)) continue;       // pemisah --- dibuang
          var h = t.match(/^#{1,6}\s+(.*)$/);            // judul -> baris tebal
          if(h){ out.push('<p class="aic-h">' + mdInline(esc(h[1])) + '</p>'); continue; }
          var b = t.match(/^[-*\u2022]\s+(.*)$/);        // bullet
          if(b){ out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>' + mdInline(esc(b[1])) + '</span></div>'); continue; }
          var n = t.match(/^(\d+)[.)]\s+(.*)$/);         // daftar bernomor
          if(n){ out.push('<div class="aic-li"><span class="aic-mk">' + n[1] + '.</span><span>' + mdInline(esc(n[2])) + '</span></div>'); continue; }
          out.push('<p>' + mdInline(esc(t)) + '</p>');   // paragraf biasa
        }
        return out.join('') || ('<p>' + mdInline(esc(String(raw))) + '</p>');
      }
      function addMsg(role, text){
        var row = document.createElement('div');
        row.className = 'aic-row ' + role;
        if(role==='ai'){
          row.innerHTML = '<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
          row.querySelector('.aic-bub').innerHTML = mdToHtml(text);
        } else {
          row.innerHTML = '<div class="aic-bub"></div>';
          row.querySelector('.aic-bub').textContent = text;
        }
        msgs.appendChild(row);
        msgs.scrollTop = msgs.scrollHeight;
        return row;
      }
      function addTyping(){
        var row = document.createElement('div');
        row.className = 'aic-row ai';
        row.innerHTML = '<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>';
        msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight;
        return row;
      }

      /* ---------- rate limit (client-side) ---------- */
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){
        var left = Math.max(0, LIMIT - getCount());
        limitEl.textContent = 'Sisa ' + left + ' pertanyaan gratis hari ini.';
        var done = left<=0;
        input.disabled = done; send.disabled = done;
        if(done){ input.placeholder = 'Batas harian tercapai, balik lagi besok ya.'; }
      }

      /* ---------- kirim ke /api/coach ---------- */
      var busy = false;
      async function ask(text){
        text = (text||'').trim();
        if(!text || busy) return;
        if(getCount() >= LIMIT){ refreshLimit(); return; }
        busy = true; send.disabled = true;
        addMsg('user', text);
        history.push({ role:'user', content:text });
        input.value = '';
        chips.innerHTML = '';
        var typing = addTyping();
        incCount();
        try{
          var res = await fetch('/api/coach', {
            method:'POST',
            headers:{ 'content-type':'application/json' },
            body: JSON.stringify({ calcContext: buildContext(), messages: history })
          });
          var data = await res.json().catch(function(){ return {error:'Respon tidak valid.'}; });
          typing.parentNode && typing.remove();
          if(data && data.reply){
            addMsg('ai', data.reply);
            history.push({ role:'assistant', content:data.reply });
          } else {
            addMsg('ai', '⚠️ ' + ((data && data.error) || 'Coach lagi sibuk, coba lagi sebentar ya.'));
          }
        }catch(e){
          typing.parentNode && typing.remove();
          addMsg('ai', '⚠️ Gagal terhubung ke Coach. Coba lagi ya.');
        }
        busy = false;
        refreshLimit();
        if(!input.disabled) input.focus();
      }

      /* ---------- preset chips ---------- */
      var PRESETS = [
        'Cicilan ini aman gak buat aku?',
        'Gimana cara ngecilin cicilan?',
        'Apa aja biaya KPR di luar cicilan?'
      ];
      function renderChips(){
        chips.innerHTML = '';
        PRESETS.forEach(function(q){
          var b = document.createElement('button');
          b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); });
          chips.appendChild(b);
        });
      }

      /* ---------- buka / tutup panel ---------- */
      var opened = false;
      trigger.addEventListener('click', function(){
        var willOpen = panel.hasAttribute('hidden');
        if(willOpen){
          panel.removeAttribute('hidden'); wrap.classList.add('open');
          applyTheme(); renderGround(); refreshLimit();
          if(!opened){ renderChips(); opened = true; }
        } else {
          panel.setAttribute('hidden',''); wrap.classList.remove('open');
        }
      });

      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });

      /* refresh gauge tiap kali user klik "Hitung" (kalau panel kebuka) */
      var bh = $('btnHitung');
      if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); }, 60); }); }
    });
  })();
</script>

