<script is:inline>
  (function() {
    function ready(fn) {
      if (window.HC && window.html2canvas && window.Chart) fn();
      else setTimeout(() => ready(fn), 100);
    }

    ready(() => {
      const $ = id => document.getElementById(id);
      const els = {
        harga: $('hargaRumah'), dp: $('dpPersen'), bunga: $('bunga'),
        tenor: $('tenor'), gaji: $('gajiCheck'),
        // Combo
        comboToggle: $('comboToggle'), comboBox: $('comboBox'),
        bungaFixed: $('bungaFixed'), durasiFixed: $('durasiFixed'), bungaFloating: $('bungaFloating'),
        // Prepay
        prepayToggle: $('prepayToggle'), prepayBox: $('prepayBox'),
        prepayAmount: $('prepayAmount'), prepayYear: $('prepayYear'),
        // Inflasi
        inflasiToggle: $('inflasiToggle'), inflasiSkenario: $('inflasiSkenario'),
        inflasiBox: $('inflationBox'), advInflasi: $('advInflasi'),
      };

      // Real-time Rp formatter
      [els.harga, els.gaji, els.prepayAmount].forEach(el => el.addEventListener('input', HC.fmtInput));

      // DP quick buttons
      document.querySelectorAll('.quick-btns button').forEach(btn => {
        btn.addEventListener('click', () => { els.dp.value = btn.dataset.dp; });
      });

      // Toggle handlers
      els.comboToggle.addEventListener('change', () => els.comboBox.classList.toggle('active', els.comboToggle.checked));
      els.prepayToggle.addEventListener('change', () => els.prepayBox.classList.toggle('active', els.prepayToggle.checked));
      els.inflasiToggle.addEventListener('change', () => els.inflasiBox.classList.toggle('active', els.inflasiToggle.checked));

      // Adv section toggle
      document.querySelectorAll('.adv-toggle').forEach(toggle => {
        toggle.addEventListener('click', () => toggle.parentElement.classList.toggle('open'));
      });

      // Anuitas formula
      function ann(p, i, n) {
        if (i === 0) return p / n;
        const r = Math.pow(1 + i, n);
        return p * (i * r) / (r - 1);
      }

      // Build amortization
      function buildAmort(pokok, bungaTahun, tahunTotal, cicilan) {
        const bunga = bungaTahun / 100 / 12;
        let saldo = pokok;
        const rows = [];
        for (let t = 1; t <= tahunTotal; t++) {
          let pokokT = 0, bungaT = 0;
          for (let m = 1; m <= 12; m++) {
            const bgn = saldo * bunga;
            const pkk = cicilan - bgn;
            pokokT += pkk;
            bungaT += bgn;
            saldo -= pkk;
          }
          rows.push({ tahun: t, pokok: pokokT, bunga: bungaT, sisa: Math.max(0, saldo) });
        }
        return rows;
      }

      // Calculate combo bunga (fixed + floating)
      function calcCombo(pokok, bungaFixed, durasiFixedTahun, bungaFloating, tenorTahun) {
        const totalBulan = tenorTahun * 12;
        const bulanFixed = durasiFixedTahun * 12;
        const bulanFloating = totalBulan - bulanFixed;

        // Cicilan fixed (asumsi: cicilan dihitung ulang setelah periode fixed)
        // Tahap 1: Hitung cicilan asumsi semua tenor pakai fixed
        const cicFixed = ann(pokok, bungaFixed / 100 / 12, totalBulan);
        // Hitung sisa pokok setelah periode fixed
        let saldoAfterFixed = pokok;
        for (let m = 0; m < bulanFixed; m++) {
          const bgn = saldoAfterFixed * (bungaFixed / 100 / 12);
          saldoAfterFixed -= (cicFixed - bgn);
        }
        // Tahap 2: Hitung cicilan baru dengan bunga floating untuk sisa tenor
        const cicFloating = ann(saldoAfterFixed, bungaFloating / 100 / 12, bulanFloating);

        // Total bayar
        const totalFixed = cicFixed * bulanFixed;
        const totalFloating = cicFloating * bulanFloating;
        const totalBayar = totalFixed + totalFloating;
        const totalBunga = totalBayar - pokok;

        return {
          cicilanFixed: cicFixed,
          cicilanFloating: cicFloating,
          totalBunga,
          totalBayar,
          saldoAfterFixed,
          bulanFixed,
          bulanFloating,
        };
      }

      // Calculate prepayment impact
      function calcPrepay(pokok, bungaTahun, tenorTahun, cicilan, prepayAmt, prepayYear) {
        const bungaBulan = bungaTahun / 100 / 12;
        let saldo = pokok;
        const prepayMonth = prepayYear * 12;
        let actualBulan = 0;
        let totalBungaBaru = 0;

        // Loop sampai saldo habis
        for (let m = 1; m <= 360; m++) { // max 30 tahun
          if (saldo <= 0.01) break;

          const bgn = saldo * bungaBulan;
          let pkk = cicilan - bgn;

          // Apply prepayment at specified month
          if (m === prepayMonth) {
            pkk += prepayAmt; // tambah ke pokok yang dibayar
          }

          // If overpay, cap at remaining balance
          if (pkk > saldo) {
            totalBungaBaru += bgn;
            saldo = 0;
            actualBulan = m;
            break;
          }

          totalBungaBaru += bgn;
          saldo -= pkk;
          actualBulan = m;
        }

        return {
          tenorBaruBulan: actualBulan,
          tenorBaruTahun: actualBulan / 12,
          totalBungaBaru,
        };
      }

      // 6 Bank Indonesia data (June 2026 indicative)
      const BANK_DATA = [
        { name: 'BCA', rate: 5.25, label: 'Fixed 3 tahun pertama' },
        { name: 'Mandiri', rate: 5.50, label: 'Fixed 5 tahun pertama' },
        { name: 'BNI', rate: 5.99, label: 'Fixed 1 tahun pertama' },
        { name: 'BRI', rate: 6.25, label: 'Fixed 3 tahun pertama' },
        { name: 'CIMB Niaga', rate: 5.49, label: 'Fixed 2 tahun pertama' },
        { name: 'BTN (Subsidi FLPP)', rate: 5.00, label: 'Flat 20 tahun (rumah subsidi max Rp 168jt)' },
      ];

      // Chart instances
      let donutChart = null;
      let lineChart = null;

      function renderDonut(dp, pokok, bunga) {
        const ctx = $('donutChart').getContext('2d');
        if (donutChart) donutChart.destroy();
        donutChart = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: ['DP', 'Pokok Pinjaman', 'Total Bunga'],
            datasets: [{
              data: [dp, pokok, bunga],
