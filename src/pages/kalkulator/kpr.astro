---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('kpr')!;
const related = getRelatedCalculators('kpr', 3);

const faqs = [
  { question: 'Bagaimana rumus menghitung cicilan KPR yang benar?', answer: 'Cicilan KPR menggunakan rumus <strong>anuitas</strong>: M = P × (i × (1+i)<sup>n</sup>) / ((1+i)<sup>n</sup> - 1). Cicilan bulanan tetap sama tiap bulan, tapi komposisi bunga vs pokok berubah — di awal lebih banyak bunga, di akhir lebih banyak pokok.' },
  { question: 'Berapa DP minimum KPR di Indonesia?', answer: 'Sesuai aturan BI: <strong>rumah pertama DP min 10%</strong> (LTV maks 90%), <strong>rumah kedua 20%</strong>, <strong>rumah ketiga+ 30%</strong>. Bank biasanya minta lebih tinggi. Idealnya siapkan DP <strong>30%</strong> untuk cicilan ringan.' },
  { question: 'Tenor KPR berapa tahun yang paling ideal?', answer: '<strong>5-10 thn</strong>: cicilan besar, total bunga kecil. <strong>15-20 thn</strong>: paling populer, balance bagus. <strong>25-30 thn</strong>: cicilan kecil tapi total bunga 2-3× pokok. Tips: pilih tenor terpanjang yang kamu mampu, lalu lunasi dipercepat saat dapat bonus.' },
  { question: 'Apa bedanya bunga fixed dan floating?', answer: '<strong>Fixed</strong>: bunga tetap selama periode tertentu (1-5 thn pertama). Predictable. <strong>Floating</strong>: bunga mengikuti BI Rate, bisa naik/turun setiap 3-6 bulan. Banyak bank menawarkan kombinasi: fixed dulu, lalu floating. WASPADA bunga "promo" 3% fixed 1 tahun!' },
  { question: 'Mengapa inflasi mempengaruhi bunga KPR?', answer: 'Bunga KPR dipengaruhi <strong>BI Rate</strong>, yang naik saat inflasi tinggi untuk menjaga daya beli Rupiah (Fisher Equation). Saat inflasi tinggi (>5%), BI Rate naik, bank juga naikkan bunga KPR. Mode Inflasi kami simulasikan dampak skenario inflasi terhadap cicilan untuk perencanaan jangka panjang.' },
  { question: 'Berapa cicilan KPR yang aman dari gaji?', answer: 'Aturan emas: <strong>cicilan KPR maksimal 30% dari gaji bulanan</strong> (Debt-to-Income Ratio max 30%). Bank approve sampai 40%, tapi itu zona berisiko. Sisakan margin untuk pajak (PBB), maintenance, asuransi, dan dana darurat 6 bulan cicilan.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": calc.shortTitle,
  "description": calc.metaDescription,
  "applicationCategory": "FinanceApplication",
  "url": `https://hitungcerdas.net/kalkulator/${calc.slug}`,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "IDR" },
};
---

<Layout
  title={calc.title}
  description={calc.metaDescription}
  keywords={calc.keywords}
  canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}
  jsonLd={jsonLd}
>
  <section class="calc-hero" style="--cat-color:#2563EB;--cat-color2:#1E40AF">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#DBEAFE;color:#1E40AF">
            <i class="ti ti-home" aria-hidden="true"></i>
            {calc.categoryLabel}
          </div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">
            {calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}
          </ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/>
            <circle cx="100" cy="100" r="65" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.15)" stroke-width="1"/>
            <g transform="translate(60 70)">
              <path d="M0 40L40 5L80 40" fill="#FBBF24" stroke="#FFF" stroke-width="2" stroke-linejoin="round"/>
              <rect x="8" y="40" width="64" height="42" fill="#FFF" stroke="#FBBF24" stroke-width="2"/>
              <rect x="30" y="55" width="20" height="27" fill="#1E4475"/>
              <rect x="15" y="48" width="10" height="10" fill="#DBEAFE" stroke="#1E4475" stroke-width="1.5"/>
              <rect x="55" y="48" width="10" height="10" fill="#DBEAFE" stroke="#1E4475" stroke-width="1.5"/>
              <rect x="50" y="12" width="6" height="14" fill="#DC2626"/>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic"><i class="ti ti-home-dollar"></i></div>
          <div>
            <h2 class="calc-card-title">Kalkulator KPR Anuitas</h2>
            <p class="calc-card-sub">Isi data → klik "Hitung Sekarang" → export hasil</p>
          </div>
        </div>

        <div class="calc-grid">
          {/* ─── INPUT FORM ─── */}
          <div class="calc-input">
            <div class="field">
              <label for="hargaRumah">Harga Rumah <span class="hint">(Rupiah)</span></label>
              <div class="input-wrap">
                <span class="input-prefix">Rp</span>
                <input type="text" id="hargaRumah" class="has-prefix" placeholder="800.000.000" value="800.000.000" inputmode="numeric" />
              </div>
            </div>

            <div class="field">
              <label for="dpPersen">DP (Down Payment) <span class="hint">(%)</span></label>
              <div class="input-wrap">
                <input type="number" id="dpPersen" class="has-suffix" placeholder="20" value="20" step="1" min="0" max="100" />
                <span class="input-suffix">%</span>
              </div>
              <div class="quick-btns">
                <button type="button" data-dp="10">10%</button>
                <button type="button" data-dp="20">20%</button>
                <button type="button" data-dp="30">30%</button>
                <button type="button" data-dp="40">40%</button>
                <button type="button" data-dp="50">50%</button>
              </div>
            </div>

            <div class="field">
              <label for="bunga">Suku Bunga <span class="hint">(per tahun)</span></label>
              <div class="input-wrap">
                <input type="number" id="bunga" class="has-suffix" placeholder="7.5" value="7.5" step="0.1" min="0" />
                <span class="input-suffix">%</span>
              </div>
              <p class="field-hint">Bunga KPR bank Indonesia: 5-12% per tahun</p>
            </div>

            <div class="field">
              <label for="tenor">Tenor (Lama Cicilan)</label>
              <select id="tenor">
                <option value="5">5 tahun</option>
                <option value="10">10 tahun</option>
                <option value="15" selected>15 tahun</option>
                <option value="20">20 tahun</option>
                <option value="25">25 tahun</option>
                <option value="30">30 tahun</option>
              </select>
            </div>

            <div class="field">
              <label for="gajiCheck">Gaji Bulanan <span class="hint">(untuk cek kelayakan)</span></label>
              <div class="input-wrap">
                <span class="input-prefix">Rp</span>
                <input type="text" id="gajiCheck" class="has-prefix" placeholder="15.000.000" value="15.000.000" inputmode="numeric" />
              </div>
            </div>

            {/* ─── INFLATION TOGGLE ─── */}
            <div class="inflation-box" id="inflationBox">
              <label class="inflation-toggle">
                <input type="checkbox" id="inflasiToggle" />
                <span>🔥 Aktifkan Mode Skenario Inflasi</span>
              </label>
              <div class="inflation-options">
                <label>Skenario Inflasi:</label>
                <select id="inflasiSkenario">
                  <option value="rendah">📉 Rendah (2.5%) — Optimis</option>
                  <option value="normal" selected>📊 Normal (3.5%) — Rata-rata historis</option>
                  <option value="tinggi">📈 Tinggi (5.0%) — Hati-hati</option>
                  <option value="krisis">⚠️ Krisis (7.5%) — Skenario terburuk</option>
                </select>
                <p class="inflation-note">
                  <strong>Cara kerja:</strong> Saat inflasi naik, BI Rate naik → bunga KPR naik. Mode ini auto-adjust suku bunga sesuai skenario inflasi (Fisher Equation).
                </p>
              </div>
            </div>

            {/* ─── ACTION BUTTONS ─── */}
            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung">
                <i class="ti ti-calculator"></i> Hitung Sekarang
              </button>
              <button type="button" class="btn-reset" id="btnReset">
                <i class="ti ti-refresh"></i> Reset
              </button>
            </div>
          </div>

          {/* ─── OUTPUT PANEL ─── */}
          <div class="calc-output">
            {/* Placeholder before calculation */}
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-calculator result-placeholder-icon"></i>
              <div class="result-placeholder-title">Hasil akan muncul di sini</div>
              <div class="result-placeholder-desc">
                Isi data di sebelah kiri, lalu klik tombol <strong>"Hitung Sekarang"</strong> untuk simulasi cicilan KPR.
              </div>
            </div>

            {/* Results wrapper (hidden until calc) */}
            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Cicilan Per Bulan</div>
                <div class="result-value" id="cicilanBulan">Rp 0</div>
                <div class="result-meta">
                  <span><i class="ti ti-info-circle"></i> <span id="metaInfo">Anuitas tetap</span></span>
                </div>
              </div>

              <div class="result-grid">
                <div class="result-item">
                  <div class="result-item-label">DP Dibayar</div>
                  <div class="result-item-value" id="totalDP">Rp 0</div>
                </div>
                <div class="result-item">
                  <div class="result-item-label">Pokok Pinjaman</div>
                  <div class="result-item-value" id="pokokPinjaman">Rp 0</div>
                </div>
                <div class="result-item">
                  <div class="result-item-label">Total Bunga</div>
                  <div class="result-item-value result-warn" id="totalBunga">Rp 0</div>
                </div>
                <div class="result-item">
                  <div class="result-item-label">Total Bayar</div>
                  <div class="result-item-value result-strong" id="totalBayar">Rp 0</div>
                </div>
              </div>

              <div class="kelayakan-box" id="kelayakanBox">
                <div class="kelayakan-hdr">
                  <i class="ti ti-shield-check"></i>
                  <span>Cek Kelayakan vs Gaji</span>
                </div>
                <div id="kelayakanBody"></div>
              </div>

              {/* Advanced Section */}
              <div class="adv-section" id="advTenor">
                <div class="adv-toggle">
                  <span><i class="ti ti-chart-bar"></i>&nbsp; Bandingkan Semua Tenor</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead>
                      <tr><th>Tenor</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bunga</th><th class="right">Total Bayar</th></tr>
                    </thead>
                    <tbody id="tenorCompareBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section" id="advAmort">
                <div class="adv-toggle">
                  <span><i class="ti ti-table"></i>&nbsp; Tabel Amortisasi Per Tahun</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead>
                      <tr><th>Tahun</th><th class="right">Pokok</th><th class="right">Bunga</th><th class="right">Sisa Pinjaman</th></tr>
                    </thead>
                    <tbody id="amortBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section" id="advInflasi" style="display:none">
                <div class="adv-toggle">
                  <span><i class="ti ti-trending-up"></i>&nbsp; Dampak Inflasi terhadap Bunga & Cicilan</span>
                  <i class="ti ti-chevron-down chev"></i>
                </div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead>
                      <tr><th>Skenario</th><th class="right">Bunga</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bayar</th></tr>
                    </thead>
                    <tbody id="inflasiCompareBody"></tbody>
                  </table>
                </div>
              </div>

              {/* Export Row */}
              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg">
                  <i class="ti ti-photo-down"></i>
                  <span>Save Image</span>
                </button>
                <button type="button" class="export-btn wa" id="exportWa">
                  <i class="ti ti-brand-whatsapp"></i>
                  <span>Share WA</span>
                </button>
                <button type="button" class="export-btn pdf" id="exportPdf">
                  <i class="ti ti-printer"></i>
                  <span>Print/PDF</span>
                </button>
                <button type="button" class="export-btn copy" id="exportCopy">
                  <i class="ti ti-copy"></i>
                  <span>Copy Teks</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Apa Itu KPR dan Cara Kerjanya?</h2>
      <p>
        <strong>KPR (Kredit Pemilikan Rumah)</strong> adalah fasilitas pinjaman dari bank untuk membeli rumah, dengan jaminan rumah itu sendiri. Kamu bayar <strong>Down Payment (DP)</strong> 10-30% di awal, sisanya menjadi pokok pinjaman yang dicicil 5-30 tahun.
      </p>

      <h3>Rumus Cicilan KPR (Anuitas)</h3>
      <div class="formula-box">
        <p class="formula"><strong>M = P × (i × (1+i)<sup>n</sup>) / ((1+i)<sup>n</sup> - 1)</strong></p>
        <ul>
          <li><strong>M</strong> = Cicilan per bulan</li>
          <li><strong>P</strong> = Pokok pinjaman (harga - DP)</li>
          <li><strong>i</strong> = Bunga bulanan (tahunan ÷ 12 ÷ 100)</li>
          <li><strong>n</strong> = Total bulan (tenor × 12)</li>
        </ul>
      </div>

      <h3>Tips Pintar Sebelum Ambil KPR</h3>
      <ol class="tips-list">
        <li><strong>DTI Maksimum 30%</strong> — Cicilan maksimal 30% gaji. Bank approve sampai 40% tapi berisiko.</li>
        <li><strong>Bandingkan 3+ Bank</strong> — Selisih bunga 1% bisa hemat puluhan juta untuk tenor 20 tahun.</li>
        <li><strong>Waspada Bunga Promo</strong> — "Bunga 3% fixed 1 tahun" lalu floating jadi 10-12%. Hitung skenario terburuk.</li>
        <li><strong>DP Minimal 20-30%</strong> — Semakin besar DP, semakin kecil bunga total.</li>
        <li><strong>Pertimbangkan Mode Inflasi</strong> — Inflasi tinggi = BI Rate naik = bunga floating naik. Siapkan dana extra.</li>
        <li><strong>Pelunasan Dipercepat</strong> — Saat dapat bonus, lunasi sebagian untuk hemat bunga.</li>
      </ol>

      <div class="cta-box">
        <h3>Coba Kalkulator KPR Sekarang</h3>
        <p>Geser ke atas, isi data rumah impianmu, dan klik "Hitung Sekarang" untuk simulasi lengkap.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <FAQ title="Pertanyaan Seputar KPR" items={faqs} />

  <section class="section">
    <div class="wrap">
      <div class="section-hdr">
        <div class="section-eyebrow">Kalkulator Lainnya</div>
        <h2 class="section-title">Hitung Juga yang Lain</h2>
      </div>
      <div class="related-grid">
        {related.map(c => <CalculatorCard calc={c} />)}
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function() {
    // Wait for HC utility to load
    function ready(fn) {
      if (window.HC && window.html2canvas) fn();
      else setTimeout(() => ready(fn), 100);
    }

    ready(() => {
      const $ = id => document.getElementById(id);
      const els = {
        harga: $('hargaRumah'), dp: $('dpPersen'), bunga: $('bunga'),
        tenor: $('tenor'), gaji: $('gajiCheck'),
        inflasiToggle: $('inflasiToggle'), inflasiSkenario: $('inflasiSkenario'),
        inflasiBox: $('inflationBox'), advInflasi: $('advInflasi'),
      };

      // Format Rupiah inputs in real-time (just formatting, not calculating)
      [els.harga, els.gaji].forEach(el => el.addEventListener('input', HC.fmtInput));

      // DP quick buttons
      document.querySelectorAll('.quick-btns button').forEach(btn => {
        btn.addEventListener('click', () => { els.dp.value = btn.dataset.dp; });
      });

      // Inflation toggle
      els.inflasiToggle.addEventListener('change', () => {
        els.inflasiBox.classList.toggle('active', els.inflasiToggle.checked);
      });

      // Advanced section toggle (delegated)
      document.querySelectorAll('.adv-toggle').forEach(toggle => {
        toggle.addEventListener('click', () => {
          toggle.parentElement.classList.toggle('open');
        });
      });

      // Anuitas formula
      function ann(p, i, n) {
        if (i === 0) return p / n;
        const r = Math.pow(1 + i, n);
        return p * (i * r) / (r - 1);
      }

      // Build amortization data
      function buildAmort(pokok, bungaTahun, tahunTotal, cicilan) {
        const bunga = bungaTahun / 100 / 12;
        let saldo = pokok;
        const rows = [];
        for (let t = 1; t <= tahunTotal; t++) {
          let pokokTahun = 0, bungaTahun = 0;
          for (let m = 1; m <= 12; m++) {
            const bgn = saldo * bunga;
            const pkk = cicilan - bgn;
            pokokTahun += pkk;
            bungaTahun += bgn;
            saldo -= pkk;
          }
          rows.push({ tahun: t, pokok: pokokTahun, bunga: bungaTahun, sisa: Math.max(0, saldo) });
        }
        return rows;
      }

      let lastCalc = null; // Store last calc result for export

      // MAIN CALCULATION FUNCTION
      function hitung() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        let bunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value) || 1;
        const gaji = HC.parseRp(els.gaji.value);

        if (harga === 0) { HC.toast('Masukkan harga rumah dulu', 'error'); return; }

        // Apply inflation adjustment
        const useInflasi = els.inflasiToggle.checked;
        let bungaOriginal = bunga;
        let skenario = null;
        if (useInflasi) {
          skenario = els.inflasiSkenario.value;
          bunga = HC.adjustInterestRate(bunga, skenario);
        }

        const dpAmt = harga * (dpPct / 100);
        const pokok = harga - dpAmt;
        const bungaBulanan = bunga / 100 / 12;
        const totalBulan = tenor * 12;
        const cicilan = ann(pokok, bungaBulanan, totalBulan);
        const totalBunga = cicilan * totalBulan - pokok;
        const totalBayar = dpAmt + cicilan * totalBulan;

        // Display
        $('cicilanBulan').textContent = HC.fmt(cicilan);
        $('metaInfo').textContent = `${tenor} tahun · Bunga ${bunga.toFixed(2)}%${useInflasi ? ' (inflasi-adjusted)' : ''}`;
        $('totalDP').textContent = HC.fmt(dpAmt);
        $('pokokPinjaman').textContent = HC.fmt(pokok);
        $('totalBunga').textContent = HC.fmt(totalBunga);
        $('totalBayar').textContent = HC.fmt(totalBayar);

        // Kelayakan check
        const $kb = $('kelayakanBody');
        if (gaji > 0) {
          const ratio = (cicilan / gaji) * 100;
          let html = '';
          if (ratio <= 30) html = `<div class="kelayakan-status ks-good"><i class="ti ti-circle-check"></i> Sangat aman — cicilan ${ratio.toFixed(1)}% dari gaji</div><p class="ks-note">Masih di bawah batas aman 30%. Ada ruang untuk maintenance & tabungan.</p>`;
          else if (ratio <= 40) html = `<div class="kelayakan-status ks-warn"><i class="ti ti-alert-triangle"></i> Cukup berat — cicilan ${ratio.toFixed(1)}% dari gaji</div><p class="ks-note">Sudah melewati zona aman 30%. Pastikan ada dana darurat 6 bulan & sumber penghasilan tambahan.</p>`;
          else html = `<div class="kelayakan-status ks-bad"><i class="ti ti-alert-circle"></i> Terlalu berat — cicilan ${ratio.toFixed(1)}% dari gaji</div><p class="ks-note">Cicilan terlalu besar. Pertimbangkan: tambah DP, perpanjang tenor, atau cari rumah lebih murah.</p>`;
          $kb.innerHTML = html;
        } else {
          $kb.innerHTML = '<p style="font-size:12px;color:var(--text-mute);padding:8px 0">Isi "Gaji Bulanan" untuk cek kelayakan otomatis</p>';
        }

        // Tenor comparison
        const tenorComp = [5, 10, 15, 20, 25, 30];
        $('tenorCompareBody').innerHTML = tenorComp.map(t => {
          const c = ann(pokok, bungaBulanan, t * 12);
          const tb = c * t * 12 - pokok;
          const tot = c * t * 12 + dpAmt;
          return `<tr class="${t === tenor ? 'active' : ''}"><td>${t} tahun</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(tb)}</td><td class="right">${HC.fmt(tot)}</td></tr>`;
        }).join('');

        // Amortization
        const amort = buildAmort(pokok, bunga, tenor, cicilan);
        $('amortBody').innerHTML = amort.map(r =>
          `<tr><td>Tahun ${r.tahun}</td><td class="right">${HC.fmt(r.pokok)}</td><td class="right" style="color:var(--red)">${HC.fmt(r.bunga)}</td><td class="right">${HC.fmt(r.sisa)}</td></tr>`
        ).join('');

        // Inflation comparison
        if (useInflasi) {
          els.advInflasi.style.display = '';
          const scenarios = ['rendah', 'normal', 'tinggi', 'krisis'];
          const labels = { rendah: 'Rendah (2.5%)', normal: 'Normal (3.5%)', tinggi: 'Tinggi (5.0%)', krisis: 'Krisis (7.5%)' };
          $('inflasiCompareBody').innerHTML = scenarios.map(s => {
            const b = HC.adjustInterestRate(bungaOriginal, s);
            const c = ann(pokok, b / 100 / 12, totalBulan);
            const tot = c * totalBulan + dpAmt;
            return `<tr class="${s === skenario ? 'active' : ''}"><td>${labels[s]}</td><td class="right">${b.toFixed(2)}%</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(tot)}</td></tr>`;
          }).join('');
        } else {
          els.advInflasi.style.display = 'none';
        }

        // Save for export
        lastCalc = {
          harga, dpPct, dpAmt, pokok, bunga, bungaOriginal, tenor, gaji,
          cicilan, totalBunga, totalBayar, useInflasi, skenario,
          ratio: gaji > 0 ? (cicilan / gaji) * 100 : 0,
        };

        // Show results
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        HC.toast('Berhasil dihitung!');
      }

      // Reset form
      function reset() {
        els.harga.value = '800.000.000';
        els.dp.value = '20';
        els.bunga.value = '7.5';
        els.tenor.value = '15';
        els.gaji.value = '15.000.000';
        els.inflasiToggle.checked = false;
        els.inflasiBox.classList.remove('active');
        $('placeholder').style.display = '';
        $('results').classList.remove('show');
        lastCalc = null;
        HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        let insight = '';
        if (c.gaji > 0) {
          if (c.ratio <= 30) insight = `Cicilan ${c.ratio.toFixed(1)}% dari gaji — SANGAT AMAN. Masih ada ruang untuk maintenance & dana darurat.`;
          else if (c.ratio <= 40) insight = `Cicilan ${c.ratio.toFixed(1)}% dari gaji — CUKUP BERAT. Siapkan dana darurat 6 bulan cicilan.`;
          else insight = `Cicilan ${c.ratio.toFixed(1)}% dari gaji — TERLALU BERAT. Pertimbangkan tambah DP atau perpanjang tenor.`;
        } else {
          insight = `Bunga total ${HC.fmtPct(c.totalBunga / c.pokok * 100, 0)} dari pokok pinjaman. Tenor ${c.tenor} tahun.`;
        }

        const inputs = [
          { label: '🏠 Harga Rumah', value: HC.fmt(c.harga) },
          { label: '💰 DP', value: `${c.dpPct}% (${HC.fmt(c.dpAmt)})` },
          { label: '📊 Suku Bunga', value: `${c.bunga.toFixed(2)}%${c.useInflasi ? ' (inflasi-adjusted)' : ''}` },
          { label: '📅 Tenor', value: `${c.tenor} tahun (${c.tenor * 12} bulan)` },
        ];
        if (c.gaji > 0) inputs.push({ label: '💵 Gaji Bulanan', value: HC.fmt(c.gaji) });
        if (c.useInflasi) inputs.push({ label: '🔥 Skenario Inflasi', value: c.skenario.charAt(0).toUpperCase() + c.skenario.slice(1) });

        const results = [
          { label: 'Cicilan/Bulan', value: HC.fmt(c.cicilan), highlight: true },
          { label: 'Pokok Pinjaman', value: HC.fmt(c.pokok) },
          { label: 'Total Bunga', value: HC.fmt(c.totalBunga) },
          { label: 'Total Bayar', value: HC.fmt(c.totalBayar), highlight: true },
        ];

        return HC.buildReportCard({
          title: '🏠 Simulasi KPR Anuitas',
          color: '#2563EB',
          color2: '#1E40AF',
          heroLabel: 'Cicilan Per Bulan',
          heroValue: HC.fmt(c.cicilan),
          heroSubtext: `${c.tenor} tahun · Bunga ${c.bunga.toFixed(2)}%`,
          inputs, results, insight,
          slug: 'kpr',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🏠 *Simulasi KPR - HitungCerdas*\n\n` +
               `Harga Rumah: ${HC.fmt(c.harga)}\n` +
               `DP ${c.dpPct}%: ${HC.fmt(c.dpAmt)}\n` +
               `Bunga: ${c.bunga.toFixed(2)}%${c.useInflasi ? ' (inflasi-adjusted)' : ''}\n` +
               `Tenor: ${c.tenor} tahun\n\n` +
               `💰 *Cicilan/Bulan: ${HC.fmt(c.cicilan)}*\n` +
               `📊 Total Bunga: ${HC.fmt(c.totalBunga)}\n` +
               `💵 Total Bayar: ${HC.fmt(c.totalBayar)}\n\n` +
               `Hitung sendiri di: https://hitungcerdas.net/kalkulator/kpr`;
      }

      // Event listeners
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);

      $('exportImg').addEventListener('click', () => {
        const card = buildReport();
        if (!card) { HC.toast('Hitung dulu sebelum export', 'error'); return; }
        HC.exportToImage(card, 'kpr-' + Date.now());
      });

      $('exportWa').addEventListener('click', () => {
        const card = buildReport();
        if (!card) { HC.toast('Hitung dulu sebelum share', 'error'); return; }
        HC.shareWhatsApp(card, summaryText(), 'kpr');
      });

      $('exportPdf').addEventListener('click', () => {
        if (!lastCalc) { HC.toast('Hitung dulu sebelum print', 'error'); return; }
        HC.exportToPDF();
      });

      $('exportCopy').addEventListener('click', () => {
        if (!lastCalc) { HC.toast('Hitung dulu sebelum copy', 'error'); return; }
        HC.copyText(summaryText(), 'Hasil tersalin!');
      });
    });
  })();
</script>
