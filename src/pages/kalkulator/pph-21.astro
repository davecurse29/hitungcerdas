<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { gaji: $('gaji'), tunj: $('tunjangan'), bonus: $('bonus'), ptkp: $('ptkp'), pphMethod: $('pphMethod'), bpjs: $('bpjs'), jenis: $('jenis') };

      [els.gaji, els.tunj, els.bonus, els.bpjs].forEach(el => el.addEventListener('input', HC.fmtInput));

      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      const BRACKETS = [
        { max: 60000000, rate: 0.05, label: 'Lapisan 1 (0-60jt)' },
        { max: 250000000, rate: 0.15, label: 'Lapisan 2 (60-250jt)' },
        { max: 500000000, rate: 0.25, label: 'Lapisan 3 (250-500jt)' },
        { max: 5000000000, rate: 0.30, label: 'Lapisan 4 (500jt-5M)' },
        { max: Infinity, rate: 0.35, label: 'Lapisan 5 (>5M)' },
      ];

      function calcPPh(pkp) {
        if (pkp <= 0) return { total: 0, breakdown: [] };
        let remaining = pkp, total = 0, prev = 0;
        const breakdown = [];
        for (const b of BRACKETS) {
          if (remaining <= 0) break;
          const slice = Math.min(remaining, b.max - prev);
          const tax = slice * b.rate;
          if (slice > 0) breakdown.push({ label: b.label, slice, rate: b.rate * 100, tax });
          total += tax;
          remaining -= slice;
          prev = b.max;
        }
        return { total, breakdown };
      }

      // ===== Tabel TER Bulanan PP 58/2023 (resmi). [batas atas bruto/bln, tarif %] =====
      const TER = {
        A: [[5400000,0],[5650000,.25],[5950000,.5],[6300000,.75],[6750000,1],[7500000,1.25],[8550000,1.5],[9650000,1.75],[10050000,2],[10350000,2.25],[10700000,2.5],[11050000,3],[11600000,3.5],[12500000,4],[13750000,5],[15100000,6],[16950000,7],[19750000,8],[24150000,9],[26450000,10],[28000000,11],[30050000,12],[32400000,13],[35400000,14],[39100000,15],[43850000,16],[47800000,17],[51400000,18],[56300000,19],[62200000,20],[68600000,21],[77500000,22],[89000000,23],[103000000,24],[125000000,25],[157000000,26],[206000000,27],[337000000,28],[454000000,29],[550000000,30],[695000000,31],[910000000,32],[1400000000,33],[Infinity,34]],
        B: [[6200000,0],[6500000,.25],[6850000,.5],[7300000,.75],[9200000,1],[10750000,1.5],[11250000,2],[11600000,2.5],[12600000,3],[13600000,4],[14950000,5],[16400000,6],[18450000,7],[21850000,8],[26000000,9],[27700000,10],[29350000,11],[31450000,12],[33950000,13],[37100000,14],[41100000,15],[45800000,16],[49500000,17],[53800000,18],[58500000,19],[64000000,20],[71000000,21],[80000000,22],[93000000,23],[109000000,24],[129000000,25],[163000000,26],[211000000,27],[374000000,28],[459000000,29],[555000000,30],[704000000,31],[957000000,32],[1405000000,33],[Infinity,34]],
        C: [[6600000,0],[6950000,.25],[7350000,.5],[7800000,.75],[8850000,1],[9800000,1.25],[10950000,1.5],[11200000,1.75],[12050000,2],[12950000,3],[14150000,4],[15550000,5],[17050000,6],[19500000,7],[22700000,8],[26600000,9],[28100000,10],[30100000,11],[32600000,12],[35400000,13],[38900000,14],[43000000,15],[47400000,16],[51200000,17],[55800000,18],[60400000,19],[66700000,20],[74500000,21],[83200000,22],[95600000,23],[110000000,24],[134000000,25],[169000000,26],[221000000,27],[390000000,28],[463000000,29],[561000000,30],[709000000,31],[965000000,32],[1419000000,33],[Infinity,34]]
      };
      function terCategory(ptkp){ return ptkp <= 58500000 ? 'A' : (ptkp <= 67500000 ? 'B' : 'C'); }
      function terRate(cat, bruto){ const t = TER[cat]; for (let i=0;i<t.length;i++){ if (bruto <= t[i][0]) return t[i][1]/100; } return t[t.length-1][1]/100; }

      let lastCalc = null;

      function hitung() {
        const gaji = HC.parseRp(els.gaji.value);
        const tunj = HC.parseRp(els.tunj.value);
        const bonus = HC.parseRp(els.bonus.value);
        const ptkp = parseInt(els.ptkp.value);
        const bpjsBulan = HC.parseRp(els.bpjs.value);

        if (gaji === 0) { HC.toast('Masukkan gaji pokok dulu', 'error'); return; }

        const isFreelancer = els.jenis.value === 'freelancer';
        const bruto = (gaji + tunj) * 12 + bonus;
        const brutoBulanReg = gaji + tunj;
        let neto, pkp, pphTahun, breakdown, pphBulan;
        let useTer = false, terCat = '', terRt = 0, pphBulanTahunan = 0, pphBulanTER = 0;

        if (isFreelancer) {
          // Bukan pegawai berkesinambungan (ber-NPWP, 1 pemberi penghasilan):
          // DPP = 50% × bruto, lalu tarif progresif Pasal 17 atas (DPP − PTKP).
          neto = bruto * 0.5; // DPP
          pkp = Math.max(0, neto - ptkp);
          const c = calcPPh(pkp); pphTahun = c.total; breakdown = c.breakdown;
          pphBulan = pphTahun / 12;
          pphBulanTahunan = pphBulan;
        } else {
          const biayaJabatan = Math.min(bruto * 0.05, 6000000);
          const bpjsTahun = bpjsBulan * 12;
          neto = bruto - biayaJabatan - bpjsTahun;
          pkp = Math.max(0, neto - ptkp);
          const c = calcPPh(pkp); pphTahun = c.total; breakdown = c.breakdown;
          pphBulanTahunan = pphTahun / 12;
          useTer = els.pphMethod.value === 'ter';
          terCat = terCategory(ptkp);
          terRt = terRate(terCat, brutoBulanReg);
          pphBulanTER = terRt * brutoBulanReg;
          pphBulan = useTer ? pphBulanTER : pphBulanTahunan;
        }
        const thp = isFreelancer ? (brutoBulanReg - pphBulan) : (brutoBulanReg - bpjsBulan - pphBulan);

        $('pphBulan').textContent = HC.fmt(pphBulan);
        $('metaInfo').textContent = isFreelancer
          ? `Bukan Pegawai · DPP 50% · PPh setahun ${HC.fmt(pphTahun)}`
          : (useTer ? `Metode TER ${terCat} · ${(terRt*100).toFixed(2)}% × bruto bulan` : `PPh setahun: ${HC.fmt(pphTahun)}`);
        $('pphMethodInfo').innerHTML = isFreelancer
          ? `<i class="ti ti-user-dollar"></i> <strong>Bukan Pegawai / Freelancer</strong> — Dasar Pengenaan Pajak = <strong>50% × bruto</strong>, lalu tarif progresif Pasal 17 atas (DPP − PTKP). Biaya jabatan & BPJS karyawan tidak berlaku. Metode TER hanya untuk pegawai tetap.`
          : (useTer
            ? `<i class="ti ti-receipt-tax"></i> <strong>TER ${terCat}</strong> — potongan riil slip Jan–Nov. Bonus/THR dipotong di bulan diterimanya, Desember dikoreksi ke total setahun (${HC.fmt(pphTahun)}).`
            : `<i class="ti ti-calculator"></i> <strong>Estimasi tahunan</strong> (progresif disetahunkan ÷12). Pilih <strong>TER</strong> untuk angka sesuai slip gaji 2024+.`);
        $('bruto').textContent = HC.fmt(bruto);
        $('neto').textContent = HC.fmt(neto);
        var netoLbl = $('neto').previousElementSibling; if (netoLbl) netoLbl.textContent = isFreelancer ? 'DPP (50% Bruto)' : 'Neto Setahun';
        $('pkp').textContent = HC.fmt(pkp);
        $('thp').textContent = HC.fmt(thp);

        $('lapisanBody').innerHTML = breakdown.length ? breakdown.map(b =>
          `<tr><td>${b.label}</td><td class="right">${HC.fmt(b.slice)}</td><td class="right">${b.rate}%</td><td class="right" style="color:var(--red);font-weight:700">${HC.fmt(b.tax)}</td></tr>`
        ).join('') : '<tr><td colspan="4" style="text-align:center;color:var(--text-mute);padding:14px">PKP nol — tidak kena pajak</td></tr>';

        const ptkpOptions = [
          { val: 54000000, label: 'TK/0 - Lajang' },
          { val: 58500000, label: 'K/0 - Menikah' },
          { val: 63000000, label: 'K/1 - 1 anak' },
          { val: 67500000, label: 'K/2 - 2 anak' },
          { val: 72000000, label: 'K/3 - 3 anak' },
        ];
        $('ptkpCompareBody').innerHTML = ptkpOptions.map(opt => {
          const pkpAlt = Math.max(0, neto - opt.val);
          const pphAlt = calcPPh(pkpAlt).total;
          return `<tr class="${opt.val === ptkp ? 'active' : ''}"><td>${opt.label}</td><td class="right">${HC.fmt(opt.val)}</td><td class="right">${HC.fmt(pphAlt)}</td><td class="right">${HC.fmt(pphAlt / 12)}</td></tr>`;
        }).join('');

        lastCalc = { gaji, tunj, bonus, ptkp, ptkpLabel: els.ptkp.options[els.ptkp.selectedIndex].text, useTer, terCat, terRt, pphBulanTahunan, pphBulanTER, bpjsBulan, bruto, neto, pkp, pphBulan, pphTahun, thp };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('PPh 21 berhasil dihitung!');
      }

      function reset() {
        els.gaji.value = '10.000.000'; els.tunj.value = '2.000.000'; els.bonus.value = '10.000.000';
        els.ptkp.value = '54000000'; els.pphMethod.value = 'tahunan'; els.bpjs.value = '400.000'; els.jenis.value = 'pegawai'; els.pphMethod.disabled = false; els.bpjs.disabled = false; els.pphMethod.style.opacity = ''; els.bpjs.style.opacity = '';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.pphBulan > 1000000
          ? `PPh ${HC.fmt(c.pphBulan)}/bulan cukup besar. Pertimbangkan bayar zakat via lembaga resmi untuk kurangi PKP sesuai PMK 254/2010.`
          : `PPh ${HC.fmt(c.pphBulan)}/bulan masih wajar. THP per bulan ${HC.fmt(c.thp)}, alokasikan 50/30/20 (kebutuhan/keinginan/tabungan).`;

        return HC.buildReportCard({
          title: '🧾 Simulasi PPh 21 — UU HPP 2022',
          color: '#DC2626', color2: '#991B1B',
          heroLabel: 'PPh 21 Per Bulan',
          heroValue: HC.fmt(c.pphBulan),
          heroSubtext: `PPh setahun: ${HC.fmt(c.pphTahun)} · ${c.ptkpLabel}`,
          inputs: [
            { label: '💼 Gaji Pokok/Bulan', value: HC.fmt(c.gaji) },
            { label: '➕ Tunjangan/Bulan', value: HC.fmt(c.tunj) },
            { label: '🎁 Bonus/THR Setahun', value: HC.fmt(c.bonus) },
            { label: '👨‍👩‍👧 Status PTKP', value: c.ptkpLabel },
          ],
          results: [
            { label: 'PPh 21/Bulan', value: HC.fmt(c.pphBulan), highlight: true },
            { label: 'PPh 21/Tahun', value: HC.fmt(c.pphTahun) },
            { label: 'Bruto Setahun', value: HC.fmt(c.bruto) },
            { label: 'PKP (Kena Pajak)', value: HC.fmt(c.pkp) },
            { label: 'Take-Home Pay/Bulan', value: HC.fmt(c.thp), highlight: true },
            { label: 'Efektif Pajak', value: HC.fmtPct(c.bruto > 0 ? (c.pphTahun / c.bruto) * 100 : 0) },
          ],
          insight, slug: 'pph-21',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🧾 *Simulasi PPh 21 - HitungCerdas*\n\n` +
               `Gaji: ${HC.fmt(c.gaji)}/bln\nTunjangan: ${HC.fmt(c.tunj)}/bln\nBonus/THR: ${HC.fmt(c.bonus)}/thn\nStatus: ${c.ptkpLabel}\n\n` +
               `💰 *PPh 21: ${HC.fmt(c.pphBulan)}/bulan*\n📊 PPh setahun: ${HC.fmt(c.pphTahun)}\n💵 Take-Home Pay: ${HC.fmt(c.thp)}/bln\n\n` +
               `Hitung di: https://hitungcerdas.net/kalkulator/pph-21`;
      }

      $('btnHitung').addEventListener('click', hitung);
      function syncJenis() {
        const fl = els.jenis.value === 'freelancer';
        els.pphMethod.disabled = fl; els.bpjs.disabled = fl;
        els.pphMethod.style.opacity = fl ? '0.5' : ''; els.bpjs.style.opacity = fl ? '0.5' : '';
        if (lastCalc) hitung();
      }
      els.jenis.addEventListener('change', syncJenis);
      els.pphMethod.addEventListener('change', () => { if (lastCalc) hitung(); });
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'pph21-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'pph-21'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 5;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function readData(){
        var pphTxt=($('pphBulan')||{}).textContent||'Rp 0';
        var brutoThnTxt=($('bruto')||{}).textContent||'Rp 0';
        var netoTxt=($('neto')||{}).textContent||'Rp 0';
        var pkpTxt=($('pkp')||{}).textContent||'Rp 0';
        var thpTxt=($('thp')||{}).textContent||'Rp 0';
        return { pphTxt:pphTxt, pphNum:num(pphTxt), brutoThnTxt:brutoThnTxt, brutoThnNum:num(brutoThnTxt),
          netoTxt:netoTxt, pkpTxt:pkpTxt, thpTxt:thpTxt, thpNum:num(thpTxt),
          gaji:($('gaji')||{}).value||'', tunjangan:($('tunjangan')||{}).value||'', bonus:($('bonus')||{}).value||'',
          ptkp:selText('ptkp'), bpjs:($('bpjs')||{}).value||'' };
      }

      function renderGround(){
        var d=readData();
        var brutoBln=d.brutoThnNum/12;
        var eff=d.brutoThnNum?(d.pphNum*12/d.brutoThnNum*100):null;
        var ctx='<div class="aic-ctx"><i class="ti ti-receipt-tax"></i> PPh 21 \u00b7 Pajak <b>'+esc(d.pphTxt)+'</b>/bln'+(eff!=null?(' \u00b7 efektif <b>'+eff.toFixed(1)+'%</b>'):'')+'</div>';
        if(!brutoBln || !d.thpNum){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat porsi gaji yang jadi take-home vs pajak.</div>'; return; }
        var thpPct=Math.max(0,Math.min(100, d.thpNum/brutoBln*100)); var cutPct=Math.max(0,100-thpPct);
        var potTxt=HC.fmt(Math.max(0,brutoBln-d.thpNum));
        var vc=eff==null?'info':(eff<5?'good':(eff<15?'info':'warn'));
        ground.innerHTML=ctx
          +'<div class="aic-stack"><div class="seg s-green" style="width:'+thpPct.toFixed(1)+'%"><span class="seg-lbl">Take-home</span></div><div class="seg s-red" style="width:'+cutPct.toFixed(1)+'%"><span class="seg-lbl">Pajak+potongan</span></div></div>'
          +'<div class="aic-legend"><span><span class="dot" style="background:#10B981"></span>Take-home/bln: <b>'+esc(d.thpTxt)+'</b></span><span><span class="dot" style="background:#FCA5A5"></span>Pajak+potongan: <b>'+esc(potTxt)+'</b></span></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti ti-info-circle"></i> Tarif pajak efektifmu '+(eff!=null?eff.toFixed(1):'0')+'% \u2014 wajar untuk sistem progresif.</div>';
      }

      function buildContext(){
        var d=readData();
        var eff=d.brutoThnNum?(d.pphNum*12/d.brutoThnNum*100):null;
        var p=[
          'Kalkulator: PPh 21 (pajak penghasilan karyawan, UU HPP & PTKP terbaru).',
          d.gaji?('Gaji pokok per bulan: Rp '+d.gaji+'.'):'',
          (d.tunjangan && d.tunjangan!=='0')?('Tunjangan per bulan: Rp '+d.tunjangan+'.'):'',
          (d.bonus && d.bonus!=='0')?('Bonus/THR per tahun: Rp '+d.bonus+'.'):'',
          d.ptkp?('Status PTKP: '+d.ptkp+'.'):'',
          (d.bpjs && d.bpjs!=='0')?('Potongan BPJS per bulan: Rp '+d.bpjs+'.'):'',
          'Penghasilan bruto setahun: '+d.brutoThnTxt+'. Neto setahun: '+d.netoTxt+'. PKP (kena pajak): '+d.pkpTxt+'.',
          'PPh 21 per bulan: '+d.pphTxt+'. Take-home pay per bulan: '+d.thpTxt+'.',
          (eff!=null?('Tarif pajak efektif (PPh setahun / bruto setahun): '+eff.toFixed(2)+'%.'):''),
          'Acuan: tarif PPh progresif 5%/15%/25%/30%/35% per lapisan PKP. Tarif efektif (rata-rata) biasanya jauh di bawah tarif marginal. Cara sah kurangi PKP antara lain zakat/sumbangan via lembaga resmi dan status PTKP yang tepat.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsg('ai',data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Kenapa pajakku segini?','Cara legal kurangi PPh 21?','Tarif efektifku wajar gak?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
