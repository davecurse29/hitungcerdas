---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('kredit-motor')!;
const related = getRelatedCalculators('kredit-motor', 3);

const faqs = [
  { question: 'Apa itu TCO (Total Cost of Ownership) motor?', answer: 'TCO motor = total biaya kepemilikan motor per bulan, BUKAN hanya cicilan. Komponen TCO: cicilan + bensin + servis berkala + pajak STNK + asuransi + perawatan + helm/jas hujan (depresiasi). Cicilan biasanya cuma 60-70% dari TCO. Untuk motor harga Rp 25 juta dengan cicilan Rp 800rb, TCO bulanan bisa Rp 1.2-1.5 juta.' },
  { question: 'Berapa DP minimum kredit motor di Indonesia?', answer: 'DP minimum kredit motor sesuai OJK: <strong>10-15% dari OTR</strong>. Promo dealer sering 0% DP dengan syarat tertentu (cicilan jadi lebih besar atau bunga lebih tinggi). Idealnya DP <strong>30%+</strong> untuk cicilan ringan.' },
  { question: 'Bunga kredit motor di Indonesia berapa?', answer: '<strong>Bunga flat</strong> 8-15% per tahun (Adira, FIF, BAF, MCF). Bunga flat = bunga dihitung dari pokok awal, total konsisten setiap bulan. Berbeda dengan KPR yang anuitas. Flat 8% ≈ Anuitas 14-15% (efektif).' },
  { question: 'Berapa biaya bensin motor matic per bulan?', answer: 'Asumsi 1 liter Pertamax untuk 35-45 km (motor matic). Untuk komuter 30 km/hari × 26 hari = 780 km/bulan, butuh ~20 liter, Rp 280rb. Untuk pemakaian harian biasa: Rp 200-350rb/bulan. Motor sport lebih boros: Rp 350-500rb. Motor listrik paling hemat: Rp 50-80rb (listrik PLN).' },
  { question: 'Mengapa inflasi mempengaruhi bunga kredit motor?', answer: 'Saat inflasi tinggi, <strong>BI Rate naik</strong>, biaya dana leasing/multifinance juga naik. Otomatis bunga kredit motor naik. Mode Inflasi kami simulasikan dampak skenario inflasi terhadap bunga & cicilan untuk perencanaan jangka panjang.' },
  { question: 'Apa biaya tersembunyi beli motor kredit?', answer: 'Selain cicilan: <strong>(1) BBN/Pajak</strong> ~Rp 200-500rb di awal, <strong>(2) STNK tahunan</strong> Rp 250-500rb/tahun, <strong>(3) Asuransi TLO</strong> Rp 600-900rb/tahun, <strong>(4) Servis berkala</strong> Rp 120-230rb/bulan (rutin), <strong>(5) Bensin</strong> Rp 200-500rb/bulan, <strong>(6) Helm + jas hujan + perlengkapan</strong> awal Rp 500rb-1jt + depresiasi ~Rp 20rb/bln.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#7C3AED;--cat-color2:#5B21B6">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#EDE9FE;color:#5B21B6"><i class="ti ti-motorbike"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">Kalkulator Kredit Motor + TCO Lengkap 2026</h1>
          <p class="calc-hero-sub">{calc.introText} Sekarang dengan <strong>TCO (Total Cost of Ownership)</strong> lengkap: bensin, servis, pajak, asuransi, perawatan, dan depresiasi perlengkapan.</p>
          <ul class="calc-hero-benefits">
            <li><i class="ti ti-check"></i> Cicilan bunga flat akurat</li>
            <li><i class="ti ti-check"></i> TCO bulanan lengkap (cicilan + bensin + servis + dll)</li>
            <li><i class="ti ti-check"></i> Profile pemakaian (Komuter / Harian / Touring)</li>
            <li><i class="ti ti-check"></i> Bandingkan motor bensin vs listrik</li>
            <li><i class="ti ti-check"></i> Mode skenario inflasi (Fisher Equation)</li>
          </ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <circle cx="60" cy="130" r="22" fill="none" stroke="#FBBF24" stroke-width="4"/>
            <circle cx="140" cy="130" r="22" fill="none" stroke="#FBBF24" stroke-width="4"/>
            <path d="M60 130L90 90L130 90L140 130" stroke="#FFF" stroke-width="3" fill="none" stroke-linecap="round"/>
            <rect x="85" y="75" width="35" height="20" fill="#FFF" rx="3"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#7C3AED 0%,#5B21B6 100%)"><i class="ti ti-motorbike"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Kredit Motor + TCO</h2><p class="calc-card-sub">Cicilan + Biaya Pemilikan Lengkap per Bulan</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Harga OTR Motor</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="harga" class="has-prefix" value="25.000.000" inputmode="numeric" /></div></div>

            <div class="field"><label>DP (Down Payment)</label>
              <div class="input-wrap"><input type="number" id="dp" class="has-suffix" value="20" step="1" min="0" max="100" /><span class="input-suffix">%</span></div>
              <div class="quick-btns">
                <button type="button" data-dp="10">10%</button><button type="button" data-dp="15">15%</button>
                <button type="button" data-dp="20">20%</button><button type="button" data-dp="30">30%</button>
                <button type="button" data-dp="50">50%</button>
              </div></div>

            <div class="field"><label>Bunga Flat per Tahun</label>
              <div class="input-wrap"><input type="number" id="bunga" class="has-suffix" value="11" step="0.5" min="0" /><span class="input-suffix">%</span></div>
              <p class="field-hint">Bunga flat dealer/leasing: 8-15% per tahun</p></div>

            <div class="field"><label>Tenor (Lama Cicilan)</label>
              <select id="tenor">
                <option value="12">12 bulan (1 tahun)</option>
                <option value="24">24 bulan (2 tahun)</option>
                <option value="36" selected>36 bulan (3 tahun)</option>
                <option value="48">48 bulan (4 tahun)</option>
                <option value="60">60 bulan (5 tahun)</option>
              </select></div>

            {/* ─── TCO PROFILE SELECTOR ─── */}
            <div class="tco-profile-box">
              <label>🏍️ Tipe Motor</label>
              <select id="motorType">
                <option value="matic">Matic (Beat/Scoopy/Mio/NMAX)</option>
                <option value="bebek">Bebek (Revo/Supra/Vega)</option>
                <option value="sport">Sport (CBR/R15/Ninja)</option>
                <option value="listrik">⚡ Motor Listrik (BeAT EM1/Alva/Polytron)</option>
              </select>
              <p class="hint-text">Tipe motor menentukan konsumsi BBM & biaya servis</p>
            </div>

            <div class="tco-profile-box">
              <label>📍 Profil Pemakaian</label>
              <select id="usageProfile">
                <option value="ringan">Ringan (≤500 km/bln) — Anak kos / weekend rider</option>
                <option value="komuter" selected>Komuter (~800 km/bln) — Kerja PP harian</option>
                <option value="aktif">Aktif (~1500 km/bln) — Ojol part-time / sales</option>
                <option value="berat">Berat (≥2500 km/bln) — Ojol full-time / kurir</option>
              </select>
              <p class="hint-text">Profil ini auto-adjust biaya bensin & servis di TCO</p>
            </div>

            {/* ─── INFLATION TOGGLE ─── */}
            <div class="inflation-box" id="inflationBox">
              <label class="inflation-toggle">
                <input type="checkbox" id="inflasiToggle" />
                <span>🔥 Aktifkan Mode Skenario Inflasi</span>
              </label>
              <div class="inflation-options">
                <label>Skenario Inflasi:</label>
                <select id="inflasiSkenario">
                  <option value="rendah">📉 Rendah (3.0%)</option>
                  <option value="normal" selected>📊 Normal (4.5%)</option>
                  <option value="tinggi">📈 Tinggi (6.0%)</option>
                  <option value="krisis">⚠️ Krisis (8.0%)</option>
                </select>
                <p class="inflation-note">Inflasi tinggi → BI Rate naik → bunga kredit motor naik.</p>
              </div>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-motorbike result-placeholder-icon"></i>
              <div class="result-placeholder-title">Cicilan + TCO Motor akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi data motor, klik <strong>"Hitung Sekarang"</strong> untuk simulasi cicilan + TCO bulanan lengkap.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Cicilan Per Bulan</div>
                <div class="result-value" id="cicilan">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="metaInfo">0 bulan</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">DP</div><div class="result-item-value" id="dpAmt">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Pokok Pinjaman</div><div class="result-item-value" id="pokok">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Bunga</div><div class="result-item-value result-warn" id="totalBunga">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Bayar</div><div class="result-item-value result-strong" id="totalBayar">Rp 0</div></div>
              </div>

              {/* ─── TCO BOX ─── */}
              <div class="tco-box">
                <h4><i class="ti ti-receipt-2"></i> Total Cost of Ownership (TCO) Bulanan</h4>
                <ul class="tco-list" id="tcoList"></ul>
                <div id="tcoWarning"></div>
              </div>

              {/* TENOR COMPARISON */}
              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Bandingkan Semua Tenor</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Tenor</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bunga</th><th class="right">Total Bayar</th></tr></thead>
                    <tbody id="tenorBody"></tbody>
                  </table>
                </div>
              </div>

              {/* COMPARE MOTOR TYPES */}
              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-arrows-right-left"></i>&nbsp; Bandingkan TCO 4 Tipe Motor</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Tipe Motor</th><th class="right">Bensin/Bln</th><th class="right">Servis/Bln</th><th class="right">TCO Total/Bln</th></tr></thead>
                    <tbody id="motorCompareBody"></tbody>
                  </table>
                  <p class="bank-disclaimer">⚡ <strong>Motor listrik PALING HEMAT</strong> untuk pemakaian harian. Bensin Rp 50-80rb/bln vs motor bensin Rp 300-500rb/bln. Plus subsidi pemerintah Rp 7 juta saat pembelian!</p>
                </div>
              </div>

              {/* INFLASI COMPARE */}
              <div class="adv-section" id="advInflasi" style="display:none">
                <div class="adv-toggle"><span><i class="ti ti-trending-up"></i>&nbsp; Dampak Inflasi terhadap Bunga</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Skenario</th><th class="right">Bunga</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bayar</th></tr></thead>
                    <tbody id="inflasiBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>TCO Motor — Lebih dari Sekedar Cicilan!</h2>
      <p>Banyak orang beli motor kredit lihat cuma cicilan: "Cuma Rp 800rb/bulan, enteng nih!" Padahal <strong>TCO (Total Cost of Ownership)</strong> motor sebenarnya 1.5-2× cicilan. Untuk Honda Scoopy Rp 25 juta dengan cicilan Rp 800rb, TCO bulanan bisa Rp 1.2-1.5 juta tergantung pemakaian. Mau bandingkan dengan mobil? Lihat <a href="/kalkulator/kredit-mobil">simulasi kredit mobil + TCO</a>. Dan sebelum ambil cicilan, pastikan kamu punya <a href="/kalkulator/dana-darurat">dana darurat</a> yang cukup.</p>

      <h3>Komponen TCO Motor</h3>
      <ul class="info-list">
        <li>🏦 <strong>Cicilan</strong> — Pokok + bunga flat</li>
        <li>⛽ <strong>Bensin</strong> — Tergantung jenis motor & profil pemakaian</li>
        <li>🔧 <strong>Servis berkala</strong> — Rp 120-230rb/bulan (oli, filter, dll)</li>
        <li>📄 <strong>Pajak STNK tahunan</strong> — Rp 250-500rb/tahun</li>
        <li>🛡️ <strong>Asuransi TLO</strong> — Rp 600-900rb/tahun (recommended)</li>
        <li>🪖 <strong>Helm + jas hujan + sarung tangan</strong> — Depresiasi ~Rp 20rb/bln</li>
        <li>🧽 <strong>Cuci & perawatan</strong> — Rp 40-80rb/bulan</li>
      </ul>

      <h3>Tips Hemat TCO Motor</h3>
      <ol class="tips-list">
        <li><strong>Pilih matic untuk kota</strong> — Konsumsi BBM 35-45 km/L, paling efisien untuk komuter.</li>
        <li><strong>Pertimbangkan motor listrik</strong> — Pemerintah kasih subsidi Rp 7 juta. Bensin hemat 80%!</li>
        <li><strong>Servis tepat waktu</strong> — Servis berkala 5000 km, lebih murah daripada turun mesin.</li>
        <li><strong>Bayar pajak STNK on time</strong> — Telat = denda 25% per tahun.</li>
        <li><strong>Pakai BBM yang direkomendasikan</strong> — Motor injection wajib Pertamax (RON 92+). Premium bikin mesin cepat rusak.</li>
        <li><strong>Asuransi TLO worth it</strong> — Rp 750rb/tahun ngeganti motor hilang Rp 25 juta!</li>
      </ol>

      <div class="cta-box">
        <h3>Hitung TCO Motormu Sekarang</h3>
        <p>Geser ke atas, pilih tipe motor & profil pemakaian, klik "Hitung Sekarang" untuk lihat biaya kepemilikan total per bulan.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Kredit Motor & TCO" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>

  <p style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:600px;">
    📅 Data & tarif diperbarui <strong>Juni 2026</strong> · Sumber: Pertamina, PLN, Bank Indonesia
  </p>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { harga: $('harga'), dp: $('dp'), bunga: $('bunga'), tenor: $('tenor'),
                    motorType: $('motorType'), usageProfile: $('usageProfile'),
                    inflasiToggle: $('inflasiToggle'), inflasiSkenario: $('inflasiSkenario'),
                    inflasiBox: $('inflationBox'), advInflasi: $('advInflasi') };
      [els.harga].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.quick-btns button').forEach(btn => btn.addEventListener('click', () => { els.dp.value = btn.dataset.dp; }));
      els.inflasiToggle.addEventListener('change', () => els.inflasiBox.classList.toggle('active', els.inflasiToggle.checked));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      // Flat interest formula
      function flat(pokok, bungaTahun, totalBulan) {
        const totalBunga = pokok * (bungaTahun / 100) * (totalBulan / 12);
        return { cicilan: (pokok + totalBunga) / totalBulan, totalBunga };
      }

      // TCO data per motor type & usage profile
      // BBM consumption: km per liter
      const MOTOR_TYPE_DATA = {
        matic:   { kmpl: 40, servisBulan: 150000, label: 'Matic' },
        bebek:   { kmpl: 50, servisBulan: 115000, label: 'Bebek' },
        sport:   { kmpl: 30, servisBulan: 210000, label: 'Sport' },
        listrik: { kmpl: 0,  servisBulan: 90000,  label: 'Motor Listrik', isElectric: true, kwhPerKm: 0.025 }, // 0.025 kWh/km, tarif PLN ~Rp 1500/kWh
      };

      const USAGE_PROFILE = {
        ringan:  { kmBulan: 400, label: 'Ringan (≤500 km/bln)' },
        komuter: { kmBulan: 800, label: 'Komuter (~800 km/bln)' },
        aktif:   { kmBulan: 1500, label: 'Aktif (~1500 km/bln)' },
        berat:   { kmBulan: 2500, label: 'Berat (≥2500 km/bln)' },
      };

      const BBM_PRICE = 16250; // 	 2026 estimasi
      const LISTRIK_PRICE = 1445; // Tarif PLN R-1 per kWh

      function calcTCO(harga, motorTypeKey, usageProfileKey, cicilanBulan) {
        const motor = MOTOR_TYPE_DATA[motorTypeKey];
        const usage = USAGE_PROFILE[usageProfileKey];
        const kmBulan = usage.kmBulan;

        let bensinBulan = 0;
        let bensinLabel = '';
        if (motor.isElectric) {
          // Listrik
          const kwhBulan = kmBulan * motor.kwhPerKm;
          bensinBulan = kwhBulan * LISTRIK_PRICE;
          bensinLabel = `${kwhBulan.toFixed(0)} kWh × Rp ${LISTRIK_PRICE.toLocaleString('id-ID')}/kWh`;
        } else {
          // Bensin
          const literBulan = kmBulan / motor.kmpl;
          bensinBulan = literBulan * BBM_PRICE;
          bensinLabel = `${literBulan.toFixed(1)} L × Rp ${BBM_PRICE.toLocaleString('id-ID')}/L (${motor.kmpl} km/L)`;
        }

        // Other costs
        const pajakBulan = harga * 0.02 / 12; // 2% nilai motor per tahun
        const asuransiBulan = harga * 0.03 / 12; // 3% nilai per tahun (TLO, estimasi konservatif)
        const cuciBulan = 70000;
        const perlengkapanBulan = 20000; // depresiasi helm, jas hujan, sarung tangan
        const servisBulan = motor.servisBulan;

        const totalTCO = cicilanBulan + bensinBulan + servisBulan + pajakBulan + asuransiBulan + cuciBulan + perlengkapanBulan;

        return {
          cicilan: cicilanBulan,
          bensin: bensinBulan,
          bensinLabel,
          servis: servisBulan,
          pajak: pajakBulan,
          asuransi: asuransiBulan,
          cuci: cuciBulan,
          perlengkapan: perlengkapanBulan,
          totalTCO,
          isElectric: motor.isElectric,
        };
      }

      let lastCalc = null;

      function hitung() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        let bunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value);
        const motorTypeKey = els.motorType.value;
        const usageKey = els.usageProfile.value;

        if (harga === 0) { HC.toast('Masukkan harga motor dulu', 'error'); return; }

        // Inflation
        const useInflasi = els.inflasiToggle.checked;
        let bungaOriginal = bunga, skenario = null;
        if (useInflasi) {
          skenario = els.inflasiSkenario.value;
          bunga = HC.adjustInterestRate(bunga, skenario);
        }

        const dpAmt = harga * (dpPct / 100);
        const pokok = harga - dpAmt;
        const { cicilan, totalBunga } = flat(pokok, bunga, tenor);
        const totalBayar = dpAmt + cicilan * tenor;

        // Calculate TCO
        const tco = calcTCO(harga, motorTypeKey, usageKey, cicilan);

        // Display main results
        $('cicilan').textContent = HC.fmt(cicilan);
        $('metaInfo').textContent = `${tenor} bulan · Bunga flat ${bunga.toFixed(2)}%${useInflasi ? ' (inflasi-adjusted)' : ''}`;
        $('dpAmt').textContent = `${HC.fmt(dpAmt)} (${dpPct}%)`;
        $('pokok').textContent = HC.fmt(pokok);
        $('totalBunga').textContent = HC.fmt(totalBunga);
        $('totalBayar').textContent = HC.fmt(totalBayar);

        // Display TCO
        const electricBadge = tco.isElectric ? '⚡' : '⛽';
        $('tcoList').innerHTML = `
          <li class="tco-cicilan">
            <span class="ico">🏦</span>
            <span class="lbl">Cicilan Kredit
              <span class="lbl-hint">${tenor} bulan, bunga ${bunga.toFixed(2)}%</span>
            </span>
            <span class="val">${HC.fmt(tco.cicilan)}</span>
          </li>
          <li>
            <span class="ico">${electricBadge}</span>
            <span class="lbl">${tco.isElectric ? 'Listrik (charging)' : 'Bensin'}
              <span class="lbl-hint">${tco.bensinLabel}</span>
            </span>
            <span class="val">${HC.fmt(tco.bensin)}</span>
          </li>
          <li>
            <span class="ico">🔧</span>
            <span class="lbl">Servis berkala
              <span class="lbl-hint">Oli, filter, periodic check</span>
            </span>
            <span class="val">${HC.fmt(tco.servis)}</span>
          </li>
          <li>
            <span class="ico">📄</span>
            <span class="lbl">Pajak STNK
              <span class="lbl-hint">${HC.fmt(tco.pajak * 12)}/tahun ÷ 12</span>
            </span>
            <span class="val">${HC.fmt(tco.pajak)}</span>
          </li>
          <li>
            <span class="ico">🛡️</span>
            <span class="lbl">Asuransi TLO
              <span class="lbl-hint">${HC.fmt(tco.asuransi * 12)}/tahun ÷ 12</span>
            </span>
            <span class="val">${HC.fmt(tco.asuransi)}</span>
          </li>
          <li>
            <span class="ico">🧽</span>
            <span class="lbl">Cuci & perawatan
              <span class="lbl-hint">Cuci motor 2× sebulan</span>
            </span>
            <span class="val">${HC.fmt(tco.cuci)}</span>
          </li>
          <li>
            <span class="ico">🪖</span>
            <span class="lbl">Helm + jas hujan
              <span class="lbl-hint">Depresiasi perlengkapan</span>
            </span>
            <span class="val">${HC.fmt(tco.perlengkapan)}</span>
          </li>
          <li class="tco-total">
            <span class="ico">💸</span>
            <span class="lbl">TCO TOTAL per Bulan</span>
            <span class="val">${HC.fmt(tco.totalTCO)}</span>
          </li>
        `;

        // TCO Warning vs Gaji
        const tcoRatio = (tco.totalTCO / 4000000) * 100; // benchmark UMR 4jt
        let warningHtml = '';
        if (tco.isElectric) {
          warningHtml = `<div class="tco-warning safe">⚡ <strong>HEMAT!</strong> Motor listrik bisa hemat ${HC.fmt(150000)} - ${HC.fmt(300000)} per bulan dibanding motor bensin. Plus subsidi pemerintah Rp 7 juta saat beli!</div>`;
        } else if (tco.totalTCO > 2000000) {
          warningHtml = `<div class="tco-warning">⚠️ <strong>TCO ${HC.fmt(tco.totalTCO)}/bulan cukup besar.</strong> Pastikan gaji minimal ${HC.fmt(tco.totalTCO * 4)} agar TCO motor tidak lebih dari 25% gaji.</div>`;
        } else {
          warningHtml = `<div class="tco-warning safe">✅ TCO terjangkau. Tetap sisihkan dana darurat 6 bulan TCO untuk masalah tak terduga.</div>`;
        }
        $('tcoWarning').innerHTML = warningHtml;

        // Tenor comparison
        const tenorOpts = [12, 24, 36, 48, 60];
        $('tenorBody').innerHTML = tenorOpts.map(t => {
          const { cicilan: c, totalBunga: tb } = flat(pokok, bunga, t);
          return `<tr class="${t === tenor ? 'active' : ''}"><td>${t} bln</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(tb)}</td><td class="right">${HC.fmt(c * t + dpAmt)}</td></tr>`;
        }).join('');

        // Compare motor types
        const types = ['matic', 'bebek', 'sport', 'listrik'];
        $('motorCompareBody').innerHTML = types.map(t => {
          const tcoAlt = calcTCO(harga, t, usageKey, cicilan);
          const lbl = MOTOR_TYPE_DATA[t].label + (t === 'listrik' ? ' ⚡' : '');
          return `<tr class="${t === motorTypeKey ? 'active' : ''}"><td>${lbl}</td><td class="right">${HC.fmt(tcoAlt.bensin)}</td><td class="right">${HC.fmt(tcoAlt.servis)}</td><td class="right" style="font-weight:700">${HC.fmt(tcoAlt.totalTCO)}</td></tr>`;
        }).join('');

        // Inflation comparison
        if (useInflasi) {
          els.advInflasi.style.display = '';
          const scenarios = ['rendah', 'normal', 'tinggi', 'krisis'];
          const labels = { rendah: 'Rendah (3.0%)', normal: 'Normal (4.5%)', tinggi: 'Tinggi (6.0%)', krisis: 'Krisis (8.0%)' };
          $('inflasiBody').innerHTML = scenarios.map(s => {
            const b = HC.adjustInterestRate(bungaOriginal, s);
            const { cicilan: c } = flat(pokok, b, tenor);
            return `<tr class="${s === skenario ? 'active' : ''}"><td>${labels[s]}</td><td class="right">${b.toFixed(2)}%</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(c * tenor + dpAmt)}</td></tr>`;
          }).join('');
        } else {
          els.advInflasi.style.display = 'none';
        }

        lastCalc = { harga, dpPct, dpAmt, pokok, bunga, bungaOriginal, tenor, cicilan, totalBunga, totalBayar,
                     motorTypeKey, motorTypeLabel: MOTOR_TYPE_DATA[motorTypeKey].label,
                     usageKey, usageLabel: USAGE_PROFILE[usageKey].label, tco, useInflasi, skenario };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Cicilan + TCO Motor berhasil dihitung!');
      }

      function reset() {
        els.harga.value = '25.000.000'; els.dp.value = '20'; els.bunga.value = '11';
        els.tenor.value = '36'; els.motorType.value = 'matic'; els.usageProfile.value = 'komuter';
        els.inflasiToggle.checked = false; els.inflasiBox.classList.remove('active');
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.tco.isElectric
          ? `⚡ Motor listrik HEMAT! Bensin cuma ${HC.fmt(c.tco.bensin)}/bln vs Rp 300-500rb motor bensin. Plus subsidi pemerintah Rp 7 juta saat beli.`
          : `TCO total ${HC.fmt(c.tco.totalTCO)}/bln. Cicilan cuma ${((c.tco.cicilan / c.tco.totalTCO) * 100).toFixed(0)}% dari TCO — sisanya untuk bensin, servis, pajak, asuransi.`;

        const inputs = [
          { label: '🏍️ Harga OTR', value: HC.fmt(c.harga) },
          { label: '💰 DP', value: `${c.dpPct}% (${HC.fmt(c.dpAmt)})` },
          { label: '📊 Bunga Flat', value: `${c.bunga.toFixed(2)}%${c.useInflasi ? ' (inflasi)' : ''}` },
          { label: '📅 Tenor', value: `${c.tenor} bulan` },
          { label: '🏍️ Tipe Motor', value: c.motorTypeLabel },
          { label: '📍 Profil Pemakaian', value: c.usageLabel },
        ];

        return HC.buildReportCard({
          title: '🏍️ Kredit Motor + TCO Lengkap',
          color: '#7C3AED', color2: '#5B21B6',
          heroLabel: 'TCO Total per Bulan',
          heroValue: HC.fmt(c.tco.totalTCO),
          heroSubtext: `Cicilan ${HC.fmt(c.cicilan)} + biaya pemilikan ${HC.fmt(c.tco.totalTCO - c.cicilan)}`,
          inputs,
          results: [
            { label: 'TCO Total/Bulan', value: HC.fmt(c.tco.totalTCO), highlight: true },
            { label: 'Cicilan/Bulan', value: HC.fmt(c.tco.cicilan) },
            { label: `${c.tco.isElectric ? 'Listrik' : 'Bensin'}/Bulan`, value: HC.fmt(c.tco.bensin) },
            { label: 'Servis Berkala', value: HC.fmt(c.tco.servis) },
            { label: 'Pajak + Asuransi', value: HC.fmt(c.tco.pajak + c.tco.asuransi) },
            { label: 'Total Bayar Cicilan', value: HC.fmt(c.totalBayar), highlight: true },
          ],
          insight, slug: 'kredit-motor',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🏍️ *Kredit Motor + TCO - HitungCerdas*\n\n` +
               `Motor: ${c.motorTypeLabel}\nHarga: ${HC.fmt(c.harga)}\nDP ${c.dpPct}%: ${HC.fmt(c.dpAmt)}\nTenor: ${c.tenor} bulan\nProfil: ${c.usageLabel}\n\n` +
               `💰 *Cicilan: ${HC.fmt(c.cicilan)}/bulan*\n\n` +
               `📊 *TCO Bulanan Lengkap:*\n` +
               `🏦 Cicilan: ${HC.fmt(c.tco.cicilan)}\n` +
               `${c.tco.isElectric ? '⚡' : '⛽'} ${c.tco.isElectric ? 'Listrik' : 'Bensin'}: ${HC.fmt(c.tco.bensin)}\n` +
               `🔧 Servis: ${HC.fmt(c.tco.servis)}\n` +
               `📄 Pajak: ${HC.fmt(c.tco.pajak)}\n` +
               `🛡️ Asuransi: ${HC.fmt(c.tco.asuransi)}\n` +
               `🧽 Cuci+perawatan: ${HC.fmt(c.tco.cuci + c.tco.perlengkapan)}\n\n` +
               `💸 *TCO TOTAL: ${HC.fmt(c.tco.totalTCO)}/bulan*\n\n` +
               `Hitung: https://hitungcerdas.net/kalkulator/kredit-motor`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'kredit-motor-tco-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'kredit-motor'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>
