<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { pinjaman: $('pinjaman'), tenor: $('tenor'), metode: $('metode'), bunga: $('bunga'), gaji: $('gaji'), cicLain: $('cicLain') };
      [els.pinjaman, els.gaji, els.cicLain].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      // 6 Banks Juni 2026 (BI Rate 5.75%)
      const BANKS = [
        { name: 'CIMB Niaga', flatBln: 0.79, efektif: 16.5 },
        { name: 'BCA', flatBln: 0.88, efektif: 18.2 },
        { name: 'Mandiri', flatBln: 0.95, efektif: 19.5 },
        { name: 'BNI', flatBln: 1.05, efektif: 21.3 },
        { name: 'BRI', flatBln: 1.15, efektif: 23.0 },
        { name: 'Danamon', flatBln: 1.35, efektif: 26.5 },
      ];

      function calcFlat(pokok, bungaThn, tenor) {
        const bungaBln = bungaThn / 12 / 100;
        const cicilanPokok = pokok / tenor;
        const cicilanBunga = pokok * bungaBln;
        const cicilan = cicilanPokok + cicilanBunga;
        return { cicilan, totalBunga: cicilanBunga * tenor, totalBayar: cicilan * tenor };
      }

      function calcEfektif(pokok, bungaThn, tenor) {
        const bungaBln = bungaThn / 12 / 100;
        const cicilanPokok = pokok / tenor;
        let sisa = pokok, totalBunga = 0, totalBayar = 0, firstCicilan = 0;
        const rows = [];
        for (let i = 1; i <= tenor; i++) {
          const bunga = sisa * bungaBln;
          const cicilan = cicilanPokok + bunga;
          if (i === 1) firstCicilan = cicilan;
          totalBunga += bunga; totalBayar += cicilan;
          rows.push({ bln: i, pokok: cicilanPokok, bunga, sisa: sisa - cicilanPokok });
          sisa -= cicilanPokok;
        }
        return { cicilan: firstCicilan, totalBunga, totalBayar, rows };
      }

      function calcAnuitas(pokok, bungaThn, tenor) {
        const bungaBln = bungaThn / 12 / 100;
        const cicilan = (pokok * bungaBln) / (1 - Math.pow(1 + bungaBln, -tenor));
        const totalBayar = cicilan * tenor;
        const totalBunga = totalBayar - pokok;
        let sisa = pokok;
        const rows = [];
        for (let i = 1; i <= tenor; i++) {
          const bunga = sisa * bungaBln;
          const cicPokok = cicilan - bunga;
          rows.push({ bln: i, pokok: cicPokok, bunga, sisa: sisa - cicPokok });
          sisa -= cicPokok;
        }
        return { cicilan, totalBunga, totalBayar, rows };
      }

      // Bunga efektif setara (APR) dari arus cicilan, via IRR bisection
      function effectiveApr(pokok, payments) {
        const npv = (i) => { let s = -pokok; for (let t = 0; t < payments.length; t++) s += payments[t] / Math.pow(1 + i, t + 1); return s; };
        if (npv(0) <= 0) return 0;
        let lo = 0, hi = 1;
        for (let k = 0; k < 100; k++) { const mid = (lo + hi) / 2; if (npv(mid) > 0) lo = mid; else hi = mid; }
        return ((lo + hi) / 2) * 12 * 100;
      }

      let lastCalc = null;

      function hitung() {
        const pokok = HC.parseRp(els.pinjaman.value);
        const tenor = parseInt(els.tenor.value);
        const metode = els.metode.value;
        const bunga = parseFloat(els.bunga.value);
        const gaji = HC.parseRp(els.gaji.value);
        const cicLain = HC.parseRp(els.cicLain.value);

        if (pokok === 0) { HC.toast('Masukkan jumlah pinjaman dulu', 'error'); return; }
        if (gaji === 0) { HC.toast('Masukkan penghasilan untuk cek DTI', 'error'); return; }

        let result;
        if (metode === 'flat') result = calcFlat(pokok, bunga, tenor);
        else if (metode === 'efektif') result = calcEfektif(pokok, bunga, tenor);
        else result = calcAnuitas(pokok, bunga, tenor);

        // DTI Ratio
        const totalCicilan = result.cicilan + cicLain;
        const dti = (totalCicilan / gaji) * 100;
        let dtiStatus = '', dtiColor = '';
        if (dti < 30) { dtiStatus = '✅ Aman'; dtiColor = 'var(--green-dark)'; }
        else if (dti < 40) { dtiStatus = '⚠️ Hati-hati'; dtiColor = 'var(--gold)'; }
        else { dtiStatus = '❌ Berbahaya'; dtiColor = 'var(--red)'; }

        const metodeLabel = { flat: 'Flat Rate', efektif: 'Efektif', anuitas: 'Anuitas' }[metode];

        $('cicilan').textContent = HC.fmt(result.cicilan);
        $('metodeLabel').textContent = `${metodeLabel} · ${bunga}%/thn · ${tenor} bln`;
        $('totalBunga').textContent = HC.fmt(result.totalBunga);
        $('totalBayar').textContent = HC.fmt(result.totalBayar);
        $('dti').textContent = dti.toFixed(1) + '%';
        $('dtiStatus').textContent = dtiStatus;
        $('dtiStatus').style.color = dtiColor;

        // Bunga efektif setara (APR)
        const payments = result.rows ? result.rows.map(r => r.pokok + r.bunga) : Array(tenor).fill(result.cicilan);
        const effApr = effectiveApr(pokok, payments);
        const effEl = $('effInfo');
        effEl.style.display = '';
        if (metode === 'flat') {
          effEl.innerHTML = `💡 Bunga <b>${bunga}%/thn flat</b> setara <b>~${effApr.toFixed(1)}% efektif/tahun</b>. Cicilan flat terlihat ringan, tapi bunga dihitung dari pokok awal terus — biaya riilnya jauh lebih tinggi. Selalu bandingkan pinjaman pakai angka <b>efektif</b>, bukan flat.`;
        } else if (metode === 'anuitas') {
          effEl.innerHTML = `✅ Anuitas: bunga <b>${bunga}%/thn</b> sudah <b>efektif</b> (≈${effApr.toFixed(1)}%/thn). Ini cara paling adil membandingkan biaya antar pinjaman.`;
        } else {
          effEl.innerHTML = `ℹ️ Efektif (sliding): bunga dari sisa pokok, cicilan menurun tiap bulan. Biaya riil ≈ <b>${effApr.toFixed(1)}% efektif/tahun</b>.`;
        }

        // Bank comparison
        let bankHtml = '';
        BANKS.forEach(b => {
          const bankResult = calcFlat(pokok, b.flatBln * 12, tenor);
          bankHtml += `<tr><td><strong>${b.name}</strong></td><td class="right">${b.flatBln}%</td><td class="right">~${b.efektif}%</td><td class="right" style="font-weight:700">${HC.fmt(bankResult.cicilan)}</td></tr>`;
        });
        $('bankBody').innerHTML = bankHtml;

        // Amortization (first 5 months)
        let amortHtml = '';
        if (result.rows) {
          result.rows.slice(0, 5).forEach(r => {
            amortHtml += `<tr><td>${r.bln}</td><td class="right">${HC.fmt(r.pokok)}</td><td class="right">${HC.fmt(r.bunga)}</td><td class="right">${HC.fmt(Math.max(0, r.sisa))}</td></tr>`;
          });
        } else {
          // Flat — manual rows
          const cicPokok = pokok / tenor;
          const cicBunga = pokok * (bunga / 12 / 100);
          let sisa = pokok;
          for (let i = 1; i <= Math.min(5, tenor); i++) {
            sisa -= cicPokok;
            amortHtml += `<tr><td>${i}</td><td class="right">${HC.fmt(cicPokok)}</td><td class="right">${HC.fmt(cicBunga)}</td><td class="right">${HC.fmt(Math.max(0, sisa))}</td></tr>`;
          }
        }
        $('amortBody').innerHTML = amortHtml;

        lastCalc = { pokok, tenor, metode, metodeLabel, bunga, effApr, gaji, cicLain, cicilan: result.cicilan, totalBunga: result.totalBunga, totalBayar: result.totalBayar, dti, dtiStatus };
        HC.history.push('kta', { inputs: HC.history.capture(['pinjaman','tenor','metode','bunga','gaji','cicLain']), summary: 'Pinjaman ' + HC.fmt(lastCalc.pokok) + ' \u00b7 ' + lastCalc.tenor + ' bln @ ' + lastCalc.bunga + '%', metrics: [{ k: 'Cicilan/bln', v: HC.fmt(lastCalc.cicilan) }, { k: 'Total bunga', v: HC.fmt(lastCalc.totalBunga) }] });
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Simulasi KTA berhasil dihitung!');
      }

      function reset() {
        els.pinjaman.value = '50.000.000'; els.tenor.value = '24'; els.metode.value = 'flat';
        var ei=$('effInfo'); if(ei) ei.style.display='none';
        els.bunga.value = '18'; els.gaji.value = '10.000.000'; els.cicLain.value = '0';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.dti < 30
          ? `DTI ratio ${c.dti.toFixed(1)}% — aman! Cicilan masih dalam batas sehat. Pastikan dana darurat juga ada.`
          : c.dti < 40
          ? `DTI ratio ${c.dti.toFixed(1)}% — hati-hati! Mendekati batas maksimal bank. Pertimbangkan tenor lebih panjang.`
          : `⚠️ DTI ratio ${c.dti.toFixed(1)}% — bahaya! Bank kemungkinan tolak pengajuan. Pertimbangkan plafon lebih kecil atau tenor lebih panjang.`;

        return HC.buildReportCard({
          title: '💳 Simulasi KTA',
          color: '#4F46E5', color2: '#3730A3',
          heroLabel: 'Cicilan per Bulan',
          heroValue: HC.fmt(c.cicilan),
          heroSubtext: `${c.metodeLabel} · ${c.bunga}%/thn · ${c.tenor} bulan`,
          inputs: [
            { label: '💰 Pinjaman', value: HC.fmt(c.pokok) },
            { label: '📅 Tenor', value: c.tenor + ' bulan' },
            { label: '📊 Metode', value: c.metodeLabel },
            { label: '💼 Penghasilan', value: HC.fmt(c.gaji) },
          ],
          results: [
            { label: 'Cicilan/bln', value: HC.fmt(c.cicilan), highlight: true },
            { label: 'Total Bunga', value: HC.fmt(c.totalBunga) },
            { label: 'Total Bayar', value: HC.fmt(c.totalBayar) },
            { label: 'DTI Ratio', value: c.dti.toFixed(1) + '%' },
            { label: 'Status DTI', value: c.dtiStatus, highlight: true },
          ],
          insight, slug: 'kta',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `💳 *Simulasi KTA - HitungCerdas*\n\nPinjaman: ${HC.fmt(c.pokok)}\nTenor: ${c.tenor} bulan\nMetode: ${c.metodeLabel}\nBunga: ${c.bunga}%/thn\n\n💰 *Cicilan/bln: ${HC.fmt(c.cicilan)}*\n📊 Total Bunga: ${HC.fmt(c.totalBunga)}\n💵 Total Bayar: ${HC.fmt(c.totalBayar)}\n\nDTI: ${c.dti.toFixed(1)}% (${c.dtiStatus})\n\nHitung di: https://hitungcerdas.net/kalkulator/kta`;
      }

            function renderHist() {
        HC.history.render('kta', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      els.metode.addEventListener('change', () => { if (lastCalc) hitung(); });
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'kta-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'kta'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });

      // ── Salin Link Hasil (share via URL) ──
      function buildShareUrl(){
        var p = new URLSearchParams();
        p.set('pj', String(HC.parseRp(els.pinjaman.value)||0));
        p.set('gj', String(HC.parseRp(els.gaji.value)||0));
        p.set('cl', String(HC.parseRp(els.cicLain.value)||0));
        p.set('bg', els.bunga.value||'0');
        p.set('tn', els.tenor.value);
        p.set('mt', els.metode.value);
        return location.origin + location.pathname + '?' + p.toString();
      }
      function setNum(el, val){ el.value = val; el.dispatchEvent(new Event('input', {bubbles:true})); }
      function loadFromUrl(){
        var q = new URLSearchParams(location.search);
        if (!q.has('pj')) return false;
        setNum(els.pinjaman, q.get('pj'));
        if (q.has('gj')) setNum(els.gaji, q.get('gj'));
        if (q.has('cl')) setNum(els.cicLain, q.get('cl'));
        if (q.has('bg')) els.bunga.value = q.get('bg');
        if (q.has('tn')) els.tenor.value = q.get('tn');
        if (q.has('mt')) els.metode.value = q.get('mt');
        return true;
      }
      $('exportLink').addEventListener('click', function(){ HC.copyText(buildShareUrl(), 'Link tersalin!'); });
      if (loadFromUrl()) { hitung(); }
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function readData(){
        var cicTxt=($('cicilan')||{}).textContent||'Rp 0';
        var ratio=parseFloat(String(($('dti')||{}).textContent||'').replace(',','.'));
        if(!isFinite(ratio)) ratio=null;
        if(ratio==null){ var g=num(($('gaji')||{}).value); if(g>0) ratio=num(cicTxt)/g*100; }
        return { cicilanTxt:cicTxt, ratio:ratio,
          pinjaman:($('pinjaman')||{}).value||'', tenor:($('tenor')||{}).value||'',
          bunga:($('bunga')||{}).value||'', gaji:($('gaji')||{}).value||'', cicLain:($('cicLain')||{}).value||'',
          metode:selText('metode'), totalBunga:($('totalBunga')||{}).textContent||'',
          totalBayar:($('totalBayar')||{}).textContent||'' };
      }


      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-cash"></i> KTA \u00b7 Cicilan <b>'+esc(d.cicilanTxt)+'</b>'+(d.ratio!=null?' \u00b7 DTI <b>'+d.ratio.toFixed(1)+'%</b>':'')+'</div>';
        if(d.ratio==null){ ground.innerHTML=ctx+'<div class="aic-nogauge">Isi "Penghasilan Bulanan" lalu hitung ulang untuk lihat gauge risiko.</div>'; return; }
        var pos=Math.max(0,Math.min(d.ratio,50))/50*100;
        var vc=d.ratio<=30?'good':(d.ratio<=40?'warn':'bad');
        var vi=d.ratio<=30?'ti-circle-check':(d.ratio<=40?'ti-alert-triangle':'ti-alert-circle');
        var vt=d.ratio<=30?'Aman \u2014 di bawah batas 30%':(d.ratio<=40?'Agak ketat \u2014 tapi bisa diatur':'Cukup berat \u2014 perlu disiasati');
        ground.innerHTML=ctx
          +'<div class="aic-gauge"><div class="aic-gauge-mark" style="left:'+pos.toFixed(1)+'%"><span>kamu \u00b7 '+d.ratio.toFixed(0)+'%</span></div>'
          +'<div class="aic-gauge-bar"><div class="z-green"></div><div class="z-amber"></div><div class="z-red"></div></div>'
          +'<div class="aic-gauge-lbl"><span class="g">Aman &le;30%</span><span class="a">Hati-hati</span><span class="r">Risiko &ge;40%</span></div></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }


      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: KTA (Kredit Tanpa Agunan).',
          d.pinjaman?('Jumlah pinjaman: Rp '+d.pinjaman+'.'):'',
          'Cicilan per bulan: '+d.cicilanTxt+'.',
          'Tenor: '+d.tenor+' bulan. Metode bunga: '+d.metode+'. Bunga: '+d.bunga+'% per tahun.',
          'Total bunga: '+d.totalBunga+'. Total bayar: '+d.totalBayar+'.',
          d.gaji?('Penghasilan bulanan: Rp '+d.gaji+'.'):'',
          (d.cicLain && d.cicLain!=='0')?('Cicilan lain per bulan: Rp '+d.cicLain+'.'):'',
          d.ratio!=null?('DTI (rasio total cicilan terhadap penghasilan): '+d.ratio.toFixed(1)+'%.'):'',
          'Acuan: DTI aman maksimal 30%, di atas 40% berisiko tinggi. Bunga KTA relatif tinggi (sering 15-25% per tahun), jadi timbang baik-baik dan bandingkan antar bank.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Aman gak ambil KTA ini?','Bunga segini wajar gak?','Cara bikin cicilan lebih ringan?','Cicilanku kebesaran gak buat gajiku?','Mending tenor pendek atau panjang?','Total bunga yang kubayar berapa?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Aman gak ambil KTA ini?','Bunga segini wajar gak?','Cara bikin cicilan lebih ringan?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
