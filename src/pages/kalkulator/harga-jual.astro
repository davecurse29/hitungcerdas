---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import EbookPromo from '../../components/EbookPromo.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('harga-jual')!;
const related = getRelatedCalculators('harga-jual', 3);

const faqs = [
  { question: 'Bagaimana cara menentukan harga jual yang benar?', answer: 'Rumus dasar: <strong>Harga Jual = HPP + Profit Margin + Fee Marketplace</strong>. Atau: <strong>Harga Jual = (HPP + Margin Rp) ÷ (1 - Fee%)</strong>. Pastikan harga di atas kompetitor minus 5-10% sebagai cushion.' },
  { question: 'Berapa target margin yang sehat untuk UMKM?', answer: 'Benchmark per industri: <strong>Fashion ritel</strong> 30-50%, <strong>F&B/kuliner</strong> 40-60%, <strong>Beauty/skincare</strong> 50-70%, <strong>Handmade/craft</strong> 50-75%, <strong>Digital/SaaS</strong> 70-90%, <strong>Jasa profesional</strong> 50-80%, <strong>Grocery/retail</strong> 5-15% (high volume).' },
  { question: 'Berapa fee marketplace di Indonesia?', answer: 'Estimasi fee 2026: <strong>Shopee</strong> 4-5% (Free Shipping) / 1,5-3% reguler. <strong>Tokopedia</strong> 4-8% (TopAds) / 1-2% reguler. <strong>TikTok Shop</strong> 1-3%. <strong>Lazada</strong> 4-6%. Belum termasuk biaya iklan/ads 2-15% dari penjualan.' },
  { question: 'Apa beda margin dan markup?', answer: '<strong>Margin</strong> = Profit ÷ Harga Jual × 100%. <strong>Markup</strong> = Profit ÷ HPP × 100%. Untuk profit Rp 20: HPP Rp 80, Harga Rp 100 → Margin 20%, Markup 25%. Margin SELALU lebih kecil dari markup untuk profit yang sama. Banyak UMKM bilang "margin 50%" padahal yang dimaksud markup 50% (= margin 33%).' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#EC4899;--cat-color2:#9D174D">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FCE7F3;color:#9D174D"><i class="ti ti-tag"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M70 50L150 50L150 130L100 180L50 130L50 100L70 50Z" fill="#FFF" stroke="#FBBF24" stroke-width="2"/>
            <circle cx="120" cy="80" r="10" fill="#FBBF24"/>
            <text x="100" y="135" text-anchor="middle" font-size="22" font-weight="900" fill="#9D174D" font-family="Inter">Rp</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#EC4899 0%,#9D174D 100%)"><i class="ti ti-tag"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Harga Jual UMKM</h2><p class="calc-card-sub">HPP + Margin + Fee Marketplace</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Modal/Bahan Baku per Unit</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="modal" class="has-prefix" value="15.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Packaging per Unit</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="packaging" class="has-prefix" value="2.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Biaya Operasional per Unit <span class="hint">(listrik, sewa, gaji alokasi)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="opex" class="has-prefix" value="3.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Target Margin Profit <span class="hint">(% dari harga jual)</span></label>
              <div class="input-wrap"><input type="number" id="margin" class="has-suffix" value="40" step="5" min="0" max="95" /><span class="input-suffix">%</span></div>
              <div class="quick-btns">
                <button type="button" data-m="20">20%</button>
                <button type="button" data-m="30">30%</button>
                <button type="button" data-m="40">40%</button>
                <button type="button" data-m="60">60%</button>
                <button type="button" data-m="70">70%</button>
              </div></div>

            <div class="field"><label>Fee Marketplace</label>
              <select id="marketplace">
                <option value="0">Direct sale (tanpa marketplace)</option>
                <option value="5" selected>Shopee Free Shipping (~5%)</option>
                <option value="2.5">Shopee Regular (~2.5%)</option>
                <option value="6">Tokopedia TopAds (~6%)</option>
                <option value="1.5">Tokopedia Regular (~1.5%)</option>
                <option value="2">TikTok Shop (~2%)</option>
                <option value="5">Lazada (~5%)</option>
              </select></div>

            <div class="field"><label>Estimasi Volume Penjualan per Bulan <span class="hint">(opsional, untuk proyeksi)</span></label>
              <input type="number" id="volume" value="100" min="0" /></div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-tag result-placeholder-icon"></i>
              <div class="result-placeholder-title">Harga jual akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi HPP & margin target, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Harga Jual Optimal</div>
                <div class="result-value" id="hargaJual">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="metaInfo">Profit per unit</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">HPP Total</div><div class="result-item-value" id="hppTotal">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Profit/Unit</div><div class="result-item-value result-strong" id="profitUnit">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Fee Marketplace</div><div class="result-item-value result-warn" id="feeAmt">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Margin Real</div><div class="result-item-value" id="marginReal">0%</div></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Bandingkan Berbagai Margin</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Target Margin</th><th class="right">Harga Jual</th><th class="right">Profit/Unit</th></tr></thead>
                    <tbody id="marginBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-cash"></i>&nbsp; Proyeksi Bulanan</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Volume/Bulan</th><th class="right">Omzet</th><th class="right">Profit Bersih</th></tr></thead>
                    <tbody id="proyeksiBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>
              <!-- ===== AI COACH KEPUTUSAN (mandiri) ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Harga sudah pas? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu pas-kan harga & margin</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal harga & margin..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hasil hitunganmu, bukan nasihat bisnis resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

    <EbookPromo calc="harga-jual" headline="Sudah dapat harga jual idealmu? Saatnya raih cuan pertamamu." />

  <section class="content-section">
    <div class="wrap-text">
      <h2>Strategi Pricing UMKM yang Cerdas</h2>
      <p>Salah pricing = bisnis gulung tikar. Banyak UMKM laris tapi rugi karena tidak hitung <strong>fee marketplace + biaya operasional</strong>. Rumus: <strong>Harga Jual = (HPP + Margin Rp) ÷ (1 - Fee%)</strong>. Untuk HPP Rp 20rb, target profit Rp 8rb, fee Shopee 5% → Harga Jual = Rp 29.500. Pahami juga beda <a href="/kalkulator/margin">margin vs markup</a> agar profit akurat. Sudah deal? Buat <a href="/kalkulator/invoice-generator">invoice profesional</a> untuk pelanggan.</p>
      <div class="cta-box"><h3>Hitung Pricing Optimal Produkmu</h3><p>Isi HPP, target margin, marketplace tujuan, klik "Hitung Sekarang" untuk analisa lengkap.</p></div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Harga Jual" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
  <p class="hc-method-note" style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:680px;line-height:1.6;padding:0 1rem;">
    📅 Diperbarui <strong>Juli 2026</strong> · Penetapan harga memakai metode cost-plus &amp; markup atas HPP. Estimasi edukatif; untuk usaha PKP, perhitungkan PPN (efektif 11%, PMK 131/2024). <strong>Sumber:</strong> <a href="https://www.pajak.go.id/" target="_blank" rel="noopener">DJP</a> (PMK 131/2024).
  </p>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { modal: $('modal'), pack: $('packaging'), opex: $('opex'),
                    margin: $('margin'), mp: $('marketplace'), vol: $('volume') };
      [els.modal, els.pack, els.opex].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.quick-btns button').forEach(btn => btn.addEventListener('click', () => { els.margin.value = btn.dataset.m; }));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      function calcHarga(hpp, marginPct, feePct) {
        const m = Math.min(Math.max(marginPct, 0), 95) / 100;  // margin = profit/harga jual, jaga < 100%
        const subtotal = hpp / (1 - m);                         // Harga (sblm fee) = HPP / (1 - margin)
        const profit = subtotal - hpp;
        const harga = subtotal / (1 - feePct / 100);
        const fee = harga * feePct / 100;
        return { harga, profit, fee, profitNet: harga - hpp - fee };
      }

      let lastCalc = null;

      function hitung() {
        const modal = HC.parseRp(els.modal.value);
        const pack = HC.parseRp(els.pack.value);
        const opex = HC.parseRp(els.opex.value);
        const marginPct = parseFloat(els.margin.value) || 0;
        const feePct = parseFloat(els.mp.value) || 0;
        const vol = parseInt(els.vol.value) || 0;

        const hpp = modal + pack + opex;
        if (hpp === 0) { HC.toast('Masukkan modal/HPP dulu', 'error'); return; }

        const { harga, profit, fee, profitNet } = calcHarga(hpp, marginPct, feePct);
        const marginReal = (profitNet / harga) * 100;

        // Round to nearest 100/500 for psychological pricing
        const hargaRounded = Math.ceil(harga / 100) * 100;

        $('hargaJual').textContent = HC.fmt(hargaRounded);
        $('metaInfo').textContent = `Profit/unit: ${HC.fmt(profitNet)} (${marginReal.toFixed(1)}% margin real)`;
        $('hppTotal').textContent = HC.fmt(hpp);
        $('profitUnit').textContent = HC.fmt(profitNet);
        $('feeAmt').textContent = HC.fmt(fee);
        $('marginReal').textContent = marginReal.toFixed(1) + '%';

        const marginComp = [20, 30, 40, 50, 60, 70];
        $('marginBody').innerHTML = marginComp.map(m => {
          const r = calcHarga(hpp, m, feePct);
          return `<tr class="${m === marginPct ? 'active' : ''}"><td>Margin ${m}%</td><td class="right">${HC.fmt(Math.ceil(r.harga / 100) * 100)}</td><td class="right" style="color:var(--green-dark);font-weight:700">${HC.fmt(r.profitNet)}</td></tr>`;
        }).join('');

        const volumes = [50, 100, 250, 500, 1000];
        $('proyeksiBody').innerHTML = volumes.map(v => {
          const omzet = hargaRounded * v;
          const profit = profitNet * v;
          return `<tr class="${v === vol ? 'active' : ''}"><td>${v} unit</td><td class="right">${HC.fmt(omzet)}</td><td class="right" style="color:var(--green-dark);font-weight:700">${HC.fmt(profit)}</td></tr>`;
        }).join('');

        lastCalc = { modal, pack, opex, hpp, marginPct, feePct, harga: hargaRounded, profitNet, fee, marginReal, vol,
                     mpLabel: els.mp.options[els.mp.selectedIndex].text };
        if (HC.history) HC.history.push('harga-jual', { inputs: HC.history.capture(['modal','packaging','opex','margin','marketplace','volume']), summary: 'Modal ' + HC.fmt(lastCalc.modal) + ' \u00b7 margin ' + lastCalc.marginPct + '%', metrics: [{ k: 'Harga jual', v: HC.fmt(lastCalc.harga) }, { k: 'Profit/unit', v: HC.fmt(lastCalc.profitNet) }] });
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Harga jual berhasil dihitung!');
      }

      function reset() {
        els.modal.value = '15.000'; els.pack.value = '2.000'; els.opex.value = '3.000';
        els.margin.value = '40'; els.mp.value = '5'; els.vol.value = '100';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const profitBulan = c.vol ? c.profitNet * c.vol : 0;
        const insight = c.marginReal >= 30
          ? `Margin real ${c.marginReal.toFixed(1)}% — SEHAT! ${c.vol ? `Proyeksi profit ${HC.fmt(profitBulan)}/bulan dengan volume ${c.vol} unit.` : ''}`
          : `Margin real ${c.marginReal.toFixed(1)}% — TIPIS. Pertimbangkan naikkan margin atau cari supplier lebih murah.`;

        return HC.buildReportCard({
          title: '🏷️ Penentuan Harga Jual UMKM',
          color: '#EC4899', color2: '#9D174D',
          heroLabel: 'Harga Jual Optimal',
          heroValue: HC.fmt(c.harga),
          heroSubtext: `Profit ${HC.fmt(c.profitNet)}/unit · Margin real ${c.marginReal.toFixed(1)}%`,
          inputs: [
            { label: '🥫 Modal/Bahan', value: HC.fmt(c.modal) },
            { label: '📦 Packaging', value: HC.fmt(c.pack) },
            { label: '⚡ Operasional', value: HC.fmt(c.opex) },
            { label: '🎯 Target Margin', value: `${c.marginPct}%` },
            { label: '🛒 Marketplace', value: c.mpLabel },
          ],
          results: [
            { label: 'Harga Jual', value: HC.fmt(c.harga), highlight: true },
            { label: 'HPP Total', value: HC.fmt(c.hpp) },
            { label: 'Profit per Unit', value: HC.fmt(c.profitNet), highlight: true },
            { label: 'Fee Marketplace', value: HC.fmt(c.fee) },
            { label: 'Margin Real', value: `${c.marginReal.toFixed(1)}%` },
            { label: `Profit ${c.vol} unit/bln`, value: HC.fmt(profitBulan) },
          ],
          insight, slug: 'harga-jual',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🏷️ *Harga Jual UMKM - HitungCerdas*\n\nHPP: ${HC.fmt(c.hpp)}\nMargin target: ${c.marginPct}%\nFee: ${c.mpLabel}\n\n💰 *Harga Jual: ${HC.fmt(c.harga)}*\n📊 Profit/Unit: ${HC.fmt(c.profitNet)} (${c.marginReal.toFixed(1)}%)\n💵 Profit ${c.vol} unit: ${HC.fmt(c.profitNet * c.vol)}/bln\n\nHitung: https://hitungcerdas.net/kalkulator/harga-jual`;
      }

            function renderHist() {
        if (HC.history) HC.history.render('harga-jual', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'harga-jual-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'harga-jual'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'harga-jual-' + Date.now()); });
    });
  })();
</script>
<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#FDF2F8;border:1px solid #FBCFE8;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#FCE7F3}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#EC4899;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#FDF2F8;color:#EC4899;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#FDF2F8;color:#EC4899;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#FDF2F8;color:#EC4899;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#EC4899;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#EC4899;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#9D174D;border-color:#9D174D;background:#FDF2F8}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#FDF2F8;color:#EC4899;border:1px solid #FBCFE8;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#FCE7F3}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#EC4899}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#EC4899;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#F9A8D4}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#F9A8D4}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#F9A8D4}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#F9A8D4}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(236,72,153,.16);color:#F9A8D4;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(236,72,153,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#F472B6}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}
</style>
<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        var mp=$('marketplace'); var mpLabel='';
        try{ mpLabel=mp.options[mp.selectedIndex].text.replace(/\s*\(.*\)\s*/,'').trim(); }catch(e){}
        return {
          hargaJual:(($('hargaJual')||{}).textContent||'').trim(),
          hargaNum:HC.parseRp((($('hargaJual')||{}).textContent||'0')),
          marginReal:parseFloat((($('marginReal')||{}).textContent||'0'))||0,
          profitUnit:(($('profitUnit')||{}).textContent||'').trim(),
          hppTotal:(($('hppTotal')||{}).textContent||'').trim(),
          feeAmt:(($('feeAmt')||{}).textContent||'').trim(),
          modal:($('modal')||{}).value||'', packaging:($('packaging')||{}).value||'', opex:($('opex')||{}).value||'',
          marginTarget:($('margin')||{}).value||'', marketplace:mpLabel, volume:($('volume')||{}).value||''
        };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-tag"></i> Harga Jual'+(d.marketplace?(' \u00b7 '+esc(d.marketplace)):'')
          +(d.hargaNum?' \u00b7 <b>'+esc(d.hargaJual)+'</b>':'')
          +(d.marginReal?' \u00b7 Margin real <b>'+d.marginReal.toFixed(1)+'%</b>':'')+'</div>';
        if(!d.hargaNum){ ground.innerHTML=ctx+'<div class="aic-nogauge">Klik "Hitung Sekarang" dulu untuk lihat gauge margin.</div>'; return; }
        var mr=d.marginReal, pos=Math.max(0,Math.min(mr,60))/60*100;
        var vc=mr<=15?'bad':(mr<=40?'good':'warn');
        var vi=mr<=15?'ti-alert-circle':(mr<=40?'ti-circle-check':'ti-alert-triangle');
        var vt=mr<=15?'Margin real tipis \u2014 rawan rugi bila ada biaya tak terduga':(mr<=40?'Margin real sehat \u2014 zona umum kebanyakan UMKM':'Margin real tebal \u2014 untung besar, pastikan harga tetap kompetitif');
        ground.innerHTML=ctx
          +'<div class="aic-gauge"><div class="aic-gauge-mark" style="left:'+pos.toFixed(1)+'%"><span>'+mr.toFixed(0)+'%</span></div>'
          +'<div class="aic-gauge-bar"><div class="z-red" style="flex:15"></div><div class="z-green" style="flex:25"></div><div class="z-amber" style="flex:20"></div></div>'
          +'<div class="aic-gauge-lbl"><span class="r">Tipis &le;15%</span><span class="g">Sehat</span><span class="a">Tebal &gt;40%</span></div></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Penetapan Harga Jual (cost-plus) untuk produk UMKM.',
          'Komponen HPP: modal/bahan Rp '+d.modal+' + kemasan Rp '+d.packaging+' + operasional per unit Rp '+d.opex+' = HPP total '+d.hppTotal+'.',
          'Target margin diisi: '+d.marginTarget+'%. Kanal/marketplace: '+(d.marketplace||'-')+' (fee '+d.feeAmt+'/unit).',
          'Hasil: harga jual optimal '+d.hargaJual+', profit bersih per unit '+d.profitUnit+', margin real '+d.marginReal.toFixed(1)+'% (profit terhadap harga jual, sudah dikurangi fee).',
          'Acuan untuk jawabanmu: harga di sini pakai metode cost-plus \u2014 Harga = HPP / (1 \u2212 margin), lalu dinaikkan agar menutup fee marketplace: Harga = HPP / ((1 \u2212 margin) \u00d7 (1 \u2212 fee)). Bedakan margin (profit \u00f7 harga jual) dan markup (profit \u00f7 HPP): margin selalu lebih kecil dari markup untuk profit yang sama; banyak orang keliru menyebut markup sebagai margin. Benchmark margin sehat BERBEDA per industri: fashion 30-50%, F&B/kuliner 40-60%, beauty/skincare 50-70%, handmade/craft 50-75%, digital/jasa 70-90%, sedangkan grocery/retail 5-15% itu WAJAR karena mengandalkan volume tinggi \u2014 jadi jangan menghakimi margin tanpa tahu industrinya. Pertimbangkan juga harga psikologis (mis. Rp 29.900 terasa lebih murah dari Rp 30.000), harga kompetitor, daya beli target pasar, dan biaya tersembunyi yang sering lupa (ongkir ditanggung, retur, promo/diskon, sampel). Cara naikkan margin tanpa naikkan harga: tekan HPP (nego supplier, kurangi waste), naikkan nilai per transaksi (bundling), atau dorong penjualan langsung agar tak kena fee marketplace. Untuk usaha PKP, harga jual sudah termasuk PPN (2026 efektif 11% untuk barang non-mewah via mekanisme DPP PMK 131/2024). Jawab ringkas, hangat, pakai sapaan "kamu", dan jangan mengarang angka di luar data.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function typeInto(bubble, text, done){ var n=0, len=text.length, step=Math.max(2, Math.round(len/90)); var t=setInterval(function(){ n=Math.min(len, n+step); bubble.innerHTML=mdToHtml(text.slice(0,n)); msgs.scrollTop=msgs.scrollHeight; if(n>=len){ clearInterval(t); done&&done(); } }, 18); }
      function mkCopyBtn(text){ var b=document.createElement('button'); b.type='button'; b.className='aic-copy'; b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>'; b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); }); return b; }
      function addMsgTyped(text){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); }); return row; }
      var FOLLOWUPS=['Harga ini masuk akal gak?','Margin real segini sehat?','Bedanya margin sama markup apa?','Gimana biar tetap untung tapi kompetitif?','Harga psikologis itu apa?','Margin bagus untuk usahaku berapa?','Fee marketplace bikin rugi gak?','Cara naikin margin tanpa naikin harga?'];
      function renderFollowups(){ chips.innerHTML=''; var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;}); var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;}); pool.slice(0,3).forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b); }); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Harga ini masuk akal gak?','Margin real segini sehat?','Bedanya margin sama markup apa?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },800); }); }
    });
  })();
</script>
