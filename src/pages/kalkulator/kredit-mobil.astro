---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('kredit-mobil')!;
const related = getRelatedCalculators('kredit-mobil', 3);

const faqs = [
  { question: 'Apa itu TCO (Total Cost of Ownership) mobil?', answer: 'TCO mobil = total biaya kepemilikan mobil per bulan, bukan cuma cicilan. Komponen: cicilan + bensin + tol + parkir + servis berkala + pajak STNK + asuransi all-risk + cuci. Untuk mobil Rp 280 juta dengan cicilan Rp 5.5 juta, TCO bulanan bisa Rp 9-11 juta. Aturan: TCO MAKSIMAL 40% gaji.' },
  { question: 'Berapa DP minimum kredit mobil di Indonesia?', answer: 'DP minimum kredit mobil per OJK: <strong>20-30% dari OTR</strong>. Showroom sering promo "DP 15%" dengan syarat bunga lebih tinggi. Idealnya DP <strong>30%+</strong> agar bunga total tidak membengkak.' },
  { question: 'Bunga kredit mobil di Indonesia berapa?', answer: 'Bunga flat kredit mobil <strong>5-9% per tahun</strong> (Maybank Finance, ACC, BCA Finance, Mandiri Tunas Finance, Astra Credit). Lebih rendah dari motor karena nominal lebih besar.' },
  { question: 'Berapa total biaya kepemilikan mobil per bulan?', answer: 'Selain cicilan, TCO bulanan mobil: <strong>Bensin</strong> Rp 1.5-3 juta (tergantung jarak), <strong>Tol/parkir</strong> Rp 300-700rb, <strong>Servis berkala</strong> Rp 350-550rb, <strong>Asuransi All Risk</strong> Rp 700rb-1,2jt/bln (~3,5% nilai mobil/thn), <strong>Pajak STNK</strong> Rp 200-400rb/bln, <strong>Cuci</strong> Rp 100rb. Total: TCO biasanya <strong>1.5-2× cicilan</strong>.' },
  { question: 'Mobil listrik (EV) lebih hemat?', answer: 'YA, jangka panjang sangat hemat: (1) <strong>Bensin</strong>: EV cuma ~Rp 500rb-1jt/bln (charging) vs ICE Rp 2-3jt/bln. (2) <strong>Insentif PPN DTP</strong>: sebagian mobil listrik (BEV, TKDN &ge;40%) bayar PPN efektif ~1% (bukan 12%), hemat puluhan juta &mdash; tapi tak semua model dapat &amp; skema bisa berubah, cek model yang kamu incar. (3) <strong>Servis lebih murah</strong>: tidak ada oli mesin, tune-up jarang. (4) <strong>Tidak kena ganjil-genap</strong> di Jakarta. Cocok untuk komuter urban yang charging di rumah malam.' },
  { question: 'Beli mobil baru atau bekas yang lebih untung?', answer: '<strong>Mobil baru</strong>: Garansi 3-5 tahun, fitur lengkap, depresiasi 20-25% di tahun pertama. <strong>Mobil bekas</strong> (3-5 thn): Harga 50-70% mobil baru, depresiasi sudah jeda, tapi risiko biaya servis lebih tinggi. <strong>Sweet spot</strong>: bekas 2-3 tahun dari pemilik pertama yang terawat.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#0891B2;--cat-color2:#155E75">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#CFFAFE;color:#155E75"><i class="ti ti-car"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">Kalkulator Kredit Mobil + TCO Lengkap 2026</h1>
          <p class="calc-hero-sub">{calc.introText} Dilengkapi <strong>TCO (Total Cost of Ownership)</strong> akurat: bensin, tol, parkir, servis, pajak STNK, asuransi all-risk, dan biaya bulanan lengkap.</p>
          <ul class="calc-hero-benefits">
            <li><i class="ti ti-check"></i> Cicilan bunga flat akurat</li>
            <li><i class="ti ti-check"></i> TCO bulanan komprehensif</li>
            <li><i class="ti ti-check"></i> 5 tipe mobil (LCGC, MPV, SUV, EV, Premium)</li>
            <li><i class="ti ti-check"></i> 4 profil pemakaian (Weekender → Heavy User)</li>
            <li><i class="ti ti-check"></i> Bandingkan EV vs Bensin</li>
            <li><i class="ti ti-check"></i> Mode skenario inflasi</li>
          </ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M40 130L50 95L75 80L125 80L150 95L160 130L160 145L40 145Z" fill="#FFF" stroke="#FBBF24" stroke-width="2"/>
            <circle cx="65" cy="145" r="14" fill="#1E293B" stroke="#FBBF24" stroke-width="2"/>
            <circle cx="135" cy="145" r="14" fill="#1E293B" stroke="#FBBF24" stroke-width="2"/>
            <rect x="80" y="90" width="40" height="20" fill="#CFFAFE" stroke="#155E75" stroke-width="1.5"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#0891B2 0%,#155E75 100%)"><i class="ti ti-car"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Kredit Mobil + TCO</h2><p class="calc-card-sub">Cicilan + Biaya Bulanan Lengkap (Bensin/Tol/Servis/Asuransi)</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Harga OTR Mobil</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="harga" class="has-prefix" value="280.000.000" inputmode="numeric" /></div></div>

            <div class="field"><label>DP (Down Payment)</label>
              <div class="input-wrap"><input type="number" id="dp" class="has-suffix" value="25" step="1" min="0" max="100" /><span class="input-suffix">%</span></div>
              <div class="quick-btns">
                <button type="button" data-dp="20">20%</button><button type="button" data-dp="25">25%</button>
                <button type="button" data-dp="30">30%</button><button type="button" data-dp="40">40%</button>
                <button type="button" data-dp="50">50%</button>
              </div></div>

            <div class="field"><label>Bunga Flat per Tahun</label>
              <div class="input-wrap"><input type="number" id="bunga" class="has-suffix" value="7" step="0.5" min="0" /><span class="input-suffix">%</span></div>
              <p class="field-hint">Bunga flat leasing mobil: 5-9% per tahun</p></div>

            <div class="field"><label>Tenor (Lama Cicilan)</label>
              <select id="tenor">
                <option value="12">12 bulan (1 tahun)</option>
                <option value="24">24 bulan (2 tahun)</option>
                <option value="36" selected>36 bulan (3 tahun)</option>
                <option value="48">48 bulan (4 tahun)</option>
                <option value="60">60 bulan (5 tahun)</option>
                <option value="72">72 bulan (6 tahun)</option>
              </select></div>

            {/* ─── TCO PROFILE SELECTORS ─── */}
            <div class="tco-profile-box">
              <label>🚗 Tipe Mobil</label>
              <select id="mobilType">
                <option value="lcgc">LCGC (Ayla/Calya/Brio/Sigra)</option>
                <option value="mpv" selected>MPV / City Car (Avanza/Xpander/Ertiga/Mobilio)</option>
                <option value="suv">SUV (HR-V/Rush/Fortuner/Pajero)</option>
                <option value="premium">Premium (Innova Zenix/Alphard/Camry)</option>
                <option value="ev">⚡ Mobil Listrik (Wuling Air/Ioniq/BYD/Atto 3)</option>
              </select>
              <p class="hint-text">Tipe mobil menentukan konsumsi BBM, biaya servis & pajak</p>
            </div>

            <div class="tco-profile-box">
              <label>📍 Profil Pemakaian</label>
              <select id="usageProfile">
                <option value="weekender">Weekender (≤1000 km/bln) — Weekend trip family</option>
                <option value="komuter" selected>Komuter (~1500 km/bln) — Kerja PP + weekend</option>
                <option value="aktif">Aktif (~2500 km/bln) — Sales / sering perjalanan</option>
                <option value="berat">Berat (≥4000 km/bln) — Rental / driver online</option>
              </select>
              <p class="hint-text">Profil ini auto-adjust bensin, tol, dan parkir di TCO</p>
            </div>

            <div class="tco-profile-box">
              <label>🛣️ Wilayah Pemakaian</label>
              <select id="wilayah">
                <option value="jakarta">DKI Jakarta (Tol mahal, parkir mall)</option>
                <option value="surabaya">Surabaya / Bandung</option>
                <option value="lainnya" selected>Kota lain Indonesia</option>
              </select>
              <p class="hint-text">Pengaruh besar di biaya tol & parkir</p>
            </div>

            {/* ─── INFLATION TOGGLE ─── */}
            <div class="inflation-box" id="inflationBox">
              <label class="inflation-toggle">
                <input type="checkbox" id="inflasiToggle" />
                <span>🔥 Aktifkan Mode Skenario Inflasi</span>
              </label>
              <div class="inflation-options">
                <label>Skenario Inflasi:</label>
                <select id="inflasiSkenario">
                  <option value="rendah">📉 Rendah (3.0%)</option>
                  <option value="normal" selected>📊 Normal (4.5%)</option>
                  <option value="tinggi">📈 Tinggi (6.0%)</option>
                  <option value="krisis">⚠️ Krisis (8.0%)</option>
                </select>
                <p class="inflation-note">Tenor mobil panjang (5-6 thn), risiko bunga naik tinggi karena inflasi.</p>
              </div>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-car result-placeholder-icon"></i>
              <div class="result-placeholder-title">Cicilan + TCO Mobil akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi data mobil, klik <strong>"Hitung Sekarang"</strong> untuk simulasi cicilan + TCO bulanan komprehensif.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Cicilan Per Bulan</div>
                <div class="result-value" id="cicilan">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="metaInfo">0 bulan</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">DP + Biaya Awal</div><div class="result-item-value" id="biayaAwal">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Pokok Pinjaman</div><div class="result-item-value" id="pokok">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Bunga</div><div class="result-item-value result-warn" id="totalBunga">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Bayar</div><div class="result-item-value result-strong" id="totalBayar">Rp 0</div></div>
              </div>

              {/* ─── TCO BOX ─── */}
              <div class="tco-box">
                <h4><i class="ti ti-receipt-2"></i> Total Cost of Ownership (TCO) Bulanan</h4>
                <ul class="tco-list" id="tcoList"></ul>
                <div id="tcoWarning"></div>
              </div>

              {/* TENOR COMPARISON */}
              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Bandingkan Semua Tenor</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Tenor</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bunga</th><th class="right">Total Bayar</th></tr></thead>
                    <tbody id="tenorBody"></tbody>
                  </table>
                </div>
              </div>

              {/* COMPARE MOBIL TYPES */}
              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-arrows-right-left"></i>&nbsp; Bandingkan TCO 5 Tipe Mobil</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Tipe Mobil</th><th class="right">Bensin/Bln</th><th class="right">TCO Total/Bln</th></tr></thead>
                    <tbody id="mobilCompareBody"></tbody>
                  </table>
                  <p class="bank-disclaimer">⚡ <strong>Mobil listrik (EV)</strong> untuk komuter urban yang charging di rumah malam paling hemat. Plus banyak model mobil listrik (BEV, TKDN tinggi) dapat insentif PPN DTP &mdash; cek apakah model incaranmu termasuk. Pastikan juga rute kamu ada stasiun pengisian (SPKLU).</p>
                </div>
              </div>

              {/* INFLASI COMPARE */}
              <div class="adv-section" id="advInflasi" style="display:none">
                <div class="adv-toggle"><span><i class="ti ti-trending-up"></i>&nbsp; Dampak Inflasi terhadap Bunga</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Skenario</th><th class="right">Bunga</th><th class="right">Cicilan/Bulan</th><th class="right">Total Bayar</th></tr></thead>
                    <tbody id="inflasiBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-trending-down"></i>&nbsp; Proyeksi Nilai Jual (Depresiasi)</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Usia</th><th class="right">Estimasi Nilai Jual</th><th class="right">Penyusutan</th></tr></thead>
                    <tbody id="depresiasiBody"></tbody>
                  </table>
                  <p id="depresiasiNote" style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5"></p>
                </div>
              </div>

              <div class="adv-section" id="evBlock">
                <div class="adv-toggle"><span><i class="ti ti-bolt"></i>&nbsp; EV vs Bensin — hemat 5 tahun</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
                    <div class="field" style="margin-bottom:8px"><label>Jarak per Hari</label>
                      <div class="input-wrap"><input type="number" id="evJarak" class="has-suffix" value="40" step="5" min="1" /><span class="input-suffix">km</span></div></div>
                    <div class="field" style="margin-bottom:8px"><label>Selisih Harga Beli EV</label>
                      <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="evPremi" class="has-prefix" value="100.000.000" inputmode="numeric" /></div></div>
                    <div class="field" style="margin-bottom:8px"><label>Harga BBM (Rp/L)</label>
                      <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="evBbm" class="has-prefix" value="16.250" inputmode="numeric" /></div></div>
                    <div class="field" style="margin-bottom:8px"><label>Konsumsi Bensin</label>
                      <div class="input-wrap"><input type="number" id="evKmL" class="has-suffix" value="12" step="1" min="1" /><span class="input-suffix">km/L</span></div></div>
                    <div class="field" style="margin-bottom:8px"><label>Harga Listrik (Rp/kWh)</label>
                      <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="evListrik" class="has-prefix" value="1.700" inputmode="numeric" /></div></div>
                    <div class="field" style="margin-bottom:8px"><label>Konsumsi Listrik</label>
                      <div class="input-wrap"><input type="number" id="evKmKwh" class="has-suffix" value="7" step="1" min="1" /><span class="input-suffix">km/kWh</span></div></div>
                  </div>
                  <button type="button" class="btn-reset" id="btnEV" style="width:100%"><i class="ti ti-bolt"></i> Bandingkan EV vs Bensin</button>
                  <div id="evResult" style="display:none;margin-top:10px"></div>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 Termasuk asumsi servis & pajak/tahun: servis bensin Rp 2,5jt vs EV Rp 1jt · pajak bensin Rp 3jt vs EV Rp 1,5jt. EV unggul di biaya energi & servis; pertimbangkan juga umur baterai. Listrik & BBM bisa kamu sesuaikan.</p>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
              </div>

              <!-- ===== AI COACH KEPUTUSAN (mandiri) ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung sama hasilnya? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu pahami biaya mobilmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal kredit mobilmu..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hasil hitunganmu, bukan nasihat keuangan berlisensi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Strategi Pintar Beli Mobil: Mind the TCO!</h2>
      <p>Mobil bukan hanya tentang cicilan bulanan. <strong>Total Cost of Ownership (TCO)</strong> = cicilan + bensin + tol + parkir + servis + asuransi + pajak. TCO biasanya <strong>1.5-2× cicilan</strong>. Untuk mobil Rp 280jt cicilan Rp 6,5jt/bln, TCO bisa Rp 10-13jt/bln. Pastikan TCO maksimal <strong>40% gaji</strong>. Budget lebih ketat? Bandingkan dengan <a href="/kalkulator/kredit-motor">simulasi kredit motor</a>. Sebelum berkomitmen cicilan besar, cek dulu kesiapan <a href="/kalkulator/dana-darurat">dana darurat</a> kamu.</p>

      <h3>Komponen TCO Mobil per Bulan</h3>
      <ul class="info-list">
        <li>🏦 <strong>Cicilan</strong> — Pokok + bunga flat</li>
        <li>⛽ <strong>Bensin / Listrik</strong> — Tergantung mobil & profil pemakaian (Rp 500rb-3jt)</li>
        <li>🛣️ <strong>Tol & parkir</strong> — Khusus DKI Jakarta bisa Rp 700rb/bln</li>
        <li>🔧 <strong>Servis berkala</strong> — Rp 350-550rb/bulan (oli, filter, periodic 10rb km)</li>
        <li>📄 <strong>Pajak STNK + BBN</strong> — 2-3% nilai mobil/tahun</li>
        <li>🛡️ <strong>Asuransi All-Risk</strong> — 3-4% nilai mobil/tahun</li>
        <li>🧽 <strong>Cuci salon</strong> — Rp 100-150rb/bulan</li>
        <li>🚨 <strong>Dana darurat servis</strong> — Rp 250rb/bulan (untuk masalah tak terduga)</li>
      </ul>

      <h3>Tips Cerdas Sebelum Ambil Kredit Mobil</h3>
      <ol class="tips-list">
        <li><strong>Hitung TCO, bukan cicilan</strong> — TCO maksimal 40% gaji. Cicilan saja maksimal 25%.</li>
        <li><strong>Pertimbangkan EV untuk komuter urban</strong> — Banyak model dapat insentif PPN DTP (cek kelayakan) + bensin hemat 70%.</li>
        <li><strong>Mobil baru depresiasi 20-25% di tahun 1</strong> — Beli mobil bekas 2-3 thn lebih value-for-money.</li>
        <li><strong>Asuransi All-Risk wajib untuk mobil kredit</strong> — Bank biasanya minta. Premi sekitar 3-4% nilai mobil (estimasi konservatif).</li>
        <li><strong>Bayar pajak STNK on time</strong> — Telat = denda 25%/tahun + bisa di-tilang.</li>
        <li><strong>Servis berkala 10rb km</strong> — Lebih murah daripada turun mesin (Rp 5-15 juta).</li>
      </ol>

      <div class="cta-box">
        <h3>Hitung TCO Mobilmu Sekarang</h3>
        <p>Pilih tipe mobil, profil pemakaian, dan wilayah — klik "Hitung Sekarang" untuk lihat biaya bulanan KOMPLIT (bukan cuma cicilan).</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Kredit Mobil & TCO" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>

  <p style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:600px;">
    📅 Data & tarif diperbarui <strong>Juni 2026</strong> · Sumber: <a href="https://www.pertamina.com/" target="_blank" rel="noopener">Pertamina</a>, <a href="https://www.pln.co.id/" target="_blank" rel="noopener">PLN</a>, <a href="https://www.bi.go.id/" target="_blank" rel="noopener">Bank Indonesia</a>
  </p>
<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EFF4FF;border:1px solid #C7DBFF;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E4EDFF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#2563EB;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EFF4FF;color:#2563EB;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#2563EB;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#2563EB;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#0891B2;border-color:#0891B2;background:#ECFEFF}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#EFF4FF;color:#2563EB;border:1px solid #D6E4FF;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#E0EBFF}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#2563EB}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#2563EB;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#8FB4FF}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#8FB4FF}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(37,99,235,.16);color:#8FB4FF;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(37,99,235,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#3B82F6}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}

  /* ==== TCO comparison bars + verdict info ==== */
  .aic-cmp{margin-top:2px}
  .aic-cmp-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
  .aic-cmp-lbl{font-size:10.5px;width:72px;flex-shrink:0;color:#64748B}
  .aic-cmp-track{flex:1;height:19px;border-radius:5px;background:#EEF2F7;position:relative;overflow:hidden}
  .aic-cmp-fill{height:100%;border-radius:5px}
  .aic-cmp-fill.cic{background:#DBEAFE}
  .aic-cmp-fill.tco{background:#2563EB}
  .aic-cmp-val{position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:11px;font-weight:700}
  .aic-cmp-val.on-light{color:#1E40AF}
  .aic-cmp-val.on-dark{color:#fff}
  .aic-verdict.info{color:#2563EB}
  .aic-verdict b{font-weight:700}
  .aic-dark .aic-cmp-lbl{color:#93A4B8}
  .aic-dark .aic-cmp-track{background:#1C2D46}
  .aic-dark .aic-cmp-fill.cic{background:#24406B}
  .aic-dark .aic-cmp-fill.tco{background:#3B82F6}
  .aic-dark .aic-cmp-val.on-light{color:#BFD4FF}
  .aic-dark .aic-verdict.info{color:#8FB4FF}
</style>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { harga: $('harga'), dp: $('dp'), bunga: $('bunga'), tenor: $('tenor'),
                    mobilType: $('mobilType'), usageProfile: $('usageProfile'), wilayah: $('wilayah'),
                    inflasiToggle: $('inflasiToggle'), inflasiSkenario: $('inflasiSkenario'),
                    inflasiBox: $('inflationBox'), advInflasi: $('advInflasi') };
      [els.harga].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.quick-btns button').forEach(btn => btn.addEventListener('click', () => { els.dp.value = btn.dataset.dp; }));
      els.inflasiToggle.addEventListener('change', () => els.inflasiBox.classList.toggle('active', els.inflasiToggle.checked));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      function flat(pokok, bungaTahun, totalBulan) {
        const totalBunga = pokok * (bungaTahun / 100) * (totalBulan / 12);
        return { cicilan: (pokok + totalBunga) / totalBulan, totalBunga };
      }

      // TCO data per mobil type
      const MOBIL_TYPE_DATA = {
        lcgc:    { kmpl: 16, servisBulan: 290000, pajakRate: 0.018, asuransiRate: 0.030, label: 'LCGC' },
        mpv:     { kmpl: 13, servisBulan: 400000, pajakRate: 0.02,  asuransiRate: 0.035, label: 'MPV / City Car' },
        suv:     { kmpl: 10, servisBulan: 520000, pajakRate: 0.022, asuransiRate: 0.038, label: 'SUV' },
        premium: { kmpl: 8,  servisBulan: 800000, pajakRate: 0.025, asuransiRate: 0.040, label: 'Premium' },
        ev:      { kmpl: 0,  servisBulan: 290000, pajakRate: 0.005, asuransiRate: 0.030, label: 'Mobil Listrik', isElectric: true, kwhPerKm: 0.18 }, // 0.18 kWh/km
      };

      const USAGE_PROFILE = {
        weekender: { kmBulan: 800,  label: 'Weekender (≤1000 km/bln)' },
        komuter:   { kmBulan: 1500, label: 'Komuter (~1500 km/bln)' },
        aktif:     { kmBulan: 2500, label: 'Aktif (~2500 km/bln)' },
        berat:     { kmBulan: 4000, label: 'Berat (≥4000 km/bln)' },
      };

      const WILAYAH = {
        jakarta:  { tolParkirBulan: 700000, label: 'DKI Jakarta' },
        surabaya: { tolParkirBulan: 350000, label: 'Surabaya / Bandung' },
        lainnya:  { tolParkirBulan: 200000, label: 'Kota lain Indonesia' },
      };

      const BBM_PRICE = 16250; // Pertamax
      const LISTRIK_PRICE = 1445; // PLN R-1

      function calcTCO(harga, mobilTypeKey, usageProfileKey, wilayahKey, cicilanBulan) {
        const mobil = MOBIL_TYPE_DATA[mobilTypeKey];
        const usage = USAGE_PROFILE[usageProfileKey];
        const wil = WILAYAH[wilayahKey];
        const kmBulan = usage.kmBulan;

        let bensinBulan = 0, bensinLabel = '';
        if (mobil.isElectric) {
          const kwhBulan = kmBulan * mobil.kwhPerKm;
          bensinBulan = kwhBulan * LISTRIK_PRICE;
          bensinLabel = `${kwhBulan.toFixed(0)} kWh × Rp ${LISTRIK_PRICE.toLocaleString('id-ID')}/kWh`;
        } else {
          const literBulan = kmBulan / mobil.kmpl;
          bensinBulan = literBulan * BBM_PRICE;
          bensinLabel = `${literBulan.toFixed(0)} L × Rp ${BBM_PRICE.toLocaleString('id-ID')}/L (${mobil.kmpl} km/L)`;
        }

        const pajakBulan = harga * mobil.pajakRate / 12;
        const asuransiBulan = harga * mobil.asuransiRate / 12;
        const tolParkirBulan = wil.tolParkirBulan * (kmBulan / 1500); // scale by usage
        const servisBulan = mobil.servisBulan;
        const cuciBulan = 140000;
        const danaDarurat = 250000;

        const totalTCO = cicilanBulan + bensinBulan + servisBulan + pajakBulan + asuransiBulan + tolParkirBulan + cuciBulan + danaDarurat;

        return {
          cicilan: cicilanBulan,
          bensin: bensinBulan,
          bensinLabel,
          servis: servisBulan,
          pajak: pajakBulan,
          asuransi: asuransiBulan,
          tolParkir: tolParkirBulan,
          cuci: cuciBulan,
          danaDarurat,
          totalTCO,
          isElectric: mobil.isElectric,
        };
      }

      let lastCalc = null;

      function hitung() {
        const harga = HC.parseRp(els.harga.value);
        const dpPct = parseFloat(els.dp.value) || 0;
        let bunga = parseFloat(els.bunga.value) || 0;
        const tenor = parseInt(els.tenor.value);
        const mobilTypeKey = els.mobilType.value;
        const usageKey = els.usageProfile.value;
        const wilayahKey = els.wilayah.value;

        if (harga === 0) { HC.toast('Masukkan harga mobil dulu', 'error'); return; }

        const useInflasi = els.inflasiToggle.checked;
        let bungaOriginal = bunga, skenario = null;
        if (useInflasi) { skenario = els.inflasiSkenario.value; bunga = HC.adjustInterestRate(bunga, skenario); }

        const dpAmt = harga * (dpPct / 100);
        const bbn = harga * 0.10;
        const asuransiThn1 = harga * 0.03;
        const biayaAwal = dpAmt + bbn + asuransiThn1;
        const pokok = harga - dpAmt;
        const { cicilan, totalBunga } = flat(pokok, bunga, tenor);
        const totalBayar = biayaAwal + cicilan * tenor;

        const tco = calcTCO(harga, mobilTypeKey, usageKey, wilayahKey, cicilan);

        $('cicilan').textContent = HC.fmt(cicilan);
        $('metaInfo').textContent = `${tenor} bulan · Bunga flat ${bunga.toFixed(2)}%${useInflasi ? ' (inflasi-adjusted)' : ''}`;
        $('biayaAwal').textContent = HC.fmt(biayaAwal);
        $('pokok').textContent = HC.fmt(pokok);
        $('totalBunga').textContent = HC.fmt(totalBunga);
        $('totalBayar').textContent = HC.fmt(totalBayar);

        // TCO display
        const electricBadge = tco.isElectric ? '⚡' : '⛽';
        $('tcoList').innerHTML = `
          <li class="tco-cicilan">
            <span class="ico">🏦</span>
            <span class="lbl">Cicilan Kredit
              <span class="lbl-hint">${tenor} bulan, bunga ${bunga.toFixed(2)}% flat</span>
            </span>
            <span class="val">${HC.fmt(tco.cicilan)}</span>
          </li>
          <li>
            <span class="ico">${electricBadge}</span>
            <span class="lbl">${tco.isElectric ? 'Listrik (charging)' : 'Bensin (Pertamax)'}
              <span class="lbl-hint">${tco.bensinLabel}</span>
            </span>
            <span class="val">${HC.fmt(tco.bensin)}</span>
          </li>
          <li>
            <span class="ico">🔧</span>
            <span class="lbl">Servis berkala
              <span class="lbl-hint">Oli, filter, tune-up (10rb km)</span>
            </span>
            <span class="val">${HC.fmt(tco.servis)}</span>
          </li>
          <li>
            <span class="ico">🛣️</span>
            <span class="lbl">Tol & parkir
              <span class="lbl-hint">${WILAYAH[wilayahKey].label}, scaled by usage</span>
            </span>
            <span class="val">${HC.fmt(tco.tolParkir)}</span>
          </li>
          <li>
            <span class="ico">📄</span>
            <span class="lbl">Pajak STNK
              <span class="lbl-hint">${HC.fmt(tco.pajak * 12)}/tahun ÷ 12</span>
            </span>
            <span class="val">${HC.fmt(tco.pajak)}</span>
          </li>
          <li>
            <span class="ico">🛡️</span>
            <span class="lbl">Asuransi All-Risk
              <span class="lbl-hint">${HC.fmt(tco.asuransi * 12)}/tahun (~${(MOBIL_TYPE_DATA[mobilTypeKey].asuransiRate * 100).toFixed(1)}% nilai)</span>
            </span>
            <span class="val">${HC.fmt(tco.asuransi)}</span>
          </li>
          <li>
            <span class="ico">🧽</span>
            <span class="lbl">Cuci salon
              <span class="lbl-hint">Cuci 2× sebulan + salon kuartalan</span>
            </span>
            <span class="val">${HC.fmt(tco.cuci)}</span>
          </li>
          <li>
            <span class="ico">🚨</span>
            <span class="lbl">Dana darurat servis
              <span class="lbl-hint">Untuk masalah tak terduga (ganti aki, dll)</span>
            </span>
            <span class="val">${HC.fmt(tco.danaDarurat)}</span>
          </li>
          <li class="tco-total">
            <span class="ico">💸</span>
            <span class="lbl">TCO TOTAL per Bulan</span>
            <span class="val">${HC.fmt(tco.totalTCO)}</span>
          </li>
        `;

        // TCO warning - assume avg gaji Rp 12 juta (industri profesional)
        const minGaji = tco.totalTCO * 2.5; // TCO max 40% gaji
        let warningHtml = '';
        if (tco.isElectric) {
          const hematPotensi = (tco.totalTCO * 0.15); // estimate hemat 15% jika compared to ICE
          warningHtml = `<div class="tco-warning safe">⚡ <strong>EV Smart Choice!</strong> Mobil listrik hemat bensin 70%, banyak model dapat insentif PPN DTP (PPN efektif ~1%, cek kelayakan), tidak kena ganjil-genap. Cocok untuk komuter urban yang charging di rumah malam.</div>`;
        } else if (tco.totalTCO > 10000000) {
          warningHtml = `<div class="tco-warning">⚠️ <strong>TCO ${HC.fmt(tco.totalTCO)}/bulan sangat besar.</strong> Pastikan gaji minimal ${HC.fmt(minGaji)} agar TCO mobil tidak lebih dari 40% gaji. Pertimbangkan mobil lebih kecil atau bekas.</div>`;
        } else if (tco.totalTCO > 6000000) {
          warningHtml = `<div class="tco-warning">💡 <strong>TCO ${HC.fmt(tco.totalTCO)}/bulan cukup besar.</strong> Pastikan gaji minimal ${HC.fmt(minGaji)}. Siapkan dana darurat 6 bulan TCO.</div>`;
        } else {
          warningHtml = `<div class="tco-warning safe">✅ TCO terjangkau ${HC.fmt(tco.totalTCO)}/bulan. Tetap sisihkan dana darurat 6 bulan TCO.</div>`;
        }
        $('tcoWarning').innerHTML = warningHtml;

        // Tenor comparison
        const tenorOpts = [12, 24, 36, 48, 60, 72];
        $('tenorBody').innerHTML = tenorOpts.map(t => {
          const { cicilan: c, totalBunga: tb } = flat(pokok, bunga, t);
          return `<tr class="${t === tenor ? 'active' : ''}"><td>${t} bln</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(tb)}</td><td class="right">${HC.fmt(c * t + biayaAwal)}</td></tr>`;
        }).join('');

        // Compare mobil types
        const types = ['lcgc', 'mpv', 'suv', 'premium', 'ev'];
        $('mobilCompareBody').innerHTML = types.map(t => {
          const tcoAlt = calcTCO(harga, t, usageKey, wilayahKey, cicilan);
          const lbl = MOBIL_TYPE_DATA[t].label + (t === 'ev' ? ' ⚡' : '');
          return `<tr class="${t === mobilTypeKey ? 'active' : ''}"><td>${lbl}</td><td class="right">${HC.fmt(tcoAlt.bensin)}</td><td class="right" style="font-weight:700">${HC.fmt(tcoAlt.totalTCO)}</td></tr>`;
        }).join('');

        // Inflation comparison
        if (useInflasi) {
          els.advInflasi.style.display = '';
          const scenarios = ['rendah', 'normal', 'tinggi', 'krisis'];
          const labels = { rendah: 'Rendah (3.0%)', normal: 'Normal (4.5%)', tinggi: 'Tinggi (6.0%)', krisis: 'Krisis (8.0%)' };
          $('inflasiBody').innerHTML = scenarios.map(s => {
            const b = HC.adjustInterestRate(bungaOriginal, s);
            const { cicilan: c } = flat(pokok, b, tenor);
            return `<tr class="${s === skenario ? 'active' : ''}"><td>${labels[s]}</td><td class="right">${b.toFixed(2)}%</td><td class="right">${HC.fmt(c)}</td><td class="right">${HC.fmt(c * tenor + biayaAwal)}</td></tr>`;
          }).join('');
        } else {
          els.advInflasi.style.display = 'none';
        }

        // Proyeksi nilai jual (depresiasi) — estimasi, tergantung merk & kondisi
        const deprMobil = [1, 0.82, 0.72, 0.64, 0.57, 0.50, 0.45, 0.40];
        const tenorTahun = Math.round(tenor / 12);
        $('depresiasiBody').innerHTML = deprMobil.slice(1).map((ret, idx) => {
          const th = idx + 1;
          const nilai = harga * ret;
          const susut = harga - nilai;
          const hl = th === tenorTahun ? ' class="active"' : '';
          return `<tr${hl}><td>Tahun ${th}${th === tenorTahun ? ' (lunas)' : ''}</td><td class="right">${HC.fmt(nilai)}</td><td class="right" style="color:var(--red,#DC2626)">-${HC.fmt(susut)} (${((susut / harga) * 100).toFixed(0)}%)</td></tr>`;
        }).join('');
        const nilaiLunas = harga * (deprMobil[Math.min(tenorTahun, deprMobil.length - 1)]);
        $('depresiasiNote').innerHTML = `💡 Saat kredit lunas (~${tenorTahun} thn), mobil diperkirakan laku <b>${HC.fmt(nilaiLunas)}</b> — padahal total yang kamu bayar (biaya awal + cicilan) <b>${HC.fmt(totalBayar)}</b>. Selisihnya adalah "biaya" memiliki mobil. Ini estimasi; merk Jepang (Toyota/Honda) biasanya lebih awet nilai jualnya, mobil Eropa/listrik bisa turun lebih cepat.`;

        lastCalc = { harga, dpPct, dpAmt, biayaAwal, pokok, bunga, bungaOriginal, tenor, cicilan, totalBunga, totalBayar,
                     mobilTypeKey, mobilTypeLabel: MOBIL_TYPE_DATA[mobilTypeKey].label,
                     usageKey, usageLabel: USAGE_PROFILE[usageKey].label,
                     wilayahKey, wilayahLabel: WILAYAH[wilayahKey].label,
                     tco, useInflasi, skenario };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Cicilan + TCO Mobil berhasil dihitung!');
      }


      // ===== EV vs Bensin (5 tahun) =====
      function hitungEV() {
        const jarak = Math.max(1, parseFloat($('evJarak').value) || 40);
        const premi = HC.parseRp($('evPremi').value);
        const bbm = HC.parseRp($('evBbm').value);
        const kmL = Math.max(1, parseFloat($('evKmL').value) || 1);
        const listrik = HC.parseRp($('evListrik').value);
        const kmKwh = Math.max(1, parseFloat($('evKmKwh').value) || 1);
        const SVB = 2500000, SVE = 1000000, PJB = 3000000, PJE = 1500000;
        const kmYr = jarak * 365;
        const eB = kmYr / kmL * bbm, eE = kmYr / kmKwh * listrik;
        const bYr = eB + SVB + PJB, eYr = eE + SVE + PJE;
        const b5 = bYr * 5, e5run = eYr * 5, evTot = e5run + premi;
        const hemat = b5 - evTot, save = bYr - eYr;
        const payback = save > 0 ? premi / save : null;
        const evMenang = hemat >= 0;
        const col = evMenang ? 'var(--green-dark,#047857)' : '#B45309';
        $('evResult').style.display = '';
        $('evResult').innerHTML =
          `<table class="compare-table">`
          + `<thead><tr><th>Selama 5 tahun</th><th class="right">⛽ Bensin</th><th class="right">⚡ EV (Listrik)</th></tr></thead>`
          + `<tbody>`
          + `<tr><td>Energi/tahun</td><td class="right">${HC.fmt(eB)}</td><td class="right" style="color:var(--green-dark)">${HC.fmt(eE)}</td></tr>`
          + `<tr><td>Servis + pajak/tahun</td><td class="right">${HC.fmt(SVB + PJB)}</td><td class="right" style="color:var(--green-dark)">${HC.fmt(SVE + PJE)}</td></tr>`
          + `<tr><td>Total biaya pakai 5 thn</td><td class="right">${HC.fmt(b5)}</td><td class="right">${HC.fmt(e5run)}</td></tr>`
          + `<tr><td>+ Selisih harga beli EV</td><td class="right">—</td><td class="right">${premi > 0 ? '+' + HC.fmt(premi) : 'Rp 0'}</td></tr>`
          + `<tr class="active"><td><b>Total 5 thn</b></td><td class="right"><b>${HC.fmt(b5)}</b></td><td class="right"><b>${HC.fmt(evTot)}</b></td></tr>`
          + `</tbody></table>`
          + `<p style="font-size:13px;margin-top:8px;font-weight:600;color:${col}">${evMenang
              ? '⚡ EV lebih hemat ' + HC.fmt(hemat) + ' dalam 5 tahun.'
              : '⛽ Bensin masih lebih murah ' + HC.fmt(-hemat) + ' dalam 5 tahun (karena selisih harga beli EV).'}</p>`
          + (payback ? `<p style="font-size:12px;color:var(--text-mute);margin-top:4px;line-height:1.5">Hemat biaya pakai EV ≈ ${HC.fmt(save)}/tahun → selisih harga beli balik modal dalam <strong>${payback.toFixed(1)} tahun</strong>${payback > 5 ? ' (di luar 5 thn — EV menang kalau dipakai lebih lama)' : ''}.</p>` : '');
      }
      ['evPremi','evBbm','evListrik'].forEach(function(id){ var e=$(id); if(e) e.addEventListener('input', HC.fmtInput); });
      var btnEV=$('btnEV'); if(btnEV) btnEV.addEventListener('click', hitungEV);

      function reset() {
        els.harga.value = '280.000.000'; els.dp.value = '25'; els.bunga.value = '7';
        els.tenor.value = '36'; els.mobilType.value = 'mpv'; els.usageProfile.value = 'komuter';
        els.wilayah.value = 'lainnya'; els.inflasiToggle.checked = false; els.inflasiBox.classList.remove('active');
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.tco.isElectric
          ? `⚡ Mobil listrik HEMAT! Bensin cuma ${HC.fmt(c.tco.bensin)}/bln vs Rp 2-3jt mobil bensin. Plus banyak model EV dapat insentif PPN DTP (cek kelayakan) + bebas ganjil-genap.`
          : `TCO total ${HC.fmt(c.tco.totalTCO)}/bln. Cicilan cuma ${((c.tco.cicilan / c.tco.totalTCO) * 100).toFixed(0)}% dari TCO. Pastikan gaji minimal ${HC.fmt(c.tco.totalTCO * 2.5)} (TCO max 40% gaji).`;

        const inputs = [
          { label: '🚗 Harga OTR', value: HC.fmt(c.harga) },
          { label: '💰 DP', value: `${c.dpPct}% (${HC.fmt(c.dpAmt)})` },
          { label: '📊 Bunga Flat', value: `${c.bunga.toFixed(2)}%${c.useInflasi ? ' (inflasi)' : ''}` },
          { label: '📅 Tenor', value: `${c.tenor} bulan (${(c.tenor / 12).toFixed(1)} thn)` },
          { label: '🚗 Tipe Mobil', value: c.mobilTypeLabel },
          { label: '📍 Profil', value: c.usageLabel },
          { label: '🏙️ Wilayah', value: c.wilayahLabel },
        ];

        return HC.buildReportCard({
          title: '🚗 Kredit Mobil + TCO Lengkap',
          color: '#0891B2', color2: '#155E75',
          heroLabel: 'TCO Total per Bulan',
          heroValue: HC.fmt(c.tco.totalTCO),
          heroSubtext: `Cicilan ${HC.fmt(c.cicilan)} + biaya kepemilikan ${HC.fmt(c.tco.totalTCO - c.cicilan)}`,
          inputs,
          results: [
            { label: 'TCO Total/Bulan', value: HC.fmt(c.tco.totalTCO), highlight: true },
            { label: 'Cicilan/Bulan', value: HC.fmt(c.tco.cicilan) },
            { label: `${c.tco.isElectric ? 'Listrik' : 'Bensin'}/Bulan`, value: HC.fmt(c.tco.bensin) },
            { label: 'Tol + Parkir', value: HC.fmt(c.tco.tolParkir) },
            { label: 'Servis + Cuci', value: HC.fmt(c.tco.servis + c.tco.cuci) },
            { label: 'Pajak + Asuransi', value: HC.fmt(c.tco.pajak + c.tco.asuransi) },
            { label: 'Biaya Awal (DP+BBN+asuransi thn1)', value: HC.fmt(c.biayaAwal) },
            { label: 'Total Bayar Cicilan', value: HC.fmt(c.totalBayar), highlight: true },
          ],
          insight, slug: 'kredit-mobil',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🚗 *Kredit Mobil + TCO - HitungCerdas*\n\n` +
               `Mobil: ${c.mobilTypeLabel}\nHarga: ${HC.fmt(c.harga)}\nDP ${c.dpPct}%: ${HC.fmt(c.dpAmt)}\nTenor: ${c.tenor} bulan\nProfil: ${c.usageLabel}\nWilayah: ${c.wilayahLabel}\n\n` +
               `💰 *Cicilan: ${HC.fmt(c.cicilan)}/bulan*\n\n` +
               `📊 *TCO Bulanan Lengkap:*\n` +
               `🏦 Cicilan: ${HC.fmt(c.tco.cicilan)}\n` +
               `${c.tco.isElectric ? '⚡' : '⛽'} ${c.tco.isElectric ? 'Listrik' : 'Bensin'}: ${HC.fmt(c.tco.bensin)}\n` +
               `🔧 Servis: ${HC.fmt(c.tco.servis)}\n` +
               `🛣️ Tol+parkir: ${HC.fmt(c.tco.tolParkir)}\n` +
               `📄 Pajak: ${HC.fmt(c.tco.pajak)}\n` +
               `🛡️ Asuransi: ${HC.fmt(c.tco.asuransi)}\n` +
               `🧽 Cuci+darurat: ${HC.fmt(c.tco.cuci + c.tco.danaDarurat)}\n\n` +
               `💸 *TCO TOTAL: ${HC.fmt(c.tco.totalTCO)}/bulan*\n` +
               `⚠️ Gaji minimal: ${HC.fmt(c.tco.totalTCO * 2.5)}\n\n` +
               `Hitung: https://hitungcerdas.net/kalkulator/kredit-mobil`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'kredit-mobil-tco-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'kredit-mobil'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }

    ready(function(){
      var wrap = $('aicWrap'); if(!wrap) return;
      var trigger = $('aicTrigger'), panel = $('aicPanel');
      var ground = $('aicGround'), msgs = $('aicMsgs'), chips = $('aicChips');
      var input = $('aicText'), send = $('aicSend'), limitEl = $('aicLimit');
      var history = [];

      function isDark(){
        var de = document.documentElement;
        return de.classList.contains('dark') || de.getAttribute('data-theme')==='dark'
            || (function(){ try{ return localStorage.getItem('hc-theme')==='dark'; }catch(e){ return false; } })();
      }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });

      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x && x.options && x.selectedIndex>=0) ? x.options[x.selectedIndex].text : ''; }
      function readData(){
        var cicTxt = ($('cicilan')||{}).textContent || 'Rp 0';
        var tcoEl = document.querySelector('#tcoList .tco-total .val');
        var tcoTxt = tcoEl ? tcoEl.textContent : '';
        return {
          cicilanTxt: cicTxt, cicNum: num(cicTxt),
          tcoTxt: tcoTxt, tcoNum: num(tcoTxt),
          harga: ($('harga')||{}).value || '',
          tenor: ($('tenor')||{}).value || '',
          bunga: ($('bunga')||{}).value || '',
          biayaAwal: ($('biayaAwal')||{}).textContent || '',
          pokok: ($('pokok')||{}).textContent || '',
          totalBunga: ($('totalBunga')||{}).textContent || '',
          totalBayar: ($('totalBayar')||{}).textContent || '',
          mobil: selText('mobilType'),
          usage: selText('usageProfile'),
          wilayah: selText('wilayah')
        };
      }

      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function renderGround(){
        var d = readData();
        var ctx = '<div class="aic-ctx"><i class="ti ti-car"></i> Kredit Mobil \u00b7 Cicilan <b>'+esc(d.cicilanTxt)+'</b>/bln</div>';
        if(!d.tcoNum || !d.cicNum){
          ground.innerHTML = ctx + '<div class="aic-nogauge">Hitung dulu untuk lihat perbandingan biaya.</div>';
          return;
        }
        var cicPct = Math.max(8, Math.min(100, d.cicNum / d.tcoNum * 100));
        var gap = Math.max(0, d.tcoNum - d.cicNum);
        ground.innerHTML = ctx
          + '<div class="aic-cmp">'
          +   '<div class="aic-cmp-row"><span class="aic-cmp-lbl">Cicilan</span>'
          +     '<div class="aic-cmp-track"><div class="aic-cmp-fill cic" style="width:'+cicPct.toFixed(1)+'%"></div><span class="aic-cmp-val on-light">'+esc(d.cicilanTxt)+'</span></div></div>'
          +   '<div class="aic-cmp-row"><span class="aic-cmp-lbl">Biaya nyata</span>'
          +     '<div class="aic-cmp-track"><div class="aic-cmp-fill tco" style="width:100%"></div><span class="aic-cmp-val on-dark">'+esc(d.tcoTxt)+'</span></div></div>'
          + '</div>'
          + '<div class="aic-verdict info"><i class="ti ti-gas-station"></i> Biaya bulanan nyata <b>'+esc(d.tcoTxt)+'</b> \u2014 ada +'+esc(HC.fmt(gap))+' buat BBM, servis, pajak, asuransi, tol/parkir.</div>';
      }

      function buildContext(){
        var d = readData();
        var p = [
          'Kalkulator: Kredit Mobil.',
          d.harga ? ('Harga mobil (OTR): Rp ' + d.harga + '.') : '',
          'Cicilan per bulan: ' + d.cicilanTxt + '.',
          'Tenor: ' + d.tenor + ' bulan. Bunga: ' + d.bunga + '% (flat).',
          'DP + biaya awal: ' + d.biayaAwal + '. Pokok pinjaman: ' + d.pokok + '.',
          'Total bunga: ' + d.totalBunga + '. Total bayar: ' + d.totalBayar + '.',
          d.tcoTxt ? ('Biaya kepemilikan bulanan sebenarnya / TCO (cicilan + BBM + servis + pajak + asuransi + tol/parkir + perawatan + depresiasi): ' + d.tcoTxt + '.') : '',
          d.mobil ? ('Jenis mobil: ' + d.mobil + '.') : '',
          d.usage ? ('Profil pemakaian: ' + d.usage + '.') : '',
          d.wilayah ? ('Wilayah: ' + d.wilayah + '.') : '',
          'Acuan umum: idealnya total biaya mobil (TCO) tidak lebih dari sekitar 20-25% penghasilan bulanan; selalu sisakan dana darurat. Cicilan bukan satu-satunya biaya.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){
        t = t.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        t = t.replace(/__([^_]+)__/g, '<strong>$1</strong>');
        t = t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g, '$1<em>$2</em>');
        t = t.replace(/`([^`]+)`/g, '<code>$1</code>');
        return t;
      }
      function mdToHtml(raw){
        var lines = String(raw).replace(/\r/g,'').split('\n'); var out=[];
        for(var i=0;i<lines.length;i++){
          var t = lines[i].trim(); if(t==='')continue;
          if(/^([-*_]\s*){3,}$/.test(t))continue;
          var h=t.match(/^#{1,6}\s+(.*)$/); if(h){ out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>'); continue; }
          var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){ out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>'); continue; }
          var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){ out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>'); continue; }
          out.push('<p>'+mdInline(esc(t))+'</p>');
        }
        return out.join('') || ('<p>'+mdInline(esc(String(raw)))+'</p>');
      }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Biaya sebenarnya mobil ini berapa?','Mending tenor pendek atau panjang?','Cara bikin cicilan lebih ringan?','Worth it gak ambil mobil ini?','DP lebih besar ngaruh berapa?','Total bunga yang kubayar berapa?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role, text){
        var row = document.createElement('div'); row.className='aic-row '+role;
        if(role==='ai'){
          row.innerHTML = '<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
          row.querySelector('.aic-bub').innerHTML = mdToHtml(text);
        } else {
          row.innerHTML = '<div class="aic-bub"></div>';
          row.querySelector('.aic-bub').textContent = text;
        }
        msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight; return row;
      }
      function addTyping(){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>';
        msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row;
      }

      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){
        var left=Math.max(0, LIMIT-getCount());
        limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.';
        var done=left<=0; input.disabled=done; send.disabled=done;
        if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; }
      }

      var busy=false;
      async function ask(text){
        text=(text||'').trim(); if(!text||busy) return;
        if(getCount()>=LIMIT){ refreshLimit(); return; }
        busy=true; send.disabled=true;
        addMsg('user',text); history.push({role:'user',content:text});
        input.value=''; chips.innerHTML='';
        var typing=addTyping(); incCount();
        try{
          var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},
            body:JSON.stringify({calcContext:buildContext(),messages:history})});
          var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};});
          typing.parentNode && typing.remove();
          if(data && data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); }
          else { addMsg('ai','\u26a0\ufe0f '+((data && data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); }
        }catch(e){ typing.parentNode && typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus();
      }

      var PRESETS=['Biaya sebenarnya mobil ini berapa?','Mending tenor pendek atau panjang?','Cara bikin cicilan lebih ringan?'];
      function renderChips(){
        chips.innerHTML='';
        PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); });
      }

      var opened=false;
      trigger.addEventListener('click', function(){
        if(panel.hasAttribute('hidden')){
          panel.removeAttribute('hidden'); wrap.classList.add('open');
          applyTheme(); renderGround(); refreshLimit();
          if(!opened){ renderChips(); opened=true; }
        } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); }
      });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>

