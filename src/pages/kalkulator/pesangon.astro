---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('pesangon')!;
const related = getRelatedCalculators('pesangon', 3);

const faqs = [
  { question: 'Saya resign (mengundurkan diri), apakah dapat pesangon?', answer: '<strong>Tidak.</strong> Berdasarkan PP 35/2021, pekerja yang mengundurkan diri atau mangkir tidak berhak atas uang pesangon maupun UPMK. Yang didapat hanya <strong>Uang Penggantian Hak (UPH)</strong> — seperti sisa cuti — dan <strong>uang pisah</strong> yang besarannya diatur dalam Perjanjian Kerja, Peraturan Perusahaan, atau PKB.' },
  { question: 'Apa itu "upah dasar" untuk menghitung pesangon?', answer: 'Upah dasar = <strong>upah pokok + tunjangan tetap</strong> yang terakhir diterima. Tunjangan tidak tetap (mis. transport/makan harian) tidak dihitung. Jika upah dasarmu lebih rendah dari upah minimum wilayah (UMP/UMK), maka yang dipakai adalah upah minimum tersebut.' },
  { question: 'Apakah pesangon dikenakan pajak?', answer: 'Ya. Pesangon yang dibayar sekaligus kena <strong>PPh 21 final</strong> dengan tarif progresif: <strong>0% s.d. Rp 50 juta</strong>, 5% di atas Rp 50–100 juta, 15% di atas Rp 100–500 juta, dan 25% di atas Rp 500 juta. Pemotongan dilakukan perusahaan sebelum pesangon dibayarkan.' },
  { question: 'Apakah hasil kalkulator ini pasti benar?', answer: 'Ini <strong>estimasi</strong> berdasarkan PP 35/2021. Angka final bisa berbeda tergantung isi Perjanjian Kerja, Peraturan Perusahaan, PKB, kesepakatan bipartit, atau putusan pengadilan hubungan industrial. Untuk kepastian, konsultasikan ke <strong>Disnaker</strong> setempat atau mediator hubungan industrial.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#0D9488;--cat-color2:#0F766E">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#CCFBF1;color:#0F766E"><i class="ti ti-briefcase"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <rect x="55" y="48" width="90" height="110" rx="8" fill="#FFF" stroke="#0F766E" stroke-width="2"/>
            <rect x="70" y="68" width="60" height="6" rx="3" fill="#0D9488" opacity=".7"/>
            <rect x="70" y="84" width="44" height="5" rx="2.5" fill="#0D9488" opacity=".45"/>
            <rect x="70" y="98" width="52" height="5" rx="2.5" fill="#0D9488" opacity=".45"/>
            <circle cx="118" cy="128" r="16" fill="#FBBF24"/>
            <text x="118" y="134" font-size="16" font-weight="700" fill="#92400E" text-anchor="middle">Rp</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%)"><i class="ti ti-briefcase"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Pesangon PHK 2026</h2><p class="calc-card-sub">Sesuai PP 35/2021 (UU Cipta Kerja) — uang pesangon, UPMK & UPH</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field">
              <label>Status Hubungan Kerja</label>
              <select id="status">
                <option value="pkwtt" selected>Pekerja Tetap (PKWTT)</option>
                <option value="pkwt">Pekerja Kontrak (PKWT)</option>
              </select>
              <p class="hint" id="statusHint" style="margin-top:6px">PKWTT memakai rumus pesangon. PKWT memakai uang kompensasi (masa kerja ÷ 12 × upah).</p>
            </div>

            <div class="field"><label>Upah Pokok per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="upahPokok" class="has-prefix" value="5.000.000" inputmode="numeric" /></div>
            </div>

            <div class="field"><label>Tunjangan Tetap per Bulan <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="tunjTetap" class="has-prefix" value="0" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Tunjangan tetap saja (mis. tunjangan jabatan). Tunjangan tidak tetap (transport/makan harian) tidak dihitung.</p>
            </div>

            <div class="field"><label>Upah Minimum Wilayah (UMP/UMK) <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="umr" class="has-prefix" value="0" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Jika upah dasarmu di bawah angka ini, sistem otomatis memakai upah minimum (simulasi konservatif).</p>
            </div>

            <div class="field">
              <label>Cara Input Masa Kerja</label>
              <select id="modeKerja">
                <option value="cepat" selected>Cepat — tahun & bulan</option>
                <option value="akurat">Akurat — tanggal mulai & PHK</option>
              </select>
            </div>

            <div id="mkCepat">
              <div class="field-row" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="field"><label>Masa Kerja (Tahun)</label>
                  <input type="number" id="mkTahun" value="7" min="0" max="50" step="1" /></div>
                <div class="field"><label>Bulan</label>
                  <input type="number" id="mkBulan" value="0" min="0" max="11" step="1" /></div>
              </div>
            </div>

            <div id="mkAkurat" style="display:none">
              <div class="field-row" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="field"><label>Tanggal Mulai Kerja</label>
                  <input type="date" id="tglMulai" /></div>
                <div class="field"><label>Tanggal PHK</label>
                  <input type="date" id="tglPhk" /></div>
              </div>
            </div>

            <div class="field pkwtt-only">
              <label>Alasan PHK</label>
              <select id="alasan">
                <option value="phk1" selected>Efisiensi cegah rugi / merger / tutup bukan rugi / pengusaha langgar (1× pesangon)</option>
                <option value="phk05">Efisiensi karena rugi / tutup karena rugi / pailit / PKPU rugi (0,5×)</option>
                <option value="phk075">Force majeure tapi perusahaan TIDAK tutup (0,75×)</option>
                <option value="pensiun">Pensiun — usia pensiun (1,75×)</option>
                <option value="meninggal">Meninggal dunia / sakit-cacat kerja &gt;12 bln (2×)</option>
                <option value="pelanggaran">Pelanggaran berat saya, sudah SP 1-2-3 (0,5×)</option>
                <option value="resign">Mengundurkan diri / mangkir (tanpa pesangon)</option>
              </select>
              <p class="hint" style="margin-top:6px">Besaran pesangon sangat tergantung alasan PHK (PP 35/2021 Pasal 41–57).</p>
            </div>

            <div class="adv-section pkwtt-only" id="uphSection" style="margin-top:4px">
              <div class="adv-toggle"><span><i class="ti ti-receipt"></i>&nbsp; Uang Penggantian Hak (UPH) — opsional</span><i class="ti ti-chevron-down chev"></i></div>
              <div class="adv-content">
                <div class="field-row" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                  <div class="field"><label>Sisa Cuti (hari)</label>
                    <input type="number" id="sisaCuti" value="0" min="0" max="60" step="1" /></div>
                  <div class="field"><label>Pola Kerja</label>
                    <select id="polaKerja"><option value="5" selected>5 hari/minggu</option><option value="6">6 hari/minggu</option></select></div>
                </div>
                <div class="field"><label>Ongkos Pulang (pekerja + keluarga)</label>
                  <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="ongkosPulang" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>Komponen Lain sesuai PK/PP/PKB</label>
                  <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="uphLain" class="has-prefix" value="0" inputmode="numeric" /></div></div>
              </div>
            </div>

            <div class="field resign-only" id="uangPisahWrap" style="display:none">
              <label>Uang Pisah (untuk resign/mangkir)</label>
              <select id="pisahMode">
                <option value="none" selected>Tidak ada / belum tahu</option>
                <option value="bulan">Sejumlah bulan upah</option>
                <option value="nominal">Nominal (Rp)</option>
              </select>
              <div class="input-wrap" id="pisahValWrap" style="margin-top:8px;display:none"><span class="input-prefix" id="pisahPrefix">Rp</span>
                <input type="text" id="pisahVal" class="has-prefix" value="0" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Besaran uang pisah tidak baku di PP — diatur dalam PK/PP/PKB perusahaanmu.</p>
            </div>

            <div class="field">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                <input type="checkbox" id="pphToggle" checked style="width:auto;margin:0" />
                <span>Hitung estimasi PPh 21 final (pajak pesangon)</span>
              </label>
            </div>

            <div class="field">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                <input type="checkbox" id="mikroToggle" style="width:auto;margin:0" />
                <span>Perusahaan saya termasuk usaha mikro/kecil</span>
              </label>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Pesangon</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-briefcase result-placeholder-icon"></i>
              <div class="result-placeholder-title">Estimasi pesangon akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi status, upah, masa kerja, alasan PHK, lalu klik <strong>"Hitung Pesangon"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label" id="heroLabel">Total Hak Pesangon (Bruto)</div>
                <div class="result-value" id="pesHero">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="pesMeta">Masa kerja 7 tahun · 1× pesangon</span></div>
              </div>

              <div class="result-grid" id="resGridPesangon">
                <div class="result-item"><div class="result-item-label">Uang Pesangon (UP)</div><div class="result-item-value" id="pesUP">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">UPMK</div><div class="result-item-value" id="pesUPMK">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">UPH</div><div class="result-item-value" id="pesUPH">Rp 0</div></div>
                <div class="result-item" id="pisahItem" style="display:none"><div class="result-item-label">Uang Pisah</div><div class="result-item-value" id="pesPisah">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Estimasi PPh 21</div><div class="result-item-value result-warn" id="pesPajak">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Estimasi Diterima (Bersih)</div><div class="result-item-value" id="pesBersih" style="color:var(--green,#059669);font-weight:700">Rp 0</div></div>
              </div>

              <div id="pesWhy" style="margin-top:12px;padding:12px 14px;border-radius:12px;background:#F0FDFA;border:1px solid #99F6E4;font-size:12.5px;line-height:1.6;color:#115E59"></div>

              <div id="pesWarn" style="display:none;margin-top:10px;padding:11px 13px;border-radius:12px;background:#FEF3C7;border:1px solid #FDE68A;font-size:12.5px;line-height:1.55;color:#92400E"></div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-list-details"></i>&nbsp; Rincian Perhitungan</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Komponen</th><th class="right">Dasar</th><th class="right">Nilai</th></tr></thead>
                    <tbody id="rincianBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-checklist"></i>&nbsp; Dokumen yang Perlu Kamu Cek</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <ul style="margin:0;padding-left:18px;font-size:13px;line-height:1.9;color:var(--text)">
                    <li>Surat PHK & alasan resmi PHK</li>
                    <li>Slip gaji 3 bulan terakhir (cek upah pokok + tunjangan tetap)</li>
                    <li>Perjanjian Kerja / Peraturan Perusahaan / PKB</li>
                    <li>Surat Peringatan (SP 1, 2, 3) — jika alasan pelanggaran</li>
                    <li>Bukti sisa cuti tahunan yang belum diambil</li>
                    <li>Bukti hak lain (THR pro-rata, bonus, ongkos pulang)</li>
                    <li>Bukti potong PPh 21 atas pesangon</li>
                  </ul>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
                <button type="button" class="export-btn link" id="exportLink"><i class="ti ti-link" style="color:#0891B2"></i><span style="color:#0891B2">Salin Link</span></button>
              </div>

              <!-- ===== AI COACH KEPUTUSAN ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung soal hakmu? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu pahami hak pesangonmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal pesangonmu..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis PP 35/2021, bukan nasihat hukum berlisensi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="wrap" style="margin-top:6px">
    <a href="/blog/cara-hitung-pesangon-phk" style="display:flex;align-items:center;gap:15px;max-width:780px;margin:0 auto;padding:17px 20px;border-radius:16px;background:linear-gradient(135deg,#F0FDFA 0%,#CCFBF1 100%);border:1px solid #5EEAD4;text-decoration:none;box-shadow:0 4px 14px rgba(13,148,136,.13)">
      <span style="flex-shrink:0;width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,#0D9488,#0F766E);display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px"><i class="ti ti-book-2"></i></span>
      <span style="flex:1;min-width:0">
        <span style="display:block;font-size:11px;font-weight:700;letter-spacing:.08em;color:#0F766E;text-transform:uppercase;margin-bottom:3px">📖 Baca Juga</span>
        <span style="display:block;font-weight:700;font-size:15.5px;color:#115E59;line-height:1.35">Cara Hitung Pesangon PHK 2026 — Panduan Lengkap</span>
        <span style="display:block;font-size:13px;color:#0F766E;margin-top:3px;line-height:1.45">Tabel UP &amp; UPMK, faktor pengali per alasan PHK, 3 contoh kasus, plus langkah hukum kalau pesangon tak dibayar.</span>
      </span>
      <span style="flex-shrink:0;width:36px;height:36px;border-radius:50%;background:#0D9488;display:flex;align-items:center;justify-content:center;color:#fff;font-size:18px"><i class="ti ti-arrow-right"></i></span>
    </a>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Cara Menghitung Pesangon PHK Sesuai PP 35/2021</h2>
      <p>Saat terjadi Pemutusan Hubungan Kerja (PHK), pengusaha wajib membayar <strong>uang pesangon (UP)</strong>, <strong>uang penghargaan masa kerja (UPMK)</strong>, dan <strong>uang penggantian hak (UPH)</strong> sesuai PP Nomor 35 Tahun 2021 (aturan pelaksana UU Cipta Kerja). Besarannya ditentukan dua hal: <strong>masa kerja</strong> dan <strong>alasan PHK</strong>. Dasar perhitungannya adalah upah pokok + tunjangan tetap. Sebelum menerima tawaran HR, pahami dulu <a href="/kalkulator/gaji-bersih">gaji bersih</a> dan kewajiban <a href="/kalkulator/pph-21">PPh 21</a>-mu, dan pastikan punya <a href="/kalkulator/dana-darurat">dana darurat</a> sebagai bantalan transisi. Untuk panduan lengkap dengan tabel, contoh kasus, dan langkah hukumnya, baca <a href="/blog/cara-hitung-pesangon-phk">cara hitung pesangon PHK 2026</a>.</p>

      <h3>Tabel Uang Pesangon (Pasal 40 ayat 2)</h3>
      <ul>
        <li>Masa kerja &lt; 1 tahun = 1× upah · 1–&lt;2 th = 2× · 2–&lt;3 = 3× · 3–&lt;4 = 4×</li>
        <li>4–&lt;5 = 5× · 5–&lt;6 = 6× · 6–&lt;7 = 7× · 7–&lt;8 = 8× · <strong>≥ 8 tahun = 9× upah</strong></li>
      </ul>

      <h3>Tabel UPMK (Pasal 40 ayat 3) — hanya jika masa kerja ≥ 3 tahun</h3>
      <ul>
        <li>3–&lt;6 th = 2× · 6–&lt;9 = 3× · 9–&lt;12 = 4× · 12–&lt;15 = 5×</li>
        <li>15–&lt;18 = 6× · 18–&lt;21 = 7× · 21–&lt;24 = 8× · <strong>≥ 24 tahun = 10× upah</strong></li>
      </ul>

      <h3>Faktor Pengali Berdasarkan Alasan PHK</h3>
      <ul>
        <li><strong>0,5×</strong> pesangon: efisiensi karena rugi, perusahaan tutup karena rugi, pailit, PKPU karena rugi, atau pelanggaran setelah SP 1-2-3</li>
        <li><strong>0,75×</strong> pesangon: keadaan memaksa (force majeure) yang tidak sampai menutup perusahaan</li>
        <li><strong>1×</strong> pesangon: efisiensi mencegah rugi, merger/peleburan, pengambilalihan, tutup bukan karena rugi, atau pengusaha melanggar kewajiban</li>
        <li><strong>1,75×</strong> pesangon: pekerja memasuki usia pensiun</li>
        <li><strong>2×</strong> pesangon: pekerja meninggal dunia atau sakit/cacat akibat kecelakaan kerja &gt;12 bulan</li>
        <li><strong>Tanpa pesangon</strong> (hanya UPH + uang pisah): mengundurkan diri (resign) atau mangkir</li>
      </ul>
      <p>Untuk pekerja kontrak (PKWT), yang berlaku bukan pesangon melainkan <strong>uang kompensasi</strong> = (masa kerja ÷ 12) × upah sebulan, sesuai PP 35/2021.</p>

      <h3>Sumber Resmi & Verifikasi</h3>
      <ul>
        <li>Naskah PP 35/2021 — <a href="https://jdih.kemnaker.go.id/asset/data_puu/PP352021.pdf" target="_blank" rel="noopener nofollow">JDIH Kemnaker</a></li>
        <li>Database peraturan — <a href="https://peraturan.bpk.go.id/Details/161904/pp-no-35-tahun-2021" target="_blank" rel="noopener nofollow">Peraturan BPK</a></li>
        <li>Literasi hukum — <a href="https://literasihukum.bphn.go.id" target="_blank" rel="noopener nofollow">BPHN Kemenkumham</a></li>
        <li>Informasi ketenagakerjaan — <a href="https://kemnaker.go.id" target="_blank" rel="noopener nofollow">Kemnaker</a></li>
      </ul>

      <div class="cta-box">
        <h3>Disclaimer Penting</h3>
        <p>Kalkulator ini memberikan <strong>estimasi</strong> berdasarkan PP 35/2021. Angka final dapat berbeda tergantung isi Perjanjian Kerja, Peraturan Perusahaan, PKB, hasil perundingan bipartit, atau putusan Pengadilan Hubungan Industrial. Untuk usaha mikro/kecil, besaran dapat ditentukan berdasarkan kesepakatan (Pasal 59). Bukan nasihat hukum. Untuk kepastian, konsultasikan ke <strong>Disnaker</strong> setempat atau mediator hubungan industrial.</p>
      </div>
    </div>
  </section>

