---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('zakat-penghasilan')!;
const related = getRelatedCalculators('zakat-penghasilan', 3);

const faqs = [
  { question: 'Apa itu zakat penghasilan?', answer: 'Zakat dari gaji/honor profesi yang capai nisab. Tarif 2,5%. Dasar: QS Adz-Dzariyat 19, Fatwa MUI 3/2003, Peraturan BAZNAS 1/2018.' },
  { question: 'Berapa nisab 2026?', answer: 'Menurut <strong>SK Ketua BAZNAS No. 15 Tahun 2026</strong> (21 Februari 2026), nisab zakat pendapatan &amp; jasa tahun 2026 senilai 85 gram emas = <strong>Rp 91.681.728/tahun</strong>, atau <strong>Rp 7.640.144/bulan</strong> bila ditunaikan tiap bulan. BAZNAS memakai acuan emas <strong>14 karat</strong> (kadar 58,33%–62,49%) dari rata-rata harga emas sepanjang 2025 — kewenangan ini bersandar pada PMA No. 31/2019 yang tidak mengatur jenis karat secara spesifik. Catatan: sebagian ulama memakai emas murni 24 karat, sehingga nisab versi tersebut jauh lebih tinggi.' },
  { question: 'Bruto atau neto?', answer: 'BAZNAS RI: bruto (lebih hati-hati). Sebagian ulama: neto setelah biaya pokok. Hasilnya tidak terlalu berbeda — Rp 10jt × 2,5% = Rp 250rb.' },
  { question: 'Bulanan atau setahun?', answer: 'Keduanya sah. Mayoritas Muslim Indonesia: per bulan (lebih terstruktur, auto-debet ke lembaga zakat resmi).' },
  { question: 'Zakat kurangi PPh 21?', answer: 'YA! Sesuai PMK 254/PMK.03/2010, zakat via lembaga resmi (BAZNAS, LAZ Kemenag) jadi <strong>pengurang PKP</strong>. Simpan bukti untuk SPT Tahunan.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#0891B2;--cat-color2:#155E75">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#CFFAFE;color:#155E75"><i class="ti ti-coin"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <circle cx="100" cy="100" r="55" fill="#FBBF24" stroke="#FFF" stroke-width="3"/>
            <text x="100" y="92" text-anchor="middle" font-size="22" font-weight="900" fill="#0A2540">2,5</text>
            <text x="100" y="113" text-anchor="middle" font-size="18" font-weight="900" fill="#0A2540">%</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#0891B2 0%,#155E75 100%)"><i class="ti ti-coin"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Zakat Penghasilan</h2><p class="calc-card-sub">2,5% dari gaji jika capai nisab 85 gr emas</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Penghasilan per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="penghasilan" class="has-prefix" value="10.000.000" inputmode="numeric" /></div>
              <p class="field-hint">Gaji + tunjangan + bonus (rata-rata)</p></div>
            <div class="field"><label>Penghasilan Lain/Bulan <span class="hint">(freelance, dividen)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="lain" class="has-prefix" placeholder="0" inputmode="numeric" /></div></div>
            <div class="field"><label>Nisab Setahun <span class="hint">(acuan BAZNAS 2026)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="nisabInput" class="has-prefix" value="91.681.728" inputmode="numeric" /></div>
              <p class="field-hint">📋 <strong>SK Ketua BAZNAS No. 15/2026</strong>: nisab zakat pendapatan &amp; jasa 2026 = 85 gram emas <strong>14 karat</strong> (kadar 58,33%&ndash;62,49%, rata-rata harga emas 2025) = <strong>Rp 91.681.728/tahun</strong> atau Rp 7.640.144/bulan. Sebagian ulama memakai emas murni 24 karat sehingga nisabnya lebih tinggi &mdash; silakan ubah angka ini bila mengikuti pendapat tersebut.</p></div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-coin result-placeholder-icon"></i>
              <div class="result-placeholder-title">Hasil akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi penghasilan bulanan, lalu klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Zakat per Bulan</div>
                <div class="result-value" id="zakatBulan">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="zakatTahun">Setahun: Rp 0</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Penghasilan/Tahun</div><div class="result-item-value" id="brutoTahun">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Nisab (85 gr emas)</div><div class="result-item-value" id="nisab">Rp 0</div></div>
              </div>

              <div class="kelayakan-box">
                <div class="kelayakan-hdr"><i class="ti ti-shield-check"></i> <span>Status Wajib Zakat</span></div>
                <div id="status"></div>
              </div>

              <div class="export-row">
                <button class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>
              <!-- ===== AI COACH ZAKAT PENGHASILAN ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Wajib zakat? Nishab? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Zakat</strong>
                      <small>Bantu pahami zakat penghasilanmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal zakat penghasilan..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Penjelasan edukatif berbasis hitunganmu, bukan fatwa resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Panduan Lengkap Zakat Penghasilan</h2>
      <p>Zakat profesi/penghasilan = <strong>2,5% dari penghasilan</strong> jika penghasilan setahun mencapai nisab. Untuk 2026, BAZNAS menetapkan nisab <strong>Rp 91.681.728/tahun</strong> (Rp 7.640.144/bulan) lewat SK Ketua BAZNAS No. 15/2026. Bayar via lembaga zakat resmi BAZNAS/LAZ Kemenag — bisa <strong>kurangi PPh 21</strong> per PMK 254/2010. Hitung pajakmu di <a href="/kalkulator/pph-21">kalkulator PPh 21</a>. Punya harta/tabungan yang sudah capai nisab? Hitung juga <a href="/kalkulator/zakat-mal">zakat mal</a>.</p>
      <div class="cta-box"><h3>Tunaikan Zakat Penghasilan</h3><p>Cek apakah penghasilanmu capai nisab, lalu hitung zakat 2,5% wajib.</p></div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
  <p class="hc-method-note" style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:680px;line-height:1.6;padding:0 1rem;">
    📅 Diperbarui <strong>Juli 2026</strong> · Zakat penghasilan = 2,5% dari penghasilan bila setahun mencapai nisab <strong>Rp 91.681.728</strong> (SK Ketua BAZNAS No. 15/2026 — 85 gram emas 14 karat, rata-rata harga 2025). Estimasi edukatif, bukan fatwa. <strong>Sumber:</strong> <a href="https://baznas.go.id/zakatpenghasilan" target="_blank" rel="noopener">BAZNAS</a>, PMA No. 31/2019 &amp; Fatwa MUI No. 3/2003.
  </p>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { p: $('penghasilan'), l: $('lain'), n: $('nisabInput') };
      Object.values(els).forEach(el => el.addEventListener('input', HC.fmtInput));

      let lastCalc = null;

      function hitung() {
        const p = HC.parseRp(els.p.value), l = HC.parseRp(els.l.value), nisab = HC.parseRp(els.n.value);
        if (p === 0) { HC.toast('Masukkan penghasilan', 'error'); return; }
        if (nisab <= 0) { HC.toast('Nisab tidak boleh kosong', 'error'); return; }

        const totalBulan = p + l;
        const brutoTahun = totalBulan * 12;
        const wajib = brutoTahun >= nisab;
        const zakatTahun = wajib ? brutoTahun * 0.025 : 0;
        const zakatBulan = zakatTahun / 12;

        $('zakatBulan').textContent = HC.fmt(zakatBulan);
        $('zakatTahun').textContent = `Setahun: ${HC.fmt(zakatTahun)}`;
        $('brutoTahun').textContent = HC.fmt(brutoTahun);
        $('nisab').textContent = HC.fmt(nisab);

        const $s = $('status');
        if (wajib) {
          const excess = brutoTahun - nisab;
          $s.innerHTML = `<div class="kelayakan-status ks-good"><i class="ti ti-circle-check"></i> WAJIB ZAKAT</div><p class="ks-note">Penghasilan ${HC.fmt(brutoTahun)} melebihi nisab ${HC.fmt(nisab)} sebesar ${HC.fmt(excess)}. Bayar 2,5% = <strong>${HC.fmt(zakatBulan)}/bln</strong>.</p>`;
        } else {
          const lack = nisab - brutoTahun;
          $s.innerHTML = `<div class="kelayakan-status ks-warn"><i class="ti ti-info-circle"></i> Belum Wajib Zakat</div><p class="ks-note">Masih ${HC.fmt(lack)} di bawah nisab. Disunnahkan sedekah/infaq.</p>`;
        }

        lastCalc = { p, l, totalBulan, brutoTahun, nisab, wajib, zakatTahun, zakatBulan };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Berhasil dihitung!');
      }

      function reset() {
        els.p.value = '10.000.000'; els.l.value = ''; els.n.value = '91.681.728';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        return HC.buildReportCard({
          title: '💰 Zakat Penghasilan', color: '#0891B2', color2: '#155E75',
          heroLabel: c.wajib ? 'Zakat Wajib/Bulan' : 'Status',
          heroValue: c.wajib ? HC.fmt(c.zakatBulan) : 'Belum Nisab',
          heroSubtext: c.wajib ? `Setahun ${HC.fmt(c.zakatTahun)} · 2,5% dari ${HC.fmt(c.brutoTahun)}` : `Belum capai nisab ${HC.fmt(c.nisab)}`,
          inputs: [
            { label: '💰 Penghasilan/bulan', value: HC.fmt(c.p) },
            { label: '💵 Penghasilan lain', value: HC.fmt(c.l) },
            { label: '📋 Nisab setahun', value: HC.fmt(c.nisab) },
          ],
          results: [
            { label: 'Penghasilan Setahun', value: HC.fmt(c.brutoTahun) },
            { label: 'Nisab Setahun', value: HC.fmt(c.nisab) },
            { label: 'Status', value: c.wajib ? '✅ Wajib Zakat' : '⏸️ Belum Nisab', highlight: c.wajib },
            { label: 'Zakat/Bulan', value: HC.fmt(c.zakatBulan), highlight: c.wajib },
            { label: 'Zakat/Tahun', value: HC.fmt(c.zakatTahun) },
          ],
          insight: c.wajib ? 'Bayar via BAZNAS/LAZ resmi untuk dapat bukti pengurang PPh 21 (PMK 254/2010).' : 'Belum wajib zakat penghasilan. Tetap sunnah sedekah/infaq.',
          slug: 'zakat-penghasilan',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `💰 *Zakat Penghasilan - HitungCerdas*\n\nPenghasilan: ${HC.fmt(c.p)}/bln\nNisab: ${HC.fmt(c.nisab)}/thn\n\n${c.wajib ? `✅ *WAJIB ZAKAT*\nZakat: ${HC.fmt(c.zakatBulan)}/bln (2,5%)` : `⏸️ Belum capai nisab`}\n\nHitung: https://hitungcerdas.net/kalkulator/zakat-penghasilan`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const r = buildReport(); if (r) HC.exportToImage(r, 'zakat-penghasilan-' + Date.now()); else HC.toast('Hitung dulu', 'error'); });
      $('exportWa').addEventListener('click', () => { const r = buildReport(); if (r) HC.shareWhatsApp(r, summaryText(), 'zakat-penghasilan'); else HC.toast('Hitung dulu', 'error'); });
      $('exportPdf').addEventListener('click', () => { if (lastCalc) HC.exportToPDF(); else HC.toast('Hitung dulu', 'error'); });
      $('exportCopy').addEventListener('click', () => { if (lastCalc) HC.copyText(summaryText(), 'Tersalin!'); else HC.toast('Hitung dulu', 'error'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'zakat-penghasilan-' + Date.now()); });
    });
  })();
</script>
<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#ECFEFF;border:1px solid #A5F3FC;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#CFFAFE}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#0891B2;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#ECFEFF;color:#0891B2;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#ECFEFF;color:#0891B2;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#ECFEFF;color:#0891B2;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#0891B2;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#0891B2;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#155E75;border-color:#155E75;background:#ECFEFF}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#ECFEFF;color:#0891B2;border:1px solid #A5F3FC;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#CFFAFE}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#0891B2}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#0891B2;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#67E8F9}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#67E8F9}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#67E8F9}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#67E8F9}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(8,145,178,.16);color:#67E8F9;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(8,145,178,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#22D3EE}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}
</style>
<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        var pr=function(x){ return (window.HC&&HC.parseRp)?(HC.parseRp(x||'')||0):0; };
        var brutoTahun=pr((($('brutoTahun')||{}).textContent)||'');
        var nisab=pr((($('nisab')||{}).textContent)||'');
        var zb=((($('zakatBulan')||{}).textContent)||'').trim();
        var zt=((($('zakatTahun')||{}).textContent)||'').trim().replace(/^Setahun:\s*/,'');
        return {
          brutoTahun:brutoTahun, brutoTahunTxt:(window.HC?HC.fmt(brutoTahun):brutoTahun),
          nisab:nisab, nisabTxt:(window.HC?HC.fmt(nisab):nisab),
          wajib:(nisab>0 && brutoTahun>=nisab),
          zakatBulanTxt:zb, zakatTahunTxt:zt,
          penghasilan:($('penghasilan')||{}).value||'', lain:($('lain')||{}).value||'', nisabInput:($('nisabInput')||{}).value||''
        };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-wallet"></i> Zakat Penghasilan</div>';
        if(!d.nisab){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat status nishab & zakatmu.</div>'; return; }
        var pct=d.nisab>0?Math.min(100,d.brutoTahun/d.nisab*100):0;
        var bar='<div style="margin:8px 0"><div style="display:flex;justify-content:space-between;font-size:11.5px;margin-bottom:3px"><span>Penghasilan/th <b>'+esc(d.brutoTahunTxt)+'</b></span><span>Nishab '+esc(d.nisabTxt)+'</span></div><div style="height:9px;border-radius:5px;background:#E5EAF1;overflow:hidden"><div style="height:100%;width:'+pct.toFixed(1)+'%;background:'+(d.wajib?'#16A34A':'#D97706')+'"></div></div></div>';
        var verdict=d.wajib
          ?'<div class="aic-verdict good"><i class="ti ti-circle-check"></i> WAJIB zakat 2,5% \u2014 <b>'+esc(d.zakatBulanTxt)+'/bulan</b> atau '+esc(d.zakatTahunTxt)+'/tahun (bila niat & syarat terpenuhi).</div>'
          :'<div class="aic-verdict warn"><i class="ti ti-info-circle"></i> Penghasilan setahun belum capai nishab \u2014 belum wajib zakat penghasilan.</div>';
        ground.innerHTML=ctx+bar+verdict;
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Zakat Penghasilan (zakat profesi) \u2014 2,5% dari penghasilan bila mencapai nishab.',
          'Input: penghasilan pokok Rp '+d.penghasilan+'/bulan'+(d.lain&&d.lain!=='0'?(', penghasilan lain Rp '+d.lain+'/bulan'):'')+', nisab setahun yang dipakai Rp '+d.nisabInput+'.',
          'Hasil: penghasilan setahun '+d.brutoTahunTxt+', nishab (85 gram emas/tahun) '+d.nisabTxt+', status '+(d.wajib?'WAJIB zakat':'BELUM wajib')+', zakat '+(d.wajib?(d.zakatBulanTxt+'/bulan atau '+d.zakatTahunTxt+'/tahun'):'Rp 0 (belum capai nishab)')+'.',
          'Acuan untuk jawabanmu: Zakat penghasilan (zakat profesi) = 2,5% dari penghasilan, wajib bila penghasilan SETAHUN mencapai nishab. Nishab resmi 2026 = Rp 91.681.728/tahun (Rp 7.640.144/bulan) per SK Ketua BAZNAS No. 15/2026, memakai acuan 85 gram emas 14 karat dari rata-rata harga emas 2025; nishab per bulan = nishab tahunan \u00f7 12. Sebagian ulama memakai emas murni 24 karat sehingga nishabnya lebih tinggi \u2014 sebutkan bila relevan. Boleh ditunaikan tiap bulan (2,5% dari penghasilan bulan itu) atau sekali setahun \u2014 keduanya sah. Ada perbedaan pendapat ulama soal dasar penghitungan: sebagian dari penghasilan BRUTO (kotor), sebagian dari NETO setelah dikurangi kebutuhan pokok/hutang \u2014 sampaikan kedua pandangan secara adil, jangan memaksakan satu. THR, bonus, dan pendapatan tidak rutin umumnya ikut dihitung saat diterima. Beda dengan zakat mal: zakat penghasilan atas pemasukan rutin, zakat mal atas harta yang sudah mengendap 1 haul \u2014 jangan menghitung ganda atas uang yang sama. Salurkan via BAZNAS atau Lembaga Amil Zakat (LAZ) resmi. Ini edukasi, BUKAN fatwa; untuk kasus spesifik sarankan bertanya ke amil/ustadz. Pakai sapaan "kamu", jawab ringkas & hangat, dan JANGAN mengarang angka di luar data di atas.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function typeInto(bubble, text, done){ var n=0, len=text.length, step=Math.max(2, Math.round(len/90)); var t=setInterval(function(){ n=Math.min(len, n+step); bubble.innerHTML=mdToHtml(text.slice(0,n)); msgs.scrollTop=msgs.scrollHeight; if(n>=len){ clearInterval(t); done&&done(); } }, 18); }
      function mkCopyBtn(text){ var b=document.createElement('button'); b.type='button'; b.className='aic-copy'; b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>'; b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); }); return b; }
      function addMsgTyped(text){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); }); return row; }
      var FOLLOWUPS=['Penghasilanku wajib zakat?','Nishab-nya berapa?','Bayar bulanan atau tahunan?','Dihitung dari gaji kotor atau bersih?','Beda zakat penghasilan & zakat mal?','THR & bonus kena zakat juga?','Bayar zakat ke mana?','Boleh dicicil tiap bulan?'];
      function renderFollowups(){ chips.innerHTML=''; var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;}); var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;}); pool.slice(0,3).forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b); }); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Penghasilanku wajib zakat?','Nishab-nya berapa?','Bayar bulanan atau tahunan?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },800); }); }
    });
  })();
</script>
