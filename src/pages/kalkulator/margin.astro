---
import Layout from '../../layouts/Layout.astro';
import EbookPromo from '../../components/EbookPromo.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('margin')!;
const related = getRelatedCalculators('margin', 3);

const faqs = [
  { question: 'Apa beda margin vs markup?', answer: '<strong>Margin</strong> = Profit ÷ Harga Jual × 100% (lebih akurat untuk bisnis). <strong>Markup</strong> = Profit ÷ Modal × 100% (lebih mudah untuk pricing). Margin selalu lebih kecil dari markup untuk profit yang sama. Markup 100% = Margin 50%. Markup 50% = Margin 33%.' },
  { question: 'Berapa margin yang sehat untuk bisnis?', answer: 'Tergantung industri: <strong>Retail/grocery</strong> 5-15% (high volume), <strong>Fashion</strong> 30-50%, <strong>F&B</strong> 40-60% (food cost max 35%), <strong>Beauty</strong> 50-70%, <strong>SaaS/digital</strong> 70-90%, <strong>Handmade</strong> 100-300%.' },
  { question: 'Cara naikkan margin tanpa naikkan harga?', answer: '(1) <strong>Negosiasi supplier</strong> diskon volume 5-15%. (2) <strong>Reduce packaging cost</strong>. (3) <strong>Bulk buying</strong> bahan saat harga turun. (4) <strong>Efisiensi operasional</strong>. (5) <strong>Bundling</strong> untuk naikkan AOV. (6) <strong>Loyalty program</strong> hindari biaya akuisisi tinggi.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#10B981;--cat-color2:#065F46">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#D1FAE5;color:#065F46"><i class="ti ti-percentage"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <circle cx="100" cy="100" r="55" fill="#FFF" stroke="#FBBF24" stroke-width="3"/>
            <text x="100" y="115" text-anchor="middle" font-size="38" font-weight="900" fill="#10B981" font-family="Inter">%</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#10B981 0%,#065F46 100%)"><i class="ti ti-percentage"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Margin & Markup</h2><p class="calc-card-sub">Profit margin, markup, dan break-even analysis</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>HPP / Modal per Unit</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="hpp" class="has-prefix" value="50.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Harga Jual per Unit</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="harga" class="has-prefix" value="80.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Biaya Tetap Bulanan <span class="hint">(sewa, gaji, utilities)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="fixedCost" class="has-prefix" value="5.000.000" inputmode="numeric" /></div></div>

            <div class="field"><label>Target Volume Penjualan per Bulan</label>
              <input type="number" id="volume" value="200" min="0" /></div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-percentage result-placeholder-icon"></i>
              <div class="result-placeholder-title">Analisa margin akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi HPP & harga jual, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Margin Profit</div>
                <div class="result-value" id="marginPct">0%</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="metaInfo">Profit per unit</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Profit per Unit</div><div class="result-item-value result-strong" id="profitUnit">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Markup</div><div class="result-item-value" id="markupPct">0%</div></div>
                <div class="result-item"><div class="result-item-label">Break-Even Volume</div><div class="result-item-value result-warn" id="bep">0 unit</div></div>
                <div class="result-item"><div class="result-item-label">Profit Bulanan</div><div class="result-item-value result-strong" id="profitBulan">Rp 0</div></div>
              </div>

              <div class="kelayakan-box">
                <div class="kelayakan-hdr"><i class="ti ti-target"></i><span>Analisa Kesehatan Margin</span></div>
                <div id="analisaBody"></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Proyeksi Berbagai Volume</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Volume/Bulan</th><th class="right">Omzet</th><th class="right">Profit Bersih</th><th class="right">Status</th></tr></thead>
                    <tbody id="volumeBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>
              <!-- ===== AI COACH KEPUTUSAN (mandiri) ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Margin sehat? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Keputusan</strong>
                      <small>Bantu baca margin & markup</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal margin & profit..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hasil hitunganmu, bukan nasihat bisnis resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

    <EbookPromo calc="margin" headline="Sudah hitung margin produkmu? Saatnya raih cuan pertamamu." />

  <section class="content-section">
    <div class="wrap-text">
      <h2>Margin vs Markup yang Sering Tertukar</h2>
      <p>Banyak UMKM bilang "margin 50%" padahal yang dimaksud markup 50% (= margin 33%). Margin selalu LEBIH KECIL dari markup. Untuk profit Rp 30, HPP Rp 50, Harga Rp 80 → Margin 37,5%, Markup 60%. Mau tentukan harga jual yang pas? Pakai <a href="/kalkulator/harga-jual">kalkulator harga jual</a>. Sudah closing? Buat <a href="/kalkulator/invoice-generator">invoice rapi</a>.</p>
      <p><strong>Break-Even Point (BEP)</strong> = volume minimum agar tidak rugi setelah biaya tetap. Untuk profit Rp 30/unit dan biaya tetap Rp 5jt/bln, BEP = 167 unit/bln. Di atas itu = profit, di bawah = rugi.</p>
      <div class="cta-box"><h3>Analisa Margin Bisnismu</h3><p>Isi HPP, harga jual, dan biaya tetap, klik "Hitung Sekarang" untuk dashboard lengkap.</p></div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Margin" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
  <p class="hc-method-note" style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:680px;line-height:1.6;padding:0 1rem;">
    📅 Diperbarui <strong>Juli 2026</strong> · Margin = (harga jual &minus; HPP) &divide; harga jual; markup = (harga jual &minus; HPP) &divide; HPP. Estimasi edukatif untuk UMKM. <strong>Sumber:</strong> prinsip akuntansi biaya.
  </p>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { hpp: $('hpp'), harga: $('harga'), fixed: $('fixedCost'), vol: $('volume') };
      [els.hpp, els.harga, els.fixed].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      let lastCalc = null;

      function hitung() {
        const hpp = HC.parseRp(els.hpp.value);
        const harga = HC.parseRp(els.harga.value);
        const fixed = HC.parseRp(els.fixed.value);
        const vol = parseInt(els.vol.value) || 0;

        if (hpp === 0 || harga === 0) { HC.toast('Masukkan HPP & harga jual dulu', 'error'); return; }
        if (harga < hpp) { HC.toast('Harga jual harus > HPP!', 'error'); return; }

        const profit = harga - hpp;
        const marginPct = (profit / harga) * 100;
        const markupPct = (profit / hpp) * 100;
        const bep = fixed > 0 && profit > 0 ? Math.ceil(fixed / profit) : 0;
        const omzet = harga * vol;
        const profitBruto = profit * vol;
        const profitBulan = profitBruto - fixed;

        $('marginPct').textContent = marginPct.toFixed(1) + '%';
        $('metaInfo').textContent = `Profit ${HC.fmt(profit)}/unit · Markup ${markupPct.toFixed(1)}%`;
        $('profitUnit').textContent = HC.fmt(profit);
        $('markupPct').textContent = markupPct.toFixed(1) + '%';
        $('bep').textContent = `${bep} unit`;
        $('profitBulan').textContent = HC.fmt(profitBulan);

        // Analisa
        let analisa = '';
        if (marginPct < 10) analisa = `<div class="kelayakan-status ks-bad"><i class="ti ti-alert-circle"></i> Margin terlalu tipis (${marginPct.toFixed(1)}%)</div><p class="ks-note">Sulit untuk bertahan & berkembang. Pertimbangkan naikkan harga atau cari supplier lebih murah.</p>`;
        else if (marginPct < 25) analisa = `<div class="kelayakan-status ks-warn"><i class="ti ti-alert-triangle"></i> Margin tipis (${marginPct.toFixed(1)}%)</div><p class="ks-note">Untuk high-volume sale (>500/bln) cukup. Untuk low-volume, perlu strategi naikkan margin.</p>`;
        else if (marginPct < 50) analisa = `<div class="kelayakan-status ks-good"><i class="ti ti-circle-check"></i> Margin sehat (${marginPct.toFixed(1)}%)</div><p class="ks-note">Sweet spot untuk kebanyakan UMKM. Ada ruang untuk diskon promo & loyalty program.</p>`;
        else analisa = `<div class="kelayakan-status ks-good"><i class="ti ti-star"></i> Margin sangat baik (${marginPct.toFixed(1)}%)</div><p class="ks-note">Margin premium! Cocok untuk produk handmade/craft/luxury. Fokus quality & branding.</p>`;
        $('analisaBody').innerHTML = analisa + `<p class="ks-note" style="margin-top:8px"><strong>BEP:</strong> ${bep} unit/bulan untuk break-even (omzet ${HC.fmt(bep * harga)}). Volume kamu ${vol}: ${vol >= bep ? '✅ untung' : '❌ masih rugi'}.</p>`;

        const volumes = [50, 100, 200, 500, 1000];
        $('volumeBody').innerHTML = volumes.map(v => {
          const oz = harga * v;
          const pf = (profit * v) - fixed;
          const status = pf > 0 ? '✅ Untung' : pf === 0 ? '⚖️ BEP' : '❌ Rugi';
          const color = pf > 0 ? 'color:var(--green-dark)' : 'color:var(--red)';
          return `<tr class="${v === vol ? 'active' : ''}"><td>${v} unit</td><td class="right">${HC.fmt(oz)}</td><td class="right" style="${color};font-weight:700">${HC.fmt(pf)}</td><td class="right">${status}</td></tr>`;
        }).join('');

        lastCalc = { hpp, harga, fixed, vol, profit, marginPct, markupPct, bep, profitBulan };
        if (HC.history) HC.history.push('margin', { inputs: HC.history.capture(['hpp','harga','fixedCost','volume']), summary: 'HPP ' + HC.fmt(lastCalc.hpp) + ' \u00b7 Harga ' + HC.fmt(lastCalc.harga), metrics: [{ k: 'Margin', v: lastCalc.marginPct.toFixed(1) + '%' }, { k: 'Profit/unit', v: HC.fmt(lastCalc.profit) }] });
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Margin berhasil dihitung!');
      }

      function reset() {
        els.hpp.value = '50.000'; els.harga.value = '80.000'; els.fixed.value = '5.000.000'; els.vol.value = '200';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const status = c.marginPct < 10 ? 'rugi' : c.marginPct < 25 ? 'tipis' : c.marginPct < 50 ? 'sehat' : 'sangat-baik';
        const insight = status === 'sangat-baik' ? `Margin ${c.marginPct.toFixed(1)}% PREMIUM — cocok untuk produk niche/handmade.` :
                        status === 'sehat' ? `Margin ${c.marginPct.toFixed(1)}% SEHAT — sweet spot UMKM, ada ruang promo.` :
                        status === 'tipis' ? `Margin ${c.marginPct.toFixed(1)}% TIPIS — butuh high-volume untuk profitable.` :
                        `Margin ${c.marginPct.toFixed(1)}% RAWAN RUGI — pertimbangkan naikkan harga.`;

        return HC.buildReportCard({
          title: '📊 Analisa Margin & Markup',
          color: '#10B981', color2: '#065F46',
          heroLabel: 'Profit Margin',
          heroValue: c.marginPct.toFixed(1) + '%',
          heroSubtext: `Profit ${HC.fmt(c.profit)}/unit · Markup ${c.markupPct.toFixed(1)}%`,
          inputs: [
            { label: '🥫 HPP per Unit', value: HC.fmt(c.hpp) },
            { label: '🏷️ Harga Jual', value: HC.fmt(c.harga) },
            { label: '🏢 Biaya Tetap/Bln', value: HC.fmt(c.fixed) },
            { label: '📦 Target Volume', value: `${c.vol} unit/bln` },
          ],
          results: [
            { label: 'Margin', value: c.marginPct.toFixed(1) + '%', highlight: true },
            { label: 'Markup', value: c.markupPct.toFixed(1) + '%' },
            { label: 'Profit/Unit', value: HC.fmt(c.profit) },
            { label: 'Break-Even Volume', value: `${c.bep} unit` },
            { label: `Omzet ${c.vol} unit`, value: HC.fmt(c.harga * c.vol) },
            { label: 'Profit Bulanan', value: HC.fmt(c.profitBulan), highlight: true },
          ],
          insight, slug: 'margin',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `📊 *Analisa Margin - HitungCerdas*\n\nHPP: ${HC.fmt(c.hpp)}\nHarga Jual: ${HC.fmt(c.harga)}\n\n📈 *Margin: ${c.marginPct.toFixed(1)}%*\n📊 Markup: ${c.markupPct.toFixed(1)}%\n💰 Profit/Unit: ${HC.fmt(c.profit)}\n⚖️ Break-Even: ${c.bep} unit/bln\n💵 Profit Bulanan: ${HC.fmt(c.profitBulan)}\n\nHitung: https://hitungcerdas.net/kalkulator/margin`;
      }

            function renderHist() {
        if (HC.history) HC.history.render('margin', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'margin-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'margin'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'margin-' + Date.now()); });
    });
  })();
</script>
<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#ECFDF5;border:1px solid #A7F3D0;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#D1FAE5}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#10B981;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#ECFDF5;color:#10B981;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#ECFDF5;color:#10B981;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl>span{flex:1 1 0}
  .aic-gauge-lbl>span:first-child{text-align:left}
  .aic-gauge-lbl>span:nth-child(2){text-align:center}
  .aic-gauge-lbl>span:last-child{text-align:right}
  .aic-gauge-lbl .g{color:#059669}
  .aic-gauge-lbl .a{color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#ECFDF5;color:#10B981;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#10B981;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#10B981;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
  @keyframes aicIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .aic-row{animation:aicIn .25s ease both}
  .aic-copy{margin-top:8px;display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#64748B;background:#fff;border:1px solid #E2E8F0;border-radius:7px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .aic-copy:hover{color:#065F46;border-color:#065F46;background:#ECFDF5}
  .aic-copy i{font-size:13px}

  .aic-chips{display:flex;flex-wrap:wrap;gap:6px;padding:0 14px 12px}
  .aic-chips:empty{display:none}
  .aic-chip{font-size:11px;background:#ECFDF5;color:#10B981;border:1px solid #A7F3D0;border-radius:14px;padding:6px 11px;cursor:pointer;font-family:inherit}
  .aic-chip:hover{background:#D1FAE5}

  .aic-input{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid #E5EAF1}
  .aic-input input{flex:1;border:1px solid #E5EAF1;border-radius:18px;padding:9px 14px;font-size:13px;background:#F8FAFC;color:#0A2540;outline:none;font-family:inherit}
  .aic-input input:focus{border-color:#10B981}
  .aic-input button{width:34px;height:34px;flex-shrink:0;border:0;border-radius:50%;background:#10B981;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px}
  .aic-input button:disabled{background:#CBD5E1;cursor:not-allowed}

  .aic-disc{display:flex;gap:6px;align-items:flex-start;padding:8px 14px;font-size:10.5px;color:#94A3B8;line-height:1.45;border-top:1px solid #F1F5F9}
  .aic-disc i{margin-top:1px}
  .aic-limit{padding:0 14px 10px;font-size:11px;color:#64748B}

  /* ===== DARK MODE (mandiri, via .aic-dark) ===== */
  .aic-dark .aic-trigger{background:#16263B;border-color:#2A445F}
  .aic-dark .aic-trigger:hover{background:#1B2E47}
  .aic-dark .aic-trigger-txt strong{color:#E8EEF6}
  .aic-dark .aic-trigger-txt small{color:#93A4B8}
  .aic-dark .aic-trigger-arr{color:#93A4B8}
  .aic-dark .aic-panel{background:#0E1A2B;border-color:#243A56}
  .aic-dark .aic-head{border-color:#243A56}
  .aic-dark .aic-head-ic{background:#172A44;color:#6EE7B7}
  .aic-dark .aic-head-tt strong{color:#E8EEF6}
  .aic-dark .aic-head-tt small{color:#93A4B8}
  .aic-dark .aic-badge{background:#172A44;color:#6EE7B7}
  .aic-dark .aic-ground{background:#122036;border-color:#243A56}
  .aic-dark .aic-ctx{color:#A9B7C9}
  .aic-dark .aic-ctx b{color:#E8EEF6}
  .aic-dark .aic-gauge-mark span{background:#E8EEF6;color:#0E1A2B}
  .aic-dark .aic-gauge-mark::after{background:#E8EEF6}
  .aic-dark .aic-gauge-bar .z-green{background:rgba(16,185,129,.24)}
  .aic-dark .aic-gauge-bar .z-amber{background:rgba(245,158,11,.24)}
  .aic-dark .aic-gauge-bar .z-red{background:rgba(239,68,68,.24)}
  .aic-dark .aic-gauge-lbl .g{color:#34D399}
  .aic-dark .aic-gauge-lbl .a{color:#FBBF24}
  .aic-dark .aic-gauge-lbl .r{color:#F87171}
  .aic-dark .aic-verdict.good{color:#34D399}
  .aic-dark .aic-verdict.warn{color:#FBBF24}
  .aic-dark .aic-verdict.bad{color:#F87171}
  .aic-dark .aic-av{background:#172A44;color:#6EE7B7}
  .aic-dark .aic-row.ai .aic-bub{background:#1B2C44;color:#E8EEF6}
  .aic-dark .aic-bub.aic-rich .aic-mk{color:#6EE7B7}
  .aic-dark .aic-bub.aic-rich code{background:rgba(255,255,255,.1)}
  .aic-dark .aic-chip{background:rgba(16,185,129,.16);color:#6EE7B7;border-color:#2A445F}
  .aic-dark .aic-chip:hover{background:rgba(16,185,129,.26)}
  .aic-dark .aic-input{border-color:#243A56}
  .aic-dark .aic-input input{background:#16263B;border-color:#2A445F;color:#E8EEF6}
  .aic-dark .aic-input input:focus{border-color:#34D399}
  .aic-dark .aic-disc{color:#7E8DA1;border-color:#1B2C44}
  .aic-dark .aic-limit{color:#93A4B8}
</style>
<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        return {
          marginPct:parseFloat((($('marginPct')||{}).textContent||'0'))||0,
          markupPct:(($('markupPct')||{}).textContent||'').trim(),
          profitUnit:(($('profitUnit')||{}).textContent||'').trim(),
          profitBulan:(($('profitBulan')||{}).textContent||'').trim(),
          bep:(($('bep')||{}).textContent||'').trim(),
          hpp:($('hpp')||{}).value||'', harga:($('harga')||{}).value||'',
          fixedCost:($('fixedCost')||{}).value||'', volume:($('volume')||{}).value||''
        };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-percentage"></i> Margin'+(d.marginPct?' <b>'+d.marginPct.toFixed(1)+'%</b>':'')
          +(d.markupPct && d.markupPct!=='0%'?' \u00b7 Markup '+esc(d.markupPct):'')
          +(d.profitUnit && d.profitUnit!=='Rp 0'?' \u00b7 Profit/unit <b>'+esc(d.profitUnit)+'</b>':'')+'</div>';
        if(!d.marginPct){ ground.innerHTML=ctx+'<div class="aic-nogauge">Klik "Hitung Sekarang" dulu untuk lihat gauge margin.</div>'; return; }
        var mr=d.marginPct, pos=Math.max(0,Math.min(mr,60))/60*100;
        var vc=mr<=15?'bad':(mr<=40?'good':'warn');
        var vi=mr<=15?'ti-alert-circle':(mr<=40?'ti-circle-check':'ti-alert-triangle');
        var vt=mr<=15?'Margin tipis \u2014 rawan rugi bila ada biaya tak terduga':(mr<=40?'Margin sehat \u2014 zona umum kebanyakan UMKM':'Margin tebal \u2014 untung besar, pastikan harga tetap kompetitif');
        ground.innerHTML=ctx
          +'<div class="aic-gauge"><div class="aic-gauge-mark" style="left:'+pos.toFixed(1)+'%"><span>'+mr.toFixed(0)+'%</span></div>'
          +'<div class="aic-gauge-bar"><div class="z-red" style="flex:15"></div><div class="z-green" style="flex:25"></div><div class="z-amber" style="flex:20"></div></div>'
          +'<div class="aic-gauge-lbl"><span class="r">Tipis &le;15%</span><span class="g">Sehat</span><span class="a">Tebal &gt;40%</span></div></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Margin & Markup (analisa keuntungan) untuk produk UMKM.',
          'Input: HPP Rp '+d.hpp+', harga jual Rp '+d.harga+((d.fixedCost && HC.parseRp(d.fixedCost)>0)?(', biaya tetap Rp '+d.fixedCost+'/bulan'):'')+(d.volume?(', target volume '+d.volume+' unit/bulan'):'')+'.',
          'Hasil: margin '+d.marginPct.toFixed(1)+'% (profit \u00f7 harga jual), markup '+d.markupPct+' (profit \u00f7 HPP), profit per unit '+d.profitUnit+', profit bulanan '+d.profitBulan+((d.bep && d.bep!=='0')?(', BEP '+d.bep):'')+'.',
          'Acuan untuk jawabanmu: margin = profit \u00f7 harga jual; markup = profit \u00f7 HPP (modal). Markup SELALU lebih besar dari margin untuk profit yang sama (markup 100% = margin 50%, markup 50% = margin 33%); banyak pelaku UMKM keliru menyebut markup sebagai margin. Benchmark margin sehat BERBEDA per industri: retail/grocery 5-15% (wajar karena mengandalkan volume tinggi), fashion 30-50%, F&B/kuliner 40-60% (food cost idealnya maksimal 35% dari harga), beauty/skincare 50-70%, SaaS/digital 70-90%, handmade markup 100-300% \u2014 jadi jangan menghakimi margin tanpa tahu industrinya. BEP (break-even point) = biaya tetap \u00f7 profit per unit = jumlah unit minimum agar tidak rugi; di atas BEP mulai untung. Cara naikkan margin tanpa naikkan harga: nego supplier/diskon volume, kurangi biaya kemasan, beli bahan borongan saat harga murah, efisiensi operasional, bundling untuk naikkan nilai per transaksi, dan program loyalitas agar biaya akuisisi rendah. Pertimbangkan juga harga psikologis dan harga kompetitor. Jawab ringkas, hangat, pakai sapaan "kamu", dan jangan mengarang angka di luar data.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function typeInto(bubble, text, done){ var n=0, len=text.length, step=Math.max(2, Math.round(len/90)); var t=setInterval(function(){ n=Math.min(len, n+step); bubble.innerHTML=mdToHtml(text.slice(0,n)); msgs.scrollTop=msgs.scrollHeight; if(n>=len){ clearInterval(t); done&&done(); } }, 18); }
      function mkCopyBtn(text){ var b=document.createElement('button'); b.type='button'; b.className='aic-copy'; b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>'; b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); }); return b; }
      function addMsgTyped(text){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); }); return row; }
      var FOLLOWUPS=['Margin segini sehat gak?','Bedanya margin sama markup?','Berapa unit biar balik biaya tetap?','Cara naikin margin tanpa naikin harga?','Margin bagus untuk usahaku berapa?','Kok markup lebih besar dari margin?','BEP-ku artinya apa?','Profit bulanan segini cukup gak?'];
      function renderFollowups(){ chips.innerHTML=''; var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;}); var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;}); pool.slice(0,3).forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b); }); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Margin segini sehat gak?','Bedanya margin sama markup?','Berapa unit biar balik biaya tetap?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },800); }); }
    });
  })();
</script>
