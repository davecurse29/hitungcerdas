---
import Layout from '../../layouts/Layout.astro';
import EbookPromo from '../../components/EbookPromo.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('roi-usaha')!;
const related = getRelatedCalculators('roi-usaha', 3);

const faqs = [
  { question: 'Apa itu ROI (Return on Investment)?', answer: 'ROI adalah <strong>persentase keuntungan dibanding modal yang ditanam</strong>. Rumusnya: (Laba Bersih ÷ Modal) × 100%. ROI mengukur seberapa efisien modalmu menghasilkan untung. Misal modal Rp 50 juta menghasilkan laba Rp 30 juta setahun, ROI tahunannya 60% — artinya tiap Rp 100 modal menghasilkan Rp 60 untung per tahun.' },
  { question: 'Apa itu payback period (balik modal)?', answer: 'Payback period adalah <strong>lama waktu sampai total laba menutup modal awal</strong>. Rumusnya: Modal ÷ Laba Bersih per bulan. Misal modal Rp 50 juta dengan laba Rp 2,5 juta/bulan → balik modal dalam 20 bulan. Semakin cepat balik modal, semakin rendah risiko usaha.' },
  { question: 'Berapa ROI usaha yang bagus?', answer: 'Tidak ada angka mutlak — tergantung jenis usaha dan risikonya. Sebagai pembanding kasar: deposito ~4-6%/tahun, reksa dana ~6-12%/tahun. Usaha UMKM biasanya diharapkan memberi ROI <strong>lebih tinggi dari instrumen pasif</strong> karena risikonya juga lebih besar. ROI tinggi belum tentu lebih baik kalau risikonya juga tinggi atau tidak berkelanjutan.' },
  { question: 'Laba bersih itu yang mana?', answer: '<strong>Laba bersih</strong> adalah pendapatan dikurangi SEMUA biaya: HPP/biaya variabel, biaya tetap (sewa, gaji), pajak, dan biaya lain. Jangan pakai omzet atau laba kotor — itu membuat ROI terlihat lebih bagus dari kenyataan. Hitung dulu laba bersih yang realistis, baru masukkan ke sini.' },
  { question: 'ROI saya terlihat tinggi tapi usaha terasa berat, kenapa?', answer: 'Bisa jadi karena beberapa hal: laba yang dipakai belum dikurangi biaya tersembunyi (gaji sendiri, penyusutan alat), modal awal belum lengkap (lupa biaya renovasi/perizinan), atau labanya tidak stabil tiap bulan. ROI hanya seakurat data yang kamu masukkan — pastikan modal dan laba bersihnya realistis dan lengkap.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#16A34A;--cat-color2:#15803D">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#DCFCE7;color:#166534"><i class="ti ti-trending-up"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M52 140 L86 108 L112 128 L150 78" stroke="#86EFAC" stroke-width="4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M134 78 H150 V94" stroke="#86EFAC" stroke-width="4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="100" cy="110" r="22" fill="#FFF" stroke="#16A34A" stroke-width="3"/>
            <text x="92" y="119" fill="#16A34A" font-size="22" font-weight="bold" font-family="sans-serif">%</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#16A34A 0%,#15803D 100%)"><i class="ti ti-trending-up"></i></div>
          <div><h2 class="calc-card-title">Kalkulator ROI & Balik Modal</h2><p class="calc-card-sub">Berapa persen untung dari modal & kapan balik modal</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Modal Awal Usaha</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="modal" class="has-prefix" value="50.000.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Total investasi awal: alat, renovasi, stok awal, perizinan, dll.</p>
            </div>

            <div class="adv-section" id="modalHelper">
              <div class="adv-toggle"><span><i class="ti ti-building-store"></i>&nbsp; Bantu hitung modal awal lengkap</span><i class="ti ti-chevron-down chev"></i></div>
              <div class="adv-content">
                <p style="font-size:12px;color:var(--text-mute);margin:0 0 10px;line-height:1.5">Rinci komponen modalmu — total dihitung otomatis. Jangan lupa <b>modal kerja/buffer</b> (dana operasional sampai usaha untung), komponen yang paling sering terlewat.</p>
                <div class="field"><label>Sewa &amp; Renovasi Tempat</label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="mSewa" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>Peralatan &amp; Mesin</label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="mAlat" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>Stok / Bahan Baku Awal</label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="mStok" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>Perizinan &amp; Legalitas <span class="hint">(NIB, sertifikasi, notaris)</span></label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="mIzin" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field" style="margin-bottom:6px"><label>Modal Kerja / Buffer <span class="hint">(dana operasional 3–6 bln)</span></label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="mKerja" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div id="modalHelperResult" style="margin-top:6px;padding:10px 12px;border-radius:10px;background:#F0FDF4;border:1px solid #BBF7D0;font-size:12.5px;line-height:1.5;color:#166534;display:none"></div>
              </div>
            </div>

            <div class="field"><label>Laba Bersih per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="laba" class="has-prefix" value="2.500.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Pendapatan dikurangi <strong>semua</strong> biaya (HPP, sewa, gaji, pajak). Bukan omzet.</p>
            </div>

            <div class="adv-section" id="labaHelper">
              <div class="adv-toggle"><span><i class="ti ti-receipt-2"></i>&nbsp; Bantu hitung laba bersih realistis</span><i class="ti ti-chevron-down chev"></i></div>
              <div class="adv-content">
                <p style="font-size:12px;color:var(--text-mute);margin:0 0 10px;line-height:1.5">Isi rincian bulananmu — laba bersih dihitung otomatis, <b>sudah termasuk gaji dirimu &amp; penyusutan alat</b> (dua hal yang paling sering lupa dihitung sehingga ROI terlihat lebih besar dari kenyataan).</p>
                <div class="field"><label>Omzet / Pendapatan per Bulan</label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="omzet" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>HPP / Modal Barang per Bulan <span class="hint">(bahan baku, kulakan)</span></label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="hpp" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>Biaya Operasional per Bulan <span class="hint">(sewa, listrik, internet, transport)</span></label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="opex" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field"><label>Gaji untuk Diri Sendiri <span class="hint">(wajib — bayar dirimu!)</span></label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="gajiDiri" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div class="field" style="margin-bottom:6px"><label>Penyusutan Alat per Bulan <span class="hint">(harga alat ÷ umur pakai bulan)</span></label><div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="penyusutan" class="has-prefix" value="0" inputmode="numeric" /></div></div>
                <div id="labaHelperResult" style="margin-top:6px;padding:10px 12px;border-radius:10px;background:#F0FDF4;border:1px solid #BBF7D0;font-size:12.5px;line-height:1.5;color:#166534;display:none"></div>
              </div>
            </div>

            <div class="field"><label>Lihat Proyeksi Selama</label>
              <div class="input-wrap"><span class="input-suffix">bulan</span>
                <input type="number" id="periode" class="has-suffix" value="24" min="1" max="120" step="1" /></div>
              <p class="hint" style="margin-top:6px">Untuk melihat total laba & ROI dalam periode tertentu.</p>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-trending-up result-placeholder-icon"></i>
              <div class="result-placeholder-title">ROI & balik modal akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi modal & laba bersih per bulan, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Balik Modal Dalam</div>
                <div class="result-value" id="payback">0 bulan</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="paybackMeta">ROI per tahun 0%</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">ROI per Bulan</div><div class="result-item-value" id="roiBulan" style="color:var(--green-dark)">0%</div></div>
                <div class="result-item"><div class="result-item-label">ROI per Tahun</div><div class="result-item-value" id="roiTahun" style="color:var(--green-dark)">0%</div></div>
                <div class="result-item"><div class="result-item-label">Total Laba Periode</div><div class="result-item-value" id="totalLaba">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Untung Bersih (stlh modal)</div><div class="result-item-value" id="netGain">Rp 0</div></div>
              </div>

              <div id="roiInfo" style="margin-top:10px;padding:11px 13px;border-radius:12px;background:#F0FDF4;border:1px solid #BBF7D0;font-size:12.5px;line-height:1.55;color:#166534"></div>

              <div id="bandingInfo" style="margin-top:10px;padding:11px 13px;border-radius:12px;background:#F8FAFC;border:1px solid #E2E8F0;font-size:12.5px;line-height:1.55;color:#475569"></div>

              <div style="margin-top:12px;padding:12px;border:1px solid var(--border);border-radius:12px;background:var(--bg-soft)">
                <div style="font-size:12.5px;font-weight:700;color:var(--text);margin-bottom:6px"><i class="ti ti-chart-line"></i> Grafik Balik Modal</div>
                <div id="roiChart"></div>
                <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:8px;font-size:11px;color:var(--text-soft)">
                  <span><span style="display:inline-block;width:14px;height:3px;background:#16A34A;vertical-align:middle;margin-right:4px"></span>Laba Kumulatif</span>
                  <span><span style="display:inline-block;width:14px;height:3px;background:#94A3B8;vertical-align:middle;margin-right:4px"></span>Modal Awal</span>
                </div>
              </div>

              <div style="margin-top:12px">
                <div style="font-size:12.5px;font-weight:700;color:var(--text);margin-bottom:8px"><i class="ti ti-chart-bar"></i> Perbandingan ROI per Tahun</div>
                <div id="roiBars"></div>
                <p class="hint" style="margin-top:6px">Pembanding: deposito ~5%/thn, reksa dana ~9%/thn (estimasi umum). Usaha riil wajar lebih tinggi karena risikonya juga lebih besar.</p>
              </div>

              <div class="adv-section" id="scenBlock">
                <div class="adv-toggle"><span><i class="ti ti-columns"></i>&nbsp; Bandingkan Skenario A vs B</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <p style="font-size:12px;color:var(--text-mute);margin:0 0 8px;line-height:1.5">Atur input skenario pertama lalu klik <b>Simpan sbg A</b>. Ubah input, klik <b>Simpan sbg B</b>. Otomatis dihitung ulang — tabel perbandingan muncul sendiri.</p>
                  <div style="display:flex;gap:8px">
                    <button type="button" class="btn-reset" id="btnScenA" style="flex:1"><i class="ti ti-bookmark"></i> Simpan sbg A</button>
                    <button type="button" class="btn-reset" id="btnScenB" style="flex:1"><i class="ti ti-bookmark"></i> Simpan sbg B</button>
                  </div>
                  <div id="scenResult" style="display:none;margin-top:10px"></div>
                  <button type="button" id="btnScenReset" style="margin-top:8px;background:none;border:none;color:var(--text-mute);font-size:12px;cursor:pointer;text-decoration:underline">Reset skenario</button>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

    <EbookPromo calc="roi-usaha" headline="Mau usaha yang cepat balik modal? Mulai dari cuan pertamamu." />

  <section class="content-section">
    <div class="wrap-text">
      <h2>Memahami ROI & Balik Modal Usaha</h2>
      <p>Sebelum memulai usaha, membeli franchise, atau menambah aset produktif, dua angka wajib kamu tahu: <strong>ROI</strong> (seberapa menguntungkan modalmu) dan <strong>payback period</strong> (kapan modal kembali). Keduanya membantu menilai apakah sebuah usaha layak dijalankan, dan membandingkan beberapa peluang sekaligus. Sebelum menghitung ROI, pastikan kamu sudah tahu <a href="/kalkulator/bep">titik impas (BEP)</a> dan <a href="/kalkulator/hpp">HPP</a> usahamu.</p>

      <h3>Rumus</h3>
      <ul>
        <li><strong>ROI per bulan</strong> = (Laba Bersih per bulan ÷ Modal) × 100%</li>
        <li><strong>ROI per tahun</strong> = ROI per bulan × 12</li>
        <li><strong>Payback period</strong> = Modal ÷ Laba Bersih per bulan (dalam bulan)</li>
      </ul>

      <h3>Gunakan Laba Bersih, Bukan Omzet</h3>
      <p>Kesalahan paling umum: memakai omzet atau laba kotor. ROI hanya bermakna kalau kamu pakai <strong>laba bersih</strong> — pendapatan dikurangi semua biaya termasuk HPP, sewa, gaji (termasuk gaji dirimu sendiri), dan pajak. Modal awal juga harus lengkap: peralatan, renovasi, stok awal, dan perizinan.</p>

      <h3>Konteks 2026</h3>
      <p>Sebagai pembanding, instrumen investasi pasif di 2026 memberi imbal hasil kira-kira: deposito 4-6%/tahun, reksa dana 6-12%/tahun. Usaha riil idealnya memberi ROI lebih tinggi karena risikonya lebih besar dan butuh tenaga. Tapi ingat — ROI tinggi di atas kertas tidak otomatis berarti usaha aman. Pertimbangkan juga kestabilan laba, ketahanan terhadap kenaikan biaya, dan apakah modelnya berkelanjutan. Kombinasikan dengan <a href="/kalkulator/investasi">simulasi investasi</a> untuk membandingkan dengan opsi pasif.</p>

      <div class="cta-box">
        <h3>Disclaimer</h3>
        <p>Kalkulator ini alat bantu simulasi &amp; edukasi. Perhitungan mengasumsikan laba bersih per bulan konstan; pada praktiknya laba bisa fluktuatif. ROI dan payback period bukan jaminan hasil dan tidak memperhitungkan nilai waktu uang (time value of money) atau risiko usaha. Gunakan sebagai panduan awal, bukan keputusan investasi final.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar ROI & Balik Modal" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>

  <p class="hc-method-note" style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:680px;line-height:1.6;padding:0 1rem;">
    📅 Diperbarui <strong>Juni 2026</strong> · ROI = (laba bersih &divide; modal investasi) &times; 100%; payback period = modal &divide; laba per periode. Estimasi edukatif untuk perencanaan. <strong>Sumber:</strong> prinsip analisis investasi.
  </p>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { modal: $('modal'), laba: $('laba'), periode: $('periode') };
      [els.modal, els.laba].forEach(el => el.addEventListener('input', HC.fmtInput));
      ['omzet','hpp','opex','gajiDiri','penyusutan'].forEach(id => { const el = $(id); if (el) { el.addEventListener('input', HC.fmtInput); el.addEventListener('input', recomputeLaba); } });
      ['mSewa','mAlat','mStok','mIzin','mKerja'].forEach(id => { const el = $(id); if (el) { el.addEventListener('input', HC.fmtInput); el.addEventListener('input', recomputeModal); } });
      function recomputeModal() {
        const sewa = HC.parseRp($('mSewa').value), alat = HC.parseRp($('mAlat').value), stok = HC.parseRp($('mStok').value), izin = HC.parseRp($('mIzin').value), kerja = HC.parseRp($('mKerja').value);
        const total = sewa + alat + stok + izin + kerja;
        const box = $('modalHelperResult');
        if (total <= 0) { box.style.display = 'none'; return; }
        els.modal.value = HC.fmtNum(total);
        box.style.display = '';
        let msg = '\u2705 Total modal awal: <b>' + HC.fmt(total) + '</b> \u2014 otomatis dipakai di kolom <b>Modal Awal Usaha</b> di atas.';
        if (kerja <= 0) msg += '<br><span style="color:#B45309">\u26a0\ufe0f Kamu belum menyiapkan modal kerja (buffer). Banyak usaha tutup bukan karena rugi, tapi kehabisan kas sebelum untung \u2014 siapkan dana operasional 3\u20136 bulan.</span>';
        box.innerHTML = msg;
      }
      function recomputeLaba() {
        const omzet = HC.parseRp($('omzet').value);
        const box = $('labaHelperResult');
        if (omzet <= 0) { box.style.display = 'none'; return; }
        const hpp = HC.parseRp($('hpp').value), opex = HC.parseRp($('opex').value), gaji = HC.parseRp($('gajiDiri').value), pny = HC.parseRp($('penyusutan').value);
        const labaRiil = omzet - hpp - opex - gaji - pny;
        box.style.display = '';
        if (labaRiil > 0) {
          els.laba.value = HC.fmtNum(labaRiil);
          box.style.background = '#F0FDF4'; box.style.borderColor = '#BBF7D0'; box.style.color = '#166534';
          let msg = '\u2705 Laba bersih riil: <b>' + HC.fmt(labaRiil) + '/bulan</b> \u2014 sudah termasuk gaji dirimu & penyusutan. Nilai ini otomatis dipakai di kolom <b>Laba Bersih per Bulan</b> di atas.';
          if (gaji <= 0) msg += '<br><span style="color:#B45309">\u26a0\ufe0f Kamu belum mengalokasikan gaji untuk diri sendiri \u2014 tanpa itu, laba (dan ROI) bisa terlihat lebih besar dari kenyataan.</span>';
          box.innerHTML = msg;
        } else {
          els.laba.value = '0';
          box.style.background = '#FEF2F2'; box.style.borderColor = '#FECACA'; box.style.color = '#991B1B';
          box.innerHTML = '\u26a0\ufe0f Dengan rincian ini, usaha <b>belum untung</b> (laba bersih \u2264 Rp 0, defisit ' + HC.fmt(Math.abs(labaRiil)) + '/bulan). Perbaiki harga jual, tekan HPP, atau kurangi biaya dulu sebelum menghitung ROI.';
        }
      }

      let lastCalc = null;

      function bulanText(bln) {
        if (bln <= 0) return '0 bulan';
        const th = Math.floor(bln / 12), sisa = Math.round(bln % 12);
        if (th >= 1 && sisa > 0) return `${th} thn ${sisa} bln`;
        if (th >= 1) return `${th} tahun`;
        return `${Math.round(bln)} bulan`;
      }

      function hitung() {
        const modal = HC.parseRp(els.modal.value);
        const laba = HC.parseRp(els.laba.value);
        const periode = parseInt(els.periode.value) || 0;

        if (modal === 0) { HC.toast('Masukkan modal awal dulu', 'error'); return; }
        if (laba <= 0) { HC.toast('Masukkan laba bersih per bulan', 'error'); return; }
        if (periode < 1) { HC.toast('Periode minimal 1 bulan', 'error'); return; }

        const payback = modal / laba;
        const roiBulan = laba / modal * 100;
        const roiTahun = roiBulan * 12;
        const totalLaba = laba * periode;
        const netGain = totalLaba - modal;

        $('payback').textContent = bulanText(payback);
        $('paybackMeta').textContent = `ROI per tahun ${roiTahun.toFixed(1)}%`;
        $('roiBulan').textContent = roiBulan.toFixed(2) + '%';
        $('roiTahun').textContent = roiTahun.toFixed(1) + '%';
        $('totalLaba').textContent = HC.fmt(totalLaba);
        $('netGain').textContent = HC.fmt(netGain);
        $('netGain').style.color = netGain >= 0 ? 'var(--green-dark)' : 'var(--red)';

        const balikDalamPeriode = payback <= periode;
        $('roiInfo').innerHTML = `\ud83d\udcb0 Modal <b>${HC.fmt(modal)}</b> dengan laba <b>${HC.fmt(laba)}/bulan</b> balik dalam <b>${bulanText(payback)}</b> (ROI <b>${roiTahun.toFixed(1)}%/tahun</b>). Dalam ${periode} bulan, total laba <b>${HC.fmt(totalLaba)}</b> \u2014 ${balikDalamPeriode ? `untung bersih <b>${HC.fmt(netGain)}</b> setelah modal kembali.` : `modal <b>belum kembali</b> (kurang ${HC.fmt(modal - totalLaba)}).`}`;

        let banding;
        if (roiTahun >= 12) banding = `\ud83d\udcca ROI ${roiTahun.toFixed(1)}%/tahun ini di atas imbal hasil instrumen pasif (deposito ~4-6%, reksa dana ~6-12%). Wajar untuk usaha riil karena risikonya lebih besar \u2014 pastikan labanya stabil & berkelanjutan.`;
        else if (roiTahun >= 6) banding = `\ud83d\udcca ROI ${roiTahun.toFixed(1)}%/tahun setara reksa dana, tapi usaha butuh tenaga & risiko lebih besar. Pertimbangkan apakah sepadan dibanding investasi pasif.`;
        else banding = `\u26a0\ufe0f ROI ${roiTahun.toFixed(1)}%/tahun tergolong rendah \u2014 di bawah atau setara deposito (~4-6%), padahal usaha berisiko & butuh tenaga. Evaluasi ulang modal, harga jual, atau efisiensi biaya.`;
        $('bandingInfo').innerHTML = banding;

        // ===== Grafik Balik Modal =====
        var xMax = Math.max(periode, Math.ceil(payback) + 2);
        if (xMax < 2) xMax = 2;
        var cumEnd = laba * xMax;
        var yMax = Math.max(cumEnd, modal) * 1.05;
        var PL = 46, PR = 306, PT = 14, PB = 150;
        var X = function(m) { return (PL + (m / xMax) * (PR - PL)).toFixed(1); };
        var Y = function(v) { return (PB - (v / yMax) * (PB - PT)).toFixed(1); };
        var svg = '<svg viewBox="0 0 320 174" style="width:100%;height:auto" xmlns="http://www.w3.org/2000/svg">';
        // area di bawah laba kumulatif sampai payback (hijau muda)
        svg += '<line x1="' + X(0) + '" y1="' + Y(0) + '" x2="' + X(xMax) + '" y2="' + Y(0) + '" stroke="#CBD5E1" stroke-width="1"/>';
        svg += '<line x1="' + X(0) + '" y1="' + Y(0) + '" x2="' + X(0) + '" y2="' + PT + '" stroke="#CBD5E1" stroke-width="1"/>';
        // garis modal (abu)
        svg += '<line x1="' + X(0) + '" y1="' + Y(modal) + '" x2="' + X(xMax) + '" y2="' + Y(modal) + '" stroke="#94A3B8" stroke-width="1.5" stroke-dasharray="4 3"/>';
        // garis laba kumulatif (hijau)
        svg += '<line x1="' + X(0) + '" y1="' + Y(0) + '" x2="' + X(xMax) + '" y2="' + Y(cumEnd) + '" stroke="#16A34A" stroke-width="2"/>';
        // titik balik modal
        if (payback <= xMax) {
          svg += '<line x1="' + X(payback) + '" y1="' + Y(0) + '" x2="' + X(payback) + '" y2="' + Y(modal) + '" stroke="#15803D" stroke-width="1" stroke-dasharray="3 3"/>';
          svg += '<circle cx="' + X(payback) + '" cy="' + Y(modal) + '" r="4" fill="#15803D"/>';
          svg += '<text x="' + X(payback) + '" y="' + (PB + 13) + '" font-size="9" fill="#15803D" text-anchor="middle" font-weight="700">balik modal</text>';
        }
        svg += '<text x="' + X(xMax) + '" y="' + (PB + 13) + '" font-size="8" fill="#94A3B8" text-anchor="end">bulan →</text>';
        svg += '<text x="' + PL + '" y="' + (PT - 4) + '" font-size="8" fill="#94A3B8">Rp</text>';
        svg += '</svg>';
        $('roiChart').innerHTML = svg;

        // ===== Perbandingan ROI (bars) =====
        var bench = [
          { label: 'Usaha kamu', val: roiTahun, color: '#16A34A', bold: true },
          { label: 'Reksa dana', val: 9, color: '#94A3B8', bold: false },
          { label: 'Deposito', val: 5, color: '#CBD5E1', bold: false }
        ];
        var bmax = Math.max(roiTahun, 12);
        var barsHtml = '';
        bench.forEach(function(b) {
          var w = bmax > 0 ? Math.max(2, b.val / bmax * 100) : 0;
          barsHtml += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">'
            + '<span style="width:88px;flex-shrink:0;font-size:11.5px;' + (b.bold ? 'font-weight:700;color:var(--text)' : 'color:var(--text-soft)') + '">' + b.label + '</span>'
            + '<div style="flex:1;height:16px;background:#F1F5F9;border-radius:5px;overflow:hidden"><div style="height:100%;width:' + w.toFixed(1) + '%;background:' + b.color + ';border-radius:5px"></div></div>'
            + '<span style="width:50px;flex-shrink:0;text-align:right;font-size:11.5px;font-weight:700;color:' + (b.bold ? '#15803D' : 'var(--text-soft)') + '">' + b.val.toFixed(1) + '%</span></div>';
        });
        $('roiBars').innerHTML = barsHtml;

        lastCalc = { modal, laba, periode, payback, roiBulan, roiTahun, totalLaba, netGain, balikDalamPeriode };
        if (HC.history) HC.history.push('roi-usaha', { inputs: HC.history.capture(['modal','laba','periode']), summary: 'Modal ' + sRp(lastCalc.modal) + ' \u00b7 Laba ' + sRp(lastCalc.laba) + ' \u00b7 ' + lastCalc.periode + ' bln', metrics: [{ k: 'ROI/thn', v: lastCalc.roiTahun.toFixed(1) + '%' }, { k: 'Balik', v: (Math.round(lastCalc.payback * 10) / 10) + ' bln' }] });
        renderHist();
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('ROI berhasil dihitung!');
      }

      function reset() {
        els.modal.value = '50.000.000'; els.laba.value = '2.500.000'; els.periode.value = '24';
        ['omzet','hpp','opex','gajiDiri','penyusutan'].forEach(id => { const el = $(id); if (el) el.value = '0'; });
        ['mSewa','mAlat','mStok','mIzin','mKerja'].forEach(id => { const el = $(id); if (el) el.value = '0'; });
        var _mh = $('modalHelperResult'); if (_mh) _mh.style.display = 'none';
        var _lh = $('labaHelperResult'); if (_lh) _lh.style.display = 'none';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        scenA = null; scenB = null; var _sr = $('scenResult'); if (_sr) { _sr.style.display = 'none'; _sr.innerHTML = ''; } lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = `Modal ${HC.fmt(c.modal)}, laba ${HC.fmt(c.laba)}/bln. Balik modal ${bulanText(c.payback)}, ROI ${c.roiTahun.toFixed(1)}%/tahun. Dalam ${c.periode} bln total laba ${HC.fmt(c.totalLaba)}. Asumsi laba konstan; estimasi edukatif, bukan jaminan hasil.`;
        return HC.buildReportCard({
          title: '\ud83d\udcc8 ROI & Balik Modal Usaha',
          color: '#16A34A', color2: '#15803D',
          heroLabel: 'Balik Modal Dalam',
          heroValue: bulanText(c.payback),
          heroSubtext: `ROI ${c.roiTahun.toFixed(1)}%/tahun`,
          inputs: [
            { label: '\ud83d\udcb5 Modal Awal', value: HC.fmt(c.modal) },
            { label: '\ud83d\udcc8 Laba Bersih/bln', value: HC.fmt(c.laba) },
            { label: '\ud83d\udcc5 Periode Proyeksi', value: c.periode + ' bulan' },
          ],
          results: [
            { label: 'Balik Modal', value: bulanText(c.payback), highlight: true },
            { label: 'ROI/tahun', value: c.roiTahun.toFixed(1) + '%', highlight: true },
            { label: 'ROI/bulan', value: c.roiBulan.toFixed(2) + '%' },
            { label: 'Total Laba ' + c.periode + ' bln', value: HC.fmt(c.totalLaba) },
          ],
          insight, slug: 'roi-usaha',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `\ud83d\udcc8 *ROI & Balik Modal Usaha - HitungCerdas*\n\nModal awal: ${HC.fmt(c.modal)}\nLaba bersih/bln: ${HC.fmt(c.laba)}\n\n\u23f1\ufe0f *Balik modal: ${bulanText(c.payback)}*\n\ud83d\udcca ROI: ${c.roiTahun.toFixed(1)}%/tahun (${c.roiBulan.toFixed(2)}%/bln)\n\ud83d\udcb0 Total laba ${c.periode} bln: ${HC.fmt(c.totalLaba)}\n\nHitung di: https://hitungcerdas.net/kalkulator/roi-usaha`;
      }

      // ===== Skenario A vs B =====
      var scenA = null, scenB = null;
      function scenFmt(v, t) { if (t === 'pct') return v.toFixed(1) + '%'; if (t === 'bulan') return (Math.round(v * 10) / 10) + ' bln'; return HC.fmt(v); }
      function sRp(v) { if (v >= 1e6) return (v / 1e6).toFixed(v % 1e6 ? 1 : 0).replace('.', ',') + 'jt'; if (v >= 1e3) return (v / 1e3).toFixed(v % 1e3 ? 1 : 0).replace('.', ',') + 'rb'; return String(v); }
      function buildSnap() {
        var c = lastCalc;
        return { label: 'Modal ' + sRp(c.modal) + ' \u00b7 Laba ' + sRp(c.laba) + ' \u00b7 ' + c.periode + ' bln', rows: [ { k: 'ROI per Tahun', v: c.roiTahun, t: 'pct' }, { k: 'Balik Modal', v: c.payback, t: 'bulan' }, { k: 'Total Laba Periode', v: c.totalLaba, t: 'rp' } ] };
      }
      function snapScenario(slot) {
        hitung();
        if (!lastCalc) { HC.toast('Isi data dulu sebelum simpan skenario', 'error'); return; }
        var snap = buildSnap();
        if (slot === 'A') scenA = snap; else scenB = snap;
        HC.toast('Tersimpan sebagai Skenario ' + slot);
        renderScenario();
      }
      function renderScenario() {
        var box = $('scenResult');
        if (!box) return;
        if (!scenA && !scenB) { box.style.display = 'none'; box.innerHTML = ''; return; }
        box.style.display = '';
        var ref = scenA || scenB, both = scenA && scenB;
        var html = '<table class="compare-table"><thead><tr><th>Metrik</th>'
          + '<th class="right">A' + (scenA ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenA.label + '</span>' : '') + '</th>'
          + '<th class="right">B' + (scenB ? '<br><span style="font-size:10px;color:var(--text-mute)">' + scenB.label + '</span>' : '') + '</th>'
          + (both ? '<th class="right">Selisih</th>' : '') + '</tr></thead><tbody>';
        for (var i = 0; i < ref.rows.length; i++) {
          var rk = ref.rows[i].k, t = ref.rows[i].t;
          var av = scenA ? scenFmt(scenA.rows[i].v, t) : '\u2014';
          var bv = scenB ? scenFmt(scenB.rows[i].v, t) : '\u2014';
          var sel = '';
          if (both) { var d = scenB.rows[i].v - scenA.rows[i].v, thr = (t === 'rp') ? 0.5 : 0.05; sel = '<td class="right">' + (Math.abs(d) < thr ? '\u2014' : (d > 0 ? '+' : '\u2212') + scenFmt(Math.abs(d), t)) + '</td>'; }
          html += '<tr' + (i === 0 ? ' class="active"' : '') + '><td>' + rk + '</td><td class="right">' + av + '</td><td class="right">' + bv + '</td>' + sel + '</tr>';
        }
        html += '</tbody></table>';
        if (both) {
          var d0 = scenB.rows[0].v - scenA.rows[0].v, msg;
          if (Math.abs(d0) < 0.05) msg = 'Kedua skenario setara di ROI tahunan.';
          else { var bBetter = d0 > 0; msg = 'Skenario ' + (bBetter ? 'B' : 'A') + ' lebih unggul \u2014 ROI tahunan lebih tinggi, selisih ' + scenFmt(Math.abs(d0), 'pct') + '.'; }
          html += '<p style="font-size:13px;margin-top:8px;font-weight:600;color:var(--green-dark,#047857)">' + msg + '</p>';
        }
        box.innerHTML = html;
        box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      document.querySelectorAll('.adv-toggle').forEach(function (t) { t.addEventListener('click', function () { t.parentElement.classList.toggle('open'); }); });
      var _bSA = $('btnScenA'); if (_bSA) _bSA.addEventListener('click', function () { snapScenario('A'); });
      var _bSB = $('btnScenB'); if (_bSB) _bSB.addEventListener('click', function () { snapScenario('B'); });
      var _bSR = $('btnScenReset'); if (_bSR) _bSR.addEventListener('click', function () { scenA = null; scenB = null; renderScenario(); HC.toast('Skenario direset', 'info'); });

            function renderHist() {
        if (HC.history) HC.history.render('roi-usaha', $('histBox'), function () { hitung(); });
      }
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'roi-usaha-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'roi-usaha'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'roi-usaha-' + Date.now()); });
    });
  })();
</script>
</Layout>
