<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function readData(){
        var sel=$('platform'); var plat='';
        try{ plat=sel.options[sel.selectedIndex].text.replace(/\s*\(.*\)\s*/,'').trim(); }catch(e){}
        return {
          platform:plat,
          net:(($('netValue')||{}).textContent||'').trim(),
          netNum:HC.parseRp((($('netValue')||{}).textContent||'0')),
          totalCut:(($('totalCut')||{}).textContent||'').trim(),
          cutPct:parseFloat((($('cutPct')||{}).textContent||'0'))||0,
          komisiRp:(($('komisiRp')||{}).textContent||'').trim(),
          ppnRp:(($('ppnRp')||{}).textContent||'').trim(),
          harga:($('harga')||{}).value||'', komisi:($('komisi')||{}).value||'',
          biayaTetap:($('biayaTetap')||{}).value||'', ppn:($('ppn')||{}).value||'',
          hpp:($('hHpp')||{}).value||'', markup:($('hMarkup')||{}).value||''
        };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-motorbike"></i> Komisi '+(d.platform?esc(d.platform):'Platform')+' \u00b7 Potongan <b>'+d.cutPct.toFixed(1)+'%</b>'
          +(d.netNum?' \u00b7 Bersih <b>'+esc(d.net)+'</b>':'')+'</div>';
        if(!d.cutPct){ ground.innerHTML=ctx+'<div class="aic-nogauge">Klik "Hitung Sekarang" dulu untuk lihat gauge beban potongan.</div>'; return; }
        var pos=Math.max(0,Math.min(d.cutPct,40))/40*100;
        var vc=d.cutPct<=22?'good':(d.cutPct<=28?'warn':'bad');
        var vi=d.cutPct<=22?'ti-circle-check':(d.cutPct<=28?'ti-alert-triangle':'ti-alert-circle');
        var vt=d.cutPct<=22?'Potongan relatif ringan':(d.cutPct<=28?'Potongan sedang \u2014 wajar untuk platform':'Potongan berat \u2014 pastikan harga app menutupinya');
        ground.innerHTML=ctx
          +'<div class="aic-gauge"><div class="aic-gauge-mark" style="left:'+pos.toFixed(1)+'%"><span>'+d.cutPct.toFixed(1)+'%</span></div>'
          +'<div class="aic-gauge-bar"><div class="z-green" style="flex:22"></div><div class="z-amber" style="flex:6"></div><div class="z-red" style="flex:12"></div></div>'
          +'<div class="aic-gauge-lbl"><span class="g">Ringan &le;22%</span><span class="a">Sedang</span><span class="r">Berat &gt;28%</span></div></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var p=[
          'Kalkulator: Komisi & Uang Bersih Merchant Platform Delivery (GoFood/GrabFood/ShopeeFood).',
          d.platform?('Platform dipilih: '+d.platform+'.'):'',
          'Harga jual di app: Rp '+d.harga+'. Komisi platform: '+d.komisi+'% + biaya transaksi Rp '+d.biayaTetap+'/pesanan. PPN atas komisi: '+d.ppn+'%.',
          'Total potongan: '+d.totalCut+' ('+d.cutPct.toFixed(1)+'% dari harga jual). Uang bersih yang diterima penjual: '+d.net+'.',
          (d.hpp && HC.parseRp(d.hpp)>0)?('Modal (HPP) per porsi yang diisi penjual: Rp '+d.hpp+', target markup '+(d.markup||'?')+'%.'):'',
          'Acuan 2026 untuk jawabanmu: komisi dihitung dari harga jual di app (BUKAN dari HPP/modal). Tarif reguler: GoFood ~20% + Rp1.000/pesanan, GrabFood ~20-30%, ShopeeFood ~20%; PPN atas komisi mengikuti tarif umum 2026 (12%, sebagian efektif 11%). Potongan efektif riil biasanya ~24-34% karena ada biaya tetap + PPN. Strategi umum penjual kuliner: naikkan harga di app sekitar 20-30% dibanding harga offline/dine-in untuk menutup potongan; dorong menu margin tinggi & bundling (biaya tetap Rp1.000 terasa berat di pesanan kecil, jadi naikkan nilai per pesanan); bandingkan potongan antar platform; arahkan pelanggan setia untuk repeat order langsung via WhatsApp/offline agar tidak selalu kena potongan. Jangan pukul rata angka \u2014 minta penjual cek potongan riil di dashboard merchant aplikasinya karena skema beda per jenis kemitraan (reguler/preferred/marketplace-only). Jawab ringkas, hangat, pakai sapaan "kamu", dan jangan mengarang angka di luar data di atas.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function typeInto(bubble, text, done){ var n=0, len=text.length, step=Math.max(2, Math.round(len/90)); var t=setInterval(function(){ n=Math.min(len, n+step); bubble.innerHTML=mdToHtml(text.slice(0,n)); msgs.scrollTop=msgs.scrollHeight; if(n>=len){ clearInterval(t); done&&done(); } }, 18); }
      function mkCopyBtn(text){ var b=document.createElement('button'); b.type='button'; b.className='aic-copy'; b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>'; b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); }); return b; }
      function addMsgTyped(text){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); }); return row; }
      var FOLLOWUPS=['Potongan segini wajar gak?','Harus naikin harga berapa di app?','Platform mana paling hemat?','Untungku masih aman gak setelah dipotong?','Gimana cara kurangi beban komisi?','Menu kecil vs bundling, mana lebih untung?','Kapan mending jualan langsung tanpa app?','PPN komisi 11 atau 12 persen sih?'];
      function renderFollowups(){ chips.innerHTML=''; var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;}); var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;}); pool.slice(0,3).forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b); }); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Potongan segini wajar gak?','Harus naikin harga berapa di app?','Platform mana paling hemat?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },300); }); }
      var ha=$('hApply'); if(ha){ ha.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },300); }); }
    });
  })();
</script>
</Layout>
