  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#FFF1E6;color:#EA580C;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
