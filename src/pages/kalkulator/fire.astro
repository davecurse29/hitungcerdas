---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('fire')!;
const related = getRelatedCalculators('fire', 3);

const faqs = [
  { question: 'Apa itu FIRE?', answer: 'FIRE = <strong>Financial Independence, Retire Early</strong> (Kemandirian Finansial, Pensiun Dini). Ini kondisi saat nilai investasimu sudah cukup besar sehingga hasil pengembangannya bisa membiayai seluruh biaya hidupmu tanpa harus bekerja. Angka kuncinya disebut <strong>FIRE Number</strong> — target dana yang, jika ditarik ~4% per tahun, cukup menutup pengeluaranmu.' },
  { question: 'Apa itu aturan 4% dan FIRE Number?', answer: 'Aturan 4% (safe withdrawal rate) berasal dari <strong>Trinity Study</strong>: secara historis, menarik sekitar 4% dari portofolio tiap tahun punya risiko kecil kehabisan dana selama ~30 tahun. Dari sini: <strong>FIRE Number = pengeluaran tahunan ÷ 4% = pengeluaran tahunan × 25</strong>. Jadi kalau pengeluaranmu Rp 8 juta/bulan (Rp 96 juta/tahun), FIRE Number-mu sekitar Rp 2,4 miliar.' },
  { question: 'Apakah aturan 4% cocok untuk Indonesia?', answer: 'Aturan 4% berbasis data pasar <strong>Amerika Serikat</strong> yang inflasinya rendah. Inflasi Indonesia lebih tinggi (~3,5-4%), jadi banyak perencana memilih SWR lebih konservatif <strong>(3-3,5%)</strong> supaya lebih aman — konsekuensinya FIRE Number jadi lebih besar. Kalkulator ini membiarkan kamu mengatur sendiri angka SWR sesuai selera risikomu.' },
  { question: 'Kenapa savings rate begitu penting?', answer: 'Karena <strong>savings rate</strong> (porsi penghasilan yang kamu sisihkan) bekerja dua arah sekaligus: makin besar yang kamu investasikan <em>dan</em> makin kecil pengeluaranmu — sehingga FIRE Number-nya ikut mengecil. Menaikkan savings rate biasanya memangkas waktu menuju FI <strong>jauh lebih cepat</strong> daripada sekadar mengejar return investasi yang tinggi.' },
  { question: 'Apa beda Lean, Normal, dan Fat FIRE?', answer: '<strong>Lean FIRE</strong> = gaya hidup hemat, FIRE Number kecil, tercapai lebih cepat. <strong>Fat FIRE</strong> = gaya hidup lebih mewah, FIRE Number besar, butuh lebih lama. <strong>Normal/Reguler FIRE</strong> ada di antaranya (sesuai pengeluaranmu sekarang). Ada juga <strong>Coast FIRE</strong>: asetmu sudah cukup untuk bertumbuh sendiri sampai usia pensiun tanpa perlu nabung lagi — kamu tinggal menutup biaya hidup harian.' },
  { question: 'Apa risiko dan keterbatasan FIRE?', answer: 'FIRE adalah <strong>estimasi berbasis asumsi</strong> return & inflasi yang bisa meleset (risiko urutan return/sequence-of-returns, lonjakan inflasi, biaya kesehatan, dll). FI juga bukan berarti berhenti produktif — banyak yang tetap berkarya, hanya saja tanpa tekanan finansial. Anggap hasil kalkulator ini sebagai <strong>peta arah</strong>, bukan jaminan. Ini edukasi, bukan nasihat keuangan atau investasi resmi.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#EA580C;--cat-color2:#C2410C">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FFEDD5;color:#C2410C"><i class="ti ti-flame"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M40 152H160" stroke="#FED7AA" stroke-width="4" stroke-linecap="round"/>
            <path d="M55 140L90 106L112 124L148 74" stroke="#FFF" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <path d="M148 74H134M148 74V88" stroke="#FFF" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M150 58C150 58 160 66 160 76C160 83 156 88 150 88C144 88 140 83 140 76C140 66 150 58 150 58Z" fill="#FDBA74" stroke="#FFF" stroke-width="2.5" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#EA580C 0%,#C2410C 100%)"><i class="ti ti-flame"></i></div>
          <div><h2 class="calc-card-title">Kalkulator FIRE</h2><p class="calc-card-sub">FIRE Number · usia merdeka · savings rate · skenario</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Usia Sekarang</label>
              <div class="input-wrap"><input type="number" id="usiaNow" value="30" min="15" max="75" /><span class="input-suffix">thn</span></div>
            </div>

            <div class="field"><label>Penghasilan per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="penghasilan" class="has-prefix" value="15.000.000" inputmode="numeric" /></div>
            </div>

            <div class="field"><label>Pengeluaran per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="pengeluaran" class="has-prefix" value="8.000.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Selisih penghasilan − pengeluaran = yang kamu investasikan tiap bulan (savings rate). Pengeluaran juga jadi dasar FIRE Number.</p>
            </div>

            <div class="field"><label>Dana Investasi Saat Ini</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="danaInvestasi" class="has-prefix" value="50.000.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Total aset yang sudah diinvestasikan (reksadana, saham, emas, dll). Bukan dana darurat/tabungan konsumtif.</p>
            </div>

            <div class="field-row">
              <div class="field"><label>Return Investasi</label>
                <div class="input-wrap"><input type="number" id="returnInvest" value="8" min="0" max="30" step="0.5" /><span class="input-suffix">%/th</span></div>
              </div>
              <div class="field"><label>Inflasi</label>
                <div class="input-wrap"><input type="number" id="inflasi" value="4" min="0" max="20" step="0.5" /><span class="input-suffix">%/th</span></div>
              </div>
            </div>
            <p class="hint" style="margin-top:-4px">Return reksadana saham/campuran umumnya ~6-10%/th. Perhitungan pakai <strong>return riil</strong> (return dikurangi inflasi) agar daya beli terjaga.</p>

            <div class="field"><label>Safe Withdrawal Rate (SWR)</label>
              <div class="input-wrap"><input type="number" id="swr" value="4" min="2" max="8" step="0.25" /><span class="input-suffix">%/th</span></div>
              <p class="hint" style="margin-top:6px">Persentase yang ditarik dari aset tiap tahun saat sudah FI. Aturan umum <strong>4%</strong> (Trinity Study). Untuk Indonesia yang inflasinya lebih tinggi, <strong>3-3,5%</strong> lebih aman.</p>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-flame result-placeholder-icon"></i>
              <div class="result-placeholder-title">Peta menuju kebebasan finansialmu akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi penghasilan, pengeluaran & dana investasi, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="view-toggle" id="viewToggle">
                <button type="button" data-view="today" class="active">Nilai Hari Ini</button>
                <button type="button" data-view="future">Nominal Masa Depan</button>
              </div>

              <div class="result-main">
                <div class="result-label">Waktu Menuju Kebebasan Finansial</div>
                <div class="result-value" id="heroYears">—</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="heroMeta">—</span></div>
              </div>

              <div class="warn-box" id="warnBox" style="display:none"></div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">FIRE Number (Target)</div><div class="result-item-value" id="fireNumber">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Usia Merdeka Finansial</div><div class="result-item-value" id="usiaFI">—</div></div>
                <div class="result-item"><div class="result-item-label">Savings Rate</div><div class="result-item-value" id="savingsRate">0%</div></div>
                <div class="result-item"><div class="result-item-label">Progress ke FI</div><div class="result-item-value" id="progressFI">0%</div></div>
                <div class="result-item"><div class="result-item-label">Investasi per Bulan</div><div class="result-item-value" id="setoranBln">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Penghasilan Pasif/bln di FI</div><div class="result-item-value" id="pasifBln">Rp 0</div></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-area-line"></i>&nbsp; Grafik Perjalanan Menuju FI</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div id="fireChart" class="mountain-wrap"></div>
                  <table class="compare-table">
                    <thead><tr><th>Usia</th><th class="right">Proyeksi Aset</th><th class="right">% FIRE</th></tr></thead>
                    <tbody id="yearlyBody"></tbody>
                  </table>
                  <p class="adv-note">Aset menanjak berkat setoran rutin + bunga majemuk, sampai menyentuh garis FIRE Number (titik ★ = merdeka finansial). Ditandai tiap 5 tahun. Nilai riil (daya beli hari ini).</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-versions"></i>&nbsp; Skenario Lean / Normal / Fat FIRE</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Jenis</th><th class="right">Pengeluaran/bln</th><th class="right">FIRE Number</th><th class="right">Menuju FI</th></tr></thead>
                    <tbody id="skenarioBody"></tbody>
                  </table>
                  <p class="adv-note">Lean = gaya hidup hemat (target kecil, cepat). Fat = gaya hidup mewah (target besar, lama). Baris ★ = pilihanmu sekarang.</p>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-adjustments-alt"></i>&nbsp; Uji Sensitivitas Asumsi</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Skenario</th><th class="right">FIRE Number</th><th class="right">Menuju FI</th></tr></thead>
                    <tbody id="sensBody"></tbody>
                  </table>
                  <p class="adv-note">FIRE sangat sensitif ke savings rate & asumsi return. ▼ hijau = FI lebih cepat; ▲ merah = lebih lama.</p>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
                <button type="button" class="export-btn link" id="exportLink"><i class="ti ti-link" style="color:#EA580C"></i><span style="color:#EA580C">Salin Link</span></button>
              </div>
              <!-- ===== AI COACH FIRE ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Kapan aku bisa merdeka finansial? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach FIRE</strong>
                      <small>Bantu pahami jalur kebebasan finansialmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal FIRE & savings rate..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Penjelasan edukatif berbasis hitunganmu, bukan nasihat keuangan/investasi resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>
              <!-- ===== /AI COACH ===== -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-content">
    <div class="wrap prose">
      <h2>Cara Menghitung FIRE Number & Waktu Menuju Kebebasan Finansial</h2>
      <p><strong>FIRE (Financial Independence, Retire Early)</strong> adalah kondisi ketika hasil investasimu sanggup membiayai hidupmu tanpa harus bekerja. Kalkulator ini bekerja dalam dua langkah: pertama menghitung <strong>FIRE Number</strong> (target dana), lalu memproyeksikan <strong>berapa tahun lagi</strong> asetmu mencapainya berdasarkan tabungan rutin dan return investasi — semuanya memakai <strong>return riil</strong> agar daya beli terjaga, bukan sekadar angka nominal besar.</p>

      <h3>Rumus Inti</h3>
      <p>FIRE Number = pengeluaran tahunan ÷ Safe Withdrawal Rate. Pada SWR 4%, ini sama dengan pengeluaran tahunan × 25. Return riil = (1 + return) ÷ (1 + inflasi) − 1. Waktu menuju FI dihitung dengan mencari kapan nilai masa depan dana investasi sekarang + setoran bulanan (di return riil) menyamai FIRE Number. Savings rate = (penghasilan − pengeluaran) ÷ penghasilan.</p>

      <h3>Savings Rate Adalah Tuas Terkuat</h3>
      <p>Dalam FIRE, menaikkan <strong>savings rate</strong> memangkas waktu menuju kebebasan finansial jauh lebih cepat daripada mengejar return tinggi — karena ia menambah setoran <em>sekaligus</em> menurunkan pengeluaran (yang otomatis mengecilkan FIRE Number). Diversifikasi ke reksadana, saham, emas, atau properti membantu, tapi kebiasaan menabung yang tinggi dan konsisten sejak dini adalah mesin utamanya.</p>

      <div class="cta-box"><h3>Hitung Jalur FIRE-mu</h3><p>Isi penghasilan & pengeluaran, lihat FIRE Number-mu dan di usia berapa kamu bisa merdeka secara finansial.</p></div>
    </div>
  </section>

  <AdSlot format="rectangle" />

  <FAQ title="Pertanyaan Seputar FIRE" items={faqs} />

  <section class="calc-related">
    <div class="wrap">
      <h2 class="calc-related-title">Kalkulator Lainnya</h2>
      <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
    </div>
  </section>

  <div class="wrap">
    <p class="calc-note">📅 Diperbarui Juli 2026 · FIRE Number memakai aturan Safe Withdrawal Rate (default 4% dari Trinity Study). Waktu menuju FI dihitung dengan metode return riil = (1+return)÷(1+inflasi)−1. Estimasi edukatif untuk perencanaan, bukan nasihat keuangan atau produk investasi. Aturan 4% berbasis pasar AS — untuk Indonesia yang inflasinya lebih tinggi, SWR 3-3,5% lebih konservatif. Sumber: Trinity Study, prinsip perencanaan keuangan.</p>
  </div>
</Layout>

<style is:global>
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .view-toggle { display:flex; gap:4px; padding:4px; background:var(--surface-2,#F1F5F9); border-radius:12px; margin-bottom:14px; }
  .view-toggle button { flex:1; padding:8px 10px; border:none; background:transparent; border-radius:9px; font-size:12.5px; font-weight:600; color:var(--text-soft,#64748B); cursor:pointer; transition:all .15s; }
  .view-toggle button.active { background:#fff; color:#EA580C; box-shadow:0 1px 3px rgba(0,0,0,.08); }
  .warn-box { background:#FFFBEB; border:1px solid #FDE68A; color:#92400E; border-radius:12px; padding:11px 13px; font-size:12.5px; line-height:1.55; margin-bottom:14px; }
  .warn-box .warn-item { display:flex; gap:7px; align-items:flex-start; }
  .warn-box .warn-item + .warn-item { margin-top:6px; }
  .result-item-value.result-good { color:var(--green-dark,#047857); }
  html.dark .view-toggle { background:#1E293B; }
  html.dark .view-toggle button.active { background:#0F172A; color:#FDBA74; }
  html.dark .warn-box { background:rgba(180,120,10,.12); border-color:rgba(251,191,36,.3); color:#FCD34D; }
  .mountain-wrap { width:100%; margin-bottom:10px; }
  .mountain-wrap svg { width:100%; height:auto; display:block; border-radius:8px; }
  .adv-note { font-size:11.5px; color:var(--text-mute); margin-top:8px; line-height:1.5; }
</style>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = {
        usiaNow: $('usiaNow'), penghasilan: $('penghasilan'), pengeluaran: $('pengeluaran'),
        danaInvestasi: $('danaInvestasi'), returnInvest: $('returnInvest'), inflasi: $('inflasi'), swr: $('swr')
      };
      [els.penghasilan, els.pengeluaran, els.danaInvestasi].forEach(el => el.addEventListener('input', HC.fmtInput));

      let lastCalc = null;
      let viewMode = 'today';

      function num(el, def) { var v = parseFloat(String(el.value).replace(',', '.')); return isFinite(v) ? v : def; }

      // ===== Inti FIRE =====
      function realRate(r, inf){ return (1 + r) / (1 + inf) - 1; }
      function fireNumberOf(pengeluaranBln, swr){ return swr > 0 ? (pengeluaranBln * 12) / swr : Infinity; }

      // Tahun untuk mencapai target (dalam terma riil). Return Infinity jika tak tercapai.
      function yearsToReach(target, principal, monthlyContrib, annualRealRate){
        if (principal >= target) return 0;
        var rMon = annualRealRate / 12;
        if (Math.abs(rMon) < 1e-9) {
          if (monthlyContrib <= 0) return Infinity;
          return (target - principal) / monthlyContrib / 12;
        }
        var cOverR = monthlyContrib / rMon;
        var numer = target + cOverR;
        var denom = principal + cOverR;
        if (denom <= 0 || numer <= 0) return Infinity;
        var x = numer / denom;
        var base = 1 + rMon;
        if (x <= 0 || base <= 0) return Infinity;
        var nMonths = Math.log(x) / Math.log(base);
        if (!isFinite(nMonths) || nMonths < 0) return Infinity;
        return nMonths / 12;
      }
      function reachableY(y){ return isFinite(y) && y >= 0 && y <= 80; }

      function fmtYr(y){
        if (!reachableY(y)) return '80+ thn';
        if (y <= 0.04) return '0 thn';
        var a = Math.floor(y); var b = Math.round((y - a) * 12);
        if (b === 12) { a += 1; b = 0; }
        return a + ' thn' + (b > 0 ? ' ' + b + ' bln' : '');
      }
      function fmtYrShort(y){ return reachableY(y) ? (y <= 0.04 ? '0' : y.toFixed(1)) + ' thn' : '80+ thn'; }

      // ===== V2: skenario, sensitivitas, proyeksi tahunan, grafik =====
      function buildAssetYears(c){
        var arr = []; var saldo = c.danaInvestasi; var setTahun = c.setoran * 12; var rr = c.rr;
        var cap = c.reachable ? Math.min(80, Math.ceil(c.yearsToFI) + 2) : 45;
        arr.push({ year: 0, usia: c.usiaNow, saldo: Math.max(0, saldo) });
        for (var y = 1; y <= cap; y++) {
          saldo = saldo * (1 + rr) + setTahun; if (saldo < 0) saldo = 0;
          arr.push({ year: y, usia: c.usiaNow + y, saldo: saldo });
          if (c.reachable && saldo >= c.fireNumber) break;
        }
        return arr;
      }
      function renderYearly(c, yearly){
        var fiYear = c.reachable ? Math.round(c.yearsToFI) : -1;
        var html = '';
        yearly.forEach(function(pt){
          var isFi = c.reachable && pt.usia === (c.usiaNow + fiYear);
          var show = (pt.year % 5 === 0) || pt.year === 0 || isFi || pt.year === yearly[yearly.length - 1].year;
          if (!show) return;
          var pct = c.fireNumber > 0 ? Math.min(999, pt.saldo / c.fireNumber * 100) : 0;
          html += '<tr' + (isFi ? ' class="active"' : '') + '><td>' + (isFi ? '\u2605 ' : '') + pt.usia + ' thn</td><td class="right">' + HC.fmt(pt.saldo) + '</td><td class="right">' + pct.toFixed(0) + '%</td></tr>';
        });
        $('yearlyBody').innerHTML = html;
      }
      function renderFireChart(c, yearly){
        var W = 340, H = 150, padL = 8, padR = 8, padT = 16, padB = 18;
        var lastYear = yearly[yearly.length - 1].year || 1;
        var maxS = c.fireNumber; yearly.forEach(function(pt){ if (pt.saldo > maxS) maxS = pt.saldo; }); if (maxS <= 0) maxS = 1;
        var xOf = function(yr){ return padL + (yr / lastYear) * (W - padL - padR); };
        var yOf = function(sv){ return H - padB - (sv / maxS) * (H - padT - padB); };
        var line = ''; yearly.forEach(function(pt, i){ line += (i === 0 ? 'M' : 'L') + xOf(pt.year).toFixed(1) + ',' + yOf(pt.saldo).toFixed(1) + ' '; });
        var area = 'M' + xOf(0).toFixed(1) + ',' + (H - padB) + ' ' + line.replace(/^M/, 'L') + 'L' + xOf(lastYear).toFixed(1) + ',' + (H - padB) + ' Z';
        var yFire = yOf(c.fireNumber);
        var fiX = c.reachable ? xOf(Math.min(lastYear, c.yearsToFI)) : null;
        var svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg">'
          + '<defs><linearGradient id="fireG" x1="0" y1="1" x2="0" y2="0">'
          + '<stop offset="0%" stop-color="#F59E0B" stop-opacity=".12"/>'
          + '<stop offset="100%" stop-color="#EA580C" stop-opacity=".55"/>'
          + '</linearGradient></defs>'
          + '<path d="' + area + '" fill="url(#fireG)"/>'
          + '<path d="' + line + '" fill="none" stroke="#EA580C" stroke-width="2.2" stroke-linejoin="round"/>'
          + '<line x1="' + padL + '" y1="' + yFire.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + yFire.toFixed(1) + '" stroke="#C2410C" stroke-width="1.1" stroke-dasharray="4 3"/>'
          + '<text x="' + (W - padR) + '" y="' + (yFire - 4).toFixed(1) + '" text-anchor="end" font-size="8.5" font-weight="700" fill="#C2410C" font-family="Inter">FIRE ' + HC.fmt(c.fireNumber) + '</text>';
        if (fiX !== null) {
          svg += '<line x1="' + fiX.toFixed(1) + '" y1="' + padT + '" x2="' + fiX.toFixed(1) + '" y2="' + (H - padB) + '" stroke="#9A3412" stroke-width="1.1" stroke-dasharray="3 3"/>'
            + '<circle cx="' + fiX.toFixed(1) + '" cy="' + yFire.toFixed(1) + '" r="3.4" fill="#EA580C" stroke="#fff" stroke-width="1.5"/>'
            + '<text x="' + fiX.toFixed(1) + '" y="' + (padT - 5) + '" text-anchor="middle" font-size="9" font-weight="700" fill="#EA580C" font-family="Inter">FI usia ' + (c.usiaNow + Math.round(c.yearsToFI)) + '</text>';
        }
        svg += '<text x="' + padL + '" y="' + (H - 5) + '" font-size="8.5" fill="#94A3B8" font-family="Inter">' + c.usiaNow + ' th</text>'
          + '<text x="' + (W - padR) + '" y="' + (H - 5) + '" text-anchor="end" font-size="8.5" fill="#94A3B8" font-family="Inter">' + (c.usiaNow + lastYear) + ' th</text>'
          + '</svg>';
        $('fireChart').innerHTML = svg;
      }
      function deltaYr(baseY, y){
        if (!reachableY(y)) return '<td class="right">80+ thn</td>';
        if (!reachableY(baseY)) return '<td class="right">' + fmtYrShort(y) + '</td>';
        var d = y - baseY;
        var col = d > 0.15 ? '#DC2626' : (d < -0.15 ? '#059669' : 'var(--text-soft)');
        var arr = d > 0.15 ? '\u25b2' : (d < -0.15 ? '\u25bc' : '\u2022');
        return '<td class="right">' + fmtYrShort(y) + ' <span style="color:' + col + ';font-weight:700;font-size:10.5px">' + arr + Math.abs(d).toFixed(1) + '</span></td>';
      }
      function renderSkenario(c){
        var types = [
          { n: 'Lean FIRE', mult: 0.7 },
          { n: 'Normal (kamu)', mult: 1.0, mine: true },
          { n: 'Fat FIRE', mult: 1.5 }
        ];
        var html = '';
        types.forEach(function(t){
          var peng = c.pengeluaran * t.mult;
          var fn = fireNumberOf(peng, c.swr);
          var yrs = yearsToReach(fn, c.danaInvestasi, c.setoran, c.rr);
          var usiaFi = reachableY(yrs) ? (c.usiaNow + Math.round(yrs)) + ' thn' : '—';
          html += '<tr' + (t.mine ? ' class="active"' : '') + '><td>' + (t.mine ? '\u2605 ' : '') + t.n + '</td><td class="right">' + HC.fmt(peng) + '</td><td class="right">' + HC.fmt(fn) + '</td><td class="right">' + fmtYrShort(yrs) + '<br><span style="font-size:10px;color:var(--text-mute)">' + usiaFi + '</span></td></tr>';
        });
        $('skenarioBody').innerHTML = html;
      }
      function renderSensitivity(c){
        var baseY = c.yearsToFI;
        var rows = [
          { n: 'Asumsimu (base)', ri: c.returnInvest, sw: c.swr, set: c.setoran },
          { n: 'Return \u22122%', ri: Math.max(0, c.returnInvest - 0.02), sw: c.swr, set: c.setoran },
          { n: 'Return +2%', ri: c.returnInvest + 0.02, sw: c.swr, set: c.setoran },
          { n: 'Setoran +20%', ri: c.returnInvest, sw: c.swr, set: c.setoran * 1.2 },
          { n: 'SWR 3,5% (aman)', ri: c.returnInvest, sw: 0.035, set: c.setoran }
        ];
        var html = '';
        rows.forEach(function(r, i){
          var rr = realRate(r.ri, c.inflasi);
          var fn = fireNumberOf(c.pengeluaran, r.sw);
          var yrs = yearsToReach(fn, c.danaInvestasi, r.set, rr);
          html += '<tr' + (i === 0 ? ' class="active"' : '') + '><td>' + r.n + '</td><td class="right">' + HC.fmt(fn) + '</td>' + (i === 0 ? ('<td class="right"><b>' + fmtYrShort(yrs) + '</b></td>') : deltaYr(baseY, yrs)) + '</tr>';
        });
        $('sensBody').innerHTML = html;
      }
      function renderAdv(){
        var c = lastCalc; if (!c) return;
        var yearly = buildAssetYears(c);
        renderFireChart(c, yearly);
        renderYearly(c, yearly);
        renderSkenario(c);
        renderSensitivity(c);
      }

      function hitung() {
        const usiaNow = num(els.usiaNow, 30);
        const penghasilan = HC.parseRp(els.penghasilan.value);
        const pengeluaran = HC.parseRp(els.pengeluaran.value);
        const danaInvestasi = HC.parseRp(els.danaInvestasi.value);
        const returnInvest = num(els.returnInvest, 8) / 100;
        const inflasi = num(els.inflasi, 4) / 100;
        const swr = num(els.swr, 4) / 100;

        if (penghasilan === 0) { HC.toast('Masukkan penghasilan bulanan dulu', 'error'); return; }
        if (pengeluaran === 0) { HC.toast('Masukkan pengeluaran bulanan dulu', 'error'); return; }
        if (swr <= 0) { HC.toast('SWR harus lebih dari 0', 'error'); return; }

        const setoran = Math.max(0, penghasilan - pengeluaran);
        const savingsRate = penghasilan > 0 ? (penghasilan - pengeluaran) / penghasilan * 100 : 0;
        const rr = realRate(returnInvest, inflasi);
        const fireNumber = fireNumberOf(pengeluaran, swr); // today's money (riil)
        const yearsToFI = yearsToReach(fireNumber, danaInvestasi, setoran, rr);
        const reachable = reachableY(yearsToFI);
        const usiaFI = reachable ? usiaNow + Math.round(yearsToFI) : null;
        const progress = fireNumber > 0 ? Math.min(999, danaInvestasi / fireNumber * 100) : 0;
        const inflFactorFI = reachable ? Math.pow(1 + inflasi, yearsToFI) : 1;
        const pasifBulanan = fireNumber * swr / 12; // today's money (= pengeluaran)

        const warns = [];
        if (setoran <= 0) warns.push('Pengeluaranmu \u2265 penghasilan — belum ada surplus untuk diinvestasikan, jadi FI belum bisa dikejar. Fokus dulu naikkan penghasilan atau tekan pengeluaran.');
        else if (savingsRate < 20) warns.push('Savings rate ' + savingsRate.toFixed(0) + '% tergolong rendah. Di FIRE, savings rate adalah tuas terkuat: menaikkannya memangkas waktu ke FI jauh lebih cepat daripada mengejar return tinggi.');
        if (inflasi >= returnInvest) warns.push('Inflasi ' + (inflasi * 100).toFixed(1) + '% \u2265 return investasi — secara riil asetmu tidak bertumbuh, FI sangat sulit dicapai. Pertimbangkan instrumen dengan potensi return lebih tinggi.');
        if (swr > 0.045) warns.push('SWR ' + (swr * 100).toFixed(2) + '% cukup agresif. Aturan 4% berbasis pasar AS; untuk Indonesia yang inflasinya lebih tinggi, 3-3,5% lebih aman (FIRE Number lebih besar, tapi risiko kehabisan dana lebih kecil).');
        if (!reachable && setoran > 0) warns.push('Dengan asumsi sekarang, FI belum tercapai dalam rentang wajar (80 tahun). Coba naikkan setoran/return, turunkan pengeluaran, atau sesuaikan SWR.');

        lastCalc = {
          usiaNow, penghasilan, pengeluaran, danaInvestasi, returnInvest, inflasi, swr,
          setoran, savingsRate, rr, fireNumber, yearsToFI, reachable, usiaFI,
          progress, inflFactorFI, pasifBulanan, warns
        };

        if (HC.history) HC.history.push('fire', {
          inputs: HC.history.capture(['usiaNow', 'penghasilan', 'pengeluaran', 'danaInvestasi', 'returnInvest', 'inflasi', 'swr']),
          summary: 'FIRE ' + (reachable ? 'di usia ' + usiaFI : 'target ' + HC.fmt(fireNumber)),
          metrics: [{ k: 'FIRE Number', v: HC.fmt(fireNumber) }, { k: 'Savings rate', v: savingsRate.toFixed(0) + '%' }]
        });
        renderHist();

        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        render();
        renderAdv();
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Jalur FIRE berhasil dihitung!');
      }

      function fvFmt(val) {
        if (viewMode === 'future' && lastCalc && lastCalc.reachable) return HC.fmt(val * lastCalc.inflFactorFI);
        return HC.fmt(val);
      }

      function render() {
        const c = lastCalc; if (!c) return;
        $('heroYears').textContent = c.reachable ? fmtYr(c.yearsToFI) : 'Belum tercapai';
        $('heroMeta').textContent = c.reachable
          ? ('FI di usia ' + c.usiaFI + ' \u00b7 savings rate ' + c.savingsRate.toFixed(0) + '% \u00b7 FIRE Number ' + fvFmt(c.fireNumber))
          : ('Belum tercapai dengan asumsi ini \u00b7 savings rate ' + c.savingsRate.toFixed(0) + '%');

        $('fireNumber').textContent = fvFmt(c.fireNumber);
        $('usiaFI').textContent = c.reachable ? ('Usia ' + c.usiaFI) : '—';
        const sr = $('savingsRate');
        sr.textContent = c.savingsRate.toFixed(0) + '%';
        sr.classList.toggle('result-good', c.savingsRate >= 50);
        sr.classList.toggle('result-warn', c.savingsRate < 20);
        $('progressFI').textContent = Math.min(999, c.progress).toFixed(0) + '%';
        $('setoranBln').textContent = HC.fmt(c.setoran) + '/bln';
        $('pasifBln').textContent = fvFmt(c.pasifBulanan) + '/bln';

        const wb = $('warnBox');
        if (c.warns.length) { wb.style.display = ''; wb.innerHTML = c.warns.map(w => '<div class="warn-item"><i class="ti ti-alert-triangle"></i><span>' + w + '</span></div>').join(''); }
        else wb.style.display = 'none';
      }

      function reset() {
        els.usiaNow.value = '30'; els.penghasilan.value = '15.000.000'; els.pengeluaran.value = '8.000.000';
        els.danaInvestasi.value = '50.000.000'; els.returnInvest.value = '8'; els.inflasi.value = '4'; els.swr.value = '4';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.setoran <= 0
          ? `Pengeluaran ≥ penghasilan, jadi FI belum bisa dikejar. Ciptakan surplus dulu — naikkan penghasilan atau tekan pengeluaran, lalu investasikan selisihnya.`
          : c.savingsRate >= 50
          ? `🔥 Savings rate ${c.savingsRate.toFixed(0)}% — agresif! Dengan disiplin ini kamu bisa FI ${c.reachable ? 'di usia ' + c.usiaFI : 'lebih cepat'}. Jaga konsistensi & diversifikasi.`
          : c.savingsRate >= 20
          ? `Savings rate ${c.savingsRate.toFixed(0)}% sudah sehat. Menaikkannya sedikit lagi memangkas waktu ke FI ${c.reachable ? '(kini di usia ' + c.usiaFI + ')' : ''} lebih cepat daripada mengejar return.`
          : `Savings rate baru ${c.savingsRate.toFixed(0)}%. Ini tuas terkuatmu — fokus tekan pengeluaran & naikkan penghasilan agar surplus investasimu bertambah.`;
        return HC.buildReportCard({
          title: '🔥 Rencana FIRE (Kebebasan Finansial)',
          color: '#EA580C', color2: '#C2410C',
          heroLabel: 'Waktu Menuju Kebebasan Finansial',
          heroValue: c.reachable ? fmtYr(c.yearsToFI) : 'Belum tercapai',
          heroSubtext: c.reachable ? `FI di usia ${c.usiaFI} · savings rate ${c.savingsRate.toFixed(0)}%` : `Savings rate ${c.savingsRate.toFixed(0)}%`,
          inputs: [
            { label: '🎂 Usia', value: c.usiaNow + ' thn' },
            { label: '💵 Penghasilan/bln', value: HC.fmt(c.penghasilan) },
            { label: '💸 Pengeluaran/bln', value: HC.fmt(c.pengeluaran) },
            { label: '📈 Return / SWR', value: (c.returnInvest * 100).toFixed(0) + '% / ' + (c.swr * 100).toFixed(1) + '%' },
          ],
          results: [
            { label: 'FIRE Number (Target)', value: HC.fmt(c.fireNumber), highlight: true },
            { label: 'Usia Merdeka Finansial', value: c.reachable ? String(c.usiaFI) : '—' },
            { label: 'Savings Rate', value: c.savingsRate.toFixed(0) + '%' },
            { label: 'Progress ke FI', value: Math.min(999, c.progress).toFixed(0) + '%' },
            { label: 'Investasi/bln', value: HC.fmt(c.setoran) },
            { label: 'Penghasilan pasif/bln di FI', value: HC.fmt(c.pasifBulanan), highlight: true },
          ],
          insight, slug: 'fire',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🔥 *FIRE - HitungCerdas*\n\nUsia ${c.usiaNow} · penghasilan ${HC.fmt(c.penghasilan)}/bln\nPengeluaran: ${HC.fmt(c.pengeluaran)}/bln\n\n🎯 *FIRE Number: ${HC.fmt(c.fireNumber)}*\n⏳ Menuju FI: ${c.reachable ? fmtYr(c.yearsToFI) + ' (usia ' + c.usiaFI + ')' : 'belum tercapai'}\n💪 Savings rate: ${c.savingsRate.toFixed(0)}%\n📊 Progress: ${Math.min(999, c.progress).toFixed(0)}%\n\nHitung di: https://hitungcerdas.net/kalkulator/fire`;
      }

      function renderHist() {
        if (HC.history) HC.history.render('fire', $('histBox'), function () { hitung(); });
      }
      renderHist();
      document.querySelectorAll('.adv-toggle').forEach(function(t){ t.addEventListener('click', function(){ t.parentElement.classList.toggle('open'); }); });

      $('viewToggle').querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
        viewMode = btn.getAttribute('data-view');
        $('viewToggle').querySelectorAll('button').forEach(b => b.classList.toggle('active', b === btn));
        render();
      }));

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'fire-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'fire'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'fire-' + Date.now()); });

      function buildShareUrl() {
        var p = new URLSearchParams();
        p.set('un', els.usiaNow.value);
        p.set('ph', String(HC.parseRp(els.penghasilan.value) || 0));
        p.set('pg', String(HC.parseRp(els.pengeluaran.value) || 0));
        p.set('di', String(HC.parseRp(els.danaInvestasi.value) || 0));
        p.set('ri', els.returnInvest.value); p.set('if', els.inflasi.value); p.set('sw', els.swr.value);
        return location.origin + location.pathname + '?' + p.toString();
      }
      function setNum(el, val) { el.value = val; el.dispatchEvent(new Event('input', { bubbles: true })); }
      function loadFromUrl() {
        var q = new URLSearchParams(location.search);
        if (!q.has('pg')) return false;
        if (q.has('un')) els.usiaNow.value = q.get('un');
        if (q.has('ph')) setNum(els.penghasilan, q.get('ph'));
        setNum(els.pengeluaran, q.get('pg'));
        if (q.has('di')) setNum(els.danaInvestasi, q.get('di'));
        if (q.has('ri')) els.returnInvest.value = q.get('ri');
        if (q.has('if')) els.inflasi.value = q.get('if');
        if (q.has('sw')) els.swr.value = q.get('sw');
        return true;
      }
      $('exportLink').addEventListener('click', function () { HC.copyText(buildShareUrl(), 'Link tersalin!'); });
      if (loadFromUrl()) { hitung(); }
    });
  })();
</script>
