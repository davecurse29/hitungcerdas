---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('pinjol-legal')!;
const related = getRelatedCalculators('pinjol-legal', 3);

const faqs = [
  { question: 'Berapa batas bunga pinjol legal OJK 2026?', answer: 'OJK 2026: bunga konsumtif <strong>maksimal 0,1%/hari</strong> (≈3%/bulan, ≈36%/tahun). Bunga produktif maksimal 0,067%/hari. Plus <strong>Lock Cap 100%</strong> — total biaya tidak boleh lebih dari pokok pinjaman. Biaya admin maks 4%. Aturan ini melindungi peminjam dari jeratan utang.' },
  { question: 'Apakah semua pinjol berbahaya?', answer: 'Tidak. <strong>Pinjol legal terdaftar OJK aman</strong> selama dipakai dengan bijak — pinjam sesuai kemampuan, baca syarat, dan bayar tepat waktu. Yang berbahaya: pinjol <strong>ilegal</strong> dengan bunga 0,5-1%/hari, akses semua data HP, dan penagihan brutal.' },
  { question: 'Kalau gagal bayar (galbay), bisa dipenjara?', answer: 'TIDAK. Gagal bayar pinjol murni urusan perdata, <strong>bukan pidana</strong>. Pinjol tidak bisa langsung penjarakan kamu. Tapi konsekuensinya: nama masuk blacklist SLIK OJK, sulit dapat kredit di masa depan, dan ditagih terus. Yang bisa dipidana: kalau kamu menipu/dokumen palsu saat ajukan.' },
  { question: 'Kapan pinjol bisa jadi pilihan?', answer: 'Pinjol legal cocok untuk: <strong>kebutuhan urgent jangka pendek</strong> (1-3 bulan), pinjaman kecil (Rp 500rb-5jt), dan kamu yakin bisa bayar tepat waktu. <strong>Hindari pinjol</strong> untuk: konsumtif gaya hidup, judi/investasi, atau menutup pinjol lain (rotasi gali-tutup-lubang).' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#DC2626;--cat-color2:#991B1B">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FEE2E2;color:#991B1B"><i class="ti ti-alert-triangle"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M100 40L165 155H35L100 40Z" fill="#FFF" stroke="#FBBF24" stroke-width="3" stroke-linejoin="round"/>
            <rect x="95" y="80" width="10" height="40" rx="3" fill="#DC2626"/>
            <circle cx="100" cy="135" r="6" fill="#DC2626"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#DC2626 0%,#991B1B 100%)"><i class="ti ti-alert-triangle"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Pinjol Legal 2026</h2><p class="calc-card-sub">OJK 2026: bunga maks 0,1%/hari · Lock Cap 100% · admin maks 4%</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field"><label>Jumlah Pinjaman</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="pinjaman" class="has-prefix" value="2.000.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Pinjol legal biasanya Rp 500rb - Rp 20jt</p>
            </div>

            <div class="field">
              <label>Tenor (Durasi Pinjam)</label>
              <select id="tenor">
                <option value="7">7 hari</option>
                <option value="14">14 hari</option>
                <option value="30" selected>30 hari (1 bulan)</option>
                <option value="60">60 hari (2 bulan)</option>
                <option value="90">90 hari (3 bulan)</option>
                <option value="180">180 hari (6 bulan)</option>
              </select>
            </div>

            <div class="field"><label>Bunga Harian</label>
              <div class="input-wrap"><span class="input-suffix">%/hari</span>
                <input type="number" id="bunga" class="has-suffix" value="0.1" min="0.01" max="2" step="0.01" /></div>
              <p class="hint" style="margin-top:6px">⚠️ OJK 2026 max <strong>0,1%/hari konsumtif</strong>. Pinjol ilegal sering 0,5-1%/hari — hindari!</p>
            </div>

            <div class="field">
              <label>Preset Bunga</label>
              <select id="preset">
                <option value="custom">Custom (gunakan input di atas)</option>
                <option value="ojk">OJK Legal Maks (0,1%/hari)</option>
                <option value="produktif">Produktif (0,067%/hari)</option>
                <option value="rendah">Pinjol Murah (0,05%/hari)</option>
                <option value="ilegal">⚠️ Ilegal (0,8%/hari) - JANGAN!</option>
              </select>
            </div>

            <div class="field"><label>Biaya Admin / Provisi</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="admin" class="has-prefix" value="80.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">OJK batasi maks <strong>4% dari plafon</strong>. Dipotong dari dana cair (kamu terima lebih sedikit!).</p>
            </div>

            <div class="field"><label>Penghasilan Bulanan <span class="hint">(opsional - untuk debt trap analysis)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="gaji" class="has-prefix" value="5.000.000" inputmode="numeric" /></div>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Biaya Sebenarnya</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-alert-triangle result-placeholder-icon"></i>
              <div class="result-placeholder-title">Biaya Pinjol Sebenarnya akan muncul</div>
              <div class="result-placeholder-desc">Isi pinjaman, tenor, bunga, klik <strong>"Hitung"</strong>. Lihat APR sebenarnya & cek apakah sesuai OJK.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Total Harus Dibayar</div>
                <div class="result-value" id="totalBayar">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="aprLabel">APR: 0%/tahun</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Pokok Pinjaman</div><div class="result-item-value" id="pokokVal">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Total Bunga</div><div class="result-item-value result-warn" id="totalBunga">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Biaya Admin</div><div class="result-item-value result-warn" id="adminVal">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Dana Cair (Diterima)</div><div class="result-item-value" id="danaCair">Rp 0</div></div>
              </div>

              <div class="adv-section" id="ojkSection">
                <div class="adv-toggle"><span><i class="ti ti-shield-check"></i>&nbsp; Cek Kepatuhan OJK 2026</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Aturan OJK</th><th>Batas</th><th>Status</th></tr></thead>
                    <tbody id="ojkBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Debt Trap Analysis</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div id="debtTrapInfo"></div>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Aturan OJK 2026 untuk Pinjol Legal</h2>
      <p>OJK menerbitkan POJK terbaru 2026 yang memperketat aturan pinjol untuk melindungi peminjam dari jeratan utang. Berikut aturan utama:</p>
      <ul>
        <li><strong>Bunga konsumtif maks 0,1%/hari</strong> (≈3%/bulan, ≈36%/tahun) — turun dari 0,4% di 2024</li>
        <li><strong>Bunga produktif maks 0,067%/hari</strong> — untuk pinjaman usaha</li>
        <li><strong>Lock Cap 100%</strong> — total biaya tidak boleh lebih dari pokok pinjaman</li>
        <li><strong>Biaya admin maks 4%</strong> dari plafon pinjaman</li>
        <li><strong>Akses HP hanya CAMILAN</strong> (Camera, Microphone, Location) — bukan kontak, galeri, dll</li>
        <li><strong>Penagihan jam 08:00-20:00</strong> waktu setempat, dilarang mengancam</li>
      </ul>

      <h3>Cara Cek Pinjol Legal vs Ilegal</h3>
      <ul>
        <li>Cek di <strong>OJK.go.id</strong> bagian "Fintech Lending" → ada daftar resmi</li>
        <li>Hubungi OJK 157 atau WA <strong>081-157-157-157</strong></li>
        <li>Pinjol legal punya alamat kantor jelas & terdaftar di app store resmi</li>
        <li>Ciri ilegal: bunga gila (0,5-1%/hari), akses semua data HP, ancam sebar foto/data</li>
      </ul>

      <h3>Jika Terjerat Pinjol Ilegal</h3>
      <ul>
        <li><strong>Jangan bayar</strong> ke rekening tidak resmi</li>
        <li>Laporkan ke Satgas PASTI OJK: <strong>157</strong> atau waspadainvestasi.ojk.go.id</li>
        <li>Blokir & screenshot semua ancaman sebagai bukti</li>
        <li>Lapor polisi jika ada ancaman fisik atau penyebaran data</li>
      </ul>

      <div class="cta-box">
        <h3>Disclaimer & Tujuan Edukasi</h3>
        <p>Kalkulator ini alat edukasi & perlindungan konsumen. HitungCerdas <strong>TIDAK berafiliasi, mempromosikan, atau menerima komisi</strong> dari platform pinjol manapun. Daftar pinjol legal dapat berubah — selalu cek terbaru di OJK.go.id atau hubungi 157.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Pinjol Legal" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { pinjaman: $('pinjaman'), tenor: $('tenor'), bunga: $('bunga'), preset: $('preset'), admin: $('admin'), gaji: $('gaji') };
      [els.pinjaman, els.admin, els.gaji].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      els.preset.addEventListener('change', () => {
        const v = els.preset.value;
        const map = { ojk: '0.1', produktif: '0.067', rendah: '0.05', ilegal: '0.8' };
        if (map[v]) els.bunga.value = map[v];
      });

      let lastCalc = null;

      function hitung() {
        const pokok = HC.parseRp(els.pinjaman.value);
        const tenor = parseInt(els.tenor.value);
        const bungaHarian = parseFloat(els.bunga.value);
        const admin = HC.parseRp(els.admin.value);
        const gaji = HC.parseRp(els.gaji.value);

        if (pokok === 0) { HC.toast('Masukkan jumlah pinjaman dulu', 'error'); return; }

        const bunga = pokok * (bungaHarian / 100) * tenor;
        const totalBayar = pokok + bunga + admin;
        const danaCair = pokok - admin;
        const apr = (bungaHarian * 365);
        const totalBiaya = bunga + admin;
        const biayaPctPokok = (totalBiaya / pokok) * 100;

        // OJK Compliance Check
        let ojkHtml = '';
        const checks = [
          { rule: 'Bunga konsumtif', limit: 'max 0,1%/hari', ok: bungaHarian <= 0.1, current: bungaHarian + '%/hari' },
          { rule: 'Lock Cap (Total biaya ≤ Pokok)', limit: 'max 100%', ok: biayaPctPokok <= 100, current: biayaPctPokok.toFixed(1) + '%' },
          { rule: 'Biaya admin', limit: 'max 4% pokok', ok: (admin / pokok * 100) <= 4, current: (admin / pokok * 100).toFixed(1) + '%' },
        ];
        checks.forEach(c => {
          ojkHtml += `<tr${c.ok ? '' : ' class="active"'}><td>${c.rule}</td><td>${c.limit}</td><td style="color:${c.ok ? 'var(--green-dark)' : 'var(--red)'};font-weight:700">${c.ok ? '✅ ' : '❌ '}${c.current}</td></tr>`;
        });
        $('ojkBody').innerHTML = ojkHtml;

        // Debt Trap Analysis
        let debtHtml = '';
        if (gaji > 0) {
          const pctGaji = (totalBayar / gaji) * 100;
          let debtStatus = '', debtColor = '';
          if (pctGaji < 20) { debtStatus = '✅ Aman'; debtColor = 'var(--green-dark)'; }
          else if (pctGaji < 40) { debtStatus = '⚠️ Hati-hati'; debtColor = 'var(--gold)'; }
          else { debtStatus = '❌ Bahaya - Debt Trap!'; debtColor = 'var(--red)'; }
          debtHtml = `
            <table class="compare-table">
              <tbody>
                <tr><td>Total bayar / penghasilan</td><td class="right" style="color:${debtColor};font-weight:700">${pctGaji.toFixed(1)}%</td></tr>
                <tr><td>Status</td><td class="right" style="color:${debtColor};font-weight:700">${debtStatus}</td></tr>
              </tbody>
            </table>
            <p style="font-size:12px;color:var(--text-soft);margin-top:10px;line-height:1.6">💡 <strong>Aturan emas:</strong> total cicilan pinjol tidak boleh lebih dari <strong>20% gaji</strong>. Kalau sudah 40%+, hentikan pinjam baru dan fokus lunasi yang ada.</p>
          `;
        } else {
          debtHtml = '<p style="font-size:13px;color:var(--text-soft)">Masukkan penghasilan bulanan untuk analisis debt trap.</p>';
        }
        $('debtTrapInfo').innerHTML = debtHtml;

        $('totalBayar').textContent = HC.fmt(totalBayar);
        $('aprLabel').textContent = `APR: ${apr.toFixed(1)}%/tahun · ${tenor} hari`;
        $('pokokVal').textContent = HC.fmt(pokok);
        $('totalBunga').textContent = HC.fmt(bunga);
        $('adminVal').textContent = HC.fmt(admin);
        $('danaCair').textContent = HC.fmt(danaCair);

        lastCalc = { pokok, tenor, bungaHarian, admin, gaji, bunga, totalBayar, danaCair, apr, biayaPctPokok };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        if (bungaHarian > 0.1) {
          HC.toast('⚠️ Bunga melebihi batas OJK 2026!', 'error');
        } else {
          HC.toast('Biaya pinjol berhasil dihitung!');
        }
      }

      function reset() {
        els.pinjaman.value = '2.000.000'; els.tenor.value = '30'; els.bunga.value = '0.1';
        els.preset.value = 'custom'; els.admin.value = '80.000'; els.gaji.value = '5.000.000';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const ojkOk = c.bungaHarian <= 0.1;
        const insight = ojkOk
          ? `Bunga ${c.bungaHarian}%/hari sesuai aturan OJK 2026. APR ${c.apr.toFixed(0)}%/tahun. Tetap pinjam bijak dan bayar tepat waktu.`
          : `⚠️ Bunga ${c.bungaHarian}%/hari MELEBIHI batas OJK 2026 (max 0,1%). Kemungkinan pinjol ilegal — lapor ke OJK 157!`;

        return HC.buildReportCard({
          title: '⚠️ Simulasi Biaya Pinjol',
          color: '#DC2626', color2: '#991B1B',
          heroLabel: 'Total Harus Dibayar',
          heroValue: HC.fmt(c.totalBayar),
          heroSubtext: `APR ${c.apr.toFixed(0)}%/thn · ${c.tenor} hari`,
          inputs: [
            { label: '💰 Pinjaman', value: HC.fmt(c.pokok) },
            { label: '📅 Tenor', value: c.tenor + ' hari' },
            { label: '📊 Bunga', value: c.bungaHarian + '%/hari' },
            { label: '🧾 Admin', value: HC.fmt(c.admin) },
          ],
          results: [
            { label: 'Total Bayar', value: HC.fmt(c.totalBayar), highlight: true },
            { label: 'Total Bunga', value: HC.fmt(c.bunga) },
            { label: 'Dana Cair', value: HC.fmt(c.danaCair) },
            { label: 'APR/Tahun', value: c.apr.toFixed(1) + '%' },
            { label: 'Status OJK', value: ojkOk ? '✅ Sesuai aturan' : '❌ Melebihi batas', highlight: true },
          ],
          insight, slug: 'pinjol-legal',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        const ojkOk = c.bungaHarian <= 0.1;
        return `⚠️ *Simulasi Pinjol - HitungCerdas*\n\nPinjaman: ${HC.fmt(c.pokok)}\nTenor: ${c.tenor} hari\nBunga: ${c.bungaHarian}%/hari (APR ${c.apr.toFixed(0)}%/thn)\n\n💵 *Total Bayar: ${HC.fmt(c.totalBayar)}*\n📥 Dana Cair: ${HC.fmt(c.danaCair)}\n📊 Total Biaya: ${HC.fmt(c.bunga + c.admin)}\n\n${ojkOk ? '✅ Sesuai aturan OJK 2026' : '❌ Melebihi batas OJK!'}\n\nCek legalitas pinjol: OJK 157\nHitung di: https://hitungcerdas.net/kalkulator/pinjol-legal`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'pinjol-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'pinjol-legal'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>
