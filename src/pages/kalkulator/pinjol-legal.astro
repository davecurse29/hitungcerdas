<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { pinjaman: $('pinjaman'), tenor: $('tenor'), bunga: $('bunga'), preset: $('preset'), admin: $('admin'), gaji: $('gaji') };
      [els.pinjaman, els.admin, els.gaji].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      els.preset.addEventListener('change', () => {
        const v = els.preset.value;
        const map = { ojk: '0.1', produktif: '0.067', rendah: '0.05', ilegal: '0.8' };
        if (map[v]) els.bunga.value = map[v];
      });

      let lastCalc = null;

      function hitung() {
        const pokok = HC.parseRp(els.pinjaman.value);
        const tenor = parseInt(els.tenor.value);
        const bungaHarian = parseFloat(els.bunga.value);
        const admin = HC.parseRp(els.admin.value);
        const gaji = HC.parseRp(els.gaji.value);

        if (pokok === 0) { HC.toast('Masukkan jumlah pinjaman dulu', 'error'); return; }

        const bunga = pokok * (bungaHarian / 100) * tenor;
        const totalBayar = pokok + bunga + admin;
        const danaCair = pokok - admin;
        const apr = (bungaHarian * 365);
        const totalBiaya = bunga + admin;
        const biayaPctPokok = (totalBiaya / pokok) * 100;

        // OJK Compliance Check
        let ojkHtml = '';
        const checks = [
          { rule: 'Bunga konsumtif', limit: 'max 0,1%/hari', ok: bungaHarian <= 0.1, current: bungaHarian + '%/hari' },
          { rule: 'Lock Cap (Total biaya ≤ Pokok)', limit: 'max 100%', ok: biayaPctPokok <= 100, current: biayaPctPokok.toFixed(1) + '%' },
          { rule: 'Biaya admin', limit: 'max 4% pokok', ok: (admin / pokok * 100) <= 4, current: (admin / pokok * 100).toFixed(1) + '%' },
        ];
        checks.forEach(c => {
          ojkHtml += `<tr${c.ok ? '' : ' class="active"'}><td>${c.rule}</td><td>${c.limit}</td><td style="color:${c.ok ? 'var(--green-dark)' : 'var(--red)'};font-weight:700">${c.ok ? '✅ ' : '❌ '}${c.current}</td></tr>`;
        });
        $('ojkBody').innerHTML = ojkHtml;

        // Debt Trap Analysis
        let debtHtml = '';
        if (gaji > 0) {
          const pctGaji = (totalBayar / gaji) * 100;
          let debtStatus = '', debtColor = '';
          if (pctGaji < 20) { debtStatus = '✅ Aman'; debtColor = 'var(--green-dark)'; }
          else if (pctGaji < 40) { debtStatus = '⚠️ Hati-hati'; debtColor = 'var(--gold)'; }
          else { debtStatus = '❌ Bahaya - Debt Trap!'; debtColor = 'var(--red)'; }
          debtHtml = `
            <table class="compare-table">
              <tbody>
                <tr><td>Total bayar / penghasilan</td><td class="right" style="color:${debtColor};font-weight:700">${pctGaji.toFixed(1)}%</td></tr>
                <tr><td>Status</td><td class="right" style="color:${debtColor};font-weight:700">${debtStatus}</td></tr>
              </tbody>
            </table>
            <p style="font-size:12px;color:var(--text-soft);margin-top:10px;line-height:1.6">💡 <strong>Aturan emas:</strong> total cicilan pinjol tidak boleh lebih dari <strong>20% gaji</strong>. Kalau sudah 40%+, hentikan pinjam baru dan fokus lunasi yang ada.</p>
          `;
        } else {
          debtHtml = '<p style="font-size:13px;color:var(--text-soft)">Masukkan penghasilan bulanan untuk analisis debt trap.</p>';
        }
        $('debtTrapInfo').innerHTML = debtHtml;

        $('totalBayar').textContent = HC.fmt(totalBayar);
        $('aprLabel').textContent = `APR: ${apr.toFixed(1)}%/tahun · ${tenor} hari`;
        $('pokokVal').textContent = HC.fmt(pokok);
        $('totalBunga').textContent = HC.fmt(bunga);
        $('adminVal').textContent = HC.fmt(admin);
        $('danaCair').textContent = HC.fmt(danaCair);

        // APR efektif (all-in: bunga + admin), disetahunkan dengan rollover
        const periodCost = totalBiaya / pokok;                         // biaya total selama `tenor` hari
        const aprEff = (Math.pow(1 + periodCost, 365 / tenor) - 1) * 100;
        const setaraBulan = periodCost * (30 / tenor) * 100;           // setara %/bulan (flat)
        const effEl = $('aprEffInfo');
        effEl.style.display = '';
        effEl.innerHTML = `💡 APR di atas (${apr.toFixed(0)}%) cuma hitung bunga. Kalau <b>biaya admin ikut dihitung</b>: biaya pinjaman ini <b>${biayaPctPokok.toFixed(1)}% dari pokok untuk ${tenor} hari</b> — setara <b>~${setaraBulan.toFixed(1)}%/bulan</b> atau <b>~${aprEff.toFixed(0)}% efektif/tahun</b> kalau dipinjam berulang. Admin yang "cuma" ${HC.fmt(admin)} jadi mahal banget di tenor pendek. Bandingkan: KTA bank ~18-26%/thn.`;

        lastCalc = { pokok, tenor, bungaHarian, admin, gaji, bunga, totalBayar, danaCair, apr, aprEff, setaraBulan, biayaPctPokok };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        if (bungaHarian > 0.1) {
          HC.toast('⚠️ Bunga melebihi batas OJK 2026!', 'error');
        } else {
          HC.toast('Biaya pinjol berhasil dihitung!');
        }
      }

      function reset() {
        els.pinjaman.value = '2.000.000'; els.tenor.value = '30'; els.bunga.value = '0.1';
        var ae=$('aprEffInfo'); if(ae) ae.style.display='none';
        els.preset.value = 'custom'; els.admin.value = '80.000'; els.gaji.value = '5.000.000';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const ojkOk = c.bungaHarian <= 0.1;
        const insight = ojkOk
          ? `Bunga ${c.bungaHarian}%/hari sesuai aturan OJK 2026. APR ${c.apr.toFixed(0)}%/tahun. Tetap pinjam bijak dan bayar tepat waktu.`
          : `⚠️ Bunga ${c.bungaHarian}%/hari MELEBIHI batas OJK 2026 (max 0,1%). Kemungkinan pinjol ilegal — lapor ke OJK 157!`;

        return HC.buildReportCard({
          title: '⚠️ Simulasi Biaya Pinjol',
          color: '#DC2626', color2: '#991B1B',
          heroLabel: 'Total Harus Dibayar',
          heroValue: HC.fmt(c.totalBayar),
          heroSubtext: `APR ${c.apr.toFixed(0)}%/thn · ${c.tenor} hari`,
          inputs: [
            { label: '💰 Pinjaman', value: HC.fmt(c.pokok) },
            { label: '📅 Tenor', value: c.tenor + ' hari' },
            { label: '📊 Bunga', value: c.bungaHarian + '%/hari' },
            { label: '🧾 Admin', value: HC.fmt(c.admin) },
          ],
          results: [
            { label: 'Total Bayar', value: HC.fmt(c.totalBayar), highlight: true },
            { label: 'Total Bunga', value: HC.fmt(c.bunga) },
            { label: 'Dana Cair', value: HC.fmt(c.danaCair) },
            { label: 'APR/Tahun', value: c.apr.toFixed(1) + '%' },
            { label: 'Status OJK', value: ojkOk ? '✅ Sesuai aturan' : '❌ Melebihi batas', highlight: true },
          ],
          insight, slug: 'pinjol-legal',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        const ojkOk = c.bungaHarian <= 0.1;
        return `⚠️ *Simulasi Pinjol - HitungCerdas*\n\nPinjaman: ${HC.fmt(c.pokok)}\nTenor: ${c.tenor} hari\nBunga: ${c.bungaHarian}%/hari (APR ${c.apr.toFixed(0)}%/thn)\n\n💵 *Total Bayar: ${HC.fmt(c.totalBayar)}*\n📥 Dana Cair: ${HC.fmt(c.danaCair)}\n📊 Total Biaya: ${HC.fmt(c.bunga + c.admin)}\n\n${ojkOk ? '✅ Sesuai aturan OJK 2026' : '❌ Melebihi batas OJK!'}\n\nCek legalitas pinjol: OJK 157\nHitung di: https://hitungcerdas.net/kalkulator/pinjol-legal`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'pinjol-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'pinjol-legal'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 5;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function readData(){
        var totalTxt=($('totalBayar')||{}).textContent||'Rp 0';
        var pokokTxt=($('pokokVal')||{}).textContent||'Rp 0';
        var bungaTxt=($('totalBunga')||{}).textContent||'Rp 0';
        var adminTxt=($('adminVal')||{}).textContent||'Rp 0';
        var cairTxt=($('danaCair')||{}).textContent||'Rp 0';
        var apr=($('aprLabel')||{}).textContent||'';
        return { totalTxt:totalTxt, totalNum:num(totalTxt), pokokTxt:pokokTxt, pokokNum:num(pokokTxt),
          bungaTxt:bungaTxt, bungaNum:num(bungaTxt), adminTxt:adminTxt, adminNum:num(adminTxt),
          cairTxt:cairTxt, apr:apr,
          pinjaman:($('pinjaman')||{}).value||'', tenor:selText('tenor'), bunga:($('bunga')||{}).value||'',
          preset:selText('preset'), admin:($('admin')||{}).value||'', gaji:($('gaji')||{}).value||'' };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-alert-triangle"></i> Pinjol \u00b7 Total balik <b>'+esc(d.totalTxt)+'</b>'+(d.apr?(' \u00b7 '+esc(d.apr)):'')+'</div>';
        if(!d.totalNum || !d.pokokNum){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat porsi biaya dari pinjamanmu.</div>'; return; }
        var biaya=Math.max(0,d.bungaNum+d.adminNum);
        var biayaPct=Math.max(0,Math.min(100, biaya/d.totalNum*100)); var pokokPct=Math.max(0,100-biayaPct);
        var ratio=d.pokokNum?biaya/d.pokokNum*100:0;
        var vc=ratio<15?'good':(ratio<30?'warn':'bad');
        var vi=ratio<15?'ti-circle-check':'ti-alert-circle';
        var vt=ratio<15?('Biaya relatif terkendali \u2014 sekitar '+ratio.toFixed(0)+'% dari pokok'):(ratio<30?('Biaya lumayan tinggi \u2014 sekitar '+ratio.toFixed(0)+'% dari pokok, timbang ulang'):('Biaya sangat tinggi \u2014 sekitar '+ratio.toFixed(0)+'% dari pokok, hati-hati'));
        ground.innerHTML=ctx
          +'<div class="aic-stack"><div class="seg s-blue" style="width:'+pokokPct.toFixed(1)+'%"><span class="seg-lbl">Pokok</span></div><div class="seg s-red" style="width:'+biayaPct.toFixed(1)+'%"><span class="seg-lbl">Biaya</span></div></div>'
          +'<div class="aic-legend"><span><span class="dot" style="background:#DBEAFE"></span>Pokok: <b>'+esc(d.pokokTxt)+'</b></span><span><span class="dot" style="background:#FCA5A5"></span>Biaya (bunga+admin): <b>'+esc(HC.fmt(biaya))+'</b></span></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var biaya=d.bungaNum+d.adminNum; var ratio=d.pokokNum?biaya/d.pokokNum*100:null;
        var p=[
          'Kalkulator: Pinjol Legal (pinjaman online berizin OJK).',
          d.pinjaman?('Jumlah pinjaman (pokok): Rp '+d.pinjaman+'.'):'',
          d.tenor?('Tenor: '+d.tenor+'.'):'',
          d.bunga?('Bunga: '+d.bunga+'% per hari.'):'',
          d.preset?('Skenario: '+d.preset+'.'):'',
          'Biaya admin: '+d.adminTxt+'. Total bunga: '+d.bungaTxt+'.',
          'Dana yang cair diterima: '+d.cairTxt+'. Total harus dibayar: '+d.totalTxt+'.',
          d.apr?(d.apr+'.'):'',
          (ratio!=null?('Total biaya (bunga+admin) sekitar '+ratio.toFixed(1)+'% dari pokok pinjaman.'):''),
          'PENTING: pinjol punya bunga & biaya jauh lebih tinggi dari kredit bank biasa. Selalu pastikan penyelenggara terdaftar resmi di OJK. Ingatkan bahaya gali-lubang-tutup-lubang, sarankan timbang sumber dana yang lebih murah jika ada, dan jangan menjanjikan apa pun. Bukan nasihat keuangan berlisensi.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsg('ai',data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Pinjaman ini mahal gak?','Aman gak ambil pinjol ini?','Ada opsi yang lebih murah?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
