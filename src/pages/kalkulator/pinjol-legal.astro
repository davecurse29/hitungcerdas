---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = "Kalkulator Pinjol Legal 2026 - Hitung Biaya Sebenarnya + Aturan OJK";
const description = "Hitung biaya pinjaman online sebenarnya sesuai aturan OJK 2026: bunga max 0,1%/hari, Lock Cap 100%, APR transparan, simulasi keterlambatan, debt trap warning. Bandingkan pinjol legal & cek OJK.";
const breadcrumbs = [
  { label: "Beranda", href: "/" },
  { label: "Kalkulator", href: "/#kalkulator" },
  { label: "Pinjol Legal" }
];

// DATA PINJOL LEGAL POPULER + ATURAN OJK 2026
const pinjolData = [
  { name: "Kredivo", tipe: "Paylater + Cash", bungaBulan: 2.6, bungaHari: 0.087, limit: 50000000, tenorMax: 12, catatan: "Cicilan e-commerce & dana tunai" },
  { name: "AdaKami", tipe: "Cash Loan", bungaBulan: 3.0, bungaHari: 0.1, limit: 80000000, tenorMax: 12, catatan: "Pinjaman tunai, verifikasi digital" },
  { name: "Kredit Pintar", tipe: "Cash Loan", bungaBulan: 3.0, bungaHari: 0.1, limit: 50000000, tenorMax: 12, catatan: "Credit scoring berbasis data" },
  { name: "JULO", tipe: "Cash Loan", bungaBulan: 1.75, bungaHari: 0.058, limit: 50000000, tenorMax: 24, catatan: "Bunga rendah untuk nasabah disiplin" },
  { name: "Tunaiku (Amar Bank)", tipe: "KTA Digital", bungaBulan: 3.0, bungaHari: 0.1, limit: 20000000, tenorMax: 20, catatan: "Produk bank, tenor panjang" },
  { name: "Indodana", tipe: "Paylater + Cash", bungaBulan: 2.5, bungaHari: 0.083, limit: 50000000, tenorMax: 12, catatan: "Belanja & pencairan dana" }
];
---

<Layout title={title} description={description} catColor="#DC2626" catColor2="#B91C1C">
  <Breadcrumb items={breadcrumbs} />

  <main class="calc-page">
    <section class="calc-hero pinjol-hero" style="--cat-color:#DC2626;--cat-color2:#B91C1C">
      <div class="hero-inner">
        <div class="hero-badge warning-badge"><i class="ti ti-shield-check"></i><span>Kalkulator Edukatif</span></div>
        <h1>Kalkulator Pinjol Legal 2026</h1>
        <p class="hero-sub">Pahami biaya pinjaman online yang sebenarnya sebelum meminjam. Sesuai aturan OJK terbaru 2026: bunga maksimal 0,1%/hari & Lock Cap 100%. Transparan, edukatif, melindungi kamu.</p>
        <div class="trust-row">
          <span class="trust-item"><i class="ti ti-check"></i> Aturan OJK 2026</span>
          <span class="trust-item"><i class="ti ti-check"></i> APR Transparan</span>
          <span class="trust-item"><i class="ti ti-check"></i> Cek Legalitas OJK</span>
          <span class="trust-item"><i class="ti ti-check"></i> Semua Bisa Diedit</span>
        </div>
        <div class="ojk-rate-badge">
          <i class="ti ti-gavel"></i>
          <span>Aturan OJK 2026: bunga konsumtif <strong>maks 0,1%/hari</strong> • biaya total <strong>maks 100% pokok</strong> (Lock Cap)</span>
        </div>
      </div>
    </section>

    <div class="calc-container">
      <div class="disclaimer-box">
        <i class="ti ti-info-circle"></i>
        <p><strong>Tujuan kalkulator ini EDUKASI & PERLINDUNGAN konsumen.</strong> Kami tidak mempromosikan atau berafiliasi dengan platform pinjol manapun. Selalu pertimbangkan alternatif lebih aman dan cek legalitas di OJK sebelum meminjam.</p>
      </div>

      <div class="calc-card">
        <h2 class="card-title"><i class="ti ti-calculator"></i> Simulasi Pinjaman Online</h2>

        <div class="form-group">
          <label>Jumlah Pinjaman</label>
          <div class="input-prefix"><span>Rp</span><input type="text" id="inJumlah" placeholder="Contoh: 2.000.000" inputmode="numeric" oninput="formatRupiahInput(this)"></div>
        </div>

        <div class="form-group">
          <label>Tenor</label>
          <div class="tenor-type-grid">
            <div>
              <label class="sub-label">Jenis Tenor</label>
              <div class="option-grid">
                <button class="opt-btn active" data-group="tenorType" data-val="hari" onclick="setOpt(this,'tenorType')">Harian</button>
                <button class="opt-btn" data-group="tenorType" data-val="bulan" onclick="setOpt(this,'tenorType')">Bulanan</button>
              </div>
            </div>
            <div>
              <label class="sub-label">Durasi</label>
              <div class="input-with-unit"><input type="number" id="inTenor" value="30" min="1" max="365"><span id="tenorUnit">hari</span></div>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label>Bunga Harian (%) <span class="editable-hint">✏️ bisa diedit</span></label>
          <div class="slider-wrap">
            <input type="range" id="slBunga" min="0.05" max="2" step="0.01" value="0.1" oninput="onPinjolBunga()">
            <div class="slider-info"><span>0,05%</span><strong id="valBunga">0,1% / hari</strong><span>2%</span></div>
          </div>
          <div class="preset-row">
            <button class="preset-btn active" onclick="setBungaPreset(0.1,this)">OJK Legal Maks (0,1%)</button>
            <button class="preset-btn" onclick="setBungaPreset(0.067,this)">Produktif (0,067%)</button>
            <button class="preset-btn danger" onclick="setBungaPreset(0.8,this)">Ilegal (0,8%)</button>
          </div>
          <p class="field-hint">💡 OJK 2026 batasi bunga konsumtif max 0,1%/hari (≈3%/bulan). Pinjol ilegal sering 0,5-1%/hari — hindari!</p>
        </div>

        <div class="form-group">
          <label>Biaya Admin / Provisi</label>
          <div class="input-prefix"><span>Rp</span><input type="text" id="inAdmin" placeholder="Contoh: 80.000" inputmode="numeric" oninput="formatRupiahInput(this)"></div>
          <p class="field-hint">OJK batasi maks 4% dari plafon. Biaya ini dipotong dari dana cair (kamu terima lebih sedikit!).</p>
        </div>

        <div class="form-group">
          <label>Penghasilan Bulanan (opsional)</label>
          <div class="input-prefix"><span>Rp</span><input type="text" id="inPenghasilan" placeholder="Untuk analisis debt trap" inputmode="numeric" oninput="formatRupiahInput(this)"></div>
        </div>

        <button class="btn-primary btn-red" onclick="hitungPinjol()"><i class="ti ti-search"></i> Hitung Biaya Sebenarnya</button>
      </div>

      <div class="hidden" id="hasilSection">
        <div class="result-hero pinjol-result-hero">
          <div class="shock-badge">⚠️ TRANSPARANSI BIAYA SEBENARNYA</div>
          <div class="pinjol-hero-inner">
            <div class="pinjol-hero-main">
              <div class="result-tag">💸 Total Yang Harus Dibayar</div>
              <div class="result-big red-num" id="resTotalBayar">Rp 0</div>
              <div class="result-sub" id="resSubInfo">untuk pinjaman Rp 0</div>
            </div>
            <div class="apr-shock">
              <div class="apr-label">APR Sesungguhnya</div>
              <div class="apr-val" id="resAPR">0%</div>
              <div class="apr-compare" id="resAPRCompare"></div>
            </div>
          </div>
        </div>

        <AdSlot position="after-result" />

        <!-- LOCK CAP CHECK -->
        <div class="calc-card" id="lockCapCard">
          <h3 class="card-title"><i class="ti ti-lock"></i> Cek Aturan Lock Cap 100% OJK</h3>
          <div class="lockcap-box" id="lockCapBox"></div>
        </div>

        <div class="calc-card">
          <h3 class="card-title"><i class="ti ti-list-details"></i> Bedah Biaya (Transparan)</h3>
          <div class="breakdown-table" id="breakdownTable"></div>
          <div class="uang-diterima" id="uangDiterima"></div>
        </div>

        <div class="calc-card" id="debtTrapCard">
          <h3 class="card-title"><i class="ti ti-alert-triangle"></i> Debt Trap Risk Meter</h3>
          <div class="trap-meter"><div class="trap-track"><div class="trap-fill" id="trapFill"></div></div><div class="trap-zones"><span>Aman</span><span>Waspada</span><span>Bahaya</span><span>🚨 Jebakan!</span></div></div>
          <div class="trap-msg" id="trapMsg"></div>
        </div>

        <div class="calc-card">
          <h3 class="card-title"><i class="ti ti-clock-exclamation"></i> Simulasi Keterlambatan</h3>
          <p class="card-sub">Geser untuk lihat dampak telat bayar (denda OJK maks 0,1%/hari)</p>
          <div class="slider-wrap"><input type="range" id="slTelat" min="0" max="60" step="1" value="0" oninput="onTelatChange()"><div class="slider-info"><span>0 hari</span><strong id="valTelat">0 hari telat</strong><span>60 hari</span></div></div>
          <div class="late-result"><div class="late-row"><span>Total tagihan normal</span><span id="lrNormal">—</span></div><div class="late-row warning"><span>Denda keterlambatan</span><span id="lrDenda">Rp 0</span></div><div class="late-row danger"><span>TOTAL dengan denda</span><span id="lrTotal">—</span></div></div>
          <div class="snowball-warning" id="snowballWarn"></div>
        </div>

        <div class="calc-card">
          <h3 class="card-title"><i class="ti ti-coins"></i> Biaya Pinjol Kamu Setara...</h3>
          <div class="relatable-grid" id="pinjolRelatable"></div>
        </div>

        <AdSlot position="mid-content" />

        <!-- PINJOL COMPARISON -->
        <div class="calc-card">
          <h3 class="card-title"><i class="ti ti-versions"></i> Bandingkan Pinjol Legal (Update 2026)</h3>
          <p class="card-sub">Semua terdaftar OJK. Bunga & aturan terupdate. Pilih yang sesuai kebutuhan.</p>
          <div class="pinjol-table" id="pinjolTable"></div>
          <details class="bank-detail"><summary>📋 Lihat aturan & detail tiap pinjol</summary><div class="pinjol-rules" id="pinjolRules"></div></details>
        </div>

        <!-- OJK CHECK -->
        <div class="calc-card ojk-card">
          <h3 class="card-title"><i class="ti ti-building-bank"></i> Cek Legalitas Pinjol</h3>
          <div class="ojk-alert"><i class="ti ti-shield-check"></i><p><strong>SELALU cek legalitas pinjol di OJK sebelum meminjam!</strong> Pinjol ilegal tidak diatur UU dan tidak bisa kamu laporkan jika bermasalah.</p></div>
          <a href="https://www.ojk.go.id/id/kanal/iknb/financial-technology/Default.aspx" class="ojk-btn" target="_blank" rel="noopener noreferrer"><i class="ti ti-external-link"></i> Cek Daftar Pinjol Legal di OJK.go.id</a>
          <a href="https://wa.me/6281157157157" class="ojk-btn secondary" target="_blank" rel="noopener noreferrer"><i class="ti ti-brand-whatsapp"></i> WhatsApp Resmi OJK: 081-157-157-157</a>
          <div class="signs-wrap">
            <div class="ilegal-signs">
              <h4>🚩 Ciri Pinjol ILEGAL</h4>
              <div class="signs-grid">
                <div class="sign-item red"><i class="ti ti-x"></i> Tidak terdaftar OJK</div>
                <div class="sign-item red"><i class="ti ti-x"></i> Minta akses kontak & galeri HP</div>
                <div class="sign-item red"><i class="ti ti-x"></i> Bunga &gt;0,1%/hari (tidak transparan)</div>
                <div class="sign-item red"><i class="ti ti-x"></i> Teror & intimidasi saat tagih</div>
                <div class="sign-item red"><i class="ti ti-x"></i> Tenor sangat pendek (7-14 hari)</div>
                <div class="sign-item red"><i class="ti ti-x"></i> Potong biaya admin besar di awal</div>
              </div>
            </div>
            <div class="legal-signs">
              <h4>✅ Ciri Pinjol LEGAL (Aturan OJK 2026)</h4>
              <div class="signs-grid">
                <div class="sign-item green"><i class="ti ti-check"></i> Terdaftar & berizin OJK</div>
                <div class="sign-item green"><i class="ti ti-check"></i> Bunga max 0,1%/hari (konsumtif)</div>
                <div class="sign-item green"><i class="ti ti-check"></i> Lock Cap 100% (biaya ≤ pokok)</div>
                <div class="sign-item green"><i class="ti ti-check"></i> Admin max 4% dari plafon</div>
                <div class="sign-item green"><i class="ti ti-check"></i> Hanya akses CAMILAN (Camera, Mic, Location)</div>
                <div class="sign-item green"><i class="ti ti-check"></i> Penagihan etis (jam 08-20)</div>
              </div>
            </div>
          </div>
        </div>

        <!-- ALTERNATIVES -->
        <div class="calc-card alt-card">
          <h3 class="card-title"><i class="ti ti-bulb"></i> Alternatif Lebih Aman dari Pinjol</h3>
          <div class="alt-grid">
            <a href="/kalkulator/dana-darurat" class="alt-item best"><div class="alt-icon">🛡️</div><div class="alt-text"><strong>Bangun Dana Darurat</strong><p>Solusi terbaik jangka panjang. Tanpa bunga, tanpa risiko debt trap.</p><span class="alt-cta">Hitung Dana Darurat →</span></div></a>
            <a href="/kalkulator/kta" class="alt-item"><div class="alt-icon">🏦</div><div class="alt-text"><strong>KTA Bank Resmi</strong><p>Bunga ~16-26%/tahun vs pinjol ~36%/tahun. Lebih lambat tapi jauh lebih murah.</p><span class="alt-cta">Simulasi KTA →</span></div></a>
            <div class="alt-item"><div class="alt-icon">👥</div><div class="alt-text"><strong>Koperasi Simpan Pinjam</strong><p>Bunga rendah (1-2%/bulan), terdaftar resmi, bantu komunitas.</p></div></div>
            <div class="alt-item"><div class="alt-icon">💚</div><div class="alt-text"><strong>Pinjam Keluarga / Sahabat</strong><p>Bunga 0% dan fleksibel. Jaga kepercayaan dengan bayar tepat waktu.</p></div></div>
          </div>
        </div>

        <!-- SCORECARD -->
        <div class="calc-card scorecard-section">
          <h3 class="card-title"><i class="ti ti-photo"></i> Kartu Edukasi — Siap Share!</h3>
          <p class="card-sub">Bantu teman & keluarga pahami biaya pinjol. Share ke Status WA, IG/FB/TikTok Story.</p>
          <div class="sc-preview-wrap">
            <div class="sc-preview" id="scPreview">
              <div class="sc-grad-overlay"></div>
              <div class="sc-content">
                <div class="sc-top"><span class="sc-brand">HitungCerdas<span class="sc-dot">.net</span></span><span class="sc-pill">⚠️ CEK PINJOL</span></div>
                <div class="sc-main">
                  <div class="sc-label">Pinjam <span id="scJumlah">Rp 0</span>, harus bayar</div>
                  <div class="sc-big red" id="scBigTotal">Rp 0</div>
                  <div class="sc-apr-box"><span class="sc-apr-lbl">APR Sesungguhnya</span><span class="sc-apr-val" id="scAPR">0%/tahun</span></div>
                </div>
                <div class="sc-compare-box">
                  <div class="sc-compare-row"><span>Pinjol ini</span><span class="sc-bad" id="scPinjolRate">0%/thn</span></div>
                  <div class="sc-compare-row"><span>KTA Bank</span><span class="sc-good">~18%/thn</span></div>
                </div>
                <div class="sc-quote" id="scQuote">"Pahami biaya sebelum meminjam 💡"</div>
                <div class="sc-foot"><span class="sc-tags">#PahamiSebelumPinjam</span><span class="sc-url">hitungcerdas.net</span></div>
              </div>
            </div>
          </div>
          <div class="sc-format-row">
            <button class="sc-fmt active" data-fmt="square" onclick="setScFormat(this,'square')">⬜ Square (IG/FB)</button>
            <button class="sc-fmt" data-fmt="story" onclick="setScFormat(this,'story')">📱 Story (WA/IG/TikTok)</button>
          </div>
          <div class="export-grid">
            <button class="export-btn primary" onclick="exportScorecard()"><i class="ti ti-download"></i> Download Kartu</button>
            <button class="export-btn wa" onclick="sharePinjolWA()"><i class="ti ti-brand-whatsapp"></i> Share WhatsApp</button>
            <button class="export-btn" onclick="copyPinjolResult()"><i class="ti ti-copy"></i> Copy Teks</button>
          </div>
        </div>

        <div style="text-align:center;margin:1rem 0"><button class="btn-secondary" onclick="resetPinjol()"><i class="ti ti-refresh"></i> Hitung Ulang</button></div>
        <AdSlot position="before-footer" />
      </div>

      <!-- EDUCATIONAL -->
      <div class="calc-card edu-card">
        <h2><i class="ti ti-book"></i> Panduan Lengkap Pinjaman Online 2026</h2>
        <h3>Apa itu Pinjol?</h3>
        <p>Pinjaman Online (Pinjol) atau Fintech Lending adalah layanan pinjam-meminjam berbasis teknologi. Prosesnya cepat (menit-jam) tapi biayanya lebih mahal dari bank. Diatur OJK melalui POJK terbaru.</p>

        <div class="info-callout">
          <i class="ti ti-gavel"></i>
          <div><strong>Aturan Baru OJK 2026:</strong> Bunga pinjol konsumtif diturunkan jadi maks <strong>0,1%/hari</strong> (dari 0,4% di 2024). Ada <strong>Lock Cap 100%</strong> — total biaya tidak boleh lebih dari pokok pinjaman. Biaya admin maks 4%. Aturan ini melindungi peminjam dari jeratan utang.</div>
        </div>

        <h3>Kenapa APR Pinjol Bisa Tinggi?</h3>
        <p>Pinjol pakai bunga harian. Bunga 0,1%/hari terlihat kecil, tapi disetahunkan jadi ~36%/tahun. Ditambah admin, APR bisa lebih tinggi. Bandingkan KTA bank yang ~16-26%/tahun. Pinjol ilegal bahkan 0,5-1%/hari (180-365%/tahun)!</p>

        <h3>Hak-Hak Kamu sebagai Peminjam (OJK)</h3>
        <ul class="edu-list">
          <li>Berhak info biaya lengkap & transparan sebelum tandatangan</li>
          <li>Penagihan hanya boleh jam 08.00-20.00 waktu setempat</li>
          <li>Penagih dilarang mengancam, intimidasi, atau permalukan</li>
          <li>Pinjol legal hanya akses CAMILAN (Camera, Microphone, Location)</li>
          <li>Total biaya tidak boleh lebih dari 100% pokok (Lock Cap)</li>
          <li>Bisa lapor ke OJK: 157 atau WA 081-157-157-157</li>
        </ul>

        <h3>Jika Terjerat Pinjol Ilegal</h3>
        <ul class="edu-list">
          <li><strong>Jangan bayar</strong> ke rekening tidak resmi</li>
          <li><strong>Laporkan</strong> ke Satgas PASTI OJK: 157 atau waspadainvestasi.ojk.go.id</li>
          <li><strong>Blokir & screenshot</strong> semua ancaman sebagai bukti</li>
          <li><strong>Lapor polisi</strong> jika ada ancaman fisik atau penyebaran data</li>
        </ul>

        <h3>FAQ Pinjol</h3>
        <div class="faq-list">
          <div class="faq-item"><button class="faq-q" onclick="toggleFaq(this)">Berapa batas bunga pinjol legal OJK 2026? <i class="ti ti-chevron-down"></i></button><div class="faq-a"><p>Per 2026, OJK batasi bunga konsumtif maks 0,1%/hari (≈3%/bulan atau ~36%/tahun) dan produktif 0,067%/hari. Ada juga Lock Cap 100%: total seluruh biaya (bunga+denda+admin) tidak boleh melebihi pokok pinjaman.</p></div></div>
          <div class="faq-item"><button class="faq-q" onclick="toggleFaq(this)">Apakah semua pinjol berbahaya? <i class="ti ti-chevron-down"></i></button><div class="faq-a"><p>Tidak. Pinjol terdaftar & berizin OJK diawasi ketat dan ada batas bunga. Yang berbahaya adalah pinjol ILEGAL — tidak terdaftar, bunga mencekik, dan menagih dengan intimidasi. Selalu cek legalitas di OJK dulu.</p></div></div>
          <div class="faq-item"><button class="faq-q" onclick="toggleFaq(this)">Kalau gagal bayar (galbay), bisa dipenjara? <i class="ti ti-chevron-down"></i></button><div class="faq-a"><p>Tidak. Utang-piutang adalah ranah perdata, bukan pidana. Tidak ada penjara untuk galbay. Tapi risikonya: masuk blacklist SLIK OJK (susah dapat kredit), denda menumpuk, dan penagihan intensif. Untuk pinjol legal, denda dibatasi Lock Cap 100%.</p></div></div>
          <div class="faq-item"><button class="faq-q" onclick="toggleFaq(this)">Kapan pinjol bisa jadi pilihan? <i class="ti ti-chevron-down"></i></button><div class="faq-a"><p>Pinjol legal bisa dipertimbangkan hanya jika: (1) benar-benar darurat tanpa pilihan lain, (2) jumlah kecil & yakin bisa bayar tepat waktu, (3) platform terdaftar OJK, (4) biaya sudah dihitung & sanggup. Tapi selalu pertimbangkan dana darurat, KTA bank, atau koperasi dulu.</p></div></div>
        </div>

        <div class="disclaimer-box edu-disclaimer">
          <i class="ti ti-info-circle"></i>
          <div><strong>Disclaimer:</strong> Kalkulator ini alat edukasi & perlindungan konsumen. Hasil adalah estimasi. HitungCerdas TIDAK berafiliasi, mempromosikan, atau menerima komisi dari platform pinjol manapun. Daftar pinjol legal dapat berubah — selalu cek terbaru di OJK.go.id atau hubungi 157. Aturan & bunga per Juni 2026, dapat berubah sesuai kebijakan OJK.</div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<div id="pinjolScExport" class="sc-export-hidden"></div>

<script define:vars={{ pinjolData }}>
const pinjolState = { jumlah:0, tenorType:'hari', tenor:30, bunga:0.1, admin:0, penghasilan:0, result:{}, scFormat:'square' };

function fmtRp(n){return 'Rp '+Math.round(n).toLocaleString('id-ID');}
function fmtCompact(n){if(n>=1e9)return 'Rp '+(n/1e9).toFixed(1)+'M';if(n>=1e6)return 'Rp '+(n/1e6).toFixed(1)+'jt';if(n>=1e3)return 'Rp '+(n/1e3).toFixed(0)+'rb';return 'Rp '+n;}
function formatRupiahInput(el){let v=el.value.replace(/\D/g,'');el.value=v?parseInt(v).toLocaleString('id-ID'):'';}
function parseRupiah(s){return parseInt((s||'0').replace(/\D/g,''))||0;}
function setOpt(btn,group){document.querySelectorAll(`[data-group="${group}"]`).forEach(b=>b.classList.remove('active'));btn.classList.add('active');pinjolState.tenorType=btn.dataset.val;document.getElementById('tenorUnit').textContent=btn.dataset.val;}
function onPinjolBunga(){const v=parseFloat(document.getElementById('slBunga').value);pinjolState.bunga=v;document.getElementById('valBunga').textContent=v+'% / hari';document.querySelectorAll('.preset-btn').forEach(b=>b.classList.remove('active'));}
function setBungaPreset(val,btn){pinjolState.bunga=val;document.getElementById('slBunga').value=val;document.getElementById('valBunga').textContent=val+'% / hari';document.querySelectorAll('.preset-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');}

function hitungPinjol(){
  const jumlah=parseRupiah(document.getElementById('inJumlah').value);
  if(!jumlah){alert('Masukkan jumlah pinjaman dulu!');return;}
  const tenor=parseInt(document.getElementById('inTenor').value)||30;
  const admin=parseRupiah(document.getElementById('inAdmin').value);
  const penghasilan=parseRupiah(document.getElementById('inPenghasilan').value);
  const bungaHarian=pinjolState.bunga/100;
  const tenorHari=pinjolState.tenorType==='bulan'?tenor*30:tenor;
  const bungaTotal=jumlah*bungaHarian*tenorHari;
  const totalBayar=jumlah+bungaTotal+admin;
  const apr=((bungaTotal+admin)/jumlah)*(365/tenorHari)*100;
  const uangDiterima=jumlah-admin;
  const biayaRatio=((totalBayar-jumlah)/jumlah)*100;
  pinjolState.jumlah=jumlah;pinjolState.tenor=tenorHari;pinjolState.admin=admin;pinjolState.penghasilan=penghasilan;
  pinjolState.result={jumlah,bungaTotal,admin,totalBayar,apr,uangDiterima,biayaRatio,tenorHari};
  renderPinjolResult();
}

function renderPinjolResult(){
  const r=pinjolState.result;
  document.getElementById('resTotalBayar').textContent=fmtRp(r.totalBayar);
  document.getElementById('resSubInfo').textContent=`untuk pinjaman ${fmtRp(r.jumlah)} selama ${r.tenorHari} hari`;
  document.getElementById('resAPR').textContent=r.apr.toFixed(0)+'%/thn';
  document.getElementById('resAPRCompare').innerHTML=`KTA bank ~18%/tahun<br><strong>Pinjol ini ${(r.apr/18).toFixed(1)}× lebih mahal!</strong>`;

  // Lock Cap check
  const biayaTotal=r.bungaTotal+r.admin;
  const capRatio=(biayaTotal/r.jumlah)*100;
  const lockBox=document.getElementById('lockCapBox');
  if(capRatio<=100){lockBox.className='lockcap-box ok';lockBox.innerHTML=`✅ <strong>Sesuai aturan OJK.</strong> Total biaya ${fmtRp(biayaTotal)} = ${capRatio.toFixed(0)}% dari pokok (batas maks 100%). Masih dalam Lock Cap.`;}
  else{lockBox.className='lockcap-box bad';lockBox.innerHTML=`🚨 <strong>MELEBIHI batas OJK!</strong> Total biaya ${fmtRp(biayaTotal)} = ${capRatio.toFixed(0)}% dari pokok. Aturan OJK maks 100%. Ini ciri pinjol ILEGAL — hindari!`;}

  // Breakdown
  document.getElementById('breakdownTable').innerHTML=`<div class="bd-row"><span>Pinjaman Pokok</span><span>${fmtRp(r.jumlah)}</span></div><div class="bd-row warning"><span>+ Bunga (${pinjolState.bunga}%/hari × ${r.tenorHari} hari)</span><span>${fmtRp(r.bungaTotal)}</span></div>${r.admin>0?`<div class="bd-row warning"><span>+ Biaya Admin</span><span>${fmtRp(r.admin)}</span></div>`:''}<div class="bd-row total"><span>= TOTAL HARUS BAYAR</span><span>${fmtRp(r.totalBayar)}</span></div><div class="bd-insight">💸 Kamu membayar <strong>${fmtRp(r.totalBayar-r.jumlah)}</strong> lebih dari yang dipinjam (${r.biayaRatio.toFixed(0)}% lebih mahal)</div>`;
  if(r.admin>0)document.getElementById('uangDiterima').innerHTML=`<div class="terima-box"><span>💰 Uang yang BENAR-BENAR diterima:</span><strong>${fmtRp(r.uangDiterima)}</strong></div>`;
  else document.getElementById('uangDiterima').innerHTML='';

  // Debt trap
  if(pinjolState.penghasilan>0){const ratio=(r.totalBayar/pinjolState.penghasilan)*100;const fill=document.getElementById('trapFill'),msg=document.getElementById('trapMsg');fill.style.width=Math.min(100,ratio)+'%';if(ratio<20){fill.style.background='#10B981';msg.className='trap-msg success';msg.innerHTML=`✅ ${ratio.toFixed(0)}% penghasilan — Masih terjangkau. Tetap hati-hati!`;}else if(ratio<50){fill.style.background='#EF9F27';msg.className='trap-msg warning';msg.innerHTML=`⚠️ ${ratio.toFixed(0)}% penghasilan — Cukup berat! Pastikan bisa bayar tepat waktu.`;}else{fill.style.background='#E24B4A';msg.className='trap-msg danger';msg.innerHTML=`🚨 ${ratio.toFixed(0)}% penghasilan — DEBT TRAP RISK TINGGI! Total bayar lebih dari setengah gajimu. Cari alternatif!`;}}else{document.getElementById('trapMsg').innerHTML='ℹ️ Isi penghasilan untuk lihat analisis debt trap.';}

  onTelatChange();

  const items=[{icon:'☕',label:'gelas kopi',val:Math.round((r.totalBayar-r.jumlah)/20000)},{icon:'🍛',label:'makan warteg',val:Math.round((r.totalBayar-r.jumlah)/15000)},{icon:'⛽',label:'liter bensin',val:Math.round((r.totalBayar-r.jumlah)/12000)},{icon:'📱',label:'bln paket data',val:Math.round((r.totalBayar-r.jumlah)/70000)}];
  document.getElementById('pinjolRelatable').innerHTML=items.map(i=>`<div class="rel-item"><span class="rel-icon">${i.icon}</span><strong>${i.val.toLocaleString('id-ID')}</strong><span>${i.label}</span></div>`).join('');

  renderPinjolTable();renderPinjolRules();renderScorecard();
  document.getElementById('hasilSection').classList.remove('hidden');
  document.getElementById('hasilSection').scrollIntoView({behavior:'smooth',block:'start'});
}

function onTelatChange(){const r=pinjolState.result;if(!r.jumlah)return;const hari=parseInt(document.getElementById('slTelat').value);document.getElementById('valTelat').textContent=hari+' hari telat';const dendaRate=0.001;const denda=r.totalBayar*dendaRate*hari;const totalDenda=r.totalBayar+denda;document.getElementById('lrNormal').textContent=fmtRp(r.totalBayar);document.getElementById('lrDenda').textContent=fmtRp(denda);document.getElementById('lrTotal').textContent=fmtRp(totalDenda);if(hari>0)document.getElementById('snowballWarn').innerHTML=`<div class="snowball-box">🚨 Telat ${hari} hari = denda ${fmtRp(denda)}! Denda OJK legal maks 0,1%/hari. Pinjol ilegal bisa berkali lipat. Bayar tepat waktu!</div>`;else document.getElementById('snowballWarn').innerHTML='';}

function renderPinjolTable(){
  const r=pinjolState.result;
  const rows=pinjolData.map(p=>{const bungaTotal=r.jumlah*(p.bungaHari/100)*r.tenorHari;const total=r.jumlah+bungaTotal;return{...p,bungaTotal,total};}).sort((a,b)=>a.bungaHari-b.bungaHari);
  document.getElementById('pinjolTable').innerHTML=`<div class="pinjol-table-inner"><div class="ptable-row header"><span>Platform</span><span>Bunga/hari</span><span>~/bulan</span><span>Total (simulasi)</span></div>${rows.map((p,i)=>`<div class="ptable-row ${i===0?'best':''}"><span>${p.name} ${i===0?'<span class="best-tag green-tag">TERENDAH</span>':''}<br><small>${p.tipe}</small></span><span>${p.bungaHari}%</span><span>${p.bungaBulan}%</span><span>${fmtRp(p.total)}</span></div>`).join('')}</div><div class="insight-box">💡 Semua terdaftar OJK. JULO bunga terendah (0,058%/hari). Bunga aktual tergantung skor kredit & profil kamu.</div>`;
}
function renderPinjolRules(){document.getElementById('pinjolRules').innerHTML=pinjolData.map(p=>`<div class="rule-item"><strong>${p.name} — ${p.tipe}</strong><div class="rule-meta"><span>Bunga: ${p.bungaHari}%/hari (~${p.bungaBulan}%/bln)</span><span>Limit: ${fmtCompact(p.limit)}</span><span>Tenor max: ${p.tenorMax} bulan</span></div><p class="rule-note">${p.catatan}</p></div>`).join('');}

function renderScorecard(){const r=pinjolState.result;document.getElementById('scJumlah').textContent=fmtCompact(r.jumlah);document.getElementById('scBigTotal').textContent=fmtRp(r.totalBayar);document.getElementById('scAPR').textContent=r.apr.toFixed(0)+'%/thn';document.getElementById('scPinjolRate').textContent=r.apr.toFixed(0)+'%/thn';document.getElementById('scQuote').textContent=r.apr>100?'"Hati-hati jebakan bunga tinggi! 🚨"':'"Pahami biaya sebelum meminjam 💡"';}
function setScFormat(btn,fmt){document.querySelectorAll('.sc-fmt').forEach(b=>b.classList.remove('active'));btn.classList.add('active');pinjolState.scFormat=fmt;document.getElementById('scPreview').className='sc-preview '+(fmt==='story'?'story-mode':'');}

async function loadH2C(){if(!window.html2canvas){const s=document.createElement('script');s.src='https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';document.head.appendChild(s);await new Promise(r=>s.onload=r);}}
async function exportScorecard(){await loadH2C();const el=document.getElementById('scPreview');const canvas=await html2canvas(el,{backgroundColor:null,scale:3,useCORS:true});const a=document.createElement('a');a.download=`HitungCerdas-Pinjol-${pinjolState.scFormat}.png`;a.href=canvas.toDataURL('image/png');a.click();}
function sharePinjolWA(){const r=pinjolState.result;const msg=`⚠️ *Tau gak biaya SEBENARNYA pinjol?*\n\n💰 Pinjam: ${fmtRp(r.jumlah)}\n💸 Total bayar: ${fmtRp(r.totalBayar)}\n📈 APR sesungguhnya: *${r.apr.toFixed(0)}%/tahun* 😱\n\nBandingkan: KTA bank cuma ~18%/tahun\n\n_Aturan OJK 2026: pinjol legal maks 0,1%/hari_\n\nHitung & cek sendiri:\n👉 https://hitungcerdas.net/kalkulator/pinjol-legal\n\n#PahamiSebelumPinjam`;window.open('https://wa.me/?text='+encodeURIComponent(msg),'_blank');}
function copyPinjolResult(){const r=pinjolState.result;navigator.clipboard.writeText(`Pinjol ${fmtRp(r.jumlah)}: total bayar ${fmtRp(r.totalBayar)}, APR ${r.apr.toFixed(0)}%/tahun. Bandingkan KTA bank ~18%/thn. Source: hitungcerdas.net`).then(()=>alert('Tersalin!'));}
function resetPinjol(){document.getElementById('hasilSection').classList.add('hidden');window.scrollTo({top:0,behavior:'smooth'});}
function toggleFaq(btn){const a=btn.nextElementSibling;a.style.display=a.style.display==='block'?'none':'block';btn.querySelector('i').style.transform=a.style.display==='block'?'rotate(180deg)':'';}
</script>

