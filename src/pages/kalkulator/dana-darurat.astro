<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { status: $('status'), pekerjaan: $('pekerjaan'), pengeluaran: $('pengeluaran'), dananow: $('dananow'), nabung: $('nabung') };
      [els.pengeluaran, els.dananow, els.nabung].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      function getMultiplier(status, pekerjaan) {
        const base = { single: 3, married: 6, family: 9 }[status];
        const extra = { karyawan: 0, kontrak: 1, freelance: 3, wirausaha: 3 }[pekerjaan];
        return Math.min(12, base + extra);
      }

      let lastCalc = null;

      function hitung() {
        const status = els.status.value;
        const pekerjaan = els.pekerjaan.value;
        const pengeluaran = HC.parseRp(els.pengeluaran.value);
        const dananow = HC.parseRp(els.dananow.value);
        const nabung = HC.parseRp(els.nabung.value);

        if (pengeluaran === 0) { HC.toast('Masukkan pengeluaran bulanan dulu', 'error'); return; }
        if (nabung === 0) { HC.toast('Masukkan kemampuan nabung', 'error'); return; }

        const multiplier = getMultiplier(status, pekerjaan);
        const target = pengeluaran * multiplier;
        const kurang = Math.max(0, target - dananow);
        const progress = target > 0 ? Math.min(100, (dananow / target) * 100) : 0;
        const bulanTercapai = nabung > 0 ? Math.ceil(kurang / nabung) : 0;

        const statusLabel = { single: 'Single', married: 'Menikah', family: 'Menikah + Tanggungan' }[status];
        const pekerjaanLabel = { karyawan: 'Karyawan Tetap', kontrak: 'Karyawan Kontrak', freelance: 'Freelance', wirausaha: 'Wirausaha' }[pekerjaan];

        $('target').textContent = HC.fmt(target);
        $('multiplier').textContent = `${multiplier}× pengeluaran bulanan`;
        $('terkumpul').textContent = HC.fmt(dananow);
        $('kurang').textContent = HC.fmt(kurang);
        $('progress').textContent = progress.toFixed(1) + '%';
        $('estimasi').textContent = bulanTercapai > 0 ? `${bulanTercapai} bulan (${(bulanTercapai/12).toFixed(1)} tahun)` : '✅ Sudah tercapai!';

        let html = '';
        const milestones = [3, 6, 12, 18, 24];
        for (const m of milestones) {
          const totalNabung = dananow + (nabung * m);
          const pctTarget = Math.min(100, (totalNabung / target) * 100);
          const tercapai = totalNabung >= target;
          html += `<tr${tercapai ? ' class="active"' : ''}><td>Bulan ${m}</td><td class="right">${HC.fmt(totalNabung)}</td><td class="right" style="font-weight:700;color:${tercapai ? 'var(--green-dark)' : 'var(--text-soft)'}">${pctTarget.toFixed(1)}%${tercapai ? ' ✅' : ''}</td></tr>`;
        }
        $('roadmapBody').innerHTML = html;

        lastCalc = { statusLabel, pekerjaanLabel, pengeluaran, dananow, nabung, multiplier, target, kurang, progress, bulanTercapai };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Dana darurat berhasil dihitung!');
      }

      function reset() {
        els.status.value = 'single'; els.pekerjaan.value = 'karyawan';
        els.pengeluaran.value = '5.000.000'; els.dananow.value = '0'; els.nabung.value = '1.000.000';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.progress >= 100
          ? `🎉 Selamat! Dana darurat sudah ${c.progress.toFixed(0)}% tercapai. Saatnya mulai investasi untuk tujuan jangka panjang.`
          : c.progress >= 50
          ? `Progress ${c.progress.toFixed(0)}% — sudah setengah jalan! Pertahankan disiplin nabung Rp ${HC.fmt(c.nabung)}/bulan.`
          : `Baru ${c.progress.toFixed(0)}% tercapai. Estimasi ${c.bulanTercapai} bulan lagi. Jangan ditarget jangka pendek, fokus konsistensi.`;

        return HC.buildReportCard({
          title: '🛡️ Dana Darurat Plan',
          color: '#F59E0B', color2: '#D97706',
          heroLabel: 'Target Dana Darurat',
          heroValue: HC.fmt(c.target),
          heroSubtext: `${c.multiplier}× pengeluaran · ${c.statusLabel}, ${c.pekerjaanLabel}`,
          inputs: [
            { label: '👤 Status', value: c.statusLabel },
            { label: '💼 Pekerjaan', value: c.pekerjaanLabel },
            { label: '💸 Pengeluaran/bln', value: HC.fmt(c.pengeluaran) },
            { label: '💰 Nabung/bln', value: HC.fmt(c.nabung) },
          ],
          results: [
            { label: 'Target Total', value: HC.fmt(c.target), highlight: true },
            { label: 'Sudah Terkumpul', value: HC.fmt(c.dananow) },
            { label: 'Masih Kurang', value: HC.fmt(c.kurang) },
            { label: 'Progress', value: c.progress.toFixed(1) + '%' },
            { label: 'Estimasi Tercapai', value: c.bulanTercapai > 0 ? c.bulanTercapai + ' bulan' : 'Tercapai ✅', highlight: true },
          ],
          insight, slug: 'dana-darurat',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🛡️ *Dana Darurat - HitungCerdas*\n\nProfil: ${c.statusLabel}, ${c.pekerjaanLabel}\nPengeluaran: ${HC.fmt(c.pengeluaran)}/bln\nMultiplier: ${c.multiplier}× pengeluaran\n\n🎯 *Target: ${HC.fmt(c.target)}*\n💰 Sudah terkumpul: ${HC.fmt(c.dananow)}\n📊 Progress: ${c.progress.toFixed(1)}%\n⏱️ Estimasi: ${c.bulanTercapai} bulan dengan nabung ${HC.fmt(c.nabung)}/bln\n\nHitung di: https://hitungcerdas.net/kalkulator/dana-darurat`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'dana-darurat-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'dana-darurat'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 5;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function readData(){
        var targetTxt=($('target')||{}).textContent||'Rp 0';
        var terkumpulTxt=($('terkumpul')||{}).textContent||'Rp 0';
        var kurangTxt=($('kurang')||{}).textContent||'Rp 0';
        var prog=parseFloat(String(($('progress')||{}).textContent||'').replace(',','.')); if(!isFinite(prog)) prog=null;
        var estimasi=($('estimasi')||{}).textContent||''; var mult=($('multiplier')||{}).textContent||'';
        return { targetTxt:targetTxt, targetNum:num(targetTxt), terkumpulTxt:terkumpulTxt, terkumpulNum:num(terkumpulTxt),
          kurangTxt:kurangTxt, prog:prog, estimasi:estimasi, mult:mult,
          status:selText('status'), pekerjaan:selText('pekerjaan'),
          pengeluaran:($('pengeluaran')||{}).value||'', dananow:($('dananow')||{}).value||'', nabung:($('nabung')||{}).value||'' };
      }

      function renderGround(){
        var d=readData();
        var ctx='<div class="aic-ctx"><i class="ti ti-shield-half"></i> Dana Darurat \u00b7 Target <b>'+esc(d.targetTxt)+'</b></div>';
        if(!d.targetNum){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat progres menuju target.</div>'; return; }
        var prog=d.prog!=null?d.prog:(d.terkumpulNum/d.targetNum*100); prog=Math.max(0,Math.min(100,prog));
        var rest=Math.max(0,100-prog); var done=prog>=100;
        var vc=done?'good':(prog>=50?'info':'warn');
        var vi=done?'ti-circle-check':'ti-target';
        var vt=done?'Target tercapai \u2014 dana daruratmu sudah aman':('Baru '+prog.toFixed(0)+'%'+(d.estimasi?(' \u2014 estimasi tercapai '+esc(d.estimasi)):''));
        ground.innerHTML=ctx
          +'<div class="aic-stack"><div class="seg s-green" style="width:'+prog.toFixed(1)+'%"><span class="seg-lbl">'+prog.toFixed(0)+'%</span></div>'+(rest>0?('<div class="seg s-grey" style="width:'+rest.toFixed(1)+'%"><span class="seg-lbl">Sisa</span></div>'):'')+'</div>'
          +'<div class="aic-legend"><span><span class="dot" style="background:#10B981"></span>Terkumpul: <b>'+esc(d.terkumpulTxt)+'</b></span><span><span class="dot" style="background:#E2E8F0"></span>Masih kurang: <b>'+esc(d.kurangTxt)+'</b></span></div>'
          +'<div class="aic-verdict '+vc+'"><i class="ti '+vi+'"></i> '+vt+'</div>';
      }

      function buildContext(){
        var d=readData();
        var prog=d.prog!=null?d.prog:(d.targetNum?d.terkumpulNum/d.targetNum*100:null);
        var p=[
          'Kalkulator: Dana Darurat (emergency fund).',
          d.status?('Status: '+d.status+'.'):'',
          d.pekerjaan?('Jenis pekerjaan: '+d.pekerjaan+'.'):'',
          d.pengeluaran?('Pengeluaran per bulan: Rp '+d.pengeluaran+'.'):'',
          d.mult?('Target ideal: '+d.mult+'.'):'',
          'Target dana darurat: '+d.targetTxt+'.',
          'Sudah terkumpul: '+d.terkumpulTxt+'. Masih kurang: '+d.kurangTxt+'.',
          (prog!=null?('Progress: '+prog.toFixed(1)+'%.'):''),
          (d.nabung && d.nabung!=='0')?('Rencana nabung per bulan: Rp '+d.nabung+'.'):'',
          d.estimasi?('Estimasi target tercapai: '+d.estimasi+'.'):'',
          'Acuan: dana darurat ideal 3-6x pengeluaran bulanan (lajang 3-6x, berkeluarga 6-12x, penghasilan tidak tetap lebih besar). Simpan di instrumen likuid & aman: tabungan, deposito, atau reksadana pasar uang.'
        ];
        return p.filter(Boolean).join('\n');
      }

      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsg('ai',data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Dana daruratku udah cukup belum?','Gimana cara cepat capai target?','Sebaiknya simpan di mana?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
