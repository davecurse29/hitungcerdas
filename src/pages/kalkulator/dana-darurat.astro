---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('dana-darurat')!;
const related = getRelatedCalculators('dana-darurat', 3);

const faqs = [
  { question: 'Apakah dana darurat harus di rekening terpisah?', answer: 'Sangat dianjurkan. Pisahkan dari rekening operasional harian agar tidak tergoda dipakai. Bisa pakai rekening tabungan biasa, e-wallet (DANA, GoPay), atau rekening bank digital (Jenius, Blu, SeaBank) yang punya bunga 2-5% dan likuid 24 jam.' },
  { question: 'Boleh investasi dulu sebelum dana darurat cukup?', answer: 'TIDAK. Dana darurat adalah pondasi keuangan. Tanpa dana darurat, ketika krisis datang kamu akan jual aset investasi dalam keadaan rugi atau berutang. Selesaikan dana darurat dulu (min 3 bulan), baru mulai investasi.' },
  { question: 'Kalau punya asuransi, dana darurat masih perlu?', answer: 'Tetap perlu. Asuransi cuma cover hal spesifik (kesehatan, jiwa, mobil), sementara dana darurat menutupi <strong>semua</strong> jenis darurat: PHK, kerusakan rumah mendadak, biaya keluarga sakit, atau kebutuhan tak terduga lainnya yang tidak ditanggung asuransi.' },
  { question: 'Dana darurat untuk karyawan sama dengan freelancer?', answer: 'Beda. Karyawan tetap = 3-6× pengeluaran cukup (penghasilan stabil). Freelancer/wirausaha = 9-12× pengeluaran (penghasilan fluktuatif, risiko kehilangan klien tinggi). Yang punya tanggungan juga butuh lebih besar.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#F59E0B;--cat-color2:#D97706">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FEF3C7;color:#92400E"><i class="ti ti-shield-check"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <path d="M100 40L160 60V100C160 135 130 160 100 170C70 160 40 135 40 100V60L100 40Z" fill="#FFF" stroke="#FBBF24" stroke-width="3" stroke-linejoin="round"/>
            <circle cx="100" cy="100" r="22" fill="none" stroke="#D97706" stroke-width="3"/>
            <text x="100" y="107" text-anchor="middle" font-size="16" font-weight="900" fill="#D97706" font-family="Inter">Rp</text>
            <path d="M75 130L90 115L100 125L125 100" stroke="#059669" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#F59E0B 0%,#D97706 100%)"><i class="ti ti-shield-check"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Dana Darurat</h2><p class="calc-card-sub">Hitung target ideal sesuai status, pekerjaan, & tanggungan</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="field">
              <label>Status Pernikahan</label>
              <select id="status">
                <option value="single">Single / Belum Menikah</option>
                <option value="married">Menikah, Belum Ada Anak</option>
                <option value="family">Menikah, Ada Anak / Tanggungan</option>
              </select>
            </div>

            <div class="field">
              <label>Jenis Pekerjaan</label>
              <select id="pekerjaan">
                <option value="karyawan">Karyawan Tetap</option>
                <option value="kontrak">Karyawan Kontrak</option>
                <option value="freelance">Freelance / Pekerja Lepas</option>
                <option value="wirausaha">Wirausaha / UMKM</option>
              </select>
            </div>

            <div class="field"><label>Pengeluaran Rutin per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="pengeluaran" class="has-prefix" value="5.000.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Total semua: sewa, makan, transport, listrik, cicilan, dll</p>
            </div>

            <div class="field"><label>Dana Darurat Saat Ini <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="dananow" class="has-prefix" value="0" inputmode="numeric" /></div>
            </div>

            <div class="field"><label>Kemampuan Nabung per Bulan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="nabung" class="has-prefix" value="1.000.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Maksimal 20-30% dari pengeluaran rutin</p>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-shield-check result-placeholder-icon"></i>
              <div class="result-placeholder-title">Target Dana Darurat akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi profil & pengeluaran, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Target Dana Darurat Ideal</div>
                <div class="result-value" id="target">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="multiplier">0× pengeluaran bulanan</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Sudah Terkumpul</div><div class="result-item-value" id="terkumpul">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Masih Kurang</div><div class="result-item-value result-warn" id="kurang">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Progress Tercapai</div><div class="result-item-value" id="progress">0%</div></div>
                <div class="result-item"><div class="result-item-label">Estimasi Tercapai</div><div class="result-item-value" id="estimasi">0 bulan</div></div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-bar"></i>&nbsp; Roadmap Tabungan Bulanan</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Bulan</th><th class="right">Total Nabung</th><th class="right">% Target</th></tr></thead>
                    <tbody id="roadmapBody"></tbody>
                  </table>
                </div>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-bulb"></i>&nbsp; Di Mana Simpan Dana Darurat?</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <table class="compare-table">
                    <thead><tr><th>Instrumen</th><th class="right">Return/Thn</th><th>Likuiditas</th></tr></thead>
                    <tbody>
                      <tr><td>Tabungan Bank Konvensional</td><td class="right">~2%</td><td>Instan ✅</td></tr>
                      <tr class="active"><td>Bank Digital (Jenius/Blu/SeaBank)</td><td class="right">~5%</td><td>Instan ✅</td></tr>
                      <tr><td>Deposito 1 Bulan</td><td class="right">~5-6%</td><td>30 hari ⚠️</td></tr>
                      <tr><td>Reksa Dana Pasar Uang (RDPU)</td><td class="right">~5-7%</td><td>1-2 hari ✅</td></tr>
                      <tr><td>E-Wallet (DANA/GoPay)</td><td class="right">~3-4%</td><td>Instan ✅</td></tr>
                    </tbody>
                  </table>
                  <p style="font-size:11.5px;color:var(--text-mute);margin-top:8px;line-height:1.5">💡 <strong>Rekomendasi:</strong> Split 50% di bank digital (instan), 50% di RDPU (return lebih tinggi). Hindari saham, properti, crypto — tidak likuid saat darurat!</p>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Apa itu Dana Darurat?</h2>
      <p>Dana darurat adalah uang yang sengaja disisihkan untuk menghadapi kejadian tak terduga — PHK, sakit, kecelakaan, atau kerusakan mendadak. Tujuannya agar kamu <strong>tidak perlu berutang</strong> atau menjual aset investasi saat krisis datang.</p>

      <h3>Berapa Idealnya Multiplier Dana Darurat?</h3>
      <table class="compare-table" style="margin:14px 0">
        <thead><tr><th>Kondisi</th><th class="right">Multiplier</th><th class="right">Contoh (Pengeluaran Rp 5jt)</th></tr></thead>
        <tbody>
          <tr><td>Single, karyawan tetap</td><td class="right"><strong>3×</strong> pengeluaran</td><td class="right">Rp 15 juta</td></tr>
          <tr><td>Menikah, karyawan tetap</td><td class="right"><strong>6×</strong> pengeluaran</td><td class="right">Rp 30 juta</td></tr>
          <tr class="active"><td>Ada tanggungan / freelance</td><td class="right"><strong>9-12×</strong> pengeluaran</td><td class="right">Rp 45-60 juta</td></tr>
        </tbody>
      </table>

      <h3>Kesalahan Umum Dana Darurat</h3>
      <ul>
        <li><strong>Dipakai untuk konsumtif</strong> — bukan tabungan liburan atau beli gadget.</li>
        <li><strong>Ditaruh di instrumen tidak likuid</strong> — saham/properti tidak bisa dicairkan cepat.</li>
        <li><strong>Dicampur rekening harian</strong> — pisahkan agar tidak tergoda dipakai.</li>
        <li><strong>Tidak pernah di-top up</strong> — setelah dipakai, segera isi kembali.</li>
      </ul>

      <div class="cta-box">
        <h3>Coba Sekarang</h3>
        <p>Isi status, pekerjaan, dan pengeluaran kamu. Klik "Hitung Sekarang" untuk dapat target dana darurat ideal plus roadmap nabung bulanan.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar Dana Darurat" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
</Layout>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(() => ready(fn), 100); }
    ready(() => {
      const $ = id => document.getElementById(id);
      const els = { status: $('status'), pekerjaan: $('pekerjaan'), pengeluaran: $('pengeluaran'), dananow: $('dananow'), nabung: $('nabung') };
      [els.pengeluaran, els.dananow, els.nabung].forEach(el => el.addEventListener('input', HC.fmtInput));
      document.querySelectorAll('.adv-toggle').forEach(t => t.addEventListener('click', () => t.parentElement.classList.toggle('open')));

      function getMultiplier(status, pekerjaan) {
        const base = { single: 3, married: 6, family: 9 }[status];
        const extra = { karyawan: 0, kontrak: 1, freelance: 3, wirausaha: 3 }[pekerjaan];
        return Math.min(12, base + extra);
      }

      let lastCalc = null;

      function hitung() {
        const status = els.status.value;
        const pekerjaan = els.pekerjaan.value;
        const pengeluaran = HC.parseRp(els.pengeluaran.value);
        const dananow = HC.parseRp(els.dananow.value);
        const nabung = HC.parseRp(els.nabung.value);

        if (pengeluaran === 0) { HC.toast('Masukkan pengeluaran bulanan dulu', 'error'); return; }
        if (nabung === 0) { HC.toast('Masukkan kemampuan nabung', 'error'); return; }

        const multiplier = getMultiplier(status, pekerjaan);
        const target = pengeluaran * multiplier;
        const kurang = Math.max(0, target - dananow);
        const progress = target > 0 ? Math.min(100, (dananow / target) * 100) : 0;
        const bulanTercapai = nabung > 0 ? Math.ceil(kurang / nabung) : 0;

        const statusLabel = { single: 'Single', married: 'Menikah', family: 'Menikah + Tanggungan' }[status];
        const pekerjaanLabel = { karyawan: 'Karyawan Tetap', kontrak: 'Karyawan Kontrak', freelance: 'Freelance', wirausaha: 'Wirausaha' }[pekerjaan];

        $('target').textContent = HC.fmt(target);
        $('multiplier').textContent = `${multiplier}× pengeluaran bulanan`;
        $('terkumpul').textContent = HC.fmt(dananow);
        $('kurang').textContent = HC.fmt(kurang);
        $('progress').textContent = progress.toFixed(1) + '%';
        $('estimasi').textContent = bulanTercapai > 0 ? `${bulanTercapai} bulan (${(bulanTercapai/12).toFixed(1)} tahun)` : '✅ Sudah tercapai!';

        let html = '';
        const milestones = [3, 6, 12, 18, 24];
        for (const m of milestones) {
          const totalNabung = dananow + (nabung * m);
          const pctTarget = Math.min(100, (totalNabung / target) * 100);
          const tercapai = totalNabung >= target;
          html += `<tr${tercapai ? ' class="active"' : ''}><td>Bulan ${m}</td><td class="right">${HC.fmt(totalNabung)}</td><td class="right" style="font-weight:700;color:${tercapai ? 'var(--green-dark)' : 'var(--text-soft)'}">${pctTarget.toFixed(1)}%${tercapai ? ' ✅' : ''}</td></tr>`;
        }
        $('roadmapBody').innerHTML = html;

        lastCalc = { statusLabel, pekerjaanLabel, pengeluaran, dananow, nabung, multiplier, target, kurang, progress, bulanTercapai };
        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('Dana darurat berhasil dihitung!');
      }

      function reset() {
        els.status.value = 'single'; els.pekerjaan.value = 'karyawan';
        els.pengeluaran.value = '5.000.000'; els.dananow.value = '0'; els.nabung.value = '1.000.000';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        const c = lastCalc;
        const insight = c.progress >= 100
          ? `🎉 Selamat! Dana darurat sudah ${c.progress.toFixed(0)}% tercapai. Saatnya mulai investasi untuk tujuan jangka panjang.`
          : c.progress >= 50
          ? `Progress ${c.progress.toFixed(0)}% — sudah setengah jalan! Pertahankan disiplin nabung Rp ${HC.fmt(c.nabung)}/bulan.`
          : `Baru ${c.progress.toFixed(0)}% tercapai. Estimasi ${c.bulanTercapai} bulan lagi. Jangan ditarget jangka pendek, fokus konsistensi.`;

        return HC.buildReportCard({
          title: '🛡️ Dana Darurat Plan',
          color: '#F59E0B', color2: '#D97706',
          heroLabel: 'Target Dana Darurat',
          heroValue: HC.fmt(c.target),
          heroSubtext: `${c.multiplier}× pengeluaran · ${c.statusLabel}, ${c.pekerjaanLabel}`,
          inputs: [
            { label: '👤 Status', value: c.statusLabel },
            { label: '💼 Pekerjaan', value: c.pekerjaanLabel },
            { label: '💸 Pengeluaran/bln', value: HC.fmt(c.pengeluaran) },
            { label: '💰 Nabung/bln', value: HC.fmt(c.nabung) },
          ],
          results: [
            { label: 'Target Total', value: HC.fmt(c.target), highlight: true },
            { label: 'Sudah Terkumpul', value: HC.fmt(c.dananow) },
            { label: 'Masih Kurang', value: HC.fmt(c.kurang) },
            { label: 'Progress', value: c.progress.toFixed(1) + '%' },
            { label: 'Estimasi Tercapai', value: c.bulanTercapai > 0 ? c.bulanTercapai + ' bulan' : 'Tercapai ✅', highlight: true },
          ],
          insight, slug: 'dana-darurat',
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        const c = lastCalc;
        return `🛡️ *Dana Darurat - HitungCerdas*\n\nProfil: ${c.statusLabel}, ${c.pekerjaanLabel}\nPengeluaran: ${HC.fmt(c.pengeluaran)}/bln\nMultiplier: ${c.multiplier}× pengeluaran\n\n🎯 *Target: ${HC.fmt(c.target)}*\n💰 Sudah terkumpul: ${HC.fmt(c.dananow)}\n📊 Progress: ${c.progress.toFixed(1)}%\n⏱️ Estimasi: ${c.bulanTercapai} bulan dengan nabung ${HC.fmt(c.nabung)}/bln\n\nHitung di: https://hitungcerdas.net/kalkulator/dana-darurat`;
      }

      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'dana-darurat-' + Date.now()); });
      $('exportWa').addEventListener('click', () => { const c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'dana-darurat'); });
      $('exportPdf').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', () => { if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
    });
  })();
</script>
