---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = "Kalkulator Dana Darurat - Berapa yang Kamu Butuhkan?";
const description = "Hitung target dana darurat idealmu berdasarkan status, pekerjaan, dan tanggungan. Lengkap dengan timeline, tips menabung, dan strategi parkir dana darurat.";
const breadcrumbs = [
  { label: "Beranda", href: "/" },
  { label: "Kalkulator", href: "/#kalkulator" },
  { label: "Dana Darurat" }
];
---

<Layout title={title} description={description} catColor="#F59E0B" catColor2="#D97706">
  <Breadcrumb items={breadcrumbs} />

  <main class="calc-page">
    <!-- HERO SECTION -->
    <section class="calc-hero" style="--cat-color:#F59E0B;--cat-color2:#D97706">
      <div class="hero-inner">
        <div class="hero-badge">
          <i class="ti ti-shield-check"></i>
          <span>Kalkulator Finansial</span>
        </div>
        <h1>Kalkulator Dana Darurat</h1>
        <p class="hero-sub">Hitung berapa dana darurat ideal untuk kondisimu — dan kapan bisa tercapai. Gratis, akurat, 100% Indonesia.</p>
        <div class="trust-row">
          <span class="trust-item"><i class="ti ti-check"></i> Sesuai standar OJK</span>
          <span class="trust-item"><i class="ti ti-check"></i> 100% Format Indonesia</span>
          <span class="trust-item"><i class="ti ti-check"></i> Gratis Selamanya</span>
        </div>
      </div>
    </section>

    <div class="calc-container">
      <!-- PROGRESS BAR -->
      <div class="wizard-progress" id="wizardProgress">
        <div class="progress-steps">
          <div class="step active" id="stepDot1">
            <div class="step-dot">1</div>
            <span>Profil</span>
          </div>
          <div class="step-line"></div>
          <div class="step" id="stepDot2">
            <div class="step-dot">2</div>
            <span>Keuangan</span>
          </div>
          <div class="step-line"></div>
          <div class="step" id="stepDot3">
            <div class="step-dot">3</div>
            <span>Hasil</span>
          </div>
        </div>
        <p class="progress-hint" id="progressHint">Langkah 1 dari 2 — Isi profil kamu dulu</p>
      </div>

      <!-- STEP 1: PROFIL -->
      <div class="calc-card" id="step1">
        <h2 class="card-title"><i class="ti ti-user"></i> Profil Kamu</h2>

        <div class="form-group">
          <label for="statusPernikahan">Status Pernikahan</label>
          <div class="option-grid">
            <button class="opt-btn active" data-group="status" data-val="single" onclick="setOption(this,'status')">
              <i class="ti ti-user"></i> Single
            </button>
            <button class="opt-btn" data-group="status" data-val="menikah" onclick="setOption(this,'status')">
              <i class="ti ti-heart"></i> Menikah
            </button>
            <button class="opt-btn" data-group="status" data-val="tanggungan" onclick="setOption(this,'status')">
              <i class="ti ti-users"></i> Ada Tanggungan
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="jenisKerja">Jenis Pekerjaan</label>
          <div class="option-grid">
            <button class="opt-btn active" data-group="kerja" data-val="tetap" onclick="setOption(this,'kerja')">
              <i class="ti ti-building"></i> Karyawan Tetap
            </button>
            <button class="opt-btn" data-group="kerja" data-val="freelance" onclick="setOption(this,'kerja')">
              <i class="ti ti-device-laptop"></i> Freelance
            </button>
            <button class="opt-btn" data-group="kerja" data-val="wirausaha" onclick="setOption(this,'kerja')">
              <i class="ti ti-briefcase"></i> Wirausaha
            </button>
          </div>
          <p class="field-hint" id="kerjaHint">Karyawan tetap = penghasilan stabil = kebutuhan buffer lebih kecil</p>
        </div>

        <div class="form-group" id="tanggunganGroup" style="display:none">
          <label for="jumlahTanggungan">Jumlah Tanggungan</label>
          <div class="slider-wrap">
            <input type="range" id="jumlahTanggungan" min="1" max="5" step="1" value="2" oninput="updateSlider('jumlahTanggungan','tanggunganVal',null,null,' orang')">
            <div class="slider-info">
              <span>1 orang</span>
              <strong id="tanggunganVal">2 orang</strong>
              <span>5 orang</span>
            </div>
          </div>
        </div>

        <button class="btn-primary" onclick="goStep(2)">
          Lanjut — Isi Data Keuangan <i class="ti ti-arrow-right"></i>
        </button>
      </div>

      <!-- STEP 2: KEUANGAN -->
      <div class="calc-card hidden" id="step2">
        <h2 class="card-title"><i class="ti ti-wallet"></i> Data Keuangan</h2>

        <div class="form-group">
          <label for="pengeluaran">Pengeluaran Bulanan <span class="required">*</span></label>
          <div class="input-prefix">
            <span>Rp</span>
            <input type="text" id="pengeluaran" placeholder="Contoh: 5.000.000" inputmode="numeric" oninput="formatRupiahInput(this)" />
          </div>
          <p class="field-hint">Semua pengeluaran rutin: makan, transport, tagihan, cicilan, dll</p>
        </div>

        <div class="form-group">
          <label for="danaSaatIni">Dana Darurat yang Sudah Punya</label>
          <div class="input-prefix">
            <span>Rp</span>
            <input type="text" id="danaSaatIni" placeholder="0 kalau belum ada" inputmode="numeric" oninput="formatRupiahInput(this)" />
          </div>
          <p class="field-hint">Tabungan yang memang dikhususkan untuk darurat</p>
        </div>

        <div class="form-group">
          <label for="kemampuanNabung">Kemampuan Menabung per Bulan</label>
          <div class="input-prefix">
            <span>Rp</span>
            <input type="text" id="kemampuanNabung" placeholder="Contoh: 500.000" inputmode="numeric" oninput="formatRupiahInput(this)" />
          </div>
          <p class="field-hint">Berapa yang bisa kamu sisihkan khusus untuk dana darurat</p>
        </div>

        <div class="btn-row">
          <button class="btn-secondary" onclick="goStep(1)">
            <i class="ti ti-arrow-left"></i> Kembali
          </button>
          <button class="btn-primary" onclick="hitungDanaDarurat()">
            <i class="ti ti-shield-check"></i> Hitung Dana Darurat
          </button>
        </div>
      </div>

      <!-- STEP 3: HASIL -->
      <div class="hidden" id="step3">

        <!-- RESULT HERO -->
        <div class="result-hero" style="--cat-color:#F59E0B">
          <div class="result-hero-inner">
            <div class="result-ring-wrap">
              <svg class="progress-ring" width="160" height="160" viewBox="0 0 160 160">
                <circle cx="80" cy="80" r="68" fill="none" stroke="rgba(245,158,11,0.15)" stroke-width="12"/>
                <circle id="progressRingCircle" cx="80" cy="80" r="68" fill="none" stroke="#F59E0B" stroke-width="12" stroke-linecap="round" stroke-dasharray="427" stroke-dashoffset="427" transform="rotate(-90 80 80)" style="transition:stroke-dashoffset 1.2s ease"/>
              </svg>
              <div class="ring-center">
                <span class="ring-pct" id="ringPct">0%</span>
                <span class="ring-label">tercapai</span>
              </div>
            </div>
            <div class="result-hero-text">
              <div class="result-tag" id="resultTag">🛡️ Dana Darurat Ideal</div>
              <div class="result-big" id="resultTarget">Rp 0</div>
              <div class="result-sub" id="resultMultiplier">= 6× pengeluaran bulanan</div>
              <div id="easterEgg" class="easter-egg hidden"></div>
            </div>
          </div>
        </div>

        <!-- AD SLOT 1 -->
        <AdSlot position="after-result" />

        <!-- GAP ANALYSIS -->
        <div class="calc-card" id="gapCard">
          <h3 class="card-title"><i class="ti ti-chart-bar"></i> Analisis Gap</h3>
          <div class="gap-table">
            <div class="gap-row">
              <span class="gap-label">🎯 Target Dana Darurat</span>
              <span class="gap-value" id="gapTarget">—</span>
            </div>
            <div class="gap-row success">
              <span class="gap-label">✅ Sudah Terkumpul</span>
              <span class="gap-value" id="gapSudah">—</span>
            </div>
            <div class="gap-row warning" id="gapKurangRow">
              <span class="gap-label">📊 Masih Kurang</span>
              <span class="gap-value" id="gapKurang">—</span>
            </div>
            <div class="gap-row highlight" id="gapTimelineRow">
              <span class="gap-label">⏰ Tercapai dalam</span>
              <span class="gap-value" id="gapTimeline">—</span>
            </div>
          </div>

          <!-- RELATABLE CONVERSION -->
          <div class="relatable-box" id="relatableBox">
            <div class="relatable-title">💡 Dana darurat ini setara dengan...</div>
            <div class="relatable-grid" id="relatableGrid"></div>
          </div>
        </div>

        <!-- CHART -->
        <div class="calc-card">
          <h3 class="card-title"><i class="ti ti-trending-up"></i> Proyeksi Tabungan</h3>
          <div class="chart-wrap">
            <canvas id="growthChart" height="280"></canvas>
          </div>
          <p class="chart-hint">Garis hijau = tabungan kamu tumbuh. Garis putus = target dana darurat.</p>
        </div>

        <!-- STRATEGY -->
        <div class="calc-card">
          <h3 class="card-title"><i class="ti ti-bulb"></i> Parkir Dana Darurat di Mana?</h3>
          <div class="strategy-grid">
            <div class="strategy-card best">
              <div class="strategy-badge">⭐ TERBAIK</div>
              <h4>Reksa Dana Pasar Uang</h4>
              <div class="strategy-return">~4-5% / tahun</div>
              <p>Likuid (bisa cairkan kapan saja), return lebih tinggi dari tabungan biasa, aman OJK.</p>
            </div>
            <div class="strategy-card">
              <h4>Deposito</h4>
              <div class="strategy-return">~3-4% / tahun</div>
              <p>Aman, dijamin LPS, tapi ada jangka waktu (kurang fleksibel).</p>
            </div>
            <div class="strategy-card">
              <h4>Tabungan Biasa</h4>
              <div class="strategy-return">~0.5-2% / tahun</div>
              <p>Paling likuid, tapi return rendah & godaan pakai lebih tinggi.</p>
            </div>
          </div>
        </div>

        <!-- AD SLOT 2 -->
        <AdSlot position="mid-content" />

        <!-- RECOMMENDATION ENGINE -->
        <div class="calc-card rec-card">
          <h3 class="card-title"><i class="ti ti-compass"></i> Langkah Selanjutnya</h3>
          <div class="rec-grid">
            <a href="/kalkulator/kta" class="rec-item urgent">
              <div class="rec-icon"><i class="ti ti-cash"></i></div>
              <div class="rec-text">
                <strong>Butuh Dana Mendesak Sekarang?</strong>
                <p>Dana darurat belum cukup tapi ada kebutuhan urgent? Pahami dulu simulasi KTA sebelum memutuskan.</p>
                <span class="rec-cta">Simulasi KTA →</span>
              </div>
            </a>
            <a href="/kalkulator/investasi" class="rec-item">
              <div class="rec-icon"><i class="ti ti-trending-up"></i></div>
              <div class="rec-text">
                <strong>Dana Darurat Sudah Cukup?</strong>
                <p>Saatnya investasikan sisa penghasilan agar uangmu bekerja lebih keras.</p>
                <span class="rec-cta">Hitung Investasi →</span>
              </div>
            </a>
            <a href="/kalkulator/gaji-bersih" class="rec-item">
              <div class="rec-icon"><i class="ti ti-wallet"></i></div>
              <div class="rec-text">
                <strong>Mau Tahu Gaji Bersih?</strong>
                <p>Hitung take-home pay setelah BPJS dan pajak — bantu atur budget nabung.</p>
                <span class="rec-cta">Cek Gaji Bersih →</span>
              </div>
            </a>
          </div>
        </div>

        <!-- EXPORT -->
        <div class="calc-card export-card">
          <h3 class="card-title"><i class="ti ti-share"></i> Simpan & Bagikan</h3>
          <div class="export-grid">
            <button class="export-btn" onclick="exportPNG()">
              <i class="ti ti-download"></i> Simpan PNG
            </button>
            <button class="export-btn wa" onclick="shareWA()">
              <i class="ti ti-brand-whatsapp"></i> Share WhatsApp
            </button>
            <button class="export-btn" onclick="copyResult()">
              <i class="ti ti-copy"></i> Copy Hasil
            </button>
          </div>
        </div>

        <!-- HITUNG ULANG -->
        <div style="text-align:center;margin:1rem 0">
          <button class="btn-secondary" onclick="resetCalc()">
            <i class="ti ti-refresh"></i> Hitung Ulang
          </button>
        </div>

        <!-- AD SLOT 3 -->
        <AdSlot position="before-footer" />
      </div>

      <!-- EDUCATIONAL CONTENT -->
      <div class="calc-card edu-card">
        <h2><i class="ti ti-book"></i> Panduan Lengkap Dana Darurat</h2>

        <h3>Apa itu Dana Darurat?</h3>
        <p>Dana darurat adalah uang yang sengaja disisihkan untuk menghadapi kejadian tak terduga — seperti PHK, sakit, kecelakaan, atau kerusakan mendadak. Tujuannya agar kamu tidak perlu berutang atau menjual aset investasi saat krisis datang.</p>

        <h3>Berapa Idealnya Dana Darurat?</h3>
        <div class="edu-table">
          <div class="edu-row header">
            <span>Kondisi</span><span>Multiplier</span><span>Contoh (Pengeluaran Rp 5jt)</span>
          </div>
          <div class="edu-row">
            <span>Single, karyawan tetap</span><span>3× pengeluaran</span><span>Rp 15 juta</span>
          </div>
          <div class="edu-row">
            <span>Menikah, karyawan tetap</span><span>6× pengeluaran</span><span>Rp 30 juta</span>
          </div>
          <div class="edu-row">
            <span>Ada tanggungan / freelance</span><span>9-12× pengeluaran</span><span>Rp 45-60 juta</span>
          </div>
        </div>

        <h3>Kesalahan Umum Dana Darurat</h3>
        <ul class="edu-list">
          <li><strong>Dipakai untuk kebutuhan konsumtif</strong> — Dana darurat bukan tabungan liburan atau beli gadget.</li>
          <li><strong>Ditaruh di instrumen tidak likuid</strong> — Saham atau properti tidak bisa dicairkan cepat saat darurat.</li>
          <li><strong>Dicampur dengan rekening harian</strong> — Pisahkan rekening dana darurat agar tidak tergoda pakai.</li>
          <li><strong>Tidak pernah di-top up</strong> — Setelah dipakai, segera isi kembali.</li>
        </ul>

        <h3>FAQ Dana Darurat</h3>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
              Apakah dana darurat harus di rekening terpisah?
              <i class="ti ti-chevron-down"></i>
            </button>
            <div class="faq-a">
              <p>Sangat disarankan. Rekening terpisah mencegah godaan untuk memakainya sehari-hari dan memudahkan tracking progress. Pilih bank yang berbeda dari rekening utama agar tidak mudah transfer.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
              Boleh investasi dulu sebelum dana darurat cukup?
              <i class="ti ti-chevron-down"></i>
            </button>
            <div class="faq-a">
              <p>Tidak disarankan. Dana darurat adalah fondasi keuangan. Tanpanya, saat krisis datang kamu terpaksa jual investasi di waktu yang tidak tepat (mungkin rugi). Selesaikan dana darurat dulu, baru investasi.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
              Kalau punya asuransi, dana darurat masih perlu?
              <i class="ti ti-chevron-down"></i>
            </button>
            <div class="faq-a">
              <p>Tetap perlu. Asuransi menanggung kejadian spesifik dan ada proses klaim yang butuh waktu. Dana darurat untuk kebutuhan kas segera — misal bayar tagihan saat menunggu klaim cair.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
              Dana darurat untuk karyawan sama dengan freelancer?
              <i class="ti ti-chevron-down"></i>
            </button>
            <div class="faq-a">
              <p>Berbeda. Freelancer dan wirausaha membutuhkan buffer lebih besar (9-12 bulan) karena penghasilan tidak tetap. Karyawan tetap bisa lebih rendah (3-6 bulan) karena ada kepastian gaji.</p>
            </div>
          </div>
        </div>
      </div>

    </div><!-- end calc-container -->
  </main>
</Layout>

<!-- SCORECARD (hidden, for export) -->
<div id="scorecard" style="position:fixed;left:-9999px;top:0;width:540px;background:#0A2540;padding:40px;border-radius:20px;color:#fff;font-family:'Poppins',sans-serif;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
    <div style="font-size:13px;font-weight:500;color:#2563EB">HitungCerdas.net</div>
    <div style="font-size:11px;background:rgba(245,158,11,0.2);color:#F59E0B;padding:4px 12px;border-radius:99px">🛡️ DANA DARURAT</div>
  </div>
  <div style="font-size:13px;color:#94A3B8;margin-bottom:4px">Target Dana Darurat Ideal</div>
  <div id="scTarget" style="font-size:36px;font-weight:700;color:#fff;margin-bottom:8px;font-family:monospace">Rp 0</div>
  <div id="scMultiplier" style="font-size:13px;color:#F59E0B;margin-bottom:20px"></div>
  <div style="background:rgba(255,255,255,0.05);border-radius:12px;padding:16px;margin-bottom:20px">
    <div id="scProgress" style="font-size:24px;font-weight:700;color:#10B981;margin-bottom:4px">0%</div>
    <div style="font-size:12px;color:#94A3B8">Progress tercapai</div>
  </div>
  <div id="scTimeline" style="font-size:13px;color:#94A3B8;margin-bottom:24px"></div>
  <div style="font-size:12px;color:#64748B">#HitungCerdas #DanaDarurat #FinancialGoals</div>
</div>

<script>
// =====================
// STATE
// =====================
const state = {
  status: 'single',
  kerja: 'tetap',
  tanggungan: 2,
  pengeluaran: 0,
  danaSaatIni: 0,
  kemampuanNabung: 0,
  result: {}
};

// =====================
// OPTION BUTTONS
// =====================
function setOption(btn, group) {
  document.querySelectorAll(`[data-group="${group}"]`).forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  state[group] = btn.dataset.val;

  if (group === 'kerja') {
    const hints = {
      tetap: 'Karyawan tetap = penghasilan stabil = kebutuhan buffer lebih kecil',
      freelance: 'Freelance = penghasilan tidak pasti = butuh buffer lebih besar (+3 bulan)',
      wirausaha: 'Wirausaha = risiko lebih tinggi = butuh buffer ekstra (+3 bulan)'
    };
    document.getElementById('kerjaHint').textContent = hints[btn.dataset.val];
  }
  if (group === 'status') {
    document.getElementById('tanggunganGroup').style.display = btn.dataset.val === 'tanggungan' ? 'block' : 'none';
  }
}

// =====================
// WIZARD NAVIGATION
// =====================
function goStep(n) {
  document.getElementById('step1').classList.toggle('hidden', n !== 1);
  document.getElementById('step2').classList.toggle('hidden', n !== 2);

  ['stepDot1','stepDot2','stepDot3'].forEach((id, i) => {
    document.getElementById(id).classList.toggle('active', i < n);
    document.getElementById(id).classList.toggle('done', i < n-1);
  });

  const hints = ['', 'Langkah 1 dari 2 — Isi profil kamu dulu', 'Langkah 2 dari 2 — Isi data keuangan'];
  document.getElementById('progressHint').textContent = hints[n] || '';
}

// =====================
// FORMAT RUPIAH INPUT
// =====================
function formatRupiahInput(el) {
  let val = el.value.replace(/\D/g, '');
  el.value = val ? parseInt(val).toLocaleString('id-ID') : '';
}

function parseRupiah(str) {
  return parseInt((str || '0').replace(/\D/g, '')) || 0;
}

function fmtRp(n) {
  return 'Rp ' + Math.round(n).toLocaleString('id-ID');
}

function fmtCompact(n) {
  if (n >= 1e9) return 'Rp ' + (n/1e9).toFixed(1) + 'M';
  if (n >= 1e6) return 'Rp ' + (n/1e6).toFixed(1) + 'jt';
  if (n >= 1e3) return 'Rp ' + (n/1e3).toFixed(0) + 'rb';
  return 'Rp ' + n;
}

function updateSlider(id, valId, fmtFn, prefix, suffix) {
  const val = document.getElementById(id).value;
  state.tanggungan = parseInt(val);
  document.getElementById(valId).textContent = (prefix||'') + val + (suffix||'');
}

// =====================
// MAIN CALCULATION
// =====================
function hitungDanaDarurat() {
  const pengeluaran = parseRupiah(document.getElementById('pengeluaran').value);
  const danaSaatIni = parseRupiah(document.getElementById('danaSaatIni').value);
  const kemampuanNabung = parseRupiah(document.getElementById('kemampuanNabung').value);

  if (!pengeluaran) {
    alert('Masukkan pengeluaran bulanan dulu ya!');
    return;
  }

  // Hitung multiplier
  let multiplier = 3;
  if (state.status === 'single') multiplier = 3;
  else if (state.status === 'menikah') multiplier = 6;
  else if (state.status === 'tanggungan') multiplier = 6 + state.tanggungan;

  if (state.kerja === 'freelance') multiplier += 3;
  else if (state.kerja === 'wirausaha') multiplier += 3;
  multiplier = Math.min(12, multiplier);

  const target = pengeluaran * multiplier;
  const gap = Math.max(0, target - danaSaatIni);
  const persen = Math.min(100, Math.round((danaSaatIni / target) * 100));
  const bulanTercapai = kemampuanNabung > 0 ? Math.ceil(gap / kemampuanNabung) : null;

  state.result = { pengeluaran, danaSaatIni, kemampuanNabung, multiplier, target, gap, persen, bulanTercapai };

  renderResult();
  showStep3();
}

// =====================
// RENDER RESULT
// =====================
function renderResult() {
  const r = state.result;

  // Ring animation
  const circumference = 427;
  const offset = circumference - (r.persen / 100) * circumference;
  setTimeout(() => {
    document.getElementById('progressRingCircle').style.strokeDashoffset = offset;
    document.getElementById('ringPct').textContent = r.persen + '%';
  }, 300);

  // Hero
  document.getElementById('resultTarget').textContent = fmtRp(r.target);
  document.getElementById('resultMultiplier').textContent = `= ${r.multiplier}× pengeluaran bulanan (${fmtCompact(r.pengeluaran)})`;

  // Easter egg
  const egg = document.getElementById('easterEgg');
  if (r.persen >= 100) { egg.textContent = '👑 Sultan! Dana darurat kamu sudah aman!'; egg.classList.remove('hidden'); }
  else if (r.persen >= 50) { egg.textContent = '💪 Mantap! Sudah lebih dari setengah jalan!'; egg.classList.remove('hidden'); }
  else if (r.persen === 0) { egg.textContent = '🚀 Mulai dari sekarang, langkah pertama adalah yang terpenting!'; egg.classList.remove('hidden'); }

  // Gap
  document.getElementById('gapTarget').textContent = fmtRp(r.target);
  document.getElementById('gapSudah').textContent = fmtRp(r.danaSaatIni);
  if (r.gap > 0) {
    document.getElementById('gapKurang').textContent = fmtRp(r.gap);
    document.getElementById('gapKurangRow').style.display = '';
  }
  if (r.bulanTercapai) {
    const thn = Math.floor(r.bulanTercapai / 12);
    const bln = r.bulanTercapai % 12;
    let timeStr = r.bulanTercapai + ' bulan';
    if (thn > 0) timeStr = (thn > 0 ? thn + ' tahun ' : '') + (bln > 0 ? bln + ' bulan' : '');
    document.getElementById('gapTimeline').textContent = timeStr + ` (nabung ${fmtCompact(r.kemampuanNabung)}/bln)`;
    document.getElementById('gapTimelineRow').style.display = '';
  } else {
    document.getElementById('gapTimeline').textContent = 'Isi kemampuan nabung untuk lihat timeline';
  }

  // Relatable conversion
  const relatableItems = [
    { icon: '☕', label: 'gelas kopi kekinian', val: Math.round(r.target / 20000) },
    { icon: '🍛', label: 'kali makan warteg', val: Math.round(r.target / 15000) },
    { icon: '⛽', label: 'liter bensin', val: Math.round(r.target / 12000) },
    { icon: '🏍️', label: 'bulan cicilan motor', val: Math.round(r.target / 800000) }
  ];
  document.getElementById('relatableGrid').innerHTML = relatableItems.map(i =>
    `<div class="rel-item"><span class="rel-icon">${i.icon}</span><strong>${i.val.toLocaleString('id-ID')}</strong><span>${i.label}</span></div>`
  ).join('');

  // Chart
  renderGrowthChart();

  // Scorecard
  document.getElementById('scTarget').textContent = fmtRp(r.target);
  document.getElementById('scMultiplier').textContent = `= ${r.multiplier}× pengeluaran bulanan`;
  document.getElementById('scProgress').textContent = r.persen + '%';
  if (r.bulanTercapai) document.getElementById('scTimeline').textContent = `Estimasi tercapai dalam ${r.bulanTercapai} bulan`;
}

function showStep3() {
  document.getElementById('step1').classList.add('hidden');
  document.getElementById('step2').classList.add('hidden');
  document.getElementById('step3').classList.remove('hidden');
  document.getElementById('wizardProgress').style.display = 'none';
  document.getElementById('step3').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// =====================
// GROWTH CHART
// =====================
function renderGrowthChart() {
  const r = state.result;
  const months = r.bulanTercapai ? Math.min(r.bulanTercapai + 6, 60) : 36;
  const labels = [], tabungan = [], targetLine = [];

  for (let m = 0; m <= months; m++) {
    labels.push(m === 0 ? 'Sekarang' : `Bln ${m}`);
    tabungan.push(Math.min(r.danaSaatIni + r.kemampuanNabung * m, r.target * 1.1));
    targetLine.push(r.target);
  }

  const ctx = document.getElementById('growthChart').getContext('2d');
  if (window._growthChart) window._growthChart.destroy();
  window._growthChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'Tabungan Kamu', data: tabungan, borderColor: '#10B981', backgroundColor: 'rgba(16,185,129,0.1)', fill: true, tension: 0.4, pointRadius: 0 },
        { label: 'Target Dana Darurat', data: targetLine, borderColor: '#F59E0B', borderDash: [6,4], pointRadius: 0, borderWidth: 2 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom' }, tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': ' + fmtRp(ctx.parsed.y) } } },
      scales: { y: { ticks: { callback: v => fmtCompact(v) } }, x: { ticks: { maxTicksLimit: 8 } } }
    }
  });
}

// =====================
// EXPORT
// =====================
async function exportPNG() {
  if (!window.html2canvas) {
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
    document.head.appendChild(s);
    await new Promise(r => s.onload = r);
  }
  const card = document.getElementById('scorecard');
  card.style.left = '0'; card.style.top = '0'; card.style.position = 'fixed'; card.style.zIndex = '9999';
  const canvas = await html2canvas(card, { backgroundColor: '#0A2540', scale: 2 });
  card.style.left = '-9999px'; card.style.position = 'fixed';
  const a = document.createElement('a');
  a.download = 'HitungCerdas-DanaDarurat.png';
  a.href = canvas.toDataURL();
  a.click();
}

function shareWA() {
  const r = state.result;
  const msg = `🛡️ Hasil Kalkulator Dana Darurat — HitungCerdas.net

💰 Target: ${fmtRp(r.target)} (${r.multiplier}× pengeluaran)
✅ Sudah punya: ${fmtRp(r.danaSaatIni)}
📊 Progress: ${r.persen}%
${r.bulanTercapai ? `⏰ Tercapai dalam: ${r.bulanTercapai} bulan` : ''}

Hitung dana daruratmu di:
👉 https://hitungcerdas.net/kalkulator/dana-darurat`;
  window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
}

function copyResult() {
  const r = state.result;
  const text = `Dana Darurat Ideal: ${fmtRp(r.target)} (${r.multiplier}× pengeluaran)\nProgress: ${r.persen}%\nSource: hitungcerdas.net`;
  navigator.clipboard.writeText(text).then(() => alert('Hasil berhasil disalin!'));
}

function resetCalc() {
  document.getElementById('step3').classList.add('hidden');
  document.getElementById('step1').classList.remove('hidden');
  document.getElementById('wizardProgress').style.display = '';
  document.getElementById('pengeluaran').value = '';
  document.getElementById('danaSaatIni').value = '';
  document.getElementById('kemampuanNabung').value = '';
  goStep(1);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function toggleFaq(btn) {
  const ans = btn.nextElementSibling;
  ans.style.display = ans.style.display === 'block' ? 'none' : 'block';
  btn.querySelector('i').style.transform = ans.style.display === 'block' ? 'rotate(180deg)' : '';
}
</script>

