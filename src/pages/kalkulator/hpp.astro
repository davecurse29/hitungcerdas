---
import Layout from '../../layouts/Layout.astro';
import EbookPromo from '../../components/EbookPromo.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('hpp')!;
const related = getRelatedCalculators('hpp', 3);

const faqs = [
  { question: 'Apa itu HPP (Harga Pokok Produksi)?', answer: 'HPP adalah <strong>total biaya untuk memproduksi satu unit produk</strong> — mencakup bahan baku, tenaga kerja langsung, dan overhead produksi (kemasan, gas, listrik, penyusutan alat). HPP per unit dihitung dengan membagi total biaya produksi dengan jumlah unit yang dihasilkan. HPP adalah fondasi penentuan harga jual: kalau HPP salah, harga jual ikut salah dan bisnis bisa rugi tanpa sadar.' },
  { question: 'Bedanya HPP dengan harga jual apa?', answer: '<strong>HPP adalah modal/biaya produksi</strong>, sedangkan <strong>harga jual adalah HPP + margin keuntungan</strong>. Contoh: HPP Rp 7.500/unit, kamu mau margin 40%, maka harga jual = Rp 7.500 / (1 - 0,40) = Rp 12.500. Selisihnya (Rp 5.000) adalah untung kotor per unit. Pakai <a href="/kalkulator/harga-jual">kalkulator harga jual</a> untuk hitung lengkap dengan biaya marketplace.' },
  { question: 'Biaya apa saja yang masuk overhead produksi?', answer: 'Overhead produksi adalah biaya produksi <strong>selain bahan baku & tenaga kerja langsung</strong>: kemasan, gas/listrik produksi, sewa dapur/workshop (porsi produksi), penyusutan peralatan, dan bahan penolong. Jangan masukkan biaya pemasaran, gaji admin, atau ongkir penjualan ke HPP — itu masuk biaya operasional, dihitung terpisah saat menentukan harga jual akhir.' },
  { question: 'Kenapa HPP perlu dihitung ulang berkala?', answer: 'Karena harga bahan baku terus bergerak. Di tengah <strong>kondisi 2026 dengan harga pangan & energi yang fluktuatif</strong>, HPP bulan lalu bisa sudah tidak akurat. Idealnya hitung ulang HPP setiap kali harga bahan baku utama berubah signifikan (di atas 10%), agar harga jual tetap menutup biaya dan margin tetap sehat.' },
  { question: 'HPP untuk usaha dagang (bukan produksi) gimana?', answer: 'Untuk usaha dagang/reseller yang tidak memproduksi sendiri, "HPP" lebih tepat disebut <strong>Harga Pokok Penjualan</strong>: harga beli barang + ongkir masuk + biaya kemasan ulang, dibagi jumlah unit. Kalkulator ini bisa dipakai dengan memasukkan harga beli barang sebagai bahan baku, lalu ongkir/kemasan sebagai overhead.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#EA580C;--cat-color2:#C2410C">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FFEDD5;color:#9A3412"><i class="ti ti-box"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <rect x="58" y="70" width="84" height="74" rx="8" fill="#FFF" stroke="#FB923C" stroke-width="2"/>
            <path d="M58 88 H142" stroke="#FED7AA" stroke-width="2"/>
            <rect x="70" y="100" width="38" height="9" rx="4" fill="#FDBA74"/>
            <rect x="70" y="116" width="58" height="9" rx="4" fill="#FED7AA"/>
            <circle cx="124" cy="64" r="16" fill="#EA580C"/>
            <path d="M118 64 l4 4 l8 -8" stroke="#FFF" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#EA580C 0%,#C2410C 100%)"><i class="ti ti-box"></i></div>
          <div><h2 class="calc-card-title">Kalkulator HPP per Unit</h2><p class="calc-card-sub">Rincian resep bahan baku + rekomendasi harga jual</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="ig-grp">Bahan Baku <span class="ig-grp-hint">(rincian per bahan)</span></div>
            <div class="ig-list" id="bahanRows"></div>
            <button type="button" class="ig-addbtn" id="addBahan"><i class="ti ti-plus"></i> Tambah Bahan</button>
            <div class="ig-subtotal"><span><i class="ti ti-shopping-cart"></i> Subtotal Bahan Baku</span><b id="bahanTotal">Rp 0</b></div>

            <div class="ig-grp">Biaya Lain</div>
            <div class="field"><label>Biaya Tenaga Kerja Langsung <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="tkl" class="has-prefix" value="150.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Upah orang yang langsung memproduksi (bukan admin/marketing).</p>
            </div>
            <div class="field"><label>Biaya Overhead Produksi <span class="hint">(opsional)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span>
                <input type="text" id="overhead" class="has-prefix" value="100.000" inputmode="numeric" /></div>
              <p class="hint" style="margin-top:6px">Kemasan, gas/listrik, penyusutan alat, bahan penolong.</p>
            </div>

            <div class="ig-grp">Hasil &amp; Target</div>
            <div class="field"><label>Jumlah Produk Dihasilkan</label>
              <div class="input-wrap"><span class="input-suffix">unit</span>
                <input type="number" id="unit" class="has-suffix" value="100" min="1" step="1" /></div>
              <p class="hint" style="margin-top:6px">Berapa unit/porsi yang dihasilkan dari satu kali produksi di atas.</p>
            </div>
            <div class="field"><label>Target Margin Keuntungan</label>
              <div class="input-wrap"><span class="input-suffix">% dari harga jual</span>
                <input type="number" id="margin" class="has-suffix" value="40" min="0" max="90" step="1" /></div>
              <p class="hint" style="margin-top:6px">Untuk rekomendasi harga jual. Margin sehat UMKM kuliner ~50-65%, retail ~20-40%.</p>
            </div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="hist-section" id="histBox" style="display:none"></div>

            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-box result-placeholder-icon"></i>
              <div class="result-placeholder-title">HPP akan muncul di sini</div>
              <div class="result-placeholder-desc">Isi rincian bahan baku & jumlah unit, klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">HPP per Unit</div>
                <div class="result-value" id="hppUnit">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="hppMeta">100 unit · total biaya Rp 0</span></div>
              </div>

              <div class="result-grid">
                <div class="result-item"><div class="result-item-label">Total Biaya Produksi</div><div class="result-item-value" id="totalBiaya">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Harga Jual Disarankan</div><div class="result-item-value" id="hargaJual">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Untung per Unit</div><div class="result-item-value" id="untungUnit" style="color:var(--green-dark)">Rp 0</div></div>
                <div class="result-item"><div class="result-item-label">Margin</div><div class="result-item-value" id="marginOut">0%</div></div>
              </div>

              <div id="hppInfo" style="margin-top:10px;padding:11px 13px;border-radius:12px;background:#FFF7ED;border:1px solid #FED7AA;font-size:12.5px;line-height:1.55;color:#9A3412"></div>

              <div style="margin-top:14px">
                <div style="font-size:12.5px;font-weight:700;color:var(--text);margin-bottom:7px"><i class="ti ti-bulb"></i> Simulasi Harga Jual per Margin</div>
                <div style="overflow-x:auto">
                  <table class="compare-table" style="width:100%;font-size:12px">
                    <thead><tr><th>Margin</th><th class="right">Harga Jual/unit</th><th class="right">Untung/unit</th><th class="right">Untung Total</th></tr></thead>
                    <tbody id="simBody"></tbody>
                  </table>
                </div>
                <p class="hint" style="margin-top:6px">Baris <b>★</b> = target marginmu. <b>Markup</b> = untung dibanding modal (HPP); <b>margin</b> = untung dibanding harga jual.</p>
              </div>

              <div class="adv-section">
                <div class="adv-toggle"><span><i class="ti ti-chart-pie"></i>&nbsp; Komposisi Biaya Produksi</span><i class="ti ti-chevron-down chev"></i></div>
                <div class="adv-content">
                  <div class="hpp-komp-grid">
                    <div id="kompDonut" class="hpp-donut-wrap"></div>
                    <table class="compare-table" style="flex:1;min-width:200px">
                      <thead><tr><th>Komponen</th><th class="right">Biaya</th><th class="right">Porsi</th></tr></thead>
                      <tbody id="kompBody"></tbody>
                    </table>
                  </div>
                </div>
              </div>

              <div class="export-row">
                <button type="button" class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button type="button" class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button type="button" class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button type="button" class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>

              <!-- ===== AI COACH HPP ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Margin sehat? HPP bisa ditekan? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach HPP</strong>
                      <small>Bantu pahami biaya & harga jualmu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal HPP & harga jual..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Estimasi edukatif berbasis hitunganmu, bukan nasihat akuntansi resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

    <EbookPromo calc="hpp" headline="Sudah tahu HPP produkmu? Saatnya bikin produk yang benar-benar cuan." />

  <section class="content-section">
    <div class="wrap-text">
      <h2>Cara Menghitung HPP (Harga Pokok Produksi) yang Benar</h2>
      <p>HPP adalah jantung dari penetapan harga. Banyak UMKM menetapkan harga jual hanya dari "kira-kira", lalu heran kenapa untungnya tipis atau malah rugi. Rumusnya sederhana: jumlahkan semua biaya produksi (bahan baku + tenaga kerja langsung + overhead), lalu bagi dengan jumlah unit yang dihasilkan. Hasilnya adalah HPP per unit — modal sebenarnya tiap produk. Setelah tahu HPP, kamu bisa tentukan harga jual dengan <a href="/kalkulator/harga-jual">kalkulator harga jual</a> dan cek kesehatan <a href="/kalkulator/margin">margin keuntungan</a>.</p>

      <h3>3 Komponen Biaya dalam HPP</h3>
      <ul>
        <li><strong>Bahan baku</strong> — bahan utama yang jadi produk (tepung, kain, komponen). Biasanya komponen terbesar. Rinci per bahan agar akurat.</li>
        <li><strong>Tenaga kerja langsung</strong> — upah orang yang langsung memproduksi. Untuk usaha mikro yang dikerjakan sendiri, bisa diisi nilai jasa wajar agar harga tidak "memakan" gaji sendiri.</li>
        <li><strong>Overhead produksi</strong> — biaya produksi lain: kemasan, gas/listrik, penyusutan alat, bahan penolong.</li>
      </ul>

      <h3>Jangan Salah Masukkan Biaya</h3>
      <p>Biaya <strong>pemasaran, gaji admin, ongkir penjualan, dan biaya marketplace</strong> bukan bagian HPP — itu biaya operasional/penjualan yang dihitung terpisah saat menentukan harga jual akhir. Mencampurnya ke HPP membuat HPP terlihat besar dan harga jual jadi tidak kompetitif.</p>

      <h3>Sesuaikan dengan Kondisi 2026</h3>
      <p>Harga bahan baku, energi, dan kemasan terus bergerak. Di tengah fluktuasi harga pangan dan biaya energi tahun 2026, HPP yang dihitung bulan lalu bisa sudah meleset. Biasakan hitung ulang HPP setiap kali harga bahan baku utama berubah signifikan, supaya harga jual selalu menutup biaya dan margin tetap terjaga. Untuk produk yang dijual lewat marketplace atau GoFood/GrabFood/ShopeeFood, ingat masih ada potongan platform yang menggerus margin — perhitungkan setelah HPP.</p>

      <div class="cta-box">
        <h3>Disclaimer</h3>
        <p>Kalkulator ini alat bantu simulasi &amp; edukasi. Hasil bersifat estimasi berdasarkan input yang kamu masukkan. Akurasi HPP bergantung pada kelengkapan & ketepatan data biaya. Untuk pembukuan resmi & pelaporan pajak, gunakan pencatatan akuntansi yang lengkap atau konsultasikan dengan akuntan.</p>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ title="Pertanyaan Seputar HPP" items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>

  <p style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:600px;">
    Diperbarui <strong>Juni 2026</strong> &middot; Kalkulator edukatif untuk UMKM Indonesia
  </p>
</Layout>

<style>
  .ig-grp{font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#EA580C;margin:16px 0 8px;display:flex;align-items:center;gap:7px}
  .ig-grp:first-child{margin-top:0}
  .ig-grp::before{content:'';width:14px;height:2px;border-radius:2px;background:currentColor;opacity:.55}
  .ig-grp-hint{font-weight:500;text-transform:none;letter-spacing:0;color:var(--text-mute,#94A3B8)}
  /* allow grid/flex columns to shrink on mobile (prevents horizontal overflow) */
  .calc-input,.calc-output{min-width:0}
  .ig-list{display:flex;flex-direction:column;gap:8px}
  .ig-row{border:1px solid var(--border,#E2E8F0);border-radius:11px;padding:8px;background:var(--bg,#fff)}
  .ig-row-top{display:flex;gap:7px;align-items:center;margin-bottom:7px}
  .ig-row-top .ig-nama{flex:1;min-width:0;border:1px solid var(--border,#E2E8F0);border-radius:8px;padding:8px 9px;font-size:13.5px;font-family:inherit;background:var(--bg,#fff);color:var(--text,#0F172A);outline:none}
  .ig-row-top .ig-nama:focus{border-color:#EA580C}
  .ig-del{flex-shrink:0;border:0;background:#FEE2E2;color:#DC2626;width:30px;height:30px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px}
  .ig-del:hover{background:#FCA5A5}
  .ig-row-bot{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
  .ig-row-bot input{border:1px solid var(--border,#E2E8F0);border-radius:8px;padding:7px 8px;font-size:13px;font-family:inherit;background:var(--bg,#fff);color:var(--text,#0F172A);outline:none;min-width:0}
  .ig-row-bot input:focus{border-color:#EA580C}
  .ig-qty{width:52px;text-align:center}
  .ig-sat{width:62px}
  .ig-mul,.ig-eq{color:var(--text-mute,#94A3B8);font-size:12px;flex-shrink:0}
  .ig-harga-wrap{display:flex;align-items:center;gap:3px;border:1px solid var(--border,#E2E8F0);border-radius:8px;padding:0 8px;background:var(--bg,#fff);flex:1 1 96px;min-width:96px}
  .ig-harga-wrap:focus-within{border-color:#EA580C}
  .ig-harga-wrap .ig-rp{font-size:11px;color:var(--text-mute,#94A3B8);flex-shrink:0}
  .ig-harga-wrap input{border:0;padding:7px 0;width:100%}
  .ig-sub{font-size:12.5px;font-weight:700;color:#C2410C;white-space:nowrap;flex-shrink:0}
  .ig-addbtn{margin-top:9px;border:1px dashed #FB923C;background:#FFF7ED;color:#C2410C;border-radius:9px;padding:8px 13px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:6px}
  .ig-addbtn:hover{background:#FFEDD5}
  .ig-subtotal{margin-top:11px;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:10px 13px;background:#FFF7ED;border:1px solid #FED7AA;border-radius:11px;font-size:13px;color:#9A3412;font-weight:600}
  .ig-subtotal b{font-size:15.5px;color:#C2410C;white-space:nowrap}
  .hpp-komp-grid{display:flex;gap:16px;align-items:center;flex-wrap:wrap}
  .hpp-donut-wrap{flex-shrink:0;display:flex;justify-content:center;align-items:center}
  .hpp-donut{width:132px;height:132px}
</style>

<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EFF4FF;border:1px solid #C7DBFF;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E4EDFF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#2563EB;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EFF4FF;color:#2563EB;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
