  .aic-legend .dot{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:6px}
  .aic-legend .modal .dot{background:#93C5FD}
  .aic-legend .cuan .dot{background:#10B981}
  .aic-legend b{color:#0A2540}
  .aic-verdict.info{color:#2563EB}
  .aic-verdict b{font-weight:700}
  .aic-dark .aic-stack .seg-modal{background:#24406B}
  .aic-dark .seg-modal .seg-lbl{color:#BFD4FF}
  .aic-dark .aic-legend{color:#A9B7C9}
  .aic-dark .aic-legend b{color:#E8EEF6}
  .aic-dark .aic-legend .modal .dot{background:#3B82F6}
  .aic-dark .aic-verdict.info{color:#8FB4FF}
</style>

<script is:inline>
  (function() {
    function ready(fn) { if (window.HC && window.html2canvas) fn(); else setTimeout(function(){ ready(fn); }, 100); }
    ready(function() {
      var $ = function(id){ return document.getElementById(id); };
      var els = { tkl: $('tkl'), overhead: $('overhead'), unit: $('unit'), margin: $('margin') };
      [els.tkl, els.overhead].forEach(function(el){ el.addEventListener('input', HC.fmtInput); });
      var lastCalc = null;

      function fmtThou(n){ return String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }

      // ===== Ingredient builder =====
      function addRow(d){
        d = d || {};
        var tr = document.createElement('div'); tr.className = 'ig-row';
        tr.innerHTML = '<div class="ig-row-top">'
          + '<input class="ig-nama" type="text" placeholder="Nama bahan (mis. Tepung)">'
          + '<button type="button" class="ig-del" aria-label="Hapus bahan"><i class="ti ti-x"></i></button>'
          + '</div>'
          + '<div class="ig-row-bot">'
          + '<input class="ig-qty" type="number" min="0" step="any" inputmode="decimal" placeholder="Jml">'
          + '<input class="ig-sat" type="text" placeholder="satuan">'
          + '<span class="ig-mul">\u00d7</span>'
          + '<div class="ig-harga-wrap"><span class="ig-rp">Rp</span><input class="ig-harga" type="text" inputmode="numeric" placeholder="0"></div>'
          + '<span class="ig-eq">=</span>'
          + '<span class="ig-sub">Rp 0</span>'
          + '</div>';
        $('bahanRows').appendChild(tr);
        tr.querySelector('.ig-nama').value = d.nama || '';
        tr.querySelector('.ig-qty').value = (d.qty != null ? d.qty : 1);
        tr.querySelector('.ig-sat').value = d.sat || '';
        var h = tr.querySelector('.ig-harga'); h.value = (d.harga != null && d.harga !== '') ? (typeof d.harga === 'number' ? fmtThou(d.harga) : d.harga) : '';
        h.addEventListener('input', HC.fmtInput);
        recalcRow(tr); recalcBahan();
      }
      function recalcRow(tr){
        var q = parseFloat(tr.querySelector('.ig-qty').value) || 0;
        var h = HC.parseRp(tr.querySelector('.ig-harga').value);
        tr.querySelector('.ig-sub').textContent = HC.fmt(q * h);
      }
      function recalcBahan(){
        var total = 0, rows = $('bahanRows').querySelectorAll('.ig-row');
        for (var i = 0; i < rows.length; i++){ var q = parseFloat(rows[i].querySelector('.ig-qty').value) || 0; var h = HC.parseRp(rows[i].querySelector('.ig-harga').value); total += q * h; }
        $('bahanTotal').textContent = HC.fmt(total);
        return total;
      }
      function readRows(){
        var out = [], rows = $('bahanRows').querySelectorAll('.ig-row');
        for (var i = 0; i < rows.length; i++){
          var nama = rows[i].querySelector('.ig-nama').value.trim();
          var q = parseFloat(rows[i].querySelector('.ig-qty').value) || 0;
          var sat = rows[i].querySelector('.ig-sat').value.trim();
          var h = HC.parseRp(rows[i].querySelector('.ig-harga').value);
          if (q * h > 0 || nama) out.push({ nama: nama, qty: q, sat: sat, harga: h, sub: q * h });
        }
        return out;
      }
      // delegated events
      $('bahanRows').addEventListener('input', function(ev){
        var tr = ev.target.closest('.ig-row'); if (tr) recalcRow(tr); recalcBahan();
      });
      $('bahanRows').addEventListener('click', function(ev){
        var del = ev.target.closest('.ig-del'); if (!del) return;
        var rows = $('bahanRows').querySelectorAll('.ig-row');
        if (rows.length <= 1) { var tr = del.closest('.ig-row'); tr.querySelector('.ig-nama').value=''; tr.querySelector('.ig-qty').value='1'; tr.querySelector('.ig-sat').value=''; tr.querySelector('.ig-harga').value=''; recalcRow(tr); recalcBahan(); return; }
        del.closest('.ig-row').remove(); recalcBahan();
      });
      $('addBahan').addEventListener('click', function(){ addRow({ qty: 1 }); });

      function seed(){
        $('bahanRows').innerHTML = '';
        addRow({ nama: 'Tepung Terigu', qty: 5, sat: 'kg', harga: 13000 });
        addRow({ nama: 'Gula Pasir', qty: 3, sat: 'kg', harga: 16000 });
        addRow({ nama: 'Telur', qty: 2, sat: 'kg', harga: 29000 });
      }

      // ===== Donut =====
      function donut(segs){
        var total = 0; segs.forEach(function(s){ total += s.val; });
        if (total <= 0) return '';
        var off = 0, c = '';
        segs.forEach(function(s){ if (s.val <= 0) return; var pct = s.val / total * 100; c += '<circle cx="60" cy="60" r="42" fill="none" stroke="' + s.color + '" stroke-width="16" pathLength="100" stroke-dasharray="' + pct.toFixed(2) + ' ' + (100 - pct).toFixed(2) + '" stroke-dashoffset="' + (-off).toFixed(2) + '" transform="rotate(-90 60 60)"></circle>'; off += pct; });
        return '<svg viewBox="0 0 120 120" class="hpp-donut" role="img" aria-label="Komposisi biaya">' + c + '<text x="60" y="56" text-anchor="middle" font-size="8.5" fill="#94A3B8">Total Biaya</text><text x="60" y="70" text-anchor="middle" font-size="10" font-weight="700" fill="#0F172A">' + HC.fmt(total) + '</text></svg>';
      }

      function hitung() {
        var bahan = recalcBahan();
        var tkl = HC.parseRp(els.tkl.value);
        var overhead = HC.parseRp(els.overhead.value);
        var unit = parseInt(els.unit.value) || 0;
        var margin = parseFloat(els.margin.value) || 0;

        var totalBiaya = bahan + tkl + overhead;
        if (totalBiaya === 0) { HC.toast('Masukkan biaya produksi dulu', 'error'); return; }
        if (unit < 1) { HC.toast('Jumlah unit minimal 1', 'error'); return; }
        if (margin >= 90) { margin = 89; els.margin.value = 89; HC.toast('Margin dibatasi maksimal 89%', 'info'); }

        var hppUnit = totalBiaya / unit;
        var hargaJual = margin > 0 ? hppUnit / (1 - margin / 100) : hppUnit;
        var untungUnit = hargaJual - hppUnit;
        var marginReal = hargaJual > 0 ? (untungUnit / hargaJual) * 100 : 0;

        $('hppUnit').textContent = HC.fmt(hppUnit);
        $('hppMeta').textContent = unit + ' unit \u00b7 total biaya ' + HC.fmt(totalBiaya);
        $('totalBiaya').textContent = HC.fmt(totalBiaya);
        $('hargaJual').textContent = HC.fmt(hargaJual);
        $('untungUnit').textContent = HC.fmt(untungUnit);
        $('marginOut').textContent = marginReal.toFixed(1) + '%';

        var markup = hppUnit > 0 ? (untungUnit / hppUnit) * 100 : 0;
        $('hppInfo').innerHTML = '\ud83d\udca1 Modal tiap produk <b>' + HC.fmt(hppUnit) + '</b>. Dengan margin ' + margin + '%, jual di <b>' + HC.fmt(hargaJual) + '/unit</b> \u2192 untung <b>' + HC.fmt(untungUnit) + '/unit</b> (markup ' + markup.toFixed(0) + '% dari modal). Harga ini belum dikurangi biaya marketplace/ongkir & operasional (sewa, marketing, admin).';

        // Simulasi
        var presets = [15, 20, 25, 30, 40, 50];
        if (margin > 0 && presets.indexOf(margin) === -1) presets.push(margin);
        presets.sort(function(a, b){ return a - b; });
        var simHtml = '';
        presets.forEach(function(m){
          var hj = m > 0 ? hppUnit / (1 - m / 100) : hppUnit;
          var uu = hj - hppUnit, ut = uu * unit, mk = hppUnit > 0 ? uu / hppUnit * 100 : 0;
          var isT = Math.abs(m - margin) < 0.01;
          simHtml += '<tr' + (isT ? ' style="background:#FFF7ED;font-weight:700"' : '') + '><td>' + (isT ? '\u2605 ' : '') + m + '% <span style="color:#9A3412;font-weight:400;font-size:11px">(markup ' + mk.toFixed(0) + '%)</span></td><td class="right">' + HC.fmt(hj) + '</td><td class="right" style="color:var(--green-dark)">' + HC.fmt(uu) + '</td><td class="right">' + HC.fmt(ut) + '</td></tr>';
        });
        $('simBody').innerHTML = simHtml;

        // Komposisi: donut + table
        var comps = [
          { label: 'Bahan Baku', val: bahan, color: '#EA580C' },
          { label: 'Tenaga Kerja Langsung', val: tkl, color: '#F59E0B' },
          { label: 'Overhead Produksi', val: overhead, color: '#FBBF24' }
        ];
        $('kompDonut').innerHTML = donut(comps);
        var bodyHtml = '';
        comps.forEach(function(c){
          var pct = totalBiaya > 0 ? (c.val / totalBiaya) * 100 : 0;
          bodyHtml += '<tr><td><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:' + c.color + ';margin-right:6px"></span>' + c.label + '</td><td class="right">' + HC.fmt(c.val) + '</td><td class="right" style="font-weight:700">' + pct.toFixed(1) + '%</td></tr>';
        });
        $('kompBody').innerHTML = bodyHtml;

        var rowsData = readRows();
        var rincian = rowsData.filter(function(r){ return r.sub > 0; }).map(function(r){ return r.nama || 'bahan'; }).slice(0, 8).join(', ');
        lastCalc = { bahan: bahan, tkl: tkl, overhead: overhead, unit: unit, margin: margin, totalBiaya: totalBiaya, hppUnit: hppUnit, hargaJual: hargaJual, untungUnit: untungUnit, marginReal: marginReal, markup: markup, rows: rowsData };
        window.HCHpp = { hppTxt: HC.fmt(hppUnit), totalTxt: HC.fmt(totalBiaya), bahanTxt: HC.fmt(bahan), tklTxt: HC.fmt(tkl), overheadTxt: HC.fmt(overhead), hargaTxt: HC.fmt(hargaJual), untungTxt: HC.fmt(untungUnit), bahan: bahan, tkl: tkl, overhead: overhead, unit: unit, margin: margin, rincian: rincian };

        var inputs = { tkl: els.tkl.value, overhead: els.overhead.value, unit: els.unit.value, margin: els.margin.value, _rows: JSON.stringify(rowsData) };
        if (HC.history) HC.history.push('hpp', { inputs: inputs, summary: 'HPP ' + HC.fmt(hppUnit) + '/unit \u00b7 ' + unit + ' unit', metrics: [{ k: 'HPP/unit', v: HC.fmt(hppUnit) }, { k: 'Harga jual', v: HC.fmt(hargaJual) }] });
        renderHist();

        $('placeholder').style.display = 'none';
        $('results').classList.add('show');
        $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        HC.toast('HPP berhasil dihitung!');
      }

      function reset() {
        seed();
        els.tkl.value = '150.000'; els.overhead.value = '100.000'; els.unit.value = '100'; els.margin.value = '40';
        $('placeholder').style.display = ''; $('results').classList.remove('show');
        lastCalc = null; window.HCHpp = null; HC.toast('Form direset', 'info');
      }

      function buildReport() {
        if (!lastCalc) return null;
        var c = lastCalc;
        var insight = 'HPP per unit ' + HC.fmt(c.hppUnit) + ' dari total biaya ' + HC.fmt(c.totalBiaya) + ' untuk ' + c.unit + ' unit. Dengan margin ' + c.margin + '%, harga jual disarankan ' + HC.fmt(c.hargaJual) + '/unit (untung ' + HC.fmt(c.untungUnit) + '/unit). Belum termasuk biaya marketplace & operasional. Estimasi edukatif.';
        var bahanInputs = c.rows.filter(function(r){ return r.sub > 0; }).slice(0, 6).map(function(r){ return { label: '\ud83e\uddfa ' + (r.nama || 'Bahan'), value: HC.fmt(r.sub) }; });
        var inputs = bahanInputs.concat([
          { label: '\ud83d\udc77 Tenaga Kerja', value: HC.fmt(c.tkl) },
          { label: '\u2699\ufe0f Overhead', value: HC.fmt(c.overhead) },
          { label: '\ud83d\udce6 Jumlah Unit', value: c.unit + ' unit' }
        ]);
        return HC.buildReportCard({
          title: '\ud83d\udce6 Hitung HPP', color: '#EA580C', color2: '#C2410C',
          heroLabel: 'HPP per Unit', heroValue: HC.fmt(c.hppUnit),
          heroSubtext: c.unit + ' unit \u00b7 total biaya ' + HC.fmt(c.totalBiaya),
          inputs: inputs,
          results: [
            { label: 'HPP/unit', value: HC.fmt(c.hppUnit), highlight: true },
            { label: 'Total Biaya', value: HC.fmt(c.totalBiaya) },
            { label: 'Harga Jual (margin ' + c.margin + '%)', value: HC.fmt(c.hargaJual), highlight: true },
            { label: 'Untung/unit', value: HC.fmt(c.untungUnit) }
          ],
          insight: insight, slug: 'hpp'
        });
      }

      function summaryText() {
        if (!lastCalc) return '';
        var c = lastCalc;
        var rin = c.rows.filter(function(r){ return r.sub > 0; }).map(function(r){ return '  - ' + (r.nama || 'bahan') + ': ' + HC.fmt(r.sub); }).join('\n');
        return '\ud83d\udce6 *Hitung HPP - HitungCerdas*\n\n*Bahan baku:*\n' + (rin || '  - ' + HC.fmt(c.bahan)) + '\nTotal bahan: ' + HC.fmt(c.bahan) + '\nTenaga kerja: ' + HC.fmt(c.tkl) + '\nOverhead: ' + HC.fmt(c.overhead) + '\nJumlah: ' + c.unit + ' unit\n\n\ud83d\udce6 *HPP/unit: ' + HC.fmt(c.hppUnit) + '*\n\ud83d\udcb0 Harga jual (margin ' + c.margin + '%): ' + HC.fmt(c.hargaJual) + '\n\ud83d\udcc8 Untung/unit: ' + HC.fmt(c.untungUnit) + '\n\nHitung di: https://hitungcerdas.net/kalkulator/hpp';
      }

      function renderHist() {
        if (HC.history) HC.history.render('hpp', $('histBox'), function (e) {
          try { var rows = JSON.parse((e.inputs && e.inputs._rows) || '[]'); if (rows.length) { $('bahanRows').innerHTML = ''; rows.forEach(function(r){ addRow({ nama: r.nama, qty: r.qty, sat: r.sat, harga: r.harga }); }); recalcBahan(); } } catch (err) {}
          hitung();
        });
      }

      seed();
      renderHist();
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      document.querySelectorAll('.adv-toggle').forEach(function(t){ t.addEventListener('click', function(){ t.parentElement.classList.toggle('open'); }); });
      $('exportImg').addEventListener('click', function(){ var c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToImage(c, 'hpp-' + Date.now()); });
      $('exportWa').addEventListener('click', function(){ var c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.shareWhatsApp(c, summaryText(), 'hpp'); });
      $('exportPdf').addEventListener('click', function(){ if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToPDF(); });
      $('exportCopy').addEventListener('click', function(){ if (!lastCalc) { HC.toast('Hitung dulu', 'error'); return; } HC.copyText(summaryText(), 'Tersalin!'); });
      $('exportExcel').addEventListener('click', function(){ var c = buildReport(); if (!c) { HC.toast('Hitung dulu', 'error'); return; } HC.exportToExcel(c, 'hpp-' + Date.now()); });
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function renderGround(){
        var d=window.HCHpp;
        var ctx='<div class="aic-ctx"><i class="ti ti-box"></i> HPP per unit: <b>'+(d?esc(d.hppTxt):'-')+'</b></div>';
        if(!d){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk lihat komposisi biaya & saran harga jual.</div>'; return; }
        var segs=[['Bahan Baku',d.bahan,'#EA580C'],['Tenaga Kerja',d.tkl,'#F59E0B'],['Overhead',d.overhead,'#FBBF24']];
        var tot=d.bahan+d.tkl+d.overhead, bars='';
        segs.forEach(function(s){ var pct=tot>0?s[1]/tot*100:0; bars+='<div style="margin:4px 0"><div style="display:flex;justify-content:space-between;font-size:11.5px;margin-bottom:2px"><span>'+s[0]+'</span><b>'+pct.toFixed(0)+'%</b></div><div style="height:7px;border-radius:4px;background:#E5EAF1;overflow:hidden"><div style="height:100%;width:'+pct.toFixed(1)+'%;background:'+s[2]+'"></div></div></div>'; });
        ground.innerHTML=ctx+'<div style="margin:8px 0">'+bars+'</div><div class="aic-verdict info"><i class="ti ti-tag"></i> Saran harga jual <b>'+esc(d.hargaTxt)+'</b>/unit (margin '+d.margin+'%, untung '+esc(d.untungTxt)+'/unit).</div>';
      }
      function buildContext(){
        var d=window.HCHpp;
        if(!d) return 'Pengguna belum menghitung HPP. Minta mereka mengisi biaya bahan baku, tenaga kerja, overhead, dan jumlah unit lalu klik Hitung Sekarang.';
        var lines=['Kalkulator: HPP (Harga Pokok Produksi) per unit untuk UMKM Indonesia.',
          'Total biaya produksi: '+d.totalTxt+' untuk '+d.unit+' unit.',
          'Komponen biaya: bahan baku '+d.bahanTxt+', tenaga kerja langsung '+d.tklTxt+', overhead '+d.overheadTxt+'.',
          'HPP per unit (modal per produk): '+d.hppTxt+'.',
          'Target margin: '+d.margin+'%. Saran harga jual: '+d.hargaTxt+' per unit. Untung per unit: '+d.untungTxt+'.'];
        if(d.rincian) lines.push('Rincian bahan baku: '+d.rincian+'.');
        lines.push('ATURAN UNTUKMU (AI): Gunakan HANYA angka di atas, jangan mengarang. Bantu UMKM memahami HPP, kesehatan margin, dan cara menekan biaya, dengan bahasa sederhana dan suportif. PENTING: harga jual ini BELUM dipotong biaya marketplace/ojol (GoFood, GrabFood, ShopeeFood biasanya potong sekitar 20-30%), ongkir, dan biaya operasional (sewa, marketing, admin). Ingatkan bila relevan. Untuk hitung harga jual lengkap di marketplace, arahkan ke kalkulator harga jual. Jangan menjawab di luar topik biaya/harga produk.');
        return lines.join('\n');
      }
      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Margin segini sehat gak?','Kenapa HPP-ku segini?','Gimana biar HPP turun?','Harga jualku kemahalan gak?','Belum kehitung biaya apa aja?','Kalau jual di GoFood gimana?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Margin segini sehat gak?','Gimana biar HPP turun?','Belum kehitung biaya apa?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
