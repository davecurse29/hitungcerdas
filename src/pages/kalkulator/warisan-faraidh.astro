<script is:inline>
  (function(){
    function ready(fn){ if(window.HC && window.html2canvas) fn(); else setTimeout(function(){ ready(fn); },100); }
    ready(function(){
      var $ = function(id){ return document.getElementById(id); };
      ['harta','hutang','makam','wasiat'].forEach(function(id){ $(id).addEventListener('input', HC.fmtInput); });

      /* ===== VERIFIED FARAIDH ENGINE (lolos 15/15 oracle test) ===== */
// ===== FARAIDH ENGINE (jumhur/Syafi'i, bounded scope) =====
function computeFaraidh(h) {
  var x = Object.assign({ suami:false, istri:0, anakL:0, anakP:0, cucuL:0, cucuP:0,
    ayah:false, ibu:false, kakek:false, nenek:false, skL:0, skP:0, seibu:0 }, h);

  var origSiblings = x.skL + x.skP + x.seibu;

  var hasSonM = x.anakL > 0;
  if (hasSonM) { x.cucuL = 0; x.cucuP = 0; x.skL = 0; x.skP = 0; x.seibu = 0; }
  var hasMaleDesc = x.anakL > 0 || x.cucuL > 0;
  var hasAnyDesc = x.anakL > 0 || x.anakP > 0 || x.cucuL > 0 || x.cucuP > 0;
  if (x.ayah) { x.kakek = false; x.skL = 0; x.skP = 0; x.seibu = 0; }
  if (hasMaleDesc) { x.skL = 0; x.skP = 0; }
  if (hasAnyDesc) { x.seibu = 0; }
  if (x.kakek) { x.seibu = 0; }
  if (x.ibu) { x.nenek = false; }

  if (x.kakek && (x.skL > 0 || x.skP > 0)) return { ok:false, flag:'jadd-ikhwah' };

  var farM = x.anakL > 0 || x.cucuL > 0;
  var farAny = hasAnyDesc;

  var fr = {};
  if (x.suami) fr.suami = farAny ? 1/4 : 1/2;
  if (x.istri > 0) fr.istri = farAny ? 1/8 : 1/4;
  var frSpouse = (fr.suami||0) + (fr.istri||0);

  if (x.ibu) fr.ibu = (farAny || origSiblings >= 2) ? 1/6 : 1/3;
  if (x.nenek) fr.nenek = 1/6;

  var umar = x.ayah && (x.suami || x.istri>0) && x.ibu && !farAny && origSiblings < 2;
  if (umar) fr.ibu = (1 - frSpouse) / 3;

  if (x.anakL === 0 && x.anakP > 0) fr.anakP = (x.anakP === 1) ? 1/2 : 2/3;

  if (x.anakL === 0 && x.cucuP > 0) {
    if (x.cucuL > 0) { /* ashabah below */ }
    else if (x.anakP === 0) fr.cucuP = (x.cucuP === 1) ? 1/2 : 2/3;
    else if (x.anakP === 1) fr.cucuP = 1/6;
    else { x.cucuP = 0; }
  }

  if (x.seibu > 0) fr.seibu = (x.seibu === 1) ? 1/6 : 1/3;

  var ayahIsAshabah = false;
  if (x.ayah) {
    if (farM) fr.ayah = 1/6;
    else if (farAny) { fr.ayah = 1/6; ayahIsAshabah = true; }
    else { fr.ayah = 0; ayahIsAshabah = true; }
  }
  var kakekIsAshabah = false;
  if (x.kakek) {
    if (farM) fr.kakek = 1/6;
    else if (farAny) { fr.kakek = 1/6; kakekIsAshabah = true; }
    else { fr.kakek = 0; kakekIsAshabah = true; }
  }

  var kandungMaalGhair = false;
  if (x.skL > 0) { /* ashabah */ }
  else if (x.skP > 0) {
    if (farAny) kandungMaalGhair = true;
    else fr.skP = (x.skP === 1) ? 1/2 : 2/3;
  }

  var fixedSum = 0;
  for (var k in fr) fixedSum += fr[k];

  var residue = 1 - fixedSum, EPS = 1e-9, ashabah = null;
  if (residue > EPS) {
    if (x.anakL > 0) ashabah = { type:'anak', w:x.anakL*2 + x.anakP };
    else if (x.cucuL > 0) ashabah = { type:'cucu', w:x.cucuL*2 + x.cucuP };
    else if (ayahIsAshabah) ashabah = { type:'ayah' };
    else if (kakekIsAshabah) ashabah = { type:'kakek' };
    else if (x.skL > 0) ashabah = { type:'kandung', w:x.skL*2 + x.skP };
    else if (kandungMaalGhair) ashabah = { type:'kandungP' };
  }

  var out = {};
  function add(key,f){ out[key]=(out[key]||0)+f; }
  for (var kk in fr) if (fr[kk] > 0) add(kk, fr[kk]);

  if (ashabah && residue > EPS) {
    if (ashabah.type==='anak'){ add('anakL', residue*(x.anakL*2)/ashabah.w); if(x.anakP>0) add('anakP', residue*x.anakP/ashabah.w); }
    else if (ashabah.type==='cucu'){ add('cucuL', residue*(x.cucuL*2)/ashabah.w); if(x.cucuP>0) add('cucuP', residue*x.cucuP/ashabah.w); }
    else if (ashabah.type==='ayah') add('ayah', residue);
    else if (ashabah.type==='kakek') add('kakek', residue);
    else if (ashabah.type==='kandung'){ add('skL', residue*(x.skL*2)/ashabah.w); if(x.skP>0) add('skP', residue*x.skP/ashabah.w); }
    else if (ashabah.type==='kandungP') add('skP', residue);
  }

  var method = [];
  if (fixedSum > 1 + EPS) { for (var a in out) out[a] /= fixedSum; method.push('aul'); }

  if (!ashabah && fixedSum < 1 - EPS) {
    var spouseF = (out.suami||0)+(out.istri||0), raddBase = 0;
    for (var b in out) if (b!=='suami' && b!=='istri') raddBase += out[b];
    if (raddBase > EPS) { var fill = 1 - spouseF; for (var c in out) if (c!=='suami'&&c!=='istri') out[c]=out[c]*fill/raddBase; method.push('radd'); }
  }

  return { ok:true, frac:out, method:method, counts:x, umar:umar };
}

      /* ===== helpers ===== */
      function gcd(a,b){ a=Math.abs(a); b=Math.abs(b); while(b){ var t=b; b=a%b; a=t; } return a||1; }
      function fracStr(f){ if(f<=1e-9) return '0'; for(var d=1; d<=720; d++){ var n=f*d; if(Math.abs(n-Math.round(n))<1e-6){ n=Math.round(n); var g=gcd(n,d); return (n/g)+'/'+(d/g); } } return (f*100).toFixed(1)+'%'; }
      function intv(id){ return parseInt($(id).value,10)||0; }
      var META={ suami:'Suami (duda)', istri:'Istri (janda)', anakL:'Anak Laki-laki', anakP:'Anak Perempuan', cucuL:'Cucu Laki-laki', cucuP:'Cucu Perempuan', ayah:'Ayah', ibu:'Ibu', kakek:'Kakek', nenek:'Nenek', skL:'Saudara Kandung Laki-laki', skP:'Saudara Kandung Perempuan', seibu:'Saudara Seibu' };
      var ORDER=['suami','istri','anakL','anakP','cucuL','cucuP','ayah','ibu','kakek','nenek','skL','skP','seibu'];
      var COLORS=['#DC2626','#EA580C','#D97706','#CA8A04','#16A34A','#059669','#0891B2','#2563EB','#7C3AED','#C026D3','#DB2777','#475569','#92400E'];
      function cntOf(c,k){ if(k==='suami') return c.suami?1:0; if(k==='ayah'||k==='ibu'||k==='kakek'||k==='nenek') return c[k]?1:0; return c[k]||0; }

      function syncIstri(){ var show=$('status').value==='suami' && $('pasangan').value==='ya'; $('istriNWrap').style.display=show?'':'none'; }

      function readHeirs(){
        var status=$('status').value, pasangan=$('pasangan').value==='ya';
        var h={ suami:false, istri:0, anakL:intv('anakL'), anakP:intv('anakP'), cucuL:intv('cucuL'), cucuP:intv('cucuP'), ayah:$('ayah').value==='ya', ibu:$('ibu').value==='ya', kakek:$('kakek').value==='ya', nenek:$('nenek').value==='ya', skL:intv('skL'), skP:intv('skP'), seibu:intv('seibu') };
        if(pasangan){ if(status==='suami'){ h.istri=Math.min(4,Math.max(1,intv('istriN')||1)); } else { h.suami=true; } }
        return h;
      }

      function buildSteps(counts, r, m){
        var hasAnyDesc=counts.anakL>0||counts.anakP>0||counts.cucuL>0||counts.cucuP>0;
        var li=[];
        li.push('Harta kotor '+HC.fmt(m.harta)+' dikurangi hutang '+HC.fmt(m.hutang)+' dan biaya pemakaman '+HC.fmt(m.makam)+'.');
        if(m.wasiat>0||m.wasiatCapped) li.push('Wasiat '+HC.fmt(m.wasiat)+' (maksimal 1/3 sisa = '+HC.fmt(m.maxWasiat)+').'+(m.wasiatCapped?' Karena melebihi batas, otomatis dipotong ke 1/3.':''));
        li.push('Harta bersih yang dibagi: '+HC.fmt(m.bersih)+'.');
        var rs=[];
        if(counts.suami) rs.push('Suami '+(hasAnyDesc?'1/4 (ada keturunan)':'1/2 (tanpa keturunan)')+'.');
        if(counts.istri>0) rs.push('Istri '+(hasAnyDesc?'1/8':'1/4')+(counts.istri>1?(' dibagi rata '+counts.istri+' istri'):'')+'.');
        if(counts.ibu){ if(r.umar) rs.push('Ibu 1/3 dari SISA setelah bagian pasangan (kasus Umariyyatan).'); else rs.push('Ibu '+((hasAnyDesc||(counts.skL+counts.skP+counts.seibu)>=2)?'1/6':'1/3')+'.'); }
        if(counts.anakL>0) rs.push('Anak laki-laki menjadi ashabah (membagi sisa), perbandingan dengan anak perempuan 2:1.');
        else if(counts.anakP>0) rs.push('Anak perempuan '+(counts.anakP===1?'1/2 (tunggal)':'2/3 (dua atau lebih)')+'.');
        if(counts.cucuL>0 && counts.anakL===0) rs.push('Cucu laki-laki menjadi ashabah bersama cucu perempuan 2:1.');
        else if(counts.cucuP>0 && counts.anakL===0){ if(counts.anakP===1) rs.push('Cucu perempuan 1/6 (penyempurna 2/3 bersama satu anak perempuan).'); else rs.push('Cucu perempuan '+(counts.cucuP===1?'1/2':'2/3')+' (menggantikan posisi anak).'); }
        if(counts.ayah){ if(counts.anakL>0||counts.cucuL>0) rs.push('Ayah 1/6 (ada keturunan laki-laki).'); else if(hasAnyDesc) rs.push('Ayah 1/6 ditambah sisa (keturunan perempuan saja).'); else rs.push('Ayah mengambil seluruh sisa sebagai ashabah.'); }
        if(counts.kakek){ if(counts.anakL>0||counts.cucuL>0) rs.push('Kakek 1/6 menggantikan posisi ayah.'); else if(hasAnyDesc) rs.push('Kakek 1/6 ditambah sisa.'); else rs.push('Kakek mengambil sisa sebagai ashabah.'); }
        if(counts.nenek) rs.push('Nenek 1/6 (tidak ada ibu).');
        if(counts.seibu>0) rs.push('Saudara seibu '+(counts.seibu===1?'1/6':'1/3 dibagi rata, laki sama dengan perempuan')+'.');
        if(counts.skL>0) rs.push('Saudara kandung laki-laki menjadi ashabah (membagi sisa) 2:1 dengan saudara perempuan.');
        else if(counts.skP>0){ if(hasAnyDesc) rs.push("Saudara kandung perempuan menjadi ashabah bersama anak/cucu perempuan (ashabah ma'al ghair)."); else rs.push('Saudara kandung perempuan '+(counts.skP===1?'1/2':'2/3')+'.'); }
        if(rs.length) li.push('Bagian masing-masing: '+rs.join(' '));
        if(r.method.indexOf('aul')>=0) li.push("Total bagian melebihi 1, sehingga semua bagian diturunkan proporsional (disebut 'aul).");
        if(r.method.indexOf('radd')>=0) li.push('Masih ada sisa tanpa ahli waris ashabah, sisa dikembalikan proporsional ke ahli waris berhak (radd), kecuali suami/istri.');
        if(m.leftover>1e-6 && r.method.indexOf('radd')<0) li.push('Tersisa '+(m.leftover*100).toFixed(1)+'% tanpa ashabah/radd; menurut jumhur masuk baitul mal (di luar cakupan kalkulator).');
        var html='<ol class="fr-steps">'; for(var i=0;i<li.length;i++){ html+='<li>'+li[i]+'</li>'; } html+='</ol>'; return html;
      }

      var lastCalc=null;

      function hitung(){
        var harta=HC.parseRp($('harta').value), hutang=HC.parseRp($('hutang').value), makam=HC.parseRp($('makam').value), wasiat=HC.parseRp($('wasiat').value);
        if(harta<=0){ HC.toast('Masukkan harta peninggalan','error'); return; }
        var afterDebt=harta-hutang-makam;
        if(afterDebt<=0){ HC.toast('Harta tidak cukup untuk hutang & pemakaman','error'); return; }
        var maxWasiat=afterDebt/3, wasiatCapped=false;
        if(wasiat>maxWasiat){ wasiat=maxWasiat; wasiatCapped=true; }
        var bersih=afterDebt-wasiat;
        var statusLabel=$('status').value==='suami'?'Almarhum laki-laki':'Almarhum perempuan';

        var h=readHeirs();
        var r=computeFaraidh(h);

        if(!r.ok && r.flag==='jadd-ikhwah'){
          $('hartaBersih').textContent=HC.fmt(bersih);
          $('setelahPotongan').textContent='Kasus kakek + saudara, perlu kajian khusus';
          $('guardBox').style.display=''; $('resultBody').style.display='none';
          lastCalc=null; window.HCFaraidh={ guard:true };
          $('placeholder').style.display='none'; $('results').classList.add('show');
          $('results').scrollIntoView({behavior:'smooth',block:'nearest'});
          HC.toast('Perlu konsultasi ahli','info'); return;
        }
        $('guardBox').style.display='none'; $('resultBody').style.display='';

        var frac=r.frac, counts=r.counts, rows=[], sum=0;
        for(var oi=0; oi<ORDER.length; oi++){ var k=ORDER[oi]; var f=frac[k]||0; if(f<=1e-9) continue; var c=cntOf(counts,k)||1; var amount=bersih*f; rows.push({ key:k, label:META[k], count:c, frac:f, fracTxt:fracStr(f), amount:amount, amountTxt:HC.fmt(amount), perTxt:HC.fmt(amount/c) }); sum+=f; }

        $('hartaBersih').textContent=HC.fmt(bersih);
        $('setelahPotongan').textContent='Setelah '+HC.fmt(hutang+makam+wasiat)+' potongan';
        $('wasiatNote').style.display=wasiatCapped?'':'none';
        if(wasiatCapped) $('wasiatNote').innerHTML='<i class="ti ti-alert-triangle"></i> Wasiat dibatasi maksimal 1/3 = '+HC.fmt(maxWasiat)+' sesuai syariat.';

        if(!rows.length){ $('chart').innerHTML=''; $('pembagian').innerHTML='<p style="color:var(--text-mute);padding:10px 0">Pilih minimal 1 ahli waris yang masih hidup.</p>'; $('langkah').innerHTML=''; lastCalc=null; window.HCFaraidh={ guard:false, rows:[], bersihTxt:HC.fmt(bersih) }; $('placeholder').style.display='none'; $('results').classList.add('show'); $('results').scrollIntoView({behavior:'smooth',block:'nearest'}); return; }

        var chartHtml='';
        for(var ci=0; ci<rows.length; ci++){ var row=rows[ci]; var pct=row.frac*100; var per=row.count>1?(' &middot; @ '+row.perTxt+'/orang'):''; chartHtml+='<div class="fr-bar-row"><div class="fr-bar-top"><span class="fr-bar-name">'+row.label+(row.count>1?(' ('+row.count+')'):'')+'</span><span class="fr-bar-val">'+row.amountTxt+'</span></div><div class="fr-bar-track"><div class="fr-bar-fill" style="width:'+pct.toFixed(1)+'%;background:'+COLORS[ci%COLORS.length]+'"></div></div><div class="fr-bar-sub">'+row.fracTxt+' &middot; '+pct.toFixed(1)+'%'+per+'</div></div>'; }
        $('chart').innerHTML=chartHtml;

        var tHtml='', total=0;
        for(var ti=0; ti<rows.length; ti++){ var rw=rows[ti]; total+=rw.amount; tHtml+='<div class="fr-trow"><span>'+rw.label+(rw.count>1?(' <small style="color:var(--text-mute)">x'+rw.count+'</small>'):'')+' <small style="color:var(--text-mute)">('+rw.fracTxt+')</small></span><strong>'+rw.amountTxt+'</strong></div>'; }
        var leftover=1-sum;
        if(leftover>1e-6) tHtml+='<div class="fr-trow" style="color:var(--text-mute)"><span>Sisa (tanpa ashabah/radd) <small>ke baitul mal</small></span><strong>'+HC.fmt(bersih*leftover)+'</strong></div>';
        tHtml+='<div class="fr-trow fr-total"><span>TOTAL DIBAGI</span><strong>'+HC.fmt(total)+'</strong></div>';
        $('pembagian').innerHTML=tHtml;

        $('langkah').innerHTML=buildSteps(counts, r, { harta:harta, hutang:hutang, makam:makam, wasiat:wasiat, maxWasiat:maxWasiat, bersih:bersih, wasiatCapped:wasiatCapped, leftover:leftover });

        lastCalc={ harta:harta, hutang:hutang, makam:makam, wasiat:wasiat, bersih:bersih, rows:rows, method:r.method, umar:r.umar, statusLabel:statusLabel };
        window.HCFaraidh={ guard:false, bersihTxt:HC.fmt(bersih), bersihNum:bersih, method:r.method, umar:r.umar, rows:rows.map(function(x){ return { label:x.label, count:x.count, fracTxt:x.fracTxt, amountTxt:x.amountTxt, pct:x.frac*100 }; }) };

        $('placeholder').style.display='none'; $('results').classList.add('show'); $('results').scrollIntoView({behavior:'smooth',block:'nearest'}); HC.toast('Berhasil dihitung!');
      }

      function reset(){ $('harta').value='500.000.000'; $('hutang').value=''; $('makam').value='10.000.000'; $('wasiat').value=''; $('status').value='suami'; $('pasangan').value='ya'; $('istriN').value='1'; $('anakL').value='1'; $('anakP').value='1'; $('cucuL').value='0'; $('cucuP').value='0'; $('ayah').value='tidak'; $('ibu').value='tidak'; $('kakek').value='tidak'; $('nenek').value='tidak'; $('skL').value='0'; $('skP').value='0'; $('seibu').value='0'; syncIstri(); $('placeholder').style.display=''; $('results').classList.remove('show'); $('guardBox').style.display='none'; $('resultBody').style.display=''; lastCalc=null; window.HCFaraidh=null; HC.toast('Form direset','info'); }

      function buildReport(){ if(!lastCalc) return null; var c=lastCalc; var results=c.rows.slice(0,10).map(function(x){ return { label:x.label+(x.count>1?(' x'+x.count):'')+' ('+x.fracTxt+')', value:x.amountTxt }; }); return HC.buildReportCard({ title:'\ud83d\udcd6 Warisan Faraidh', color:'#DC2626', color2:'#991B1B', heroLabel:'Harta Bersih Dibagi', heroValue:HC.fmt(c.bersih), heroSubtext:c.statusLabel+' \u00b7 QS An-Nisa 11-12', inputs:[ {label:'\ud83d\udcb0 Total Harta',value:HC.fmt(c.harta)}, {label:'\ud83d\udcb3 Hutang',value:HC.fmt(c.hutang)}, {label:'\u26b0\ufe0f Pemakaman',value:HC.fmt(c.makam)}, {label:'\ud83d\udcdc Wasiat',value:HC.fmt(c.wasiat)} ], results:results, insight:'Hasil ESTIMASI berbasis hukum faraidh (jumhur). Kasus kompleks (kakek + saudara, kalalah, khuntsa) WAJIB dikonsultasikan ke Pengadilan Agama atau ahli faraidh.', slug:'warisan-faraidh' }); }

      function summaryText(){ if(!lastCalc) return ''; var c=lastCalc; var s='\ud83d\udcd6 *Warisan Faraidh - HitungCerdas*\n\nHarta bersih dibagi: '+HC.fmt(c.bersih)+'\n\n*Pembagian:*\n'; c.rows.forEach(function(x){ s+='\u2022 '+x.label+(x.count>1?(' x'+x.count):'')+': '+x.amountTxt+' ('+x.fracTxt+')\n'; }); s+='\n\u26a0\ufe0f Estimasi. Konsultasi Pengadilan Agama untuk pembagian resmi.\nHitung: https://hitungcerdas.net/kalkulator/warisan-faraidh'; return s; }

      $('status').addEventListener('change', syncIstri);
      $('pasangan').addEventListener('change', syncIstri);
      $('btnHitung').addEventListener('click', hitung);
      $('btnReset').addEventListener('click', reset);
      $('exportImg').addEventListener('click', function(){ var r=buildReport(); if(r) HC.exportToImage(r,'warisan-'+Date.now()); else HC.toast('Hitung dulu','error'); });
      $('exportWa').addEventListener('click', function(){ var r=buildReport(); if(r) HC.shareWhatsApp(r, summaryText(), 'warisan-faraidh'); else HC.toast('Hitung dulu','error'); });
      $('exportPdf').addEventListener('click', function(){ if(lastCalc) HC.exportToPDF(); else HC.toast('Hitung dulu','error'); });
      $('exportCopy').addEventListener('click', function(){ if(lastCalc) HC.copyText(summaryText(),'Tersalin!'); else HC.toast('Hitung dulu','error'); });
      $('exportExcel').addEventListener('click', function(){ var c=buildReport(); if(!c){ HC.toast('Hitung dulu','error'); return; } HC.exportToExcel(c,'warisan-faraidh-'+Date.now()); });
      syncIstri();
    });
  })();
</script>

<script is:inline>
  (function(){
    var LIMIT = 10;
    function ready(fn){ if(window.HC){ fn(); } else { setTimeout(function(){ready(fn);},120); } }
    function $(id){ return document.getElementById(id); }
    ready(function(){
      var wrap=$('aicWrap'); if(!wrap) return;
      var trigger=$('aicTrigger'), panel=$('aicPanel'), ground=$('aicGround'), msgs=$('aicMsgs'), chips=$('aicChips');
      var input=$('aicText'), send=$('aicSend'), limitEl=$('aicLimit'); var history=[];
      function isDark(){ var de=document.documentElement; return de.classList.contains('dark')||de.getAttribute('data-theme')==='dark'||(function(){try{return localStorage.getItem('hc-theme')==='dark';}catch(e){return false;}})(); }
      function applyTheme(){ wrap.classList.toggle('aic-dark', isDark()); }
      applyTheme();
      try{ new MutationObserver(applyTheme).observe(document.documentElement,{attributes:true,attributeFilter:['class','data-theme']}); }catch(e){}
      window.addEventListener('storage', function(e){ if(e.key==='hc-theme') applyTheme(); });
      function num(v){ try{ return HC.parseRp(String(v||'')); }catch(e){ return 0; } }
      function selText(id){ var x=$(id); return (x&&x.options&&x.selectedIndex>=0)?x.options[x.selectedIndex].text:''; }
      function esc(t){ return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }


      function renderGround(){
        var FRCOLORS=['#DC2626','#EA580C','#D97706','#16A34A','#0891B2','#2563EB'];
        var d=window.HCFaraidh;
        var ctx='<div class="aic-ctx"><i class="ti ti-book"></i> Warisan Faraidh</div>';
        if(!d || d.guard || !d.rows || !d.rows.length){ ground.innerHTML=ctx+'<div class="aic-nogauge">Hitung dulu untuk melihat ringkasan pembagian.</div>'; return; }
        var bars='';
        d.rows.slice(0,6).forEach(function(r,i){ bars+='<div style="margin:5px 0"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:2px"><span>'+esc(r.label)+'</span><b>'+esc(r.amountTxt)+'</b></div><div style="height:7px;border-radius:5px;background:#E5EAF1;overflow:hidden"><div style="height:100%;width:'+Math.max(2,r.pct).toFixed(1)+'%;background:'+FRCOLORS[i%FRCOLORS.length]+'"></div></div></div>'; });
        ground.innerHTML=ctx+'<div style="margin:8px 0">'+bars+'</div><div class="aic-verdict info"><i class="ti ti-info-circle"></i> Harta bersih <b>'+esc(d.bersihTxt)+'</b> dibagi sesuai ketentuan faraidh.</div>';
      }
      function buildContext(){
        var d=window.HCFaraidh;
        if(!d) return 'Pengguna belum menghitung. Minta mereka mengisi data ahli waris lalu klik Hitung Sekarang.';
        if(d.guard) return 'Kasus kakek bersama saudara kandung (jadd wal ikhwah) adalah masalah khilafiyah yang rumit. JANGAN menghitung angka apa pun. Arahkan pengguna untuk konsultasi ke Pengadilan Agama atau ahli faraidh.';
        var lines=['Kalkulator: Warisan Faraidh (hukum waris Islam, mazhab jumhur/Syafii).','Harta bersih yang dibagi: '+d.bersihTxt+'.','Hasil pembagian final dari mesin kalkulator:'];
        (d.rows||[]).forEach(function(r){ lines.push('- '+r.label+(r.count>1?(' ('+r.count+' orang)'):'')+': '+r.amountTxt+' (bagian '+r.fracTxt+').'); });
        if(d.umar) lines.push('Catatan: kasus Umariyyatan, ibu mendapat 1/3 dari sisa setelah bagian pasangan.');
        if(d.method&&d.method.indexOf('aul')>=0) lines.push("Catatan: terjadi 'aul, total bagian melebihi 1 sehingga semua diturunkan proporsional.");
        if(d.method&&d.method.indexOf('radd')>=0) lines.push('Catatan: terjadi radd, sisa dikembalikan ke ahli waris berhak kecuali suami/istri.');
        lines.push('ATURAN UNTUKMU (AI): Gunakan HANYA angka di atas. DILARANG mengarang, mengubah, atau menghitung ulang angka. Tugasmu menjelaskan ALASAN dan dalil pembagian dengan bahasa sederhana dan menenangkan. Ini edukasi, BUKAN fatwa resmi. Untuk kasus rumit atau sengketa, selalu arahkan ke Pengadilan Agama atau ahli faraidh. Jangan menjawab di luar topik warisan Islam.');
        return lines.join('\n');
      }
      function mdInline(t){ t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); t=t.replace(/__([^_]+)__/g,'<strong>$1</strong>'); t=t.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g,'$1<em>$2</em>'); t=t.replace(/`([^`]+)`/g,'<code>$1</code>'); return t; }
      function mdToHtml(raw){ var lines=String(raw).replace(/\r/g,'').split('\n'); var out=[]; for(var i=0;i<lines.length;i++){ var t=lines[i].trim(); if(t==='')continue; if(/^([-*_]\s*){3,}$/.test(t))continue; var h=t.match(/^#{1,6}\s+(.*)$/); if(h){out.push('<p class="aic-h">'+mdInline(esc(h[1]))+'</p>');continue;} var b=t.match(/^[-*\u2022]\s+(.*)$/); if(b){out.push('<div class="aic-li"><span class="aic-mk">\u2022</span><span>'+mdInline(esc(b[1]))+'</span></div>');continue;} var n=t.match(/^(\d+)[.)]\s+(.*)$/); if(n){out.push('<div class="aic-li"><span class="aic-mk">'+n[1]+'.</span><span>'+mdInline(esc(n[2]))+'</span></div>');continue;} out.push('<p>'+mdInline(esc(t))+'</p>'); } return out.join('')||('<p>'+mdInline(esc(String(raw)))+'</p>'); }
      // ── UI canggih: typewriter (live-format) + copy + chip lanjutan ──
      function typeInto(bubble, text, done){
        var n=0, len=text.length, step=Math.max(2, Math.round(len/90));
        var t=setInterval(function(){
          n=Math.min(len, n+step);
          bubble.innerHTML=mdToHtml(text.slice(0,n));
          msgs.scrollTop=msgs.scrollHeight;
          if(n>=len){ clearInterval(t); done&&done(); }
        }, 18);
      }
      function mkCopyBtn(text){
        var b=document.createElement('button'); b.type='button'; b.className='aic-copy';
        b.innerHTML='<i class="ti ti-copy"></i><span>Salin</span>';
        b.addEventListener('click', function(){ HC.copyText(text, 'Jawaban tersalin!'); });
        return b;
      }
      function addMsgTyped(text){
        var row=document.createElement('div'); row.className='aic-row ai';
        row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>';
        var bub=row.querySelector('.aic-bub'); msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight;
        typeInto(bub, text, function(){ bub.appendChild(mkCopyBtn(text)); renderFollowups(); });
        return row;
      }
      var FOLLOWUPS=['Kenapa anak laki 2x anak perempuan?','Apa itu ashabah?','Apa dasar hukum pembagian ini?','Bagaimana posisi cucu dalam warisan?','Kapan harus ke Pengadilan Agama?','Apa beda dengan dibagi rata?'];
      function renderFollowups(){
        chips.innerHTML='';
        var asked=history.filter(function(m){return m.role==='user';}).map(function(m){return m.content;});
        var pool=FOLLOWUPS.filter(function(q){return asked.indexOf(q)<0;});
        pool.slice(0,3).forEach(function(q){
          var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q;
          b.addEventListener('click', function(){ ask(q); }); chips.appendChild(b);
        });
      }
      function addMsg(role,text){ var row=document.createElement('div'); row.className='aic-row '+role; if(role==='ai'){ row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-rich"></div>'; row.querySelector('.aic-bub').innerHTML=mdToHtml(text); } else { row.innerHTML='<div class="aic-bub"></div>'; row.querySelector('.aic-bub').textContent=text; } msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function addTyping(){ var row=document.createElement('div'); row.className='aic-row ai'; row.innerHTML='<div class="aic-av"><i class="ti ti-sparkles"></i></div><div class="aic-bub aic-typing"><span></span><span></span><span></span></div>'; msgs.appendChild(row); msgs.scrollTop=msgs.scrollHeight; return row; }
      function todayKey(){ var d=new Date(); return 'hc-coach-'+d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate(); }
      function getCount(){ try{ return parseInt(localStorage.getItem(todayKey())||'0',10)||0; }catch(e){ return 0; } }
      function incCount(){ try{ localStorage.setItem(todayKey(), getCount()+1); }catch(e){} }
      function refreshLimit(){ var left=Math.max(0,LIMIT-getCount()); limitEl.textContent='Sisa '+left+' pertanyaan gratis hari ini.'; var done=left<=0; input.disabled=done; send.disabled=done; if(done){ input.placeholder='Batas harian tercapai, balik lagi besok ya.'; } }
      var busy=false;
      async function ask(text){ text=(text||'').trim(); if(!text||busy)return; if(getCount()>=LIMIT){refreshLimit();return;} busy=true; send.disabled=true; addMsg('user',text); history.push({role:'user',content:text}); input.value=''; chips.innerHTML=''; var typing=addTyping(); incCount();
        try{ var res=await fetch('/api/coach',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({calcContext:buildContext(),messages:history})}); var data=await res.json().catch(function(){return {error:'Respon tidak valid.'};}); typing.parentNode&&typing.remove(); if(data&&data.reply){ addMsgTyped(data.reply); history.push({role:'assistant',content:data.reply}); } else { addMsg('ai','\u26a0\ufe0f '+((data&&data.error)||'Coach lagi sibuk, coba lagi sebentar ya.')); } }
        catch(e){ typing.parentNode&&typing.remove(); addMsg('ai','\u26a0\ufe0f Gagal terhubung ke Coach. Coba lagi ya.'); }
        busy=false; refreshLimit(); if(!input.disabled) input.focus(); }
      var PRESETS=['Jelaskan pembagian ini','Kenapa bagiannya segini?','Apa dasar hukumnya?'];
      function renderChips(){ chips.innerHTML=''; PRESETS.forEach(function(q){ var b=document.createElement('button'); b.type='button'; b.className='aic-chip'; b.textContent=q; b.addEventListener('click',function(){ask(q);}); chips.appendChild(b); }); }
      var opened=false;
      trigger.addEventListener('click', function(){ if(panel.hasAttribute('hidden')){ panel.removeAttribute('hidden'); wrap.classList.add('open'); applyTheme(); renderGround(); refreshLimit(); if(!opened){renderChips();opened=true;} } else { panel.setAttribute('hidden',''); wrap.classList.remove('open'); } });
      send.addEventListener('click', function(){ ask(input.value); });
      input.addEventListener('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); ask(input.value); } });
      var bh=$('btnHitung'); if(bh){ bh.addEventListener('click', function(){ setTimeout(function(){ if(!panel.hasAttribute('hidden')) renderGround(); },60); }); }
    });
  })();
</script>
