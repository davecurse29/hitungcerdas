---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import AdSlot from '../../components/AdSlot.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getCalculatorBySlug, getRelatedCalculators } from '../../data/calculators';

const calc = getCalculatorBySlug('warisan-faraidh')!;
const related = getRelatedCalculators('warisan-faraidh', 3);

const faqs = [
  { question: 'Dasar hukum waris Islam?', answer: 'QS An-Nisa 11-12 (pembagian rinci), An-Nisa 176 (kalalah), serta hadits Nabi. Pembagian bersifat presisi matematis dan disebut ilmu faraidh.' },
  { question: 'Urutan penyelesaian?', answer: '1) Biaya pengurusan jenazah, 2) Pelunasan hutang almarhum, 3) Wasiat (maksimal 1/3 sisa, bukan untuk ahli waris), 4) Sisa dibagi ke ahli waris faraidh.' },
  { question: 'Anak laki vs perempuan?', answer: 'Kaidah dasar QS An-Nisa 11: <strong>anak laki = 2x anak perempuan</strong>. Alasan: laki-laki memikul kewajiban nafkah, perempuan tidak.' },
  { question: 'Bagian suami/istri?', answer: '<strong>Suami</strong>: 1/2 (tanpa keturunan), 1/4 (ada keturunan). <strong>Istri</strong>: 1/4 (tanpa keturunan), 1/8 (ada keturunan). Jika beberapa istri, bagian itu dibagi rata.' },
  { question: 'Apa itu aul dan radd?', answer: '<strong>Aul</strong>: bila total bagian melebihi 1, semua bagian diturunkan proporsional agar pas 100%. <strong>Radd</strong>: bila masih ada sisa dan tidak ada ahli waris ashabah, sisa dikembalikan ke ahli waris berhak, kecuali suami/istri. Kalkulator ini menangani keduanya otomatis.' },
  { question: 'Kapan WAJIB ke Pengadilan Agama?', answer: 'Kasus kompleks: kakek bersama saudara (jadd wal ikhwah), kalalah berlapis, anak angkat, khuntsa, ahli waris hilang (mafqud), atau ada sengketa. Pembagian resmi dan eksekusinya memerlukan putusan Pengadilan Agama.' },
];

const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Kalkulator', href: '/#tools' }, { label: calc.shortTitle }];
---

<Layout title={calc.title} description={calc.metaDescription} keywords={calc.keywords} canonical={`https://hitungcerdas.net/kalkulator/${calc.slug}`}>
  <section class="calc-hero" style="--cat-color:#DC2626;--cat-color2:#991B1B">
    <div class="wrap">
      <Breadcrumb items={bcItems} />
      <div class="calc-hero-grid">
        <div class="calc-hero-text">
          <div class="calc-hero-tag" style="background:#FEE2E2;color:#991B1B"><i class="ti ti-book"></i> {calc.categoryLabel}</div>
          <h1 class="calc-hero-title">{calc.h1}</h1>
          <p class="calc-hero-sub">{calc.introText}</p>
          <ul class="calc-hero-benefits">{calc.benefits.map(b => <li><i class="ti ti-check"></i> {b}</li>)}</ul>
        </div>
        <div class="calc-hero-illust">
          <svg viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" fill="rgba(255,255,255,.08)"/>
            <rect x="55" y="50" width="90" height="110" rx="6" fill="#FFF" stroke="#FBBF24" stroke-width="2.5"/>
            <rect x="65" y="65" width="70" height="3" fill="#0A2540"/>
            <rect x="65" y="75" width="50" height="2" fill="#94A3B8"/>
            <rect x="65" y="82" width="65" height="2" fill="#94A3B8"/>
            <circle cx="100" cy="135" r="14" fill="#FBBF24"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <section class="calc-section">
    <div class="wrap">
      <div class="calc-card">
        <div class="calc-card-hdr">
          <div class="calc-card-hdr-ic" style="background:linear-gradient(135deg,#DC2626 0%,#991B1B 100%)"><i class="ti ti-book"></i></div>
          <div><h2 class="calc-card-title">Kalkulator Warisan Faraidh</h2><p class="calc-card-sub">Pembagian sesuai QS An-Nisa 11-12 (mazhab jumhur)</p></div>
        </div>

        <div class="calc-grid">
          <div class="calc-input">
            <div class="fr-grp">Harta &amp; Kewajiban</div>
            <div class="field"><label>Total Harta Peninggalan</label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="harta" class="has-prefix" value="500.000.000" inputmode="numeric" /></div></div>
            <div class="field-row">
              <div class="field"><label>Hutang Almarhum</label>
                <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="hutang" class="has-prefix" placeholder="0" inputmode="numeric" /></div></div>
              <div class="field"><label>Biaya Pemakaman</label>
                <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="makam" class="has-prefix" value="10.000.000" inputmode="numeric" /></div></div>
            </div>
            <div class="field"><label>Wasiat <span class="hint">(maks 1/3 sisa)</span></label>
              <div class="input-wrap"><span class="input-prefix">Rp</span><input type="text" id="wasiat" class="has-prefix" placeholder="0" inputmode="numeric" /></div></div>

            <div class="fr-grp">Pasangan</div>
            <div class="field-row">
              <div class="field"><label>Jenis Kelamin Almarhum</label>
                <select id="status"><option value="suami">Laki-laki</option><option value="istri">Perempuan</option></select></div>
              <div class="field"><label>Pasangan Masih Hidup?</label>
                <select id="pasangan"><option value="ya">Ya</option><option value="tidak">Tidak</option></select></div>
            </div>
            <div class="field" id="istriNWrap"><label>Jumlah Istri <span class="hint">(poligami, 1-4)</span></label>
              <input type="number" id="istriN" value="1" min="1" max="4" /></div>

            <div class="fr-grp">Keturunan</div>
            <div class="field-row">
              <div class="field"><label>Anak Laki-laki</label><input type="number" id="anakL" value="1" min="0" max="20" /></div>
              <div class="field"><label>Anak Perempuan</label><input type="number" id="anakP" value="1" min="0" max="20" /></div>
            </div>
            <div class="field-row">
              <div class="field"><label>Cucu Laki <span class="hint">(dari anak laki)</span></label><input type="number" id="cucuL" value="0" min="0" max="20" /></div>
              <div class="field"><label>Cucu Perempuan <span class="hint">(dari anak laki)</span></label><input type="number" id="cucuP" value="0" min="0" max="20" /></div>
            </div>

            <div class="fr-grp">Orang Tua &amp; Kakek-Nenek</div>
            <div class="field-row">
              <div class="field"><label>Ayah</label><select id="ayah"><option value="ya">Hidup</option><option value="tidak" selected>Meninggal</option></select></div>
              <div class="field"><label>Ibu</label><select id="ibu"><option value="ya">Hidup</option><option value="tidak" selected>Meninggal</option></select></div>
            </div>
            <div class="field-row">
              <div class="field"><label>Kakek <span class="hint">(dari ayah)</span></label><select id="kakek"><option value="ya">Hidup</option><option value="tidak" selected>Meninggal</option></select></div>
              <div class="field"><label>Nenek</label><select id="nenek"><option value="ya">Hidup</option><option value="tidak" selected>Meninggal</option></select></div>
            </div>

            <div class="fr-grp">Saudara <span style="text-transform:none;font-weight:500;color:var(--text-mute)">(berlaku bila tanpa anak &amp; ayah)</span></div>
            <div class="field-row">
              <div class="field"><label>Saudara Kandung Laki</label><input type="number" id="skL" value="0" min="0" max="20" /></div>
              <div class="field"><label>Saudara Kandung Pr</label><input type="number" id="skP" value="0" min="0" max="20" /></div>
            </div>
            <div class="field"><label>Saudara Seibu <span class="hint">(beda ayah)</span></label><input type="number" id="seibu" value="0" min="0" max="20" /></div>

            <div class="calc-action-bar">
              <button type="button" class="btn-hitung" id="btnHitung"><i class="ti ti-calculator"></i> Hitung Sekarang</button>
              <button type="button" class="btn-reset" id="btnReset"><i class="ti ti-refresh"></i> Reset</button>
            </div>
          </div>

          <div class="calc-output">
            <div class="result-placeholder" id="placeholder">
              <i class="ti ti-book result-placeholder-icon"></i>
              <div class="result-placeholder-title">Hasil akan muncul di sini</div>
              <div class="result-placeholder-desc">Lengkapi data ahli waris, lalu klik <strong>"Hitung Sekarang"</strong>.</div>
            </div>

            <div class="result-wrapper" id="results">
              <div class="result-main">
                <div class="result-label">Harta Bersih Dibagi</div>
                <div class="result-value" id="hartaBersih">Rp 0</div>
                <div class="result-meta"><i class="ti ti-info-circle"></i> <span id="setelahPotongan">Setelah hutang, makam, wasiat</span></div>
              </div>

              <div class="fr-guard" id="guardBox">
                <h4><i class="ti ti-alert-triangle"></i> Perlu Kajian Khusus</h4>
                <p>Kombinasi <strong>kakek + saudara kandung</strong> (jadd wal ikhwah) termasuk masalah khilafiyah yang penyelesaiannya berbeda antar ulama. Demi keamanan, kalkulator tidak menghitung kasus ini. Silakan konsultasi ke <strong>Pengadilan Agama</strong> atau ahli faraidh.</p>
              </div>

              <div id="resultBody">
                <div class="fr-wasiat-note" id="wasiatNote"></div>

                <div class="fr-subhead"><i class="ti ti-chart-bar"></i> Visualisasi Pembagian</div>
                <div class="fr-chart" id="chart"></div>

                <div class="kelayakan-box">
                  <div class="kelayakan-hdr"><i class="ti ti-users"></i> <span>Rincian per Ahli Waris</span></div>
                  <div id="pembagian" style="margin-top:4px"></div>
                </div>

                <div class="fr-subhead"><i class="ti ti-list-numbers"></i> Langkah Perhitungan</div>
                <div id="langkah"></div>
              </div>

              <div class="kelayakan-box" style="background:var(--gold-light);border-color:var(--gold-dark)">
                <div class="kelayakan-hdr" style="color:var(--gold-dark)"><i class="ti ti-alert-circle"></i> <span>Disclaimer</span></div>
                <div style="font-size:12px;line-height:1.6;color:var(--text)">
                  Hasil <strong>estimasi edukatif</strong> berbasis mazhab jumhur. Cakupan: pasangan, anak, cucu (dari anak laki), orang tua, kakek-nenek, saudara kandung &amp; seibu. <strong>Belum mencakup</strong> saudara seayah, khuntsa, mafqud, &amp; dzawil arham. Untuk pembagian resmi atau sengketa, <strong>WAJIB</strong> ke <strong>Pengadilan Agama</strong> atau ahli faraidh.
                </div>
              </div>

              <div class="export-row">
                <button class="export-btn img" id="exportImg"><i class="ti ti-photo-down"></i><span>Save Image</span></button>
                <button class="export-btn wa" id="exportWa"><i class="ti ti-brand-whatsapp"></i><span>Share WA</span></button>
                <button class="export-btn pdf" id="exportPdf"><i class="ti ti-printer"></i><span>Print/PDF</span></button>
                <button class="export-btn copy" id="exportCopy"><i class="ti ti-copy"></i><span>Copy Teks</span></button>
                <button type="button" class="export-btn" id="exportExcel"><i class="ti ti-file-spreadsheet" style="color:#1D6F42"></i><span style="color:#1D6F42">Excel</span></button>
              </div>

              <!-- ===== AI COACH FARAIDH ===== -->
              <div class="aic-wrap" id="aicWrap">
                <button type="button" class="aic-trigger" id="aicTrigger">
                  <span class="aic-trigger-ic"><i class="ti ti-sparkles"></i></span>
                  <span class="aic-trigger-txt">
                    <strong>Tanya AI Coach</strong>
                    <small>Bingung pembagiannya? Tanya di sini</small>
                  </span>
                  <i class="ti ti-chevron-down aic-trigger-arr"></i>
                </button>
                <div class="aic-panel" id="aicPanel" hidden>
                  <div class="aic-head">
                    <span class="aic-head-ic"><i class="ti ti-sparkles"></i></span>
                    <div class="aic-head-tt">
                      <strong>AI Coach Faraidh</strong>
                      <small>Bantu pahami pembagian warismu</small>
                    </div>
                    <span class="aic-badge">BETA</span>
                  </div>
                  <div class="aic-ground" id="aicGround"></div>
                  <div class="aic-msgs" id="aicMsgs"></div>
                  <div class="aic-chips" id="aicChips"></div>
                  <div class="aic-input">
                    <input type="text" id="aicText" placeholder="Tanya soal pembagian warisan..." maxlength="600" autocomplete="off" />
                    <button type="button" id="aicSend" aria-label="Kirim"><i class="ti ti-arrow-up"></i></button>
                  </div>
                  <div class="aic-disc">
                    <i class="ti ti-info-circle"></i>
                    <span>Penjelasan edukatif berbasis hasil hitunganmu, bukan fatwa resmi.</span>
                  </div>
                  <div class="aic-limit" id="aicLimit"></div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="wrap-text">
      <h2>Memahami Hukum Waris Islam (Faraidh)</h2>
      <p>Faraidh adalah ilmu pembagian warisan berdasarkan QS An-Nisa 11-12. Sebelum dibagi: pengurusan jenazah, lalu hutang, lalu wasiat (maksimal 1/3 sisa), baru ahli waris. Anak laki memperoleh 2x bagian anak perempuan karena tanggung jawab nafkah. Pelajari lebih dalam di <a href="/blog/panduan-warisan-faraidh">panduan lengkap warisan faraidh</a>. Mengelola harta sesuai syariat? Hitung juga <a href="/kalkulator/zakat-mal">zakat mal</a> atas harta yang mencapai nisab, dan rencanakan <a href="/kalkulator/dana-haji-umrah">dana haji</a>.</p>
      <div class="cta-box"><h3>Konsultasi Pengadilan Agama</h3><p>Untuk pembagian resmi dan sengketa, hubungi Pengadilan Agama setempat atau ulama spesialis faraidh.</p></div>
    </div>
  </section>

  <AdSlot format="horizontal" />
  <FAQ items={faqs} />

  <section class="section"><div class="wrap">
    <div class="section-hdr"><div class="section-eyebrow">Kalkulator Lainnya</div><h2 class="section-title">Hitung Juga yang Lain</h2></div>
    <div class="related-grid">{related.map(c => <CalculatorCard calc={c} />)}</div>
  </div></section>
  <p class="hc-method-note" style="text-align:center;font-size:.85rem;color:#64748b;margin:1.2rem auto;max-width:680px;line-height:1.6;padding:0 1rem;">
    📅 Diperbarui <strong>Juni 2026</strong> · Pembagian mengikuti ketentuan faraidh dalam Al-Qur&rsquo;an (QS An-Nisa) &amp; Kompilasi Hukum Islam (KHI). Estimasi edukatif; untuk kasus kompleks atau sengketa, konsultasikan ahli faraidh atau Pengadilan Agama. <strong>Sumber:</strong> Kompilasi Hukum Islam (KHI).
  </p>
</Layout>

<style>
  .fr-grp{margin:14px 0 4px;font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#DC2626;display:flex;align-items:center;gap:7px}
  .fr-grp:first-child{margin-top:0}
  .fr-grp::before{content:'';width:14px;height:2px;border-radius:2px;background:currentColor;opacity:.55}
  .fr-guard{display:none;background:#FEF3C7;border:1px solid #FBBF24;border-radius:14px;padding:16px;margin:14px 0}
  .fr-guard h4{margin:0 0 6px;color:#92400E;font-size:15px;display:flex;align-items:center;gap:8px}
  .fr-guard p{margin:0;font-size:13px;line-height:1.6;color:#78350F}
  .fr-wasiat-note{display:none;font-size:12px;color:#92400E;background:#FEF3C7;border-radius:10px;padding:8px 11px;margin:12px 0 4px;line-height:1.5}
  .fr-subhead{display:flex;align-items:center;gap:7px;font-size:13px;font-weight:700;color:var(--text);margin:16px 0 8px}
  .fr-subhead i{color:#DC2626}
  .fr-chart{margin:2px 0 6px}
  .fr-bar-row{margin:10px 0}
  .fr-bar-top{display:flex;justify-content:space-between;align-items:baseline;font-size:13px;margin-bottom:4px;gap:8px}
  .fr-bar-name{font-weight:600;color:var(--text)}
  .fr-bar-val{font-weight:700;color:var(--text);white-space:nowrap}
  .fr-bar-track{height:11px;border-radius:6px;background:var(--soft,#F1F5F9);overflow:hidden}
  .fr-bar-fill{height:100%;border-radius:6px;transition:width .5s ease;min-width:3px}
  .fr-bar-sub{font-size:11.5px;color:var(--text-mute);margin-top:3px}
  .fr-trow{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px;gap:10px}
  .fr-trow.fr-total{font-weight:700;color:#DC2626;border-bottom:none;padding-top:9px}
  .fr-steps{margin:4px 0 0;padding-left:20px;font-size:12.5px;line-height:1.7;color:var(--text)}
  .fr-steps li{margin-bottom:6px}
</style>

<style is:global>
  .aic-wrap{margin-top:18px}
  .aic-trigger{width:100%;display:flex;align-items:center;gap:12px;background:#EFF4FF;border:1px solid #C7DBFF;border-radius:14px;padding:13px 15px;cursor:pointer;text-align:left;transition:background .15s;font-family:inherit}
  .aic-trigger:hover{background:#E4EDFF}
  .aic-trigger-ic{width:36px;height:36px;flex-shrink:0;border-radius:50%;background:#2563EB;color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px}
  .aic-trigger-txt{flex:1;display:flex;flex-direction:column;line-height:1.25}
  .aic-trigger-txt strong{font-size:14px;color:#0A2540}
  .aic-trigger-txt small{font-size:12px;color:#64748B}
  .aic-trigger-arr{font-size:18px;color:#64748B;transition:transform .2s}
  .aic-wrap.open .aic-trigger-arr{transform:rotate(180deg)}

  .aic-panel{margin-top:10px;background:#fff;border:1px solid #E5EAF1;border-radius:16px;overflow:hidden;animation:aicIn .2s ease}
  @keyframes aicIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .aic-head{display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #E5EAF1}
  .aic-head-ic{width:30px;height:30px;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:16px}
  .aic-head-tt{flex:1;display:flex;flex-direction:column;line-height:1.2}
  .aic-head-tt strong{font-size:14px;color:#0A2540}
  .aic-head-tt small{font-size:11px;color:#64748B}
  .aic-badge{font-size:10px;font-weight:700;background:#EFF4FF;color:#2563EB;padding:2px 8px;border-radius:8px}

  .aic-ground{padding:12px 14px;border-bottom:1px solid #E5EAF1;background:#F8FAFC}
  .aic-ctx{font-size:12px;color:#475569;margin-bottom:10px}
  .aic-ctx b{color:#0A2540;font-weight:700}
  .aic-gauge{position:relative;padding-top:19px}
  .aic-gauge-mark{position:absolute;top:0;z-index:3}
  .aic-gauge-mark span{display:block;font-size:10px;font-weight:700;background:#0A2540;color:#fff;padding:1px 7px;border-radius:9px;white-space:nowrap;transform:translateX(-50%)}
  .aic-gauge-mark::after{content:"";position:absolute;left:0;top:15px;width:2px;height:15px;background:#0A2540}
  .aic-gauge-bar{display:flex;height:10px;border-radius:5px;overflow:hidden}
  .aic-gauge-bar .z-green{flex:0 0 60%;background:#D1FAE5}
  .aic-gauge-bar .z-amber{flex:0 0 20%;background:#FEF3C7}
  .aic-gauge-bar .z-red{flex:0 0 20%;background:#FEE2E2}
  .aic-gauge-lbl{display:flex;font-size:10px;margin-top:5px}
  .aic-gauge-lbl .g{flex:0 0 60%;color:#059669}
  .aic-gauge-lbl .a{flex:0 0 20%;text-align:center;color:#D97706;font-weight:600}
  .aic-gauge-lbl .r{flex:0 0 20%;text-align:right;color:#DC2626}
  .aic-verdict{font-size:12.5px;font-weight:600;margin-top:11px;display:flex;align-items:center;gap:6px}
  .aic-verdict.good{color:#059669}
  .aic-verdict.warn{color:#D97706}
  .aic-verdict.bad{color:#DC2626}
  .aic-nogauge{font-size:11px;color:#94A3B8;padding:4px 0}

  .aic-msgs{padding:12px 14px;display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto}
  .aic-msgs:empty{display:none}
  .aic-row{display:flex;gap:8px;align-items:flex-start}
  .aic-row.user{justify-content:flex-end}
  .aic-av{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:#EFF4FF;color:#2563EB;display:flex;align-items:center;justify-content:center;font-size:13px}
  .aic-bub{max-width:82%;font-size:13px;line-height:1.55;border-radius:13px;padding:9px 12px;white-space:pre-wrap;word-wrap:break-word;overflow-wrap:anywhere}
  .aic-row.ai .aic-bub{background:#F1F5F9;color:#0A2540}
  .aic-row.user .aic-bub{background:#2563EB;color:#fff}
  .aic-bub.aic-rich{white-space:normal}
  .aic-bub.aic-rich p{margin:0 0 7px}
  .aic-bub.aic-rich p:last-child{margin-bottom:0}
  .aic-bub.aic-rich p.aic-h{font-weight:700;margin:10px 0 5px}
  .aic-bub.aic-rich p.aic-h:first-child{margin-top:0}
  .aic-bub.aic-rich strong{font-weight:700}
  .aic-bub.aic-rich em{font-style:italic}
  .aic-bub.aic-rich code{background:rgba(0,0,0,.06);padding:1px 5px;border-radius:4px;font-size:12px}
  .aic-bub.aic-rich .aic-li{display:flex;gap:7px;margin:4px 0;align-items:flex-start}
  .aic-bub.aic-rich .aic-li:first-child{margin-top:0}
  .aic-bub.aic-rich .aic-mk{flex-shrink:0;color:#2563EB;font-weight:700;min-width:15px}
  .aic-typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#94A3B8;margin:0 1px;animation:aicblink 1.2s infinite}
  .aic-typing span:nth-child(2){animation-delay:.2s}
  .aic-typing span:nth-child(3){animation-delay:.4s}
  @keyframes aicblink{0%,60%,100%{opacity:.3}30%{opacity:1}}
