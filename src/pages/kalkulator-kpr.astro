---
// src/pages/kalkulator-kpr.astro
// Kalkulator KPR Pro — Premium calculator with amortization, prepayment, charts
import CalculatorLayout from '../components/CalculatorLayout.astro';
---

<CalculatorLayout
  title="Kalkulator KPR — Hitung Cicilan, Bunga & Simulasi Pelunasan KPR Rumah"
  description="Kalkulator KPR online gratis. Hitung cicilan KPR, total bunga, simulasi pelunasan sebagian (prepayment), dan lihat tabel amortisasi lengkap per bulan."
  icon="🏠"
  category="KALKULATOR KEUANGAN"
  categoryColor="blue"
  breadcrumb={[
    { label: 'Kalkulator Keuangan', href: '/kalkulator-keuangan' },
    { label: 'Kalkulator KPR' }
  ]}
>

  <!-- Main Calculator Section -->
  <div class="calc-grid">
    <!-- LEFT: Input Form -->
    <div class="calc-panel">
      <h3>Detail KPR</h3>

      <div class="form-group">
        <label class="form-label">Harga Properti</label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="harga" class="form-input" value="500.000.000" inputmode="numeric" data-format="rupiah" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Uang Muka (DP) <span class="form-hint">%</span></label>
          <div class="form-input-suffix">
            <input type="number" id="dpPersen" class="form-input" value="20" min="0" max="100" step="1" />
            <span class="suffix">%</span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tenor</label>
          <div class="form-input-suffix">
            <input type="number" id="tenor" class="form-input" value="15" min="1" max="30" step="1" />
            <span class="suffix">tahun</span>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Jenis Bunga</label>
        <select id="jenisBunga" class="form-input">
          <option value="fixed">Fixed (bunga tetap sepanjang tenor)</option>
          <option value="floating">Floating (mengikuti BI rate)</option>
          <option value="fixToFloat" selected>Fix-to-Floating (umum di bank)</option>
        </select>
      </div>

      <div class="form-row" id="fixedRateGroup">
        <div class="form-group">
          <label class="form-label">Bunga Fix <span class="form-hint">tahun 1-N</span></label>
          <div class="form-input-suffix">
            <input type="number" id="bungaFix" class="form-input" value="6.5" min="0" max="30" step="0.1" />
            <span class="suffix">%</span>
          </div>
        </div>
        <div class="form-group" id="periodeGroup">
          <label class="form-label">Periode Fix</label>
          <div class="form-input-suffix">
            <input type="number" id="periodeFix" class="form-input" value="3" min="1" max="10" step="1" />
            <span class="suffix">tahun</span>
          </div>
        </div>
      </div>

      <div class="form-group" id="floatingRateGroup">
        <label class="form-label">Bunga Floating <span class="form-hint">setelah periode fix</span></label>
        <div class="form-input-suffix">
          <input type="number" id="bungaFloat" class="form-input" value="10.5" min="0" max="30" step="0.1" />
          <span class="suffix">%</span>
        </div>
      </div>

      <details class="advanced-toggle">
        <summary>Biaya tambahan (opsional)</summary>
        <div class="form-row" style="margin-top: 12px;">
          <div class="form-group">
            <label class="form-label">Biaya Provisi <span class="form-hint">% pokok</span></label>
            <div class="form-input-suffix">
              <input type="number" id="provisi" class="form-input" value="1" min="0" max="5" step="0.1" />
              <span class="suffix">%</span>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Biaya Admin</label>
            <div class="form-input-prefix">
              <span class="prefix">Rp</span>
              <input type="text" id="admin" class="form-input" value="5.000.000" inputmode="numeric" data-format="rupiah" />
            </div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Asuransi (Jiwa + Kebakaran) <span class="form-hint">per bulan</span></label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="asuransi" class="form-input" value="500.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </details>

      <div class="info-box">
        <span class="info-box-icon">ℹ️</span>
        <div>
          <strong>Tip:</strong> Bank Indonesia umumnya pakai sistem <em>Fix-to-Floating</em>. Bunga rendah di tahun-tahun awal lalu naik mengikuti suku bunga acuan BI.
        </div>
      </div>
    </div>

    <!-- RIGHT: Results -->
    <div class="calc-panel calc-panel-dark">
      <h3 style="color: rgba(255,255,255,0.85);">Hasil Perhitungan</h3>

      <div class="result-main">
        <span class="label">CICILAN PER BULAN <span id="cicilanLabel" style="color: rgba(255,255,255,0.5);">(Tahun 1)</span></span>
        <div class="value" id="cicilanPerBulan">Rp 0</div>
        <div class="cicilan-secondary" id="cicilanSecondary"></div>
      </div>

      <div class="result-grid">
        <div class="result-card">
          <span class="label">UANG MUKA</span>
          <span class="value" id="resUangMuka">Rp 0</span>
        </div>
        <div class="result-card">
          <span class="label">PINJAMAN POKOK</span>
          <span class="value" id="resPokok">Rp 0</span>
        </div>
        <div class="result-card warning">
          <span class="label">TOTAL BUNGA</span>
          <span class="value" id="resTotalBunga">Rp 0</span>
        </div>
        <div class="result-card">
          <span class="label">TOTAL BAYAR</span>
          <span class="value" id="resTotalBayar">Rp 0</span>
        </div>
      </div>

      <div class="rasio-box">
        <div class="rasio-label">
          <span>Rasio Bunga vs Pokok</span>
          <span id="rasioBunga">0%</span>
        </div>
        <div class="rasio-bar">
          <div class="rasio-fill" id="rasioFill" style="width: 0%;"></div>
        </div>
      </div>

      <div class="action-buttons">
        <button class="btn-action primary" onclick="window.print()">🖨️ Print / Save PDF</button>
        <button class="btn-action secondary" onclick="document.getElementById('amortisasi').scrollIntoView({behavior:'smooth'})">📊 Lihat Tabel</button>
      </div>
    </div>
  </div>

  <!-- Tenor Comparison Table -->
  <section class="comparison-section">
    <h2>Perbandingan Tenor</h2>
    <p class="section-sub">Lihat cicilan jika kamu pilih tenor berbeda</p>
    <div class="tenor-table-wrap">
      <table class="tenor-table">
        <thead>
          <tr>
            <th>Tenor</th>
            <th>Cicilan/Bulan</th>
            <th>Total Bunga</th>
            <th>Total Bayar</th>
          </tr>
        </thead>
        <tbody id="tenorTableBody">
          <!-- Filled by JS -->
        </tbody>
      </table>
    </div>
  </section>

  <!-- Prepayment Simulator -->
  <section class="prepayment-section">
    <div class="prepayment-head">
      <h2>💡 Simulasi Pelunasan Sebagian (Prepayment)</h2>
      <p class="section-sub">Punya dana lebih? Lihat berapa hemat bunga atau berapa cepat lunas.</p>
    </div>

    <div class="prepayment-form">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Bayar Tambahan di Bulan Ke-</label>
          <input type="number" id="prepaymentBulan" class="form-input" value="24" min="1" max="360" step="1" />
        </div>
        <div class="form-group">
          <label class="form-label">Jumlah Pelunasan</label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="prepaymentJumlah" class="form-input" value="50.000.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </div>
    </div>

    <div class="prepayment-results" id="prepaymentResults">
      <!-- Filled by JS -->
    </div>
  </section>

  <!-- Amortization Table -->
  <section class="amortization-section" id="amortisasi">
    <div class="amortization-head">
      <h2>📋 Tabel Amortisasi Lengkap</h2>
      <p class="section-sub">Rincian pokok, bunga, dan sisa pinjaman setiap bulan</p>
    </div>

    <div class="amortization-controls">
      <button class="btn-tahun-nav" id="prevTahun">← Sebelumnya</button>
      <span class="tahun-indicator">Tahun <span id="currentTahun">1</span> dari <span id="totalTahun">15</span></span>
      <button class="btn-tahun-nav" id="nextTahun">Berikutnya →</button>
    </div>

    <div class="amortization-table-wrap">
      <table class="amortization-table">
        <thead>
          <tr>
            <th>Bulan</th>
            <th>Cicilan</th>
            <th>Bunga</th>
            <th>Pokok</th>
            <th>Sisa Pinjaman</th>
          </tr>
        </thead>
        <tbody id="amortisasiBody">
          <!-- Filled by JS -->
        </tbody>
        <tfoot>
          <tr>
            <td><strong>Total Tahun</strong></td>
            <td id="totalCicilanTahun"><strong>Rp 0</strong></td>
            <td id="totalBungaTahun"><strong>Rp 0</strong></td>
            <td id="totalPokokTahun"><strong>Rp 0</strong></td>
            <td>—</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

  <!-- Tips Section -->
  <section class="tips-section">
    <h2>💡 Tips KPR Cerdas</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon">📊</div>
        <h4>DP Minimal 30%</h4>
        <p>Semakin besar DP, semakin kecil pokok dan total bunga. DP 30% bikin cicilan turun signifikan dibanding 20%.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">⏰</div>
        <h4>Tenor Pendek = Hemat Bunga</h4>
        <p>Tenor 15 tahun vs 20 tahun bisa hemat ratusan juta. Tapi cicilan bulanan akan lebih besar.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">💰</div>
        <h4>Cicilan Max 30% Gaji</h4>
        <p>Standar bank: cicilan KPR tidak boleh lebih dari 30% gaji bulanan. Idealnya 20-25% untuk keamanan keuangan.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">🔄</div>
        <h4>Pelunasan Sebagian Pas Bonus</h4>
        <p>Dapat THR atau bonus? Bayar sebagian KPR-mu. Hemat puluhan juta bunga dalam jangka panjang.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section-calc">
    <h2>❓ Pertanyaan Umum</h2>
    <div class="faq-list">
      <details class="faq-item" open>
        <summary>Apa beda bunga Fixed, Floating, dan Fix-to-Floating?</summary>
        <div class="faq-answer">
          <p><strong>Fixed:</strong> Bunga tetap selama tenor (umumnya 1-5 tahun). Cicilan stabil, tapi tidak banyak bank yang nawarin untuk tenor panjang.</p>
          <p><strong>Floating:</strong> Bunga mengikuti BI rate. Risiko: kalau BI rate naik, cicilan ikut naik.</p>
          <p><strong>Fix-to-Floating:</strong> Yang paling umum. Misal: fix 3 tahun di 6%, lalu floating mengikuti BI rate (biasanya 10-12%).</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Berapa DP minimum untuk KPR di Indonesia?</summary>
        <div class="faq-answer">
          <p>Bank Indonesia mengatur Loan-to-Value (LTV) ratio. Untuk rumah pertama, DP minimum biasanya 10-15%. Untuk rumah kedua dan seterusnya, DP minimum bisa 20-30%.</p>
          <p>Tapi praktiknya, bank sering minta DP 20-30% untuk persetujuan lebih mudah.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apakah cicilan KPR bisa di-take over ke bank lain?</summary>
        <div class="faq-answer">
          <p>Ya, namanya <strong>refinancing</strong> atau <strong>take over KPR</strong>. Kamu pindahkan KPR ke bank lain yang menawarkan bunga lebih rendah.</p>
          <p>Pertimbangkan: biaya provisi, biaya appraisal ulang, dan denda dari bank lama. Kalau total saving > total biaya, layak take over.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Bagaimana cara melunasi KPR lebih cepat?</summary>
        <div class="faq-answer">
          <p>3 cara utama:</p>
          <p><strong>1. Pelunasan sebagian (prepayment):</strong> Bayar lebih saat ada uang lebih. Bisa pilih: perpendek tenor atau kurangi cicilan.</p>
          <p><strong>2. Naikkan cicilan bulanan:</strong> Mis. dari 5jt jadi 6jt. Bisa potong tenor signifikan.</p>
          <p><strong>3. Pelunasan total:</strong> Bayar sisa pokok sekaligus. Cek dulu denda pelunasan dipercepat di kontrak.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apa bedanya KPR Subsidi dan KPR Non-Subsidi?</summary>
        <div class="faq-answer">
          <p><strong>KPR Subsidi (FLPP):</strong> Untuk rumah dengan harga max Rp 150-200jt (tergantung wilayah). Bunga rendah ~5% fix sepanjang tenor max 20 tahun. Syarat: penghasilan max Rp 4-8jt/bulan.</p>
          <p><strong>KPR Non-Subsidi (Komersial):</strong> Untuk semua harga rumah. Bunga komersial (8-12%). Tidak ada batas penghasilan.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Related Calculators -->
  <section class="related-section">
    <h2>Kalkulator Terkait</h2>
    <div class="related-grid">
      <a href="/simulasi-kredit-mobil" class="related-card">
        <span class="related-icon">🚗</span>
        <h4>Simulasi Kredit Mobil</h4>
        <p>Hitung cicilan kredit mobil dengan asuransi dan biaya tambahan</p>
      </a>
      <a href="/kalkulator-gaji-bersih" class="related-card">
        <span class="related-icon">💼</span>
        <h4>Kalkulator Gaji Bersih</h4>
        <p>Cek take-home pay untuk planning cicilan KPR</p>
      </a>
      <a href="/kalkulator-investasi" class="related-card">
        <span class="related-icon">📈</span>
        <h4>Kalkulator Investasi</h4>
        <p>Rencanakan dana DP dengan compound interest</p>
      </a>
    </div>
  </section>

</CalculatorLayout>

<style>
/* Cicilan Secondary (untuk fix-to-floating display) */
.cicilan-secondary {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px dashed rgba(255,255,255,0.15);
  font-size: 13px;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
}
.cicilan-secondary strong { color: rgba(255,255,255,0.9); }

/* Rasio Bunga Bar */
.rasio-box {
  margin-top: 20px;
  padding: 14px 16px;
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
}
.rasio-label {
  display: flex;
  justify-content: space-between;
  font-size: 12.5px;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  margin-bottom: 8px;
}
.rasio-label span:last-child { color: var(--gold); font-size: 14px; }
.rasio-bar {
  height: 8px;
  background: rgba(255,255,255,0.08);
  border-radius: 6px;
  overflow: hidden;
}
.rasio-fill {
  height: 100%;
  background: linear-gradient(90deg, #F87171, #DC2626);
  border-radius: 6px;
  transition: width .4s var(--ease);
}

/* Action Buttons */
.action-buttons {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.action-buttons .btn-action.primary {
  flex: 1;
  background: var(--gold);
  color: var(--navy);
}
.action-buttons .btn-action.primary:hover { background: #FCD34D; }
.action-buttons .btn-action.secondary {
  background: rgba(255,255,255,0.08);
  color: #fff;
  flex: 1;
}
.action-buttons .btn-action.secondary:hover { background: rgba(255,255,255,0.14); }

/* Advanced Toggle */
.advanced-toggle {
  border: 1px dashed var(--line);
  border-radius: 10px;
  padding: 8px 14px;
  margin-bottom: 16px;
}
.advanced-toggle summary {
  cursor: pointer;
  list-style: none;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--ink-2);
  display: flex;
  align-items: center;
  gap: 6px;
}
.advanced-toggle summary::-webkit-details-marker { display: none; }
.advanced-toggle summary::before {
  content: "▸";
  transition: transform .2s;
  font-size: 12px;
  color: var(--ink-3);
}
.advanced-toggle[open] summary::before { transform: rotate(90deg); }

/* Section Common */
.comparison-section,
.prepayment-section,
.amortization-section,
.tips-section,
.faq-section-calc,
.related-section {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--line);
}
.comparison-section h2,
.prepayment-section h2,
.amortization-section h2,
.tips-section h2,
.faq-section-calc h2,
.related-section h2 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(24px, 3.5vw, 32px);
  letter-spacing: -0.01em;
  margin: 0 0 8px;
  color: var(--ink);
}
.section-sub {
  font-size: 14.5px;
  color: var(--ink-3);
  margin: 0 0 24px;
}

/* Tenor Comparison Table */
.tenor-table-wrap {
  overflow-x: auto;
  border-radius: 16px;
  border: 1px solid var(--line);
}
.tenor-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.tenor-table thead {
  background: var(--bg-soft);
}
.tenor-table th {
  padding: 14px 18px;
  text-align: left;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--ink-3);
}
.tenor-table td {
  padding: 14px 18px;
  border-top: 1px solid var(--line);
  color: var(--ink);
}
.tenor-table tbody tr:hover { background: var(--bg-soft); }
.tenor-table .recommended {
  background: rgba(16,185,129,0.06);
  font-weight: 600;
}
.tenor-table .recommended td:first-child::before {
  content: "⭐ ";
}

/* Prepayment Section */
.prepayment-form {
  background: var(--bg-soft);
  padding: 20px;
  border-radius: 14px;
  margin-bottom: 24px;
}
.prepayment-results {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 700px) {
  .prepayment-results { grid-template-columns: 1fr; }
}
.prepayment-card {
  border: 1.5px solid var(--line);
  border-radius: 16px;
  padding: 20px;
  background: #fff;
}
.prepayment-card.strategy-1 { border-color: #10B981; background: rgba(16,185,129,0.04); }
.prepayment-card.strategy-2 { border-color: #2563EB; background: rgba(37,99,235,0.04); }
.prepayment-card .strategy-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 4px 10px;
  border-radius: 6px;
  margin-bottom: 10px;
}
.prepayment-card.strategy-1 .strategy-tag {
  background: #D1FAE5;
  color: #065F46;
}
.prepayment-card.strategy-2 .strategy-tag {
  background: #DBEAFE;
  color: #1E40AF;
}
.prepayment-card h4 {
  font-size: 16px;
  font-weight: 700;
  margin: 0 0 12px;
  color: var(--ink);
}
.prepayment-card .pre-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  font-size: 14px;
  color: var(--ink-2);
}
.prepayment-card .pre-row strong { color: var(--ink); }
.prepayment-card .savings {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px dashed var(--line);
  text-align: center;
}
.prepayment-card .savings-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.06em;
}
.prepayment-card .savings-value {
  font-size: 22px;
  font-weight: 700;
  color: #10B981;
  margin-top: 4px;
}
.prepayment-card.strategy-2 .savings-value { color: #2563EB; }

/* Amortization Table */
.amortization-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 12px;
}
.btn-tahun-nav {
  padding: 8px 16px;
  border: 1px solid var(--line);
  background: #fff;
  border-radius: 8px;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--ink-2);
  cursor: pointer;
  transition: all .15s;
}
.btn-tahun-nav:hover:not(:disabled) {
  background: var(--bg-soft);
  border-color: var(--ink-3);
}
.btn-tahun-nav:disabled { opacity: 0.4; cursor: not-allowed; }
.tahun-indicator {
  font-size: 14px;
  color: var(--ink-2);
}
.tahun-indicator span { font-weight: 700; color: var(--ink); }

.amortization-table-wrap {
  overflow-x: auto;
  border-radius: 16px;
  border: 1px solid var(--line);
}
.amortization-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13.5px;
}
.amortization-table thead {
  background: var(--navy);
  color: #fff;
}
.amortization-table th {
  padding: 12px 14px;
  text-align: right;
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.06em;
}
.amortization-table th:first-child { text-align: left; }
.amortization-table td {
  padding: 11px 14px;
  border-top: 1px solid var(--line);
  text-align: right;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.amortization-table td:first-child { text-align: left; font-weight: 600; }
.amortization-table tbody tr:nth-child(even) { background: var(--bg-soft); }
.amortization-table tfoot {
  background: var(--bg-warm, #F1F5F9);
  font-weight: 700;
}
.amortization-table tfoot td { border-top: 2px solid var(--ink); }

/* Tips Grid */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}
.tip-card {
  background: var(--bg-soft);
  border-radius: 16px;
  padding: 22px;
  border: 1px solid var(--line);
}
.tip-icon {
  font-size: 28px;
  margin-bottom: 10px;
}
.tip-card h4 {
  font-size: 15.5px;
  font-weight: 700;
  margin: 0 0 8px;
  color: var(--ink);
}
.tip-card p {
  font-size: 13.5px;
  color: var(--ink-3);
  line-height: 1.55;
  margin: 0;
}

/* FAQ Calc */
.faq-section-calc .faq-list { max-width: 100%; }
.faq-section-calc .faq-item {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  margin-bottom: 10px;
  overflow: hidden;
}
.faq-section-calc .faq-item summary {
  list-style: none;
  cursor: pointer;
  padding: 16px 20px;
  font-weight: 600;
  font-size: 14.5px;
  color: var(--ink);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}
.faq-section-calc .faq-item summary::-webkit-details-marker { display: none; }
.faq-section-calc .faq-item summary::after {
  content: "+";
  font-size: 22px;
  color: var(--ink-3);
  transition: transform .2s;
}
.faq-section-calc .faq-item[open] summary::after {
  transform: rotate(45deg);
  color: var(--blue);
}
.faq-section-calc .faq-answer {
  padding: 0 20px 18px;
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.6;
}
.faq-section-calc .faq-answer p { margin: 0 0 8px; }
.faq-section-calc .faq-answer p:last-child { margin-bottom: 0; }

/* Related Cards */
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.related-card {
  display: flex;
  flex-direction: column;
  padding: 22px;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 16px;
  text-decoration: none;
  color: var(--ink);
  transition: all .2s;
}
.related-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
  color: var(--ink);
  text-decoration: none;
}
.related-icon { font-size: 32px; margin-bottom: 10px; }
.related-card h4 {
  font-size: 15.5px;
  font-weight: 700;
  margin: 0 0 6px;
  color: var(--ink);
}
.related-card p {
  font-size: 13px;
  color: var(--ink-3);
  margin: 0;
}

/* Print Styles */
@media print {
  .site-header, .site-footer, .breadcrumb, .action-buttons,
  .related-section, .faq-section-calc { display: none !important; }
  .calc-page { padding: 0; }
  .calc-panel-dark { background: #fff !important; color: #000 !important; border: 1px solid #ccc; }
  .calc-panel-dark * { color: #000 !important; }
  .result-main .value { color: #000 !important; }
}
</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';
import { 
  hitungCicilan, 
  hitungTotalBunga, 
  hitungTotalBayar, 
  generateAmortisasi, 
  groupAmortisasiPerTahun,
  simulasiPrepayment 
} from '../utils/loan.js';

// === DOM Elements ===
const $ = (id) => document.getElementById(id);

// Inputs
const hargaEl = $('harga');
const dpPersenEl = $('dpPersen');
const tenorEl = $('tenor');
const jenisBungaEl = $('jenisBunga');
const bungaFixEl = $('bungaFix');
const periodeFixEl = $('periodeFix');
const bungaFloatEl = $('bungaFloat');
const provisiEl = $('provisi');
const adminEl = $('admin');
const asuransiEl = $('asuransi');
const prepaymentBulanEl = $('prepaymentBulan');
const prepaymentJumlahEl = $('prepaymentJumlah');

// State
let currentAmortGroups = [];
let currentTahunIdx = 0;

// === Rupiah Input Formatting ===
document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

// === Toggle Field Visibility based on Jenis Bunga ===
function updateFieldVisibility() {
  const jenis = jenisBungaEl.value;
  const periodeGroup = $('periodeGroup');
  const floatingGroup = $('floatingRateGroup');
  if (jenis === 'fixed') {
    periodeGroup.style.display = 'none';
    floatingGroup.style.display = 'none';
  } else if (jenis === 'floating') {
    periodeGroup.style.display = 'none';
    floatingGroup.style.display = 'block';
  } else {
    periodeGroup.style.display = 'block';
    floatingGroup.style.display = 'block';
  }
}

// === Main Recalculation ===
function recalculate() {
  const harga = parseRupiah(hargaEl.value);
  const dpPersen = parseFloat(dpPersenEl.value) || 0;
  const tenorTahun = parseInt(tenorEl.value) || 1;
  const tenorBulan = tenorTahun * 12;
  const jenis = jenisBungaEl.value;
  const bungaFix = parseFloat(bungaFixEl.value) || 0;
  const periodeFix = parseInt(periodeFixEl.value) || 1;
  const bungaFloat = parseFloat(bungaFloatEl.value) || 0;
  const provisi = parseFloat(provisiEl.value) || 0;
  const admin = parseRupiah(adminEl.value);
  const asuransi = parseRupiah(asuransiEl.value);

  if (!harga || harga <= 0) return;

  const uangMuka = harga * (dpPersen / 100);
  const pokok = harga - uangMuka;

  // Bunga rata-rata untuk perhitungan total
  let bungaRataRata;
  if (jenis === 'fixed') {
    bungaRataRata = bungaFix;
  } else if (jenis === 'floating') {
    bungaRataRata = bungaFloat;
  } else {
    // Fix-to-floating: weighted average
    const yearsFix = Math.min(periodeFix, tenorTahun);
    const yearsFloat = Math.max(0, tenorTahun - periodeFix);
    bungaRataRata = (bungaFix * yearsFix + bungaFloat * yearsFloat) / tenorTahun;
  }

  // Cicilan tahun 1 (fix rate)
  let cicilanTahun1, cicilanFloating;
  if (jenis === 'fixed') {
    cicilanTahun1 = hitungCicilan(pokok, bungaFix, tenorBulan);
    cicilanFloating = null;
  } else if (jenis === 'floating') {
    cicilanTahun1 = hitungCicilan(pokok, bungaFloat, tenorBulan);
    cicilanFloating = null;
  } else {
    cicilanTahun1 = hitungCicilan(pokok, bungaFix, tenorBulan);
    // Cicilan floating dihitung saat transisi (sisa pokok dengan bunga float)
    const sisaPokokSetelahFix = pokok * Math.pow(1 + bungaFix/100/12, periodeFix*12) - cicilanTahun1 * (Math.pow(1+bungaFix/100/12, periodeFix*12)-1) / (bungaFix/100/12);
    const sisaTenorBulan = (tenorTahun - periodeFix) * 12;
    cicilanFloating = sisaTenorBulan > 0 ? hitungCicilan(sisaPokokSetelahFix, bungaFloat, sisaTenorBulan) : 0;
  }

  const totalBunga = hitungTotalBunga(pokok, bungaRataRata, tenorBulan);
  const totalBayar = pokok + totalBunga;
  const rasioBungaPokok = (totalBunga / pokok) * 100;

  // Update DOM
  $('cicilanPerBulan').textContent = formatRupiah(cicilanTahun1 + asuransi);
  
  if (jenis === 'fixToFloat' && cicilanFloating) {
    $('cicilanLabel').textContent = `(Tahun 1-${periodeFix})`;
    $('cicilanSecondary').innerHTML = 
      `Setelah tahun ${periodeFix}: <strong>${formatRupiah(cicilanFloating + asuransi)}/bulan</strong> ` +
      `<span style="opacity:.6">(estimasi bunga floating ${bungaFloat}%)</span>`;
  } else {
    $('cicilanLabel').textContent = '';
    $('cicilanSecondary').innerHTML = '';
  }

  $('resUangMuka').textContent = formatRupiah(uangMuka);
  $('resPokok').textContent = formatRupiah(pokok);
  $('resTotalBunga').textContent = formatRupiah(totalBunga);
  $('resTotalBayar').textContent = formatRupiah(totalBayar);
  $('rasioBunga').textContent = formatPercent(rasioBungaPokok, 1);
  $('rasioFill').style.width = `${Math.min(rasioBungaPokok, 200) / 2}%`;

  // Update tenor comparison table
  updateTenorTable(pokok, bungaRataRata);

  // Update amortization
  const amortisasi = generateAmortisasi(pokok, bungaRataRata, tenorBulan);
  currentAmortGroups = groupAmortisasiPerTahun(amortisasi);
  $('totalTahun').textContent = currentAmortGroups.length;
  currentTahunIdx = 0;
  renderAmortisasi();

  // Update prepayment
  updatePrepayment(pokok, bungaRataRata, tenorBulan);
}

// === Tenor Comparison Table ===
function updateTenorTable(pokok, bunga) {
  const tenorOptions = [5, 10, 15, 20, 25, 30];
  const currentTenor = parseInt(tenorEl.value);
  let html = '';
  tenorOptions.forEach(t => {
    const bulan = t * 12;
    const cic = hitungCicilan(pokok, bunga, bulan);
    const tBunga = hitungTotalBunga(pokok, bunga, bulan);
    const tBayar = pokok + tBunga;
    const isCurrent = t === currentTenor;
    html += `<tr class="${isCurrent ? 'recommended' : ''}">
      <td>${t} tahun</td>
      <td>${formatRupiah(cic)}</td>
      <td>${formatRupiah(tBunga)}</td>
      <td>${formatRupiah(tBayar)}</td>
    </tr>`;
  });
  $('tenorTableBody').innerHTML = html;
}

// === Prepayment Simulation ===
function updatePrepayment(pokok, bunga, tenorBulan) {
  const bulanPrepay = parseInt(prepaymentBulanEl.value) || 24;
  const jumlahPrepay = parseRupiah(prepaymentJumlahEl.value);
  if (!jumlahPrepay || bulanPrepay >= tenorBulan) {
    $('prepaymentResults').innerHTML = '<div class="info-box"><span class="info-box-icon">ℹ️</span><div>Masukkan jumlah pelunasan dan bulan pelunasan yang valid (sebelum tenor selesai).</div></div>';
    return;
  }
  const sim = simulasiPrepayment(pokok, bunga, tenorBulan, bulanPrepay, jumlahPrepay);
  if (sim.lunas) {
    $('prepaymentResults').innerHTML = `
      <div class="info-box" style="grid-column: 1/-1;">
        <span class="info-box-icon">✅</span>
        <div>Pelunasan ini cukup untuk melunasi seluruh KPR. KPR <strong>lunas ${sim.hematBulan} bulan lebih cepat</strong> dari jadwal.</div>
      </div>`;
    return;
  }
  $('prepaymentResults').innerHTML = `
    <div class="prepayment-card strategy-1">
      <span class="strategy-tag">STRATEGI 1</span>
      <h4>⏰ Perpendek Tenor (Cicilan Tetap)</h4>
      <div class="pre-row"><span>Cicilan/bulan</span><strong>${formatRupiah(sim.strategi1.cicilan)}</strong></div>
      <div class="pre-row"><span>Sisa tenor setelah pelunasan</span><strong>${sim.strategi1.tenorBaru} bulan</strong></div>
      <div class="pre-row"><span>Hemat waktu</span><strong>${sim.strategi1.hematBulan} bulan</strong></div>
      <div class="savings">
        <div class="savings-label">HEMAT BUNGA</div>
        <div class="savings-value">${formatRupiah(sim.strategi1.hematBunga)}</div>
      </div>
    </div>
    <div class="prepayment-card strategy-2">
      <span class="strategy-tag">STRATEGI 2</span>
      <h4>💰 Kurangi Cicilan (Tenor Tetap)</h4>
      <div class="pre-row"><span>Cicilan baru/bulan</span><strong>${formatRupiah(sim.strategi2.cicilan)}</strong></div>
      <div class="pre-row"><span>Sisa tenor</span><strong>${sim.strategi2.tenor} bulan</strong></div>
      <div class="pre-row"><span>Pengurangan cicilan</span><strong>${formatRupiah(sim.strategi1.cicilan - sim.strategi2.cicilan)}/bulan</strong></div>
      <div class="savings">
        <div class="savings-label">HEMAT BUNGA</div>
        <div class="savings-value">${formatRupiah(sim.strategi2.hematBunga)}</div>
      </div>
    </div>
  `;
}

// === Amortization Table Rendering ===
function renderAmortisasi() {
  if (!currentAmortGroups.length) return;
  const group = currentAmortGroups[currentTahunIdx];
  $('currentTahun').textContent = group.tahun;
  let html = '';
  group.rows.forEach(r => {
    html += `<tr>
      <td>${r.bulan}</td>
      <td>${formatRupiah(r.cicilan)}</td>
      <td>${formatRupiah(r.bunga)}</td>
      <td>${formatRupiah(r.pokok)}</td>
      <td>${formatRupiah(r.sisaPokok)}</td>
    </tr>`;
  });
  $('amortisasiBody').innerHTML = html;
  $('totalCicilanTahun').innerHTML = `<strong>${formatRupiah(group.totalCicilan)}</strong>`;
  $('totalBungaTahun').innerHTML = `<strong>${formatRupiah(group.totalBunga)}</strong>`;
  $('totalPokokTahun').innerHTML = `<strong>${formatRupiah(group.totalPokok)}</strong>`;
  $('prevTahun').disabled = currentTahunIdx === 0;
  $('nextTahun').disabled = currentTahunIdx >= currentAmortGroups.length - 1;
}

// === Event Listeners ===
[dpPersenEl, tenorEl, jenisBungaEl, bungaFixEl, periodeFixEl, bungaFloatEl, provisiEl, prepaymentBulanEl].forEach(el => {
  el.addEventListener('input', recalculate);
  el.addEventListener('change', () => {
    updateFieldVisibility();
    recalculate();
  });
});

$('prevTahun').addEventListener('click', () => {
  if (currentTahunIdx > 0) {
    currentTahunIdx--;
    renderAmortisasi();
  }
});
$('nextTahun').addEventListener('click', () => {
  if (currentTahunIdx < currentAmortGroups.length - 1) {
    currentTahunIdx++;
    renderAmortisasi();
  }
});

// Initial render
updateFieldVisibility();
recalculate();
</script>