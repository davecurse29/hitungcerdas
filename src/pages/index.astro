---
// Homepage HitungCerdas — Premium design
import Layout from '../layouts/Layout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';
import { CALCULATORS, CATEGORIES } from '../data/calculators';

const homepageTitle = 'HitungCerdas — 21 Kalkulator Keuangan, Bisnis & Islami Online Gratis Indonesia';
const homepageDesc = 'Kalkulator finansial Indonesia GRATIS: KPR Premium, PPh 21 UU HPP 2026, gaji bersih, zakat mal, investasi & pinjol legal. Mobile-friendly, no login.';

const faqs = [
  {
    question: 'Apakah HitungCerdas benar-benar gratis?',
    answer: 'Ya, semua tools di HitungCerdas <strong>100% gratis</strong> dan tidak memerlukan login atau registrasi. Kami didukung oleh iklan Google AdSense untuk menjaga platform tetap dapat diakses semua orang.',
  },
  {
    question: 'Apakah hasil perhitungan akurat?',
    answer: 'Semua perhitungan menggunakan rumus standar yang sama dengan yang dipakai industri (UU HPP untuk PPh 21, formula KPR anuitas, dll). Namun, hasilnya bersifat <strong>estimasi</strong> — angka final dari bank, kantor pajak, atau platform tergantung kebijakan masing-masing institusi.',
  },
  {
    question: 'Apakah data yang saya masukkan aman?',
    answer: 'Sangat aman. Semua perhitungan dilakukan langsung di browser kamu (<strong>client-side</strong>). Tidak ada data yang dikirim atau disimpan di server kami. Begitu kamu menutup halaman, data hilang sepenuhnya.',
  },
  {
    question: 'Bisakah saya pakai di HP?',
    answer: 'Tentu! HitungCerdas didesain <strong>mobile-first</strong>. Semua tools terlihat baik dan mudah dipakai di layar HP, tablet, maupun laptop. Tidak perlu instal aplikasi apa pun.',
  },
  {
    question: 'Apakah hasil kalkulator bisa dijadikan acuan resmi?',
    answer: 'Hasil perhitungan bersifat <strong>estimasi dan edukasi</strong>. Untuk keputusan keuangan penting (seperti pengajuan KPR, pelaporan pajak, atau investasi besar), selalu konsultasikan dengan profesional terkait — bank, konsultan pajak, atau perencana keuangan berlisensi.',
  },
];

const articles = [
  { slug: 'cara-menghitung-kpr', title: 'Cara Menghitung Cicilan KPR yang Benar di 2026', category: 'PANDUAN KPR', readTime: '5 min', color: '#2563EB', color2: '#1E40AF' },
  { slug: 'cara-menghitung-pph-21', title: 'Cara Menghitung PPh 21 Karyawan Sesuai Aturan Terbaru', category: 'PANDUAN PAJAK', readTime: '7 min', color: '#DC2626', color2: '#991B1B' },
  { slug: 'cara-menghitung-gaji-bersih', title: 'Cara Menghitung Gaji Bersih Karyawan dengan Mudah', category: 'GAJI & PENGHASILAN', readTime: '4 min', color: '#059669', color2: '#047857' },
  { slug: 'cara-menentukan-harga-jual', title: 'Cara Menentukan Harga Jual Produk agar Tetap Untung', category: 'UMKM', readTime: '6 min', color: '#EC4899', color2: '#9D174D' },
];

// Kalkulator paling populer (estimasi tren — mudah disesuaikan saat data analytics matang)
const POPULAR_SLUGS = ['kpr', 'gaji-bersih', 'pph-21', 'kredit-mobil', 'zakat-penghasilan', 'investasi'];
const popularCalcs = POPULAR_SLUGS.map(s => CALCULATORS.find(c => c.slug === s)).filter(Boolean);
---

<Layout
  title={homepageTitle}
  description={homepageDesc}
  keywords={['kalkulator keuangan', 'kalkulator bisnis', 'kalkulator islami', 'kalkulator KPR', 'kalkulator PPh 21', 'kalkulator gaji bersih', 'kalkulator zakat', 'kalkulator investasi', 'hitung kpr online', 'hitung pajak online']}
>
  {/* ═══════════════ HERO ═══════════════ */}
  <section class="hero" id="beranda">
    <div class="hero-particles" aria-hidden="true">
      {Array.from({ length: 9 }).map((_, i) => <span class={`particle p-${i + 1}`}></span>)}
    </div>

    <div class="hero-wrap">
      {/* Hero illustration (desktop only) */}
      <svg class="hero-illust" viewBox="0 0 340 340" fill="none" aria-hidden="true">
        <circle cx="170" cy="170" r="140" fill="url(#hg1)" opacity=".6" />
        <circle cx="170" cy="170" r="100" fill="url(#hg2)" opacity=".4" />
        <defs>
          <radialGradient id="hg1" cx="50%" cy="50%">
            <stop offset="0%" stop-color="#FCD34D" stop-opacity=".4" />
            <stop offset="100%" stop-color="#F59E0B" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="hg2" cx="50%" cy="50%">
            <stop offset="0%" stop-color="#FFFFFF" stop-opacity=".25" />
            <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0" />
          </radialGradient>
        </defs>

        {/* Calculator center */}
        <g class="float-1">
          <rect x="115" y="100" width="110" height="150" rx="14" fill="#FFFFFF" stroke="#13335C" stroke-width="2" />
          <rect x="125" y="112" width="90" height="32" rx="6" fill="#0A2540" />
          <text x="207" y="135" text-anchor="end" font-size="18" font-weight="800" fill="#FCD34D" font-family="Inter,sans-serif">8,420</text>
          <text x="135" y="128" font-size="9" font-weight="600" fill="rgba(255,255,255,.5)" font-family="Inter,sans-serif">RESULT</text>
          <rect x="125" y="152" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="150" y="152" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="175" y="152" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="200" y="152" width="15" height="20" rx="4" fill="#F59E0B" />
          <rect x="125" y="177" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="150" y="177" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="175" y="177" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="200" y="177" width="15" height="20" rx="4" fill="#F59E0B" />
          <rect x="125" y="202" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="150" y="202" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="175" y="202" width="20" height="20" rx="4" fill="#F1F5F9" />
          <rect x="200" y="202" width="15" height="20" rx="4" fill="#F59E0B" />
          <rect x="125" y="227" width="45" height="16" rx="4" fill="#059669" />
          <rect x="175" y="227" width="20" height="16" rx="4" fill="#F1F5F9" />
          <rect x="200" y="227" width="15" height="16" rx="4" fill="#F59E0B" />
        </g>

        {/* Spinning coin top-right */}
        <g class="float-2" transform="translate(245 60)">
          <circle class="spin-coin" cx="0" cy="0" r="22" fill="#F59E0B" stroke="#B45309" stroke-width="2" />
          <text x="0" y="6" text-anchor="middle" font-size="14" font-weight="900" fill="#FFFFFF" font-family="Inter,sans-serif">Rp</text>
        </g>

        {/* Chart card top-left */}
        <g class="float-3" transform="translate(40 80)">
          <rect x="0" y="0" width="80" height="60" rx="10" fill="#FFFFFF" stroke="#13335C" stroke-width="2" />
          <text x="10" y="16" font-size="8" font-weight="700" fill="#475569" font-family="Inter,sans-serif">PROFIT</text>
          <path d="M10 50L25 35L40 42L55 25L70 18" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          <circle cx="70" cy="18" r="3" fill="#059669" />
        </g>

        {/* House bottom-left */}
        <g class="float-4" transform="translate(45 230)">
          <path d="M0 22L20 6L40 22" stroke="#2563EB" stroke-width="2.5" stroke-linejoin="round" fill="#DBEAFE" />
          <rect x="6" y="22" width="28" height="22" fill="#FFFFFF" stroke="#2563EB" stroke-width="2" />
          <rect x="16" y="30" width="8" height="14" fill="#2563EB" />
        </g>

        {/* Coin stack bottom-right */}
        <g class="float-2" transform="translate(245 230)">
          <ellipse cx="0" cy="38" rx="26" ry="6" fill="#B45309" />
          <rect x="-26" y="28" width="52" height="10" fill="#F59E0B" />
          <ellipse cx="0" cy="28" rx="26" ry="6" fill="#FCD34D" stroke="#B45309" stroke-width="1.5" />
          <ellipse cx="0" cy="14" rx="26" ry="6" fill="#F59E0B" />
          <rect x="-26" y="4" width="52" height="10" fill="#F59E0B" />
          <ellipse cx="0" cy="4" rx="26" ry="6" fill="#FCD34D" stroke="#B45309" stroke-width="1.5" />
          <text x="0" y="8" text-anchor="middle" font-size="10" font-weight="900" fill="#B45309" font-family="Inter,sans-serif">Rp</text>
        </g>
      </svg>

      <div class="hero-content">
        <div class="badge">
          <span class="dot"></span>
          21 kalkulator gratis · Keuangan · Bisnis · Islami
        </div>

        <h1>
          Kalkulator <span class="hl">Keuangan, Bisnis &amp; Islami</span>
          <br />Online Gratis Indonesia
        </h1>

        <p class="hero-sub">
          Hitung cicilan KPR &amp; kredit kendaraan, KTA, pinjol legal, dana darurat, pajak PPh 21,
          gaji bersih, investasi, zakat fitrah/mal/penghasilan, warisan faraidh, dan dana haji —
          21 kalkulator gratis dalam satu website, optimal di HP.
        </p>

        <div class="hero-btns">
          <a href="#tools" class="btn btn-pri">
            <i class="ti ti-calculator" aria-hidden="true"></i>
            Coba Kalkulator
          </a>
          <a href="#tools" class="btn btn-sec">
            <i class="ti ti-grid-dots" aria-hidden="true"></i>
            Lihat Semua Tools
          </a>
        </div>

        <div class="hero-feats">
          <div class="feat"><i class="ti ti-check"></i> Gratis selamanya</div>
          <div class="feat"><i class="ti ti-check"></i> Tanpa login</div>
          <div class="feat"><i class="ti ti-check"></i> Hasil instan</div>
          <div class="feat"><i class="ti ti-check"></i> Mobile-friendly</div>
          <div class="feat"><i class="ti ti-check"></i> Format Rupiah</div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════ SEARCH BAR ═══════════════ */}
  <div class="search-wrap">
    <div class="search-box">
      <div class="search-ic">
        <i class="ti ti-search" aria-hidden="true"></i>
      </div>
      <input
        type="text"
        class="search-input"
        id="searchInput"
        placeholder="Cari kalkulator keuangan, bisnis, atau islami..."
        autocomplete="off"
      />
      <button class="search-btn" id="searchBtn">Cari</button>
    </div>
    <div class="search-results" id="searchResults"></div>
  </div>

  <AdSlot format="horizontal" className="mt-ad" />

  {/* ═══════════════ KALKULATOR POPULER ═══════════════ */}
  <section class="section" id="populer">
    <div class="wrap">
      <div class="section-hdr">
        <div class="section-eyebrow">Paling Sering Dipakai</div>
        <h2 class="section-title">Kalkulator Paling Populer</h2>
        <p class="section-desc">
          Mulai dari yang paling banyak dicari pengunjung — KPR, gaji bersih, pajak,
          kredit kendaraan, zakat, dan investasi. Langsung pilih dan hitung dalam hitungan detik.
        </p>
      </div>

      <div class="tool-grid">
        {popularCalcs.map(calc => <CalculatorCard calc={calc} />)}
      </div>
    </div>
  </section>

  {/* ═══════════════ TOOLS GRID ═══════════════ */}
  <section class="section" id="tools">
    <div class="wrap">
      <div class="section-hdr">
        <div class="section-eyebrow">21 Kalkulator Gratis</div>
        <h2 class="section-title">Pilih Kalkulator yang Kamu Butuhkan</h2>
        <p class="section-desc">
          21 kalkulator gratis untuk keuangan, bisnis, dan kebutuhan Islami — dirancang sederhana
          untuk karyawan, UMKM, freelancer, hingga keluarga Muslim Indonesia.
        </p>
      </div>

      <div class="cat-tabs" role="tablist">
        <button class="cat-tab active" data-cat="semua">Semua Tools</button>
        <button class="cat-tab" data-cat="keuangan">Kalkulator Keuangan</button>
        <button class="cat-tab" data-cat="bisnis">Kalkulator Bisnis & Tools</button>
        <button class="cat-tab" data-cat="islami">Kalkulator Islami</button>
      </div>

      <div class="tool-grid">
        {CALCULATORS.map(calc => <CalculatorCard calc={calc} />)}
      </div>
    </div>
  </section>

  <AdSlot format="rectangle" />

  {/* ═══════════════ BENEFITS ═══════════════ */}
  <section class="section benefits-bg">
    <div class="wrap">
      <div class="section-hdr">
        <div class="section-eyebrow">Kenapa Kami</div>
        <h2 class="section-title">Kenapa Pakai HitungCerdas?</h2>
        <p class="section-desc">
          Dibangun untuk pengguna Indonesia dengan fokus pada kecepatan, kemudahan, dan akurasi hasil.
        </p>
      </div>

      <div class="benefits-grid">
        <div class="benefit-card reveal">
          <div class="benefit-ic" style="background:#DBEAFE;color:#2563EB">
            <svg viewBox="0 0 40 40" fill="none">
              <path d="M22 4L8 22H18L16 36L32 16H22L24 4Z" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="benefit-title">Cepat & Praktis</h3>
          <p class="benefit-desc">Hasil tampil instan begitu kamu mengetik input. Tidak perlu submit form atau loading lama.</p>
        </div>

        <div class="benefit-card reveal">
          <div class="benefit-ic" style="background:#D1FAE5;color:#059669">
            <svg viewBox="0 0 40 40" fill="none">
              <circle cx="20" cy="20" r="15" fill="currentColor" fill-opacity=".18" stroke="currentColor" stroke-width="2" />
              <circle cx="14" cy="17" r="1.8" fill="currentColor" />
              <circle cx="26" cy="17" r="1.8" fill="currentColor" />
              <path d="M13 24C13 24 15 28 20 28C25 28 27 24 27 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
            </svg>
          </div>
          <h3 class="benefit-title">Mudah Dipahami</h3>
          <p class="benefit-desc">Hasil ditampilkan dengan visual yang jelas. Cocok untuk pengguna awam yang tidak suka angka.</p>
        </div>

        <div class="benefit-card reveal">
          <div class="benefit-ic" style="background:#FEF3C7;color:#F59E0B">
            <svg viewBox="0 0 40 40" fill="none">
              <circle cx="13" cy="13" r="5" fill="currentColor" fill-opacity=".5" stroke="currentColor" stroke-width="2" />
              <circle cx="27" cy="13" r="5" fill="currentColor" fill-opacity=".5" stroke="currentColor" stroke-width="2" />
              <path d="M5 32C5 26 8 22 13 22C18 22 21 26 21 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
              <path d="M19 32C19 26 22 22 27 22C32 22 35 26 35 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="currentColor" fill-opacity=".15" />
            </svg>
          </div>
          <h3 class="benefit-title">Cocok untuk Semua</h3>
          <p class="benefit-desc">Karyawan, freelancer, UMKM, pebisnis online — tools yang relevan untuk semua profesi.</p>
        </div>

        <div class="benefit-card reveal">
          <div class="benefit-ic" style="background:#FCE7F3;color:#EC4899">
            <svg viewBox="0 0 40 40" fill="none">
              <rect x="8" y="14" width="24" height="20" rx="2" fill="currentColor" fill-opacity=".15" stroke="currentColor" stroke-width="2" />
              <path d="M8 14L8 12C8 10.9 8.9 10 10 10H30C31.1 10 32 10.9 32 12V14" stroke="currentColor" stroke-width="2" />
              <line x1="20" y1="14" x2="20" y2="34" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M20 14C18 9 14 9 14 12C14 14 16 14 20 14Z" fill="currentColor" />
              <path d="M20 14C22 9 26 9 26 12C26 14 24 14 20 14Z" fill="currentColor" />
            </svg>
          </div>
          <h3 class="benefit-title">Gratis Tanpa Login</h3>
          <p class="benefit-desc">Tidak ada batasan, tidak perlu daftar, tidak perlu password. Langsung pakai.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════ ARTICLES ═══════════════ */}
  <section class="section" id="blog">
    <div class="wrap">
      <div class="section-hdr">
        <div class="section-eyebrow">Edukasi</div>
        <h2 class="section-title">Artikel & Panduan</h2>
        <p class="section-desc">
          Pelajari konsep keuangan dan bisnis dasar dengan bahasa yang mudah dipahami.
        </p>
      </div>

      <div class="art-grid">
        {articles.map(art => (
          <a href={`/blog/${art.slug}`} class="art-card reveal" style={`--art-color:${art.color};--art-color2:${art.color2}`}>
            <div class="art-img">
              <i class="ti ti-file-text"></i>
            </div>
            <div class="art-body">
              <div class="art-cat">{art.category}</div>
              <h3 class="art-title">{art.title}</h3>
              <div class="art-meta"><i class="ti ti-clock"></i> {art.readTime} baca</div>
              <span class="art-link">Baca Artikel <i class="ti ti-arrow-right"></i></span>
            </div>
          </a>
        ))}
      </div>

      <div class="art-cta">
        <a href="/blog" class="btn btn-ghost">
          Lihat Semua Artikel <i class="ti ti-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <AdSlot format="horizontal" />

  <FAQ items={faqs} />
</Layout>

<style>
  /* ═══════════════ HERO ═══════════════ */
  .hero {
    background: linear-gradient(135deg, #0A2540 0%, #13335C 50%, #1E4475 100%);
    color: #fff;
    padding: 64px 0 56px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 140%;
    background: radial-gradient(ellipse, rgba(37, 99, 235, .25), transparent 60%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, .06) 1px, transparent 0);
    background-size: 24px 24px;
    pointer-events: none;
    opacity: .5;
  }

  .hero-wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    animation: fadeUp .5s ease both;
  }

  .hero-content > * {
    animation: fadeUp .5s ease both;
  }

  .hero-content > *:nth-child(1) { animation-delay: .05s; }
  .hero-content > *:nth-child(2) { animation-delay: .15s; }
  .hero-content > *:nth-child(3) { animation-delay: .25s; }
  .hero-content > *:nth-child(4) { animation-delay: .35s; }
  .hero-content > *:nth-child(5) { animation-delay: .45s; }

  .hero-illust {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    width: 340px;
    height: 340px;
    display: none;
    pointer-events: none;
    z-index: 0;
  }

  @media (min-width: 1024px) {
    .hero-illust {
      display: block;
    }
    .hero-content {
      padding-right: 380px;
    }
    .hero h1 {
      max-width: none;
    }
    .hero-sub,
    .hero-btns,
    .hero-feats {
      max-width: 600px;
    }
  }

  .hero h1 {
    color: #fff;
    font-size: clamp(28px, 4.1vw, 46px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -.025em;
    margin: 0 0 18px;
    max-width: 820px;
  }

  .hero h1 .hl {
    background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 50%, #FCD34D 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-style: italic;
  }

  .badge {
    margin-bottom: 18px;
  }

  .hero-sub {
    font-size: clamp(15px, 1.5vw, 18px);
    color: rgba(255, 255, 255, .75);
    line-height: 1.65;
    margin: 0 0 28px;
    max-width: 660px;
    font-weight: 400;
  }

  .hero-btns {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .hero-feats {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .feat {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255, 255, 255, .85);
  }

  .feat i {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(16, 185, 129, .18);
    color: #34D399;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* ═══════════════ PARTICLES ═══════════════ */
  .hero-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .particle {
    position: absolute;
    background: #FCD34D;
    border-radius: 50%;
    opacity: 0;
    animation: particleFloat 14s linear infinite;
  }

  .p-1 { left: 8%; width: 4px; height: 4px; animation-delay: 0s; }
  .p-2 { left: 22%; width: 3px; height: 3px; animation-delay: 2s; animation-duration: 16s; }
  .p-3 { left: 38%; width: 5px; height: 5px; animation-delay: 4s; animation-duration: 13s; }
  .p-4 { left: 55%; width: 3px; height: 3px; animation-delay: 1s; animation-duration: 15s; }
  .p-5 { left: 68%; width: 4px; height: 4px; animation-delay: 3s; animation-duration: 17s; }
  .p-6 { left: 84%; width: 3px; height: 3px; animation-delay: 5s; background: #FBBF24; }
  .p-7 { left: 14%; width: 2px; height: 2px; animation-delay: 6s; animation-duration: 18s; background: rgba(255, 255, 255, .6); }
  .p-8 { left: 48%; width: 2px; height: 2px; animation-delay: 7s; animation-duration: 19s; background: rgba(255, 255, 255, .6); }
