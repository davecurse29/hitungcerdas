  .site-header, .site-footer, .breadcrumb, .action-buttons,
  .tips-section, .faq-section-calc, .related-section { display: none !important; }
  .calc-page { padding: 0; }
  .calc-panel-dark { background: #fff !important; color: #000 !important; border: 1px solid #ccc; }
  .calc-panel-dark * { color: #000 !important; }
  .result-main .value { color: #000 !important; }
}
</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';

const $ = (id) => document.getElementById(id);

const ASURANSI_RATES = { tlo: 2.5, allrisk: 6.0, none: 0 };
const ASURANSI_LABEL = {
  tlo: 'TLO (Total Loss Only)',
  allrisk: 'All Risk (Comprehensive)',
  none: 'Tanpa Asuransi',
};

const JENIS_DEFAULT_HARGA = {
  matic: 25000000, bebek: 18000000, sport: 35000000,
  bigbike: 95000000, listrik: 22000000,
};

// Format tenor display dengan rounding
function formatTenor(bulan) {
  const tahun = bulan / 12;
  if (Number.isInteger(tahun)) {
    return `${bulan} bulan (${tahun} thn)`;
  }
  return `${bulan} bulan (~${Math.round(tahun)} thn)`;
}

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

$('jenisMotor').addEventListener('change', () => {
  const jenis = $('jenisMotor').value;
  $('harga').value = formatNumber(JENIS_DEFAULT_HARGA[jenis]);
  if (jenis === 'bigbike') $('jenisAsuransi').value = 'allrisk';
  else if (jenis === 'sport') $('jenisAsuransi').value = 'tlo';
  else if (jenis === 'matic' || jenis === 'bebek' || jenis === 'listrik') {
    $('jenisAsuransi').value = JENIS_DEFAULT_HARGA[jenis] >= 30000000 ? 'tlo' : 'none';
  }
  recalculate();
});

function recalculate() {
  const harga = parseRupiah($('harga').value);
  const dpPersen = parseFloat($('dpPersen').value) || 0;
  const tenorBulan = parseInt($('tenor').value) || 12;
  const tenorTahun = tenorBulan / 12;
  const bunga = parseFloat($('bunga').value) || 0;
  const jenisAsuransi = $('jenisAsuransi').value;
  const bbnPersen = parseFloat($('bbn').value) || 0;
  const admin = parseRupiah($('admin').value);

  if (!harga || harga <= 0) return;

  const dp = harga * (dpPersen / 100);
  const bbn = harga * (bbnPersen / 100);
  const pokok = harga - dp;
  const totalBunga = pokok * (bunga / 100) * tenorTahun;
  const totalCicilan = pokok + totalBunga;
  const cicilanPerBulan = totalCicilan / tenorBulan;

  const tarifAsuransi = ASURANSI_RATES[jenisAsuransi];
  const asuransiPerTahun = harga * (tarifAsuransi / 100);
  const asuransiTotal = asuransiPerTahun * tenorTahun;

  const totalMuka = dp + bbn + admin + (tarifAsuransi > 0 ? asuransiPerTahun : 0);
  const totalCost = dp + totalCicilan + bbn + admin + asuransiTotal;
  const effectiveRatio = ((totalCost - harga) / harga) * 100;

  $('cicilanPerBulan').textContent = formatRupiah(cicilanPerBulan);
  $('resTotalMuka').textContent = formatRupiah(totalMuka);
  $('resPokok').textContent = formatRupiah(pokok);
  $('resTotalBunga').textContent = formatRupiah(totalBunga);
  $('resTotalCost').textContent = formatRupiah(totalCost);
  $('effectiveRatio').textContent = formatPercent(effectiveRatio, 1);
  $('tcoFill').style.width = `${Math.min(effectiveRatio, 100)}%`;

  $('bdDp').textContent = formatRupiah(dp);
  $('bdBbn').textContent = formatRupiah(bbn);
  $('bdAdmin').textContent = formatRupiah(admin);
  $('bdCicilan').textContent = formatRupiah(totalCicilan);
  $('bdAsuransi').textContent = formatRupiah(asuransiTotal);
  $('bdAsuransiHint').textContent = ASURANSI_LABEL[jenisAsuransi];
  $('bdAsuransiRow').style.display = tarifAsuransi > 0 ? 'grid' : 'none';
  $('bdTotal').textContent = formatRupiah(totalCost);

  const cashTotal = harga + bbn + asuransiTotal;
  const creditTotal = totalCost;

  $('vsCashHarga').textContent = formatRupiah(harga);
  $('vsCashBbn').textContent = formatRupiah(bbn);
  $('vsCashAsuransi').textContent = formatRupiah(asuransiTotal);
  $('vsCashTotal').textContent = formatRupiah(cashTotal);

  $('vsCreditDp').textContent = formatRupiah(dp);
  $('vsCreditCicilan').textContent = formatRupiah(totalCicilan);
  $('vsCreditBiaya').textContent = formatRupiah(bbn + admin);
  $('vsCreditAsuransi').textContent = formatRupiah(asuransiTotal);
  $('vsCreditTotal').textContent = formatRupiah(creditTotal);

  const selisih = creditTotal - cashTotal;
  const selisihPersen = (selisih / cashTotal) * 100;
  const returnNeeded = selisihPersen / tenorTahun;
  $('vsConclusion').innerHTML = `
    <strong>💡 Kesimpulan:</strong> Beli kredit lebih mahal <strong>${formatRupiah(selisih)}</strong> 
    (${formatPercent(selisihPersen, 1)}) dibanding cash. 
    Kalau punya cash + bisa investasi sisanya dengan return >${formatPercent(returnNeeded, 1)}/tahun, 
    <strong>beli cash lebih menguntungkan</strong>.
    ${tenorTahun >= 3 ? '<br><br>⚠️ <strong>Catatan:</strong> Tenor panjang motor berisiko — motor depresiasi 15-20%/tahun. Saat lunas, nilai motor mungkin < sisa hutang.' : ''}
  `;

  // Tenor comparison dengan formatTenor (FIXED)
  const tenorOptions = [12, 24, 35, 48];
  let tHtml = '';
  tenorOptions.forEach(t => {
    const tTahun = t / 12;
    const tBunga = pokok * (bunga / 100) * tTahun;
    const tCicilan = (pokok + tBunga) / t;
    const tBayar = pokok + tBunga;
    const isCurrent = t === tenorBulan;
    tHtml += `<tr class="${isCurrent ? 'recommended' : ''}">
      <td>${formatTenor(t)}</td>
      <td>${formatRupiah(tCicilan)}</td>
      <td>${formatRupiah(tBunga)}</td>
      <td>${formatRupiah(tBayar)}</td>
    </tr>`;
  });
  $('tenorTableBody').innerHTML = tHtml;
}

['dpPersen','tenor','bunga','jenisAsuransi','bbn'].forEach(id => {
  $(id).addEventListener('input', recalculate);
  $(id).addEventListener('change', recalculate);
});

recalculate();
</script>