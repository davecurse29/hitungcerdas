---
// src/pages/simulasi-kredit-mobil.astro
// Kalkulator Kredit Mobil Pro — TCO + Asuransi + BBN + Balloon Payment
import CalculatorLayout from '../components/CalculatorLayout.astro';
---

<CalculatorLayout
  title="Simulasi Kredit Mobil — Hitung Cicilan, Asuransi, BBN & Total Biaya 5 Tahun"
  description="Kalkulator simulasi kredit mobil online gratis. Hitung cicilan, BBN, asuransi TLO/All Risk, dan total biaya kepemilikan mobil 5 tahun. Cash vs kredit comparison."
  icon="🚗"
  category="KALKULATOR KEUANGAN"
  categoryColor="yellow"
  breadcrumb={[
    { label: 'Kalkulator Keuangan', href: '/kalkulator-keuangan' },
    { label: 'Simulasi Kredit Mobil' }
  ]}
>

  <div class="calc-grid">
    <!-- LEFT: Input -->
    <div class="calc-panel">
      <h3>Detail Kredit Mobil</h3>

      <div class="form-group">
        <label class="form-label">Harga Mobil (OTR)</label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="harga" class="form-input" value="300.000.000" inputmode="numeric" data-format="rupiah" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">DP <span class="form-hint">min 25%</span></label>
          <div class="form-input-suffix">
            <input type="number" id="dpPersen" class="form-input" value="30" min="25" max="80" step="1" />
            <span class="suffix">%</span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tenor</label>
          <div class="form-input-suffix">
            <input type="number" id="tenor" class="form-input" value="5" min="1" max="7" step="1" />
            <span class="suffix">tahun</span>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Suku Bunga Flat <span class="form-hint">leasing 6-10%</span></label>
        <div class="form-input-suffix">
          <input type="number" id="bunga" class="form-input" value="7.5" min="0" max="30" step="0.1" />
          <span class="suffix">% /tahun</span>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Jenis Asuransi</label>
        <select id="jenisAsuransi" class="form-input">
          <option value="tlo">TLO (Total Loss Only) — ~0,4%/tahun</option>
          <option value="allrisk" selected>All Risk — ~2,5%/tahun (recommended)</option>
          <option value="combo">Combo (All Risk + TLO bertahap)</option>
          <option value="none">Tanpa Asuransi (tidak disarankan)</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">Wilayah Asuransi <span class="form-hint">tarif OJK</span></label>
        <select id="wilayah" class="form-input">
          <option value="1">Wilayah 1 — Sumatera & Kepri</option>
          <option value="2" selected>Wilayah 2 — DKI, Banten, Jabar</option>
          <option value="3">Wilayah 3 — Selain wilayah 1 & 2</option>
        </select>
      </div>

      <details class="advanced-toggle">
        <summary>Balloon Payment & Biaya Lain (opsional)</summary>
        <div class="form-row" style="margin-top: 12px;">
          <div class="form-group">
            <label class="form-label">Balloon Payment <span class="form-hint">% dari pokok</span></label>
            <div class="form-input-suffix">
              <input type="number" id="balloon" class="form-input" value="0" min="0" max="40" step="5" />
              <span class="suffix">%</span>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">BBN <span class="form-hint">Bea Balik Nama</span></label>
            <div class="form-input-suffix">
              <input type="number" id="bbn" class="form-input" value="12.5" min="0" max="20" step="0.5" />
              <span class="suffix">%</span>
            </div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Provisi <span class="form-hint">% pokok</span></label>
            <div class="form-input-suffix">
              <input type="number" id="provisi" class="form-input" value="1" min="0" max="5" step="0.1" />
              <span class="suffix">%</span>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Admin & Provisi</label>
            <div class="form-input-prefix">
              <span class="prefix">Rp</span>
              <input type="text" id="admin" class="form-input" value="2.500.000" inputmode="numeric" data-format="rupiah" />
            </div>
          </div>
        </div>
      </details>

      <div class="info-box">
        <span class="info-box-icon">ℹ️</span>
        <div>
          <strong>Note:</strong> Leasing mobil pakai bunga <strong>flat</strong> (bukan efektif seperti KPR). Total bunga dihitung dari pokok awal × bunga × tenor tahun.
        </div>
      </div>
    </div>

    <!-- RIGHT: Results -->
    <div class="calc-panel calc-panel-dark">
      <h3 style="color: rgba(255,255,255,0.85);">Hasil Simulasi</h3>

      <div class="result-main">
        <span class="label">CICILAN PER BULAN</span>
        <div class="value" id="cicilanPerBulan">Rp 0</div>
        <div class="cicilan-secondary" id="cicilanSecondary"></div>
      </div>

      <div class="result-grid">
        <div class="result-card">
          <span class="label">UANG MUKA + BIAYA</span>
          <span class="value" id="resTotalMuka">Rp 0</span>
        </div>
        <div class="result-card">
          <span class="label">POKOK DIFINANCE</span>
          <span class="value" id="resPokok">Rp 0</span>
        </div>
        <div class="result-card warning">
          <span class="label">TOTAL BUNGA</span>
          <span class="value" id="resTotalBunga">Rp 0</span>
        </div>
        <div class="result-card warning">
          <span class="label">TOTAL COST 5TH</span>
          <span class="value" id="resTotalCost">Rp 0</span>
        </div>
      </div>

      <div class="tco-box">
        <div class="tco-label">
          <span>Effective Cost vs Harga Mobil</span>
          <span id="effectiveRatio">0%</span>
        </div>
        <div class="tco-bar">
          <div class="tco-fill" id="tcoFill" style="width: 0%;"></div>
        </div>
        <div class="tco-hint">Total biaya kepemilikan lebih tinggi dari harga mobil</div>
      </div>

      <div class="action-buttons">
        <button class="btn-action primary" onclick="window.print()">🖨️ Print / Save PDF</button>
        <button class="btn-action secondary" onclick="document.getElementById('breakdown').scrollIntoView({behavior:'smooth'})">📊 Detail</button>
      </div>
    </div>
  </div>

  <!-- Cost Breakdown -->
  <section class="breakdown-section" id="breakdown">
    <h2>📊 Rincian Total Biaya Kepemilikan</h2>
    <p class="section-sub">Berapa total yang kamu keluarkan dari beli sampai akhir kredit</p>

    <div class="breakdown-grid">
      <div class="breakdown-row">
        <div class="breakdown-icon">💰</div>
        <div class="breakdown-text">
          <h4>Uang Muka (DP)</h4>
          <p>Dibayar di awal sebelum mobil diserahkan</p>
        </div>
        <div class="breakdown-amount" id="bdDp">Rp 0</div>
      </div>
      <div class="breakdown-row">
        <div class="breakdown-icon">📋</div>
        <div class="breakdown-text">
          <h4>BBN (Bea Balik Nama)</h4>
          <p>Pajak balik nama, BPKB, STNK</p>
        </div>
        <div class="breakdown-amount" id="bdBbn">Rp 0</div>
      </div>
      <div class="breakdown-row">
        <div class="breakdown-icon">📝</div>
        <div class="breakdown-text">
          <h4>Provisi & Admin</h4>
          <p>Biaya proses leasing</p>
        </div>
        <div class="breakdown-amount" id="bdAdmin">Rp 0</div>
      </div>
      <div class="breakdown-row">
        <div class="breakdown-icon">💳</div>
        <div class="breakdown-text">
          <h4>Total Cicilan</h4>
          <p>Pokok + bunga selama tenor</p>
        </div>
        <div class="breakdown-amount" id="bdCicilan">Rp 0</div>
      </div>
      <div class="breakdown-row">
        <div class="breakdown-icon">🛡️</div>
        <div class="breakdown-text">
          <h4>Asuransi (Selama Tenor)</h4>
          <p id="bdAsuransiHint">All Risk Wilayah 2</p>
        </div>
        <div class="breakdown-amount" id="bdAsuransi">Rp 0</div>
      </div>
      <div class="breakdown-row" id="bdBalloonRow" style="display:none;">
        <div class="breakdown-icon">🎈</div>
        <div class="breakdown-text">
          <h4>Balloon Payment (Akhir Tenor)</h4>
          <p>Bayar sekaligus di bulan terakhir</p>
        </div>
        <div class="breakdown-amount" id="bdBalloon">Rp 0</div>
      </div>
      <div class="breakdown-row breakdown-total">
        <div class="breakdown-icon">🎯</div>
        <div class="breakdown-text">
          <h4>TOTAL COST OF OWNERSHIP</h4>
          <p>Total semua biaya kepemilikan</p>
        </div>
        <div class="breakdown-amount" id="bdTotal">Rp 0</div>
      </div>
    </div>
  </section>

  <!-- Cash vs Credit -->
  <section class="comparison-section">
    <h2>💵 Cash vs Kredit — Mana Lebih Untung?</h2>
    <p class="section-sub">Bandingkan total biaya beli cash vs kredit untuk pertimbangan keputusan</p>

    <div class="vs-grid">
      <div class="vs-card vs-cash">
        <div class="vs-tag">CASH</div>
        <h4>💵 Beli Tunai</h4>
        <table class="vs-table">
          <tr><td>Harga Mobil</td><td id="vsCashHarga">Rp 0</td></tr>
          <tr><td>BBN</td><td id="vsCashBbn">Rp 0</td></tr>
          <tr><td>Asuransi 5 tahun</td><td id="vsCashAsuransi">Rp 0</td></tr>
          <tr class="vs-total"><td>Total Cash</td><td id="vsCashTotal">Rp 0</td></tr>
        </table>
      </div>
      <div class="vs-card vs-credit">
        <div class="vs-tag">KREDIT</div>
        <h4>💳 Kredit Leasing</h4>
        <table class="vs-table">
          <tr><td>DP</td><td id="vsCreditDp">Rp 0</td></tr>
          <tr><td>Total Cicilan</td><td id="vsCreditCicilan">Rp 0</td></tr>
          <tr><td>BBN + Admin + Provisi</td><td id="vsCreditBiaya">Rp 0</td></tr>
          <tr><td>Asuransi 5 tahun</td><td id="vsCreditAsuransi">Rp 0</td></tr>
          <tr class="vs-total"><td>Total Kredit</td><td id="vsCreditTotal">Rp 0</td></tr>
        </table>
      </div>
    </div>

    <div class="vs-conclusion" id="vsConclusion">
      <!-- Filled by JS -->
    </div>
  </section>

  <!-- Tenor Comparison -->
  <section class="tenor-section">
    <h2>📅 Perbandingan Tenor</h2>
    <p class="section-sub">Lihat cicilan dan total bunga untuk tenor berbeda</p>
    <div class="tenor-table-wrap">
      <table class="tenor-table">
        <thead>
          <tr><th>Tenor</th><th>Cicilan/Bulan</th><th>Total Bunga</th><th>Total Bayar</th></tr>
        </thead>
        <tbody id="tenorTableBody"></tbody>
      </table>
    </div>
  </section>

  <!-- Tips -->
  <section class="tips-section">
    <h2>💡 Tips Beli Mobil Cerdas</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon">💰</div>
        <h4>DP Minimal 30%</h4>
        <p>Bunga leasing flat 7-10% bikin total bunga besar. DP gede = pokok kecil = total bunga kecil.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">⏰</div>
        <h4>Tenor Max 5 Tahun</h4>
        <p>Tenor 6-7 tahun bikin total bunga membengkak. Mobil bisa rusak/depresiasi sebelum lunas.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">🛡️</div>
        <h4>All Risk Tahun 1-3</h4>
        <p>Mobil baru perlu All Risk. Setelah 3 tahun, pindah ke TLO untuk hemat premi.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">🚗</div>
        <h4>Resale Value Penting</h4>
        <p>Pilih merk dengan harga jual stabil (Toyota, Honda). Mobil Jepang depresiasi 10-15%/tahun.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section-calc">
    <h2>❓ Pertanyaan Umum Kredit Mobil</h2>
    <div class="faq-list">
      <details class="faq-item" open>
        <summary>Apa beda bunga flat dan bunga efektif?</summary>
        <div class="faq-answer">
          <p><strong>Bunga Flat:</strong> Bunga dihitung dari pokok awal selama tenor. Total bunga = Pokok × bunga × tahun. Standar di leasing mobil/motor.</p>
          <p><strong>Bunga Efektif:</strong> Bunga dihitung dari sisa pokok yang menyusut tiap bulan. Standar di KPR.</p>
          <p>Bunga flat 7% setara dengan bunga efektif ~13-14%. Pastikan compare yang setara!</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Berapa DP minimum kredit mobil 2026?</summary>
        <div class="faq-answer">
          <p>OJK mengatur DP minimum kredit kendaraan bermotor (KKB):</p>
          <p><strong>Mobil baru:</strong> Minimum 25% (sebelumnya 30%, dilonggarkan untuk dorong industri otomotif).</p>
          <p><strong>Mobil bekas:</strong> Minimum 30%.</p>
          <p>Tapi praktiknya, leasing sering minta DP 30-50% untuk approval lebih mudah.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apa itu asuransi TLO dan All Risk?</summary>
        <div class="faq-answer">
          <p><strong>TLO (Total Loss Only):</strong> Klaim asuransi hanya jika mobil hilang/rusak total (>75% rusak). Premi murah ~0,4%/tahun dari harga mobil.</p>
          <p><strong>All Risk (Comprehensive):</strong> Cover semua risiko: lecet, penyok, kecelakaan, banjir, hilang. Premi ~2,5%/tahun. Direkomendasikan untuk mobil baru.</p>
          <p>Strategi: All Risk untuk 3 tahun pertama, lalu pindah TLO untuk hemat.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apa itu Balloon Payment?</summary>
        <div class="faq-answer">
          <p>Balloon Payment adalah skema kredit dengan cicilan lebih kecil di awal, tapi ada pembayaran besar (balloon) di akhir tenor.</p>
          <p>Misal: Kredit Rp 200jt, tenor 5 tahun, balloon 20%. Yang dicicil cuma 80% (Rp 160jt). Di bulan ke-60, bayar Rp 40jt sekaligus.</p>
          <p>Cocok untuk: orang yang ingin upgrade mobil tiap 5 tahun (balloon = trade-in value). Risiko: kalau dana balloon tidak siap, harus refinance.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Bagaimana cara hitung BBN (Bea Balik Nama)?</summary>
        <div class="faq-answer">
          <p>BBN mobil baru biasanya 12,5% dari harga off-the-road (OTR). Komponen:</p>
          <p>• BBN-KB (Bea Balik Nama Kendaraan Bermotor): 10% dari harga</p>
          <p>• PKB (Pajak Kendaraan Bermotor): 1,5% dari NJKB</p>
          <p>• SWDKLLJ: Rp 143.000</p>
          <p>• Biaya STNK & TNKB: ~Rp 200.000-500.000</p>
          <p>Untuk mobil mewah, ada PPnBM 10-95% tergantung kategori.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Related -->
  <section class="related-section">
    <h2>Kalkulator Terkait</h2>
    <div class="related-grid">
      <a href="/simulasi-kredit-motor" class="related-card">
        <span class="related-icon">🏍️</span>
        <h4>Simulasi Kredit Motor</h4>
        <p>Hitung cicilan motor + asuransi + BBN</p>
      </a>
      <a href="/kalkulator-gaji-bersih" class="related-card">
        <span class="related-icon">💼</span>
        <h4>Kalkulator Gaji Bersih</h4>
        <p>Cek take-home pay untuk planning cicilan</p>
      </a>
      <a href="/kalkulator-investasi" class="related-card">
        <span class="related-icon">📈</span>
        <h4>Kalkulator Investasi</h4>
        <p>Investasi vs beli mobil cash</p>
      </a>
    </div>
  </section>

</CalculatorLayout>

<style>
.cicilan-secondary {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px dashed rgba(255,255,255,0.15);
  font-size: 13px;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
}
.cicilan-secondary strong { color: rgba(255,255,255,0.9); }

.tco-box {
  margin-top: 20px;
  padding: 14px 16px;
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
}
.tco-label {
  display: flex;
  justify-content: space-between;
  font-size: 12.5px;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  margin-bottom: 8px;
}
.tco-label span:last-child { color: var(--gold); font-size: 14px; }
.tco-bar {
  height: 8px;
  background: rgba(255,255,255,0.08);
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 6px;
}
.tco-fill {
  height: 100%;
  background: linear-gradient(90deg, #FBBF24, #DC2626);
  border-radius: 6px;
  transition: width .4s var(--ease);
}
.tco-hint {
  font-size: 11.5px;
  color: rgba(255,255,255,0.5);
  text-align: center;
}

.action-buttons {
  display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap;
}
.action-buttons .btn-action.primary {
  flex: 1; background: var(--gold); color: var(--navy);
}
.action-buttons .btn-action.primary:hover { background: #FCD34D; }
.action-buttons .btn-action.secondary {
  background: rgba(255,255,255,0.08); color: #fff; flex: 1;
}
.action-buttons .btn-action.secondary:hover { background: rgba(255,255,255,0.14); }

.advanced-toggle {
  border: 1px dashed var(--line); border-radius: 10px;
  padding: 8px 14px; margin-bottom: 16px;
}
.advanced-toggle summary {
  cursor: pointer; list-style: none;
  font-size: 13.5px; font-weight: 600;
  color: var(--ink-2);
  display: flex; align-items: center; gap: 6px;
}
.advanced-toggle summary::-webkit-details-marker { display: none; }
.advanced-toggle summary::before {
  content: "▸"; transition: transform .2s;
  font-size: 12px; color: var(--ink-3);
}
.advanced-toggle[open] summary::before { transform: rotate(90deg); }

.breakdown-section,
.comparison-section,
.tenor-section,
.tips-section,
.faq-section-calc,
.related-section {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--line);
}
.breakdown-section h2,
.comparison-section h2,
.tenor-section h2,
.tips-section h2,
.faq-section-calc h2,
.related-section h2 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(24px, 3.5vw, 32px);
  margin: 0 0 8px;
  color: var(--ink);
}
.section-sub {
  font-size: 14.5px;
  color: var(--ink-3);
  margin: 0 0 24px;
}

/* Breakdown Rows */
.breakdown-grid {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 16px;
  overflow: hidden;
}
.breakdown-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 16px;
  align-items: center;
  padding: 18px 22px;
  border-bottom: 1px solid var(--line);
}
.breakdown-row:last-child { border-bottom: none; }
.breakdown-icon {
  font-size: 24px;
  width: 44px; height: 44px;
  display: grid; place-items: center;
  background: var(--bg-soft);
  border-radius: 10px;
}
.breakdown-text h4 {
  font-size: 14.5px;
  font-weight: 700;
  margin: 0 0 2px;
  color: var(--ink);
}
.breakdown-text p {
  font-size: 12.5px;
  color: var(--ink-3);
  margin: 0;
}
.breakdown-amount {
  font-size: 16px;
  font-weight: 700;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.breakdown-total {
  background: var(--navy);
  color: #fff;
}
.breakdown-total .breakdown-icon { background: rgba(255,255,255,0.12); }
.breakdown-total .breakdown-text h4 { color: #fff; font-size: 13px; letter-spacing: 0.06em; }
.breakdown-total .breakdown-text p { color: rgba(255,255,255,0.6); }
.breakdown-total .breakdown-amount { color: var(--gold); font-size: 20px; }

/* Cash vs Credit */
.vs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 700px) {
  .vs-grid { grid-template-columns: 1fr; }
}
.vs-card {
  border: 2px solid var(--line);
  border-radius: 16px;
  padding: 22px;
  background: #fff;
  position: relative;
}
.vs-card.vs-cash { border-color: #10B981; background: #ECFDF5; }
.vs-card.vs-credit { border-color: #2563EB; background: #EFF6FF; }
.vs-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 4px 10px;
  border-radius: 6px;
  margin-bottom: 10px;
}
.vs-card.vs-cash .vs-tag { background: #D1FAE5; color: #065F46; }
.vs-card.vs-credit .vs-tag { background: #DBEAFE; color: #1E40AF; }
.vs-card h4 {
  font-size: 18px; font-weight: 700;
  margin: 0 0 14px; color: var(--ink);
}
.vs-table {
  width: 100%; font-size: 13.5px;
  border-collapse: collapse;
}
.vs-table td {
  padding: 8px 0;
  color: var(--ink-2);
}
.vs-table td:last-child {
  text-align: right;
  font-weight: 600;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.vs-total td {
