</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';

const $ = (id) => document.getElementById(id);

// Asuransi rates per wilayah & jenis (% per tahun)
const ASURANSI_RATES = {
  tlo: { 1: 0.24, 2: 0.44, 3: 0.24 },
  allrisk: { 1: 1.17, 2: 1.17, 3: 0.92 }, // average rates atas
  combo: { 1: 0.71, 2: 0.81, 3: 0.58 }, // tahun 1-3 AllRisk, 4-5 TLO weighted
  none: { 1: 0, 2: 0, 3: 0 },
};

const ASURANSI_LABEL = {
  tlo: 'TLO (Total Loss Only)',
  allrisk: 'All Risk (Comprehensive)',
  combo: 'Combo All Risk + TLO',
  none: 'Tanpa Asuransi',
};

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

function recalculate() {
  const harga = parseRupiah($('harga').value);
  const dpPersen = parseFloat($('dpPersen').value) || 0;
  const tenorTahun = parseInt($('tenor').value) || 1;
  const tenorBulan = tenorTahun * 12;
  const bunga = parseFloat($('bunga').value) || 0;
  const jenisAsuransi = $('jenisAsuransi').value;
  const wilayah = parseInt($('wilayah').value);
  const balloonPersen = parseFloat($('balloon').value) || 0;
  const bbnPersen = parseFloat($('bbn').value) || 0;
  const provisiPersen = parseFloat($('provisi').value) || 0;
  const admin = parseRupiah($('admin').value);

  if (!harga || harga <= 0) return;

  // Calc dasar
  const dp = harga * (dpPersen / 100);
  const bbn = harga * (bbnPersen / 100);
  const pokokTotal = harga - dp;
  const balloon = pokokTotal * (balloonPersen / 100);
  const pokokFinance = pokokTotal - balloon; // yg dicicil
  const provisi = pokokFinance * (provisiPersen / 100);

  // Bunga flat: total bunga = pokokFinance × bunga × tahun
  const totalBunga = pokokFinance * (bunga / 100) * tenorTahun;
  const totalCicilan = pokokFinance + totalBunga;
  const cicilanPerBulan = totalCicilan / tenorBulan;

  // Asuransi
  const tarifAsuransi = ASURANSI_RATES[jenisAsuransi][wilayah];
  const asuransiPerTahun = harga * (tarifAsuransi / 100);
  const asuransiTotal = asuransiPerTahun * tenorTahun;

  // Total upfront
  const totalMuka = dp + bbn + provisi + admin + asuransiPerTahun;

  // Total cost of ownership
  const totalCost = dp + totalCicilan + balloon + bbn + provisi + admin + asuransiTotal;
  const effectiveRatio = ((totalCost - harga) / harga) * 100;

  // Update DOM
  $('cicilanPerBulan').textContent = formatRupiah(cicilanPerBulan);
  if (balloon > 0) {
    $('cicilanSecondary').innerHTML = `Bulan ke-${tenorBulan}: bayar tambahan <strong>${formatRupiah(balloon)}</strong> (balloon payment)`;
  } else {
    $('cicilanSecondary').innerHTML = '';
  }
  $('resTotalMuka').textContent = formatRupiah(totalMuka);
  $('resPokok').textContent = formatRupiah(pokokFinance);
  $('resTotalBunga').textContent = formatRupiah(totalBunga);
  $('resTotalCost').textContent = formatRupiah(totalCost);
  $('effectiveRatio').textContent = formatPercent(effectiveRatio, 1);
  $('tcoFill').style.width = `${Math.min(effectiveRatio, 100)}%`;

  // Breakdown
  $('bdDp').textContent = formatRupiah(dp);
  $('bdBbn').textContent = formatRupiah(bbn);
  $('bdAdmin').textContent = formatRupiah(provisi + admin);
  $('bdCicilan').textContent = formatRupiah(totalCicilan);
  $('bdAsuransi').textContent = formatRupiah(asuransiTotal);
  $('bdAsuransiHint').textContent = `${ASURANSI_LABEL[jenisAsuransi]} — Wilayah ${wilayah}`;
  if (balloon > 0) {
    $('bdBalloonRow').style.display = 'grid';
    $('bdBalloon').textContent = formatRupiah(balloon);
  } else {
    $('bdBalloonRow').style.display = 'none';
  }
  $('bdTotal').textContent = formatRupiah(totalCost);

  // Cash vs Credit (5 tahun asuransi for fair comparison)
  const asuransi5Tahun = asuransiPerTahun * 5;
  const cashTotal = harga + bbn + asuransi5Tahun;
  const creditTotal = totalCost + (asuransiTotal === asuransi5Tahun ? 0 : (asuransi5Tahun - asuransiTotal));
  const selisih = creditTotal - cashTotal;
  const selisihPersen = (selisih / cashTotal) * 100;

  $('vsCashHarga').textContent = formatRupiah(harga);
  $('vsCashBbn').textContent = formatRupiah(bbn);
  $('vsCashAsuransi').textContent = formatRupiah(asuransi5Tahun);
  $('vsCashTotal').textContent = formatRupiah(cashTotal);

  $('vsCreditDp').textContent = formatRupiah(dp);
  $('vsCreditCicilan').textContent = formatRupiah(totalCicilan + balloon);
  $('vsCreditBiaya').textContent = formatRupiah(bbn + provisi + admin);
  $('vsCreditAsuransi').textContent = formatRupiah(asuransi5Tahun);
  $('vsCreditTotal').textContent = formatRupiah(dp + totalCicilan + balloon + bbn + provisi + admin + asuransi5Tahun);

  const creditMinusCash = (dp + totalCicilan + balloon + bbn + provisi + admin + asuransi5Tahun) - cashTotal;
  const creditMinusCashPersen = (creditMinusCash / cashTotal) * 100;
  $('vsConclusion').innerHTML = `
    <strong>💡 Kesimpulan:</strong> Beli kredit lebih mahal <strong>${formatRupiah(creditMinusCash)}</strong> 
    (${formatPercent(creditMinusCashPersen, 1)}) dibanding cash. 
    Selisih ini adalah biaya untuk "tidak harus keluarkan uang sekaligus". 
    Kalau punya dana cash + masih bisa investasi sisanya di reksadana/saham dengan return >${formatPercent(creditMinusCashPersen/5, 1)}/tahun, 
    <strong>beli cash lebih menguntungkan</strong>.
  `;

  // Tenor comparison
  const tenorOptions = [1, 2, 3, 4, 5, 6, 7];
  let tHtml = '';
  tenorOptions.forEach(t => {
    const tBulan = t * 12;
    const tTotalBunga = pokokFinance * (bunga / 100) * t;
    const tTotalCicilan = pokokFinance + tTotalBunga;
    const tCicilan = tTotalCicilan / tBulan;
    const tBayar = pokokFinance + tTotalBunga + balloon;
    const isCurrent = t === tenorTahun;
    tHtml += `<tr class="${isCurrent ? 'recommended' : ''}">
      <td>${t} tahun</td>
      <td>${formatRupiah(tCicilan)}</td>
      <td>${formatRupiah(tTotalBunga)}</td>
      <td>${formatRupiah(tBayar)}</td>
    </tr>`;
  });
  $('tenorTableBody').innerHTML = tHtml;
}

['dpPersen','tenor','bunga','jenisAsuransi','wilayah','balloon','bbn','provisi'].forEach(id => {
  $(id).addEventListener('input', recalculate);
  $(id).addEventListener('change', recalculate);
});

recalculate();
</script>