---
// Halaman "Pasang Widget" — hub embed widget untuk pemilik website (indexable)
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AdSlot from '../components/AdSlot.astro';
import FAQ from '../components/FAQ.astro';

const pageTitle = 'Pasang Widget Kalkulator Gratis di Website Kamu | HitungCerdas';
const pageDesc = 'Pasang widget kalkulator KPR gratis di blog atau website kamu — tinggal copy-paste kode embed. Tool interaktif untuk pembaca, ringan, dan tanpa biaya.';
const keywords = ['widget kalkulator', 'embed kalkulator kpr', 'widget kpr gratis', 'pasang kalkulator di website', 'widget keuangan gratis', 'embed kalkulator'];
const canonical = 'https://hitungcerdas.net/widget';

const bcItems = [
  { label: 'Beranda', href: '/' },
  { label: 'Pasang Widget' },
];

const widgets = [
  {
    slug: 'kpr',
    name: 'Simulasi Cicilan KPR',
    desc: 'Pengunjung bisa menghitung perkiraan cicilan KPR per bulan langsung di halamanmu — tanpa berpindah situs.',
    height: 560,
    embedUrl: 'https://hitungcerdas.net/embed/kpr/',
    embedCode: `<iframe src="https://hitungcerdas.net/embed/kpr/" width="100%" height="560" style="border:1px solid #e5e7eb;border-radius:14px;max-width:480px" loading="lazy" title="Simulasi Cicilan KPR"></iframe>
<p style="font-size:13px;color:#555">Kalkulator KPR oleh <a href="https://hitungcerdas.net/kalkulator/kpr/" target="_blank" rel="noopener">HitungCerdas</a></p>`,
  },
];

const benefits = [
  { icon: 'ti-gift', title: 'Gratis selamanya', desc: 'Tanpa biaya, tanpa langganan. Satu-satunya syarat: biarkan baris kredit tetap ada.' },
  { icon: 'ti-copy', title: 'Tinggal copy-paste', desc: 'Salin satu blok kode, tempel di HTML halamanmu. Tidak perlu coding.' },
  { icon: 'ti-mouse', title: 'Interaktif buat pembaca', desc: 'Pembaca bisa menghitung sendiri di artikelmu — engagement & waktu baca naik.' },
  { icon: 'ti-rocket', title: 'Ringan & responsif', desc: 'Dimuat lazy, otomatis menyesuaikan layar HP maupun desktop.' },
];

const faqs = [
  { question: 'Apakah widget ini benar-benar gratis?', answer: 'Ya, 100% gratis tanpa biaya tersembunyi. Satu-satunya syarat adalah membiarkan baris kredit <strong>"oleh HitungCerdas"</strong> tetap ada pada kode embed.' },
  { question: 'Apakah widget memperlambat website saya?', answer: 'Tidak. Widget dimuat secara <em>lazy</em> (hanya saat terlihat) dan berukuran ringan, jadi tidak mengganggu kecepatan halaman.' },
  { question: 'Bisakah ukurannya saya ubah?', answer: 'Bisa. Sesuaikan atribut <strong>width</strong> dan <strong>height</strong> pada kode iframe sesuai kebutuhan tata letak situsmu.' },
  { question: 'Bisakah dipasang di Instagram atau Facebook?', answer: 'Tidak. Media sosial tidak mengizinkan kode iframe. Widget ini khusus untuk website/blog. Untuk media sosial, cukup bagikan tautan kalkulatornya langsung.' },
];
---

<Layout title={pageTitle} description={pageDesc} keywords={keywords} canonical={canonical}>
  <section class="section">
    <div class="wrap">
      <Breadcrumb items={bcItems} />

      <div class="section-hdr">
        <div class="section-eyebrow">Gratis untuk Pemilik Website</div>
        <h1 class="section-title">Pasang Widget Kalkulator Gratis di Website Kamu</h1>
        <p class="section-desc">
          Punya blog atau website? Tempelkan kalkulator interaktif HitungCerdas langsung di halamanmu.
          Pembaca bisa menghitung sendiri tanpa berpindah situs — cukup copy-paste satu blok kode, gratis.
        </p>
      </div>

      <div class="benefits">
        {benefits.map((b) => (
          <div class="benefit">
            <div class="benefit-ic"><i class={`ti ${b.icon}`}></i></div>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>

      <div class="steps">
        <div class="step"><span class="step-n">1</span><p>Klik <strong>"Salin Kode"</strong> pada widget yang kamu mau.</p></div>
        <div class="step"><span class="step-n">2</span><p>Tempel kode di HTML halaman atau artikel website kamu, di tempat widget ingin ditampilkan.</p></div>
        <div class="step"><span class="step-n">3</span><p>Selesai — widget langsung tampil &amp; berfungsi. Pembaca bisa menghitung tanpa meninggalkan halamanmu.</p></div>
      </div>
    </div>
  </section>

  <AdSlot format="rectangle" />

  <section class="section section-soft">
    <div class="wrap">
      <h2 class="wgt-h2">Widget yang tersedia</h2>
      {widgets.map((w) => (
        <div class="wgt-card">
          <div class="wgt-head">
            <h3>{w.name}</h3>
            <p>{w.desc}</p>
          </div>
          <div class="wgt-body">
            <div class="wgt-preview">
              <div class="wgt-preview-lbl">Pratinjau langsung</div>
              <iframe src={w.embedUrl} width="100%" height={w.height} loading="lazy" title={w.name} class="wgt-frame"></iframe>
            </div>
            <div class="wgt-code">
              <div class="code-bar">
                <span class="code-lbl">Kode embed</span>
                <button class="copy-btn" type="button" data-target={`code-${w.slug}`}>Salin Kode</button>
              </div>
              <textarea id={`code-${w.slug}`} class="code-box" readonly rows="6">{w.embedCode}</textarea>
              <p class="attr-note">
                <i class="ti ti-info-circle"></i>
                Mohon biarkan baris kredit <strong>"oleh HitungCerdas"</strong> tetap ada — itu satu-satunya syarat yang membuat widget ini gratis.
              </p>
            </div>
          </div>
        </div>
      ))}
      <p class="more-note">Widget lain (Investasi, Cicilan Kredit, dan lainnya) menyusul. Punya permintaan? <a href="/kontak/">Hubungi kami</a>.</p>
    </div>
  </section>

  <FAQ title="Pertanyaan Seputar Widget" items={faqs} />
</Layout>

<style>
  .benefits {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 14px;
    margin-bottom: 26px;
  }
  .benefit {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 18px;
  }
  .benefit-ic {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    background: var(--blue-light, #DBEAFE);
    color: var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 12px;
  }
  .benefit h3 { font-size: 15px; font-weight: 700; color: var(--navy); font-family: var(--ff-display); margin: 0 0 6px; }
  .benefit p { font-size: 13px; color: var(--text-soft); line-height: 1.55; margin: 0; }

  .steps { display: flex; flex-direction: column; gap: 12px; max-width: 720px; }
  .step { display: flex; align-items: flex-start; gap: 12px; }
  .step-n {
    flex: 0 0 auto; width: 28px; height: 28px; border-radius: 50%;
    background: var(--navy); color: #fff; font-size: 14px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .step p { font-size: 14.5px; color: var(--text-soft); line-height: 1.55; margin: 2px 0 0; }
  .step strong { color: var(--navy); }

  .wgt-h2 { font-size: 22px; font-weight: 800; color: var(--navy); font-family: var(--ff-display); margin: 0 0 18px; }
  .wgt-card { background: #fff; border: 1px solid var(--border); border-radius: var(--r-lg, 16px); overflow: hidden; }
  .wgt-head { padding: 18px 20px; border-bottom: 1px solid var(--border); }
  .wgt-head h3 { font-size: 17px; font-weight: 700; color: var(--navy); font-family: var(--ff-display); margin: 0 0 4px; }
  .wgt-head p { font-size: 13.5px; color: var(--text-soft); line-height: 1.55; margin: 0; }

  .wgt-body { display: grid; grid-template-columns: minmax(0, 340px) 1fr; gap: 22px; padding: 20px; align-items: start; }
  .wgt-preview-lbl, .code-lbl { font-size: 11px; font-weight: 700; color: var(--text-mute); text-transform: uppercase; letter-spacing: .06em; }
  .wgt-preview-lbl { display: block; margin-bottom: 8px; }
  .wgt-frame { border: 1px solid var(--border); border-radius: 12px; display: block; }

  .code-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .copy-btn {
    background: var(--blue); color: #fff; border: 0; font-size: 12.5px; font-weight: 600;
    padding: 7px 14px; border-radius: 8px; cursor: pointer; font-family: inherit;
    transition: background .15s;
  }
  .copy-btn:hover { background: var(--blue-dark, #1E40AF); }
  .code-box {
    width: 100%; font-family: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;
    font-size: 12px; line-height: 1.55; color: #0A2540; background: var(--bg-soft, #F8FAFC);
    border: 1px solid var(--border); border-radius: 10px; padding: 12px; resize: vertical;
  }
  .attr-note {
    font-size: 12.5px; color: var(--text-soft); line-height: 1.55; margin: 10px 0 0;
    display: flex; gap: 7px; align-items: flex-start;
  }
  .attr-note i { color: var(--blue); flex: 0 0 auto; margin-top: 2px; }
  .more-note { font-size: 13.5px; color: var(--text-soft); margin: 18px 0 0; }
  .more-note a { color: var(--blue); text-decoration: none; font-weight: 600; }
  .more-note a:hover { text-decoration: underline; }
  .section-soft { background: var(--bg-soft, #F8FAFC); }

  @media (max-width: 640px) {
    .wgt-body { grid-template-columns: 1fr; }
  }

  /* ── Dark mode ── */
  :global([data-theme="dark"]) .benefit,
  :global([data-theme="dark"]) .wgt-card { background: var(--bg-card); }
  :global([data-theme="dark"]) .code-box { background: var(--bg-soft); color: var(--text); }
  :global([data-theme="dark"]) .benefit h3,
  :global([data-theme="dark"]) .wgt-h2,
  :global([data-theme="dark"]) .wgt-head h3 { color: var(--text); }
  :global([data-theme="dark"]) .section-soft { background: var(--bg-soft); }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var ta = document.getElementById(btn.getAttribute('data-target'));
      if (!ta) return;
      var done = function () {
        var prev = btn.textContent;
        btn.textContent = '\u2713 Tersalin!';
        setTimeout(function () { btn.textContent = prev; }, 1800);
      };
      try {
        ta.select();
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(ta.value).then(done, function () { document.execCommand('copy'); done(); });
        } else {
          document.execCommand('copy');
          done();
        }
      } catch (e) {
        document.execCommand('copy');
        done();
      }
    });
  });
</script>
