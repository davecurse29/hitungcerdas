</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';

const $ = (id) => document.getElementById(id);

// === Constants: UU HPP Progressive Tax Lapisan ===
const LAPISAN = [
  { batas: 60_000_000, tarif: 0.05 },
  { batas: 250_000_000, tarif: 0.15 },
  { batas: 500_000_000, tarif: 0.25 },
  { batas: 5_000_000_000, tarif: 0.30 },
  { batas: Infinity, tarif: 0.35 },
];

// === Rupiah Input Formatting ===
document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

// === Update PTKP Display ===
function updatePtkpDisplay() {
  const select = $('statusPtkp');
  const ptkp = parseInt(select.options[select.selectedIndex].dataset.ptkp);
  $('ptkpAmount').textContent = `Rp ${formatNumber(ptkp)}/tahun`;
}

// === Calculate PPh 21 with Progressive Tariff ===
function hitungPajakProgresif(pkp) {
  if (pkp <= 0) return { total: 0, breakdown: [] };
  let pajak = 0;
  let breakdown = [];
  let sisa = pkp;
  let batasPrev = 0;
  
  for (const lap of LAPISAN) {
    if (sisa <= 0) break;
    const range = lap.batas - batasPrev;
    const kena = Math.min(sisa, range);
    const pajakLapisan = kena * lap.tarif;
    pajak += pajakLapisan;
    breakdown.push({
      tarif: lap.tarif * 100,
      batasFrom: batasPrev,
      batasTo: lap.batas === Infinity ? null : lap.batas,
      kena,
      pajak: pajakLapisan,
    });
    sisa -= kena;
    batasPrev = lap.batas;
  }
  return { total: pajak, breakdown };
}

// === Main Recalculation ===
function recalculate() {
  const gajiPokok = parseRupiah($('gajiPokok').value);
  const tunjangan = parseRupiah($('tunjangan').value);
  const bonus = parseRupiah($('bonus').value);
  const bpjsKesehatan = parseRupiah($('bpjsKesehatan').value);
  const bpjsKetenagakerjaan = parseRupiah($('bpjsKetenagakerjaan').value);
  const potonganLain = parseRupiah($('potonganLain').value);
  const select = $('statusPtkp');
  const ptkp = parseInt(select.options[select.selectedIndex].dataset.ptkp);
  const statusLabel = select.options[select.selectedIndex].value;
  const metode = $('metodeHitung').value;

  updatePtkpDisplay();

  if (!gajiPokok) return;

  // Bruto setahun
  const brutoTahun = (gajiPokok + tunjangan) * 12 + bonus;

  // Biaya jabatan: 5% dari bruto, max Rp 6jt/tahun
  const biayaJabatan = Math.min(brutoTahun * 0.05, 6_000_000);

  // BPJS Ketenagakerjaan setahun (boleh dikurangkan)
  const bpjsTKTahun = bpjsKetenagakerjaan * 12;

  // Neto setahun
  const netoTahun = brutoTahun - biayaJabatan - bpjsTKTahun;

  // PKP
  const pkp = Math.max(0, netoTahun - ptkp);

  // Hitung pajak
  const { total: pphTahun, breakdown } = hitungPajakProgresif(pkp);
  const pphBulan = pphTahun / 12;

  // Take-home pay per bulan
  const grossBulanan = gajiPokok + tunjangan;
  const takeHome = grossBulanan - bpjsKesehatan - bpjsKetenagakerjaan - potonganLain - pphBulan;

  // Tarif efektif
  const effectiveTax = brutoTahun > 0 ? (pphTahun / brutoTahun) * 100 : 0;

  // Update DOM
  $('takeHomePay').textContent = formatRupiah(takeHome);
  $('resBruto').textContent = formatRupiah(grossBulanan);
  $('resPkp').textContent = formatRupiah(pkp);
  $('resPphBulan').textContent = formatRupiah(pphBulan);
  $('resPphTahun').textContent = formatRupiah(pphTahun);
  $('effectiveTaxRate').textContent = formatPercent(effectiveTax, 2);
  $('effectiveTaxFill').style.width = `${Math.min(effectiveTax * 3, 100)}%`;

  // Update rincian
  $('rGajiTahun').textContent = formatRupiah(gajiPokok * 12);
  $('rTunjanganTahun').textContent = formatRupiah(tunjangan * 12);
  $('rBonusTahun').textContent = formatRupiah(bonus);
  $('rBrutoTotal').textContent = formatRupiah(brutoTahun);
  $('rBiayaJabatan').textContent = formatRupiah(biayaJabatan);
  $('rBpjsTK').textContent = formatRupiah(bpjsTKTahun);
  $('rPengurangTotal').textContent = formatRupiah(biayaJabatan + bpjsTKTahun);
  $('rNetoTahun').textContent = formatRupiah(netoTahun);
  $('rStatusPtkp').textContent = statusLabel.replace('TK', 'TK/').replace('K', 'K/').replace('//', '/');
  $('rPtkpAmount').textContent = formatRupiah(ptkp);
  $('rPkpTotal').textContent = formatRupiah(pkp);

  // Lapisan breakdown
  let lapisanHtml = '';
  if (breakdown.length === 0 || pkp <= 0) {
    lapisanHtml = '<tr><td colspan="2" style="text-align:center; color:var(--ink-3); padding:16px 0;">PKP ≤ 0, tidak ada pajak terutang</td></tr>';
  } else {
    breakdown.forEach((lap, idx) => {
      if (lap.kena > 0) {
        const range = lap.batasTo 
          ? `${formatRupiah(lap.batasFrom)} – ${formatRupiah(lap.batasTo)}` 
          : `> ${formatRupiah(lap.batasFrom)}`;
        lapisanHtml += `
          <tr class="rincian-lapisan-row">
            <td>${lap.tarif}% × ${formatRupiah(lap.kena)}<br><span class="rincian-hint">${range}</span></td>
            <td>${formatRupiah(lap.pajak)}</td>
          </tr>`;
      }
    });
    lapisanHtml += `<tr class="rincian-total"><td>Total PPh 21 Setahun</td><td>${formatRupiah(pphTahun)}</td></tr>`;
  }
  $('tableLapisan').innerHTML = lapisanHtml;

  // Show/hide TER table
  $('terTable').style.display = metode === 'ter' ? 'block' : 'none';
}

// === Event Listeners ===
$('statusPtkp').addEventListener('change', recalculate);
$('metodeHitung').addEventListener('change', recalculate);

// Initial
updatePtkpDisplay();
recalculate();
</script>