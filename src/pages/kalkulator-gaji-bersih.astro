---
// src/pages/kalkulator-gaji-bersih.astro
// Kalkulator Gaji Bersih Pro — Take Home Pay Calculator
import CalculatorLayout from '../components/CalculatorLayout.astro';
---

<CalculatorLayout
  title="Kalkulator Gaji Bersih — Hitung Take Home Pay Karyawan Indonesia"
  description="Kalkulator gaji bersih online gratis. Hitung take-home pay setelah BPJS Kesehatan, BPJS Ketenagakerjaan, PPh 21, dan potongan lainnya. Cocok untuk karyawan & HRD."
  icon="💼"
  category="KALKULATOR KEUANGAN"
  categoryColor="green"
  breadcrumb={[
    { label: 'Kalkulator Keuangan', href: '/kalkulator-keuangan' },
    { label: 'Kalkulator Gaji Bersih' }
  ]}
>

  <div class="calc-grid">
    <!-- LEFT: Input -->
    <div class="calc-panel">
      <h3>Komponen Penghasilan</h3>

      <div class="form-group">
        <label class="form-label">Gaji Pokok <span class="form-hint">per bulan</span></label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="gajiPokok" class="form-input" value="8.000.000" inputmode="numeric" data-format="rupiah" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Tunjangan Tetap</label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="tunjangan" class="form-input" value="1.500.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Lembur / Komisi</label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="lembur" class="form-input" value="0" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </div>

      <h3 style="margin-top: 28px;">Potongan</h3>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">BPJS Kesehatan <span class="form-hint">1% gaji</span></label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="bpjsKesehatan" class="form-input" value="80.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">JHT <span class="form-hint">2%</span></label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="jht" class="form-input" value="160.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">JP (Jaminan Pensiun) <span class="form-hint">1%</span></label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="jp" class="form-input" value="80.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">PPh 21</label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="pph21" class="form-input" value="100.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Potongan Lain <span class="form-hint">kasbon, koperasi, dll</span></label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="potonganLain" class="form-input" value="0" inputmode="numeric" data-format="rupiah" />
        </div>
      </div>

      <div class="info-box">
        <span class="info-box-icon">ℹ️</span>
        <div>
          <strong>Catatan BPJS:</strong> Standar potongan karyawan adalah BPJS Kesehatan 1% (max Rp 120rb), JHT 2%, JP 1%. Total BPJS karyawan ~4% gaji.
        </div>
      </div>
    </div>

    <!-- RIGHT: Results -->
    <div class="calc-panel calc-panel-dark">
      <h3 style="color: rgba(255,255,255,0.85);">Hasil Perhitungan</h3>

      <div class="result-main">
        <span class="label">TAKE HOME PAY <span style="color: rgba(255,255,255,0.5);">/bulan</span></span>
        <div class="value" id="takeHomePay">Rp 0</div>
      </div>

      <div class="result-grid">
        <div class="result-card">
          <span class="label">GAJI BRUTO</span>
          <span class="value" id="resBruto">Rp 0</span>
        </div>
        <div class="result-card warning">
          <span class="label">TOTAL POTONGAN</span>
          <span class="value" id="resTotalPotongan">Rp 0</span>
        </div>
        <div class="result-card">
          <span class="label">% POTONGAN</span>
          <span class="value" id="resPersenPotongan">0%</span>
        </div>
        <div class="result-card success">
          <span class="label">% TAKE HOME</span>
          <span class="value" id="resPersenTakeHome">0%</span>
        </div>
      </div>

      <!-- Pie Chart Breakdown -->
      <div class="breakdown-chart">
        <div class="breakdown-bar">
          <div class="bar-segment bar-takehome" id="barTakeHome" style="width: 0%;" title="Take Home Pay"></div>
          <div class="bar-segment bar-bpjs" id="barBpjs" style="width: 0%;" title="BPJS"></div>
          <div class="bar-segment bar-pajak" id="barPajak" style="width: 0%;" title="Pajak"></div>
          <div class="bar-segment bar-lain" id="barLain" style="width: 0%;" title="Lainnya"></div>
        </div>
        <div class="breakdown-legend">
          <div class="legend-item"><span class="dot dot-takehome"></span> Take Home <strong id="legendTakeHome">0%</strong></div>
          <div class="legend-item"><span class="dot dot-bpjs"></span> BPJS <strong id="legendBpjs">0%</strong></div>
          <div class="legend-item"><span class="dot dot-pajak"></span> Pajak <strong id="legendPajak">0%</strong></div>
          <div class="legend-item"><span class="dot dot-lain"></span> Lainnya <strong id="legendLain">0%</strong></div>
        </div>
      </div>

      <div class="action-buttons">
        <button class="btn-action primary" onclick="window.print()">🖨️ Print Slip Gaji</button>
      </div>
    </div>
  </div>

  <!-- 50/30/20 Allocation -->
  <section class="allocation-section">
    <h2>💰 Aturan Alokasi 50/30/20</h2>
    <p class="section-sub">Standar global untuk financial planning. Take home pay <strong id="thpDisplay">Rp 0</strong>/bulan sebaiknya dibagi:</p>

    <div class="allocation-grid">
      <div class="allocation-card needs">
        <div class="allocation-percent">50%</div>
        <h4>Kebutuhan</h4>
        <div class="allocation-amount" id="alloc50">Rp 0</div>
        <p>Sewa/cicilan rumah, makan, transport, BPJS, internet, listrik</p>
      </div>
      <div class="allocation-card wants">
        <div class="allocation-percent">30%</div>
        <h4>Keinginan</h4>
        <div class="allocation-amount" id="alloc30">Rp 0</div>
        <p>Hiburan, makan di luar, hobi, langganan streaming, traveling</p>
      </div>
      <div class="allocation-card savings">
        <div class="allocation-percent">20%</div>
        <h4>Tabungan & Investasi</h4>
        <div class="allocation-amount" id="alloc20">Rp 0</div>
        <p>Dana darurat, investasi reksadana/saham, asuransi, dana pensiun</p>
      </div>
    </div>
  </section>

  <!-- Slip Gaji Preview -->
  <section class="slip-section">
    <h2>📄 Preview Slip Gaji</h2>
    <p class="section-sub">Format slip gaji standar Indonesia. Klik "Print Slip Gaji" untuk simpan PDF.</p>

    <div class="slip-preview">
      <div class="slip-header">
        <div>
          <div class="slip-company">SLIP GAJI KARYAWAN</div>
          <div class="slip-period" id="slipPeriod">Periode: Bulan Berjalan</div>
        </div>
        <div class="slip-logo">HC</div>
      </div>

      <table class="slip-table">
        <thead>
          <tr><th>Komponen</th><th>Penghasilan</th><th>Potongan</th></tr>
        </thead>
        <tbody>
          <tr><td>Gaji Pokok</td><td id="slipGajiPokok">Rp 0</td><td>—</td></tr>
          <tr><td>Tunjangan Tetap</td><td id="slipTunjangan">Rp 0</td><td>—</td></tr>
          <tr><td>Lembur / Komisi</td><td id="slipLembur">Rp 0</td><td>—</td></tr>
          <tr><td>BPJS Kesehatan</td><td>—</td><td id="slipBpjsK">Rp 0</td></tr>
          <tr><td>JHT</td><td>—</td><td id="slipJht">Rp 0</td></tr>
          <tr><td>JP</td><td>—</td><td id="slipJp">Rp 0</td></tr>
          <tr><td>PPh 21</td><td>—</td><td id="slipPph">Rp 0</td></tr>
          <tr><td>Potongan Lain</td><td>—</td><td id="slipLain">Rp 0</td></tr>
        </tbody>
        <tfoot>
          <tr><td><strong>Total</strong></td><td id="slipTotalBruto"><strong>Rp 0</strong></td><td id="slipTotalPotongan"><strong>Rp 0</strong></td></tr>
          <tr class="slip-thp"><td colspan="2"><strong>TAKE HOME PAY</strong></td><td id="slipThp"><strong>Rp 0</strong></td></tr>
        </tfoot>
      </table>
    </div>
  </section>

  <!-- Tips Section -->
  <section class="tips-section">
    <h2>💡 Tips Mengoptimalkan Gaji Bersih</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon">💸</div>
        <h4>Negosiasi Tunjangan Pajak</h4>
        <p>Minta gaji "net" alih-alih "gross". Beberapa perusahaan menanggung PPh 21 untuk karyawan key position.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">🎯</div>
        <h4>Cicilan Max 30% Take Home</h4>
        <p>Jaga total cicilan (KPR + KKB + kartu kredit) tidak lebih 30% take-home pay. Lebih dari itu = stres keuangan.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">💰</div>
        <h4>Auto-Debit Tabungan</h4>
        <p>Setup auto-debit ke rekening tabungan/investasi minimum 20% take-home setiap tanggal gajian.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">📊</div>
        <h4>Pisahkan Rekening Bonus</h4>
        <p>THR dan bonus jangan masuk rekening utama. Pisahkan untuk investasi atau dana darurat.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section-calc">
    <h2>❓ Pertanyaan Umum</h2>
    <div class="faq-list">
      <details class="faq-item" open>
        <summary>Berapa standar potongan BPJS karyawan?</summary>
        <div class="faq-answer">
          <p><strong>BPJS Kesehatan:</strong> 1% dari gaji (karyawan), max Rp 120rb/bulan</p>
          <p><strong>BPJS JHT (Jaminan Hari Tua):</strong> 2% dari gaji</p>
          <p><strong>BPJS JP (Jaminan Pensiun):</strong> 1% dari gaji (max gaji Rp 9,5jt)</p>
          <p><strong>BPJS JKM (Jaminan Kematian):</strong> 0% dari karyawan (ditanggung perusahaan)</p>
          <p><strong>BPJS JKK (Jaminan Kecelakaan Kerja):</strong> 0% dari karyawan (ditanggung perusahaan)</p>
          <p>Total potongan BPJS karyawan ~4% dari gaji.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Bedanya gaji bruto, gaji neto, dan take home pay?</summary>
        <div class="faq-answer">
          <p><strong>Gaji Bruto:</strong> Total penghasilan kotor = gaji pokok + tunjangan + lembur + bonus (sebelum dipotong apapun).</p>
          <p><strong>Gaji Neto:</strong> Penghasilan setelah dikurangi biaya jabatan dan BPJS Ketenagakerjaan (untuk perhitungan pajak).</p>
          <p><strong>Take Home Pay (THP):</strong> Yang benar-benar masuk rekening kamu = bruto - semua potongan (BPJS + pajak + kasbon + dll).</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apakah lembur dipotong pajak?</summary>
        <div class="faq-answer">
          <p>Ya. Uang lembur termasuk dalam penghasilan bruto dan dihitung untuk PPh 21. Tapi tidak dihitung untuk BPJS Ketenagakerjaan (BPJS hanya menghitung gaji pokok + tunjangan tetap).</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Bagaimana cara hitung gaji prorata (masuk pertengahan bulan)?</summary>
        <div class="faq-answer">
          <p>Gaji prorata = (Gaji bulanan / hari kerja sebulan) × hari kerja aktual</p>
          <p>Contoh: Gaji Rp 8jt, mulai kerja tanggal 10, hari kerja sebulan 22 hari:</p>
          <p>Hari kerja sisa = 22 - 7 (tgl 1-9 hari libur/tidak kerja) = 15 hari</p>
          <p>Prorata = 8.000.000 / 22 × 15 = Rp 5.454.545</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Berapa minimum gaji bersih untuk hidup layak di Jakarta?</summary>
        <div class="faq-answer">
          <p>Berdasarkan estimasi 2026 untuk single dewasa di Jakarta:</p>
          <p><strong>Bertahan hidup:</strong> Rp 5-6jt take-home (kos ekonomis, makan sederhana, transport umum)</p>
          <p><strong>Hidup nyaman:</strong> Rp 10-12jt take-home (kos/kontrak layak, makan bervariasi, transport pribadi)</p>
          <p><strong>Lifestyle baik:</strong> Rp 18jt+ take-home (apartemen, hiburan, traveling, investasi)</p>
          <p>UMP Jakarta 2026 sekitar Rp 5,4jt (gross).</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Related Calculators -->
  <section class="related-section">
    <h2>Kalkulator Terkait</h2>
    <div class="related-grid">
      <a href="/kalkulator-pph-21" class="related-card">
        <span class="related-icon">📋</span>
        <h4>Kalkulator PPh 21</h4>
        <p>Hitung pajak penghasilan akurat dengan UU HPP</p>
      </a>
      <a href="/kalkulator-kpr" class="related-card">
        <span class="related-icon">🏠</span>
        <h4>Kalkulator KPR</h4>
        <p>Cek kemampuan cicilan KPR dari take-home pay</p>
      </a>
      <a href="/kalkulator-investasi" class="related-card">
        <span class="related-icon">📈</span>
        <h4>Kalkulator Investasi</h4>
        <p>Alokasikan 20% take-home untuk investasi</p>
      </a>
    </div>
  </section>

</CalculatorLayout>

<style>
/* Breakdown Chart */
.breakdown-chart {
  margin-top: 20px;
  padding: 14px 16px;
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
}
.breakdown-bar {
  display: flex;
  height: 14px;
  background: rgba(255,255,255,0.08);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 12px;
}
.bar-segment {
  height: 100%;
  transition: width .4s var(--ease);
}
.bar-takehome { background: #34D399; }
.bar-bpjs { background: #60A5FA; }
.bar-pajak { background: #F87171; }
.bar-lain { background: #C084FC; }

.breakdown-legend {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  font-size: 12.5px;
  color: rgba(255,255,255,0.75);
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
}
.legend-item strong { color: #fff; margin-left: auto; }
.dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-takehome { background: #34D399; }
.dot-bpjs { background: #60A5FA; }
.dot-pajak { background: #F87171; }
.dot-lain { background: #C084FC; }

/* Action Buttons */
.action-buttons {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.action-buttons .btn-action.primary {
  flex: 1;
  background: var(--gold);
  color: var(--navy);
}
.action-buttons .btn-action.primary:hover { background: #FCD34D; }

/* Allocation Section */
.allocation-section,
.slip-section,
.tips-section,
.faq-section-calc,
.related-section {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--line);
}
.allocation-section h2,
.slip-section h2,
.tips-section h2,
.faq-section-calc h2,
.related-section h2 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(24px, 3.5vw, 32px);
  margin: 0 0 8px;
  color: var(--ink);
}
.section-sub {
  font-size: 14.5px;
  color: var(--ink-3);
  margin: 0 0 24px;
}

.allocation-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 16px;
}
.allocation-card {
  background: #fff;
  border: 2px solid var(--line);
  border-radius: 16px;
  padding: 24px;
  text-align: center;
}
.allocation-card.needs { border-color: #2563EB; background: #EFF6FF; }
.allocation-card.wants { border-color: #EC4899; background: #FDF2F8; }
.allocation-card.savings { border-color: #10B981; background: #ECFDF5; }
.allocation-percent {
  font-family: var(--font-display);
  font-size: 44px;
  line-height: 1;
  margin-bottom: 8px;
  color: var(--ink);
}
.allocation-card.needs .allocation-percent { color: #2563EB; }
.allocation-card.wants .allocation-percent { color: #EC4899; }
.allocation-card.savings .allocation-percent { color: #10B981; }
.allocation-card h4 {
  font-size: 15px;
  font-weight: 700;
  margin: 0 0 8px;
  color: var(--ink);
}
.allocation-amount {
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 12px;
  font-variant-numeric: tabular-nums;
}
.allocation-card p {
  font-size: 13px;
  color: var(--ink-3);
  margin: 0;
  line-height: 1.5;
}

/* Slip Gaji */
.slip-preview {
  background: #fff;
  border: 2px solid var(--line);
  border-radius: 16px;
  overflow: hidden;
}
.slip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--navy);
  color: #fff;
  padding: 20px 28px;
}
.slip-company {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.04em;
}
.slip-period {
  font-size: 12.5px;
  color: rgba(255,255,255,0.7);
  margin-top: 4px;
}
.slip-logo {
  width: 44px;
  height: 44px;
  background: var(--gold);
  border-radius: 10px;
  display: grid;
  place-items: center;
  font-weight: 800;
  color: var(--navy);
  font-size: 15px;
}
.slip-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.slip-table thead { background: var(--bg-soft); }
.slip-table th {
  padding: 12px 20px;
  text-align: right;
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--ink-3);
}
.slip-table th:first-child { text-align: left; }
.slip-table td {
  padding: 11px 20px;
  border-top: 1px solid var(--line);
  text-align: right;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.slip-table td:first-child { text-align: left; color: var(--ink-2); }
.slip-table tfoot td {
  padding: 14px 20px;
  background: var(--bg-soft);
  border-top: 2px solid var(--ink);
}
.slip-table tfoot .slip-thp td {
  background: var(--navy);
  color: #fff;
}
.slip-table tfoot .slip-thp td:last-child { color: var(--gold); font-size: 16px; }

/* Tips Grid */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}
.tip-card {
  background: var(--bg-soft);
  border-radius: 16px;
  padding: 22px;
  border: 1px solid var(--line);
}
.tip-icon { font-size: 28px; margin-bottom: 10px; }
.tip-card h4 {
  font-size: 15.5px;
  font-weight: 700;
  margin: 0 0 8px;
  color: var(--ink);
}
.tip-card p {
  font-size: 13.5px;
  color: var(--ink-3);
  line-height: 1.55;
  margin: 0;
}

/* FAQ */
.faq-section-calc .faq-list { max-width: 100%; }
.faq-section-calc .faq-item {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  margin-bottom: 10px;
  overflow: hidden;
}
.faq-section-calc .faq-item summary {
  list-style: none;
  cursor: pointer;
  padding: 16px 20px;
  font-weight: 600;
  font-size: 14.5px;
  color: var(--ink);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.faq-section-calc .faq-item summary::-webkit-details-marker { display: none; }
.faq-section-calc .faq-item summary::after {
  content: "+";
  font-size: 22px;
  color: var(--ink-3);
  transition: transform .2s;
}
.faq-section-calc .faq-item[open] summary::after {
  transform: rotate(45deg);
  color: var(--blue);
}
.faq-section-calc .faq-answer {
  padding: 0 20px 18px;
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.6;
}
.faq-section-calc .faq-answer p { margin: 0 0 8px; }
.faq-section-calc .faq-answer p:last-child { margin-bottom: 0; }

/* Related Cards */
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.related-card {
  display: flex;
  flex-direction: column;
  padding: 22px;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 16px;
  text-decoration: none;
  color: var(--ink);
  transition: all .2s;
}
.related-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
  color: var(--ink);
  text-decoration: none;
}
.related-icon { font-size: 32px; margin-bottom: 10px; }
.related-card h4 { font-size: 15.5px; font-weight: 700; margin: 0 0 6px; color: var(--ink); }
.related-card p { font-size: 13px; color: var(--ink-3); margin: 0; }

@media print {
  .site-header, .site-footer, .breadcrumb, .action-buttons,
  .tips-section, .faq-section-calc, .related-section,
  .allocation-section { display: none !important; }
  .calc-page { padding: 0; }
  .calc-panel-dark { background: #fff !important; color: #000 !important; border: 1px solid #ccc; }
  .calc-panel-dark * { color: #000 !important; }
  .result-main .value { color: #000 !important; }
}
</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';

const $ = (id) => document.getElementById(id);

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

function recalculate() {
  const gajiPokok = parseRupiah($('gajiPokok').value);
  const tunjangan = parseRupiah($('tunjangan').value);
  const lembur = parseRupiah($('lembur').value);
  const bpjsKesehatan = parseRupiah($('bpjsKesehatan').value);
  const jht = parseRupiah($('jht').value);
  const jp = parseRupiah($('jp').value);
  const pph21 = parseRupiah($('pph21').value);
  const potonganLain = parseRupiah($('potonganLain').value);

  const bruto = gajiPokok + tunjangan + lembur;
  const totalBpjs = bpjsKesehatan + jht + jp;
  const totalPotongan = totalBpjs + pph21 + potonganLain;
  const takeHome = bruto - totalPotongan;
  
  const persenPotongan = bruto > 0 ? (totalPotongan / bruto) * 100 : 0;
  const persenTakeHome = bruto > 0 ? (takeHome / bruto) * 100 : 0;
  const persenBpjs = bruto > 0 ? (totalBpjs / bruto) * 100 : 0;
  const persenPajak = bruto > 0 ? (pph21 / bruto) * 100 : 0;
  const persenLain = bruto > 0 ? (potonganLain / bruto) * 100 : 0;

  // Main results
  $('takeHomePay').textContent = formatRupiah(takeHome);
  $('resBruto').textContent = formatRupiah(bruto);
  $('resTotalPotongan').textContent = formatRupiah(totalPotongan);
  $('resPersenPotongan').textContent = formatPercent(persenPotongan, 1);
  $('resPersenTakeHome').textContent = formatPercent(persenTakeHome, 1);

  // Breakdown bar
  $('barTakeHome').style.width = `${persenTakeHome}%`;
  $('barBpjs').style.width = `${persenBpjs}%`;
  $('barPajak').style.width = `${persenPajak}%`;
  $('barLain').style.width = `${persenLain}%`;
  $('legendTakeHome').textContent = formatPercent(persenTakeHome, 0);
  $('legendBpjs').textContent = formatPercent(persenBpjs, 0);
  $('legendPajak').textContent = formatPercent(persenPajak, 0);
  $('legendLain').textContent = formatPercent(persenLain, 0);

  // Allocation 50/30/20
  $('thpDisplay').textContent = formatRupiah(takeHome);
  $('alloc50').textContent = formatRupiah(takeHome * 0.5);
  $('alloc30').textContent = formatRupiah(takeHome * 0.3);
  $('alloc20').textContent = formatRupiah(takeHome * 0.2);

  // Slip Gaji
  const months = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  const now = new Date();
  $('slipPeriod').textContent = `Periode: ${months[now.getMonth()]} ${now.getFullYear()}`;
  $('slipGajiPokok').textContent = formatRupiah(gajiPokok);
  $('slipTunjangan').textContent = formatRupiah(tunjangan);
  $('slipLembur').textContent = formatRupiah(lembur);
  $('slipBpjsK').textContent = formatRupiah(bpjsKesehatan);
  $('slipJht').textContent = formatRupiah(jht);
  $('slipJp').textContent = formatRupiah(jp);
  $('slipPph').textContent = formatRupiah(pph21);
  $('slipLain').textContent = formatRupiah(potonganLain);
  $('slipTotalBruto').innerHTML = `<strong>${formatRupiah(bruto)}</strong>`;
  $('slipTotalPotongan').innerHTML = `<strong>${formatRupiah(totalPotongan)}</strong>`;
  $('slipThp').innerHTML = `<strong>${formatRupiah(takeHome)}</strong>`;
}

recalculate();
</script>

