import AdSlot from '../../components/AdSlot.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
const datePublished = '2026-07-04';
const dateModified = '2026-07-04';
const today = new Date(datePublished).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Blog', href: '/blog' }, { label: 'Cara Menghitung FIRE' }];

const faqs = [
  { q: 'Apa itu FIRE?', a: 'FIRE adalah singkatan Financial Independence, Retire Early — kondisi ketika hasil pengembangan aset investasimu sudah cukup untuk membiayai seluruh biaya hidup tanpa harus bekerja. Kamu tetap boleh bekerja, tapi karena pilihan, bukan keharusan.' },
  { q: 'Berapa dana yang dibutuhkan untuk FIRE?', a: 'Patokannya FIRE Number = pengeluaran tahunan dibagi withdrawal rate. Pada aturan 4%, ini sama dengan pengeluaran tahunan dikali 25. Contoh: pengeluaran Rp 8 juta per bulan (Rp 96 juta per tahun) butuh FIRE Number sekitar Rp 2,4 miliar.' },
  { q: 'Apa itu aturan 4%?', a: 'Aturan 4% adalah pedoman bahwa kamu bisa menarik sekitar 4% dari portofolio tiap tahun (disesuaikan inflasi) dengan risiko kecil kehabisan dana selama sekitar 30 tahun. Berasal dari riset William Bengen (1994) dan Trinity Study (1998) berbasis pasar Amerika Serikat.' },
  { q: 'Apakah FIRE sama dengan pensiun dini?', a: 'Berkaitan, tapi tidak persis sama. Pensiun dini fokus pada berhenti bekerja lebih awal; FIRE fokus pada kemandirian finansial — punya aset yang membiayai hidup. Banyak orang yang sudah FIRE tetap produktif, hanya saja tanpa tekanan finansial.' },
  { q: 'Apakah FIRE cocok untuk orang Indonesia?', a: 'Konsepnya cocok, tapi angkanya perlu disesuaikan. Inflasi Indonesia (sekitar 3-4%) lebih tinggi dari AS, jadi banyak yang memakai withdrawal rate lebih konservatif (3-3,5%) agar lebih aman — konsekuensinya FIRE Number jadi lebih besar.' },
  { q: 'Bagaimana cara mempercepat FIRE?', a: 'Tuas paling kuat adalah menaikkan savings rate: perbesar selisih penghasilan dan pengeluaran, lalu investasikan. Ini bekerja ganda karena menambah setoran sekaligus menurunkan FIRE Number. Menaikkan penghasilan, menekan pengeluaran, dan menghindari utang konsumtif adalah kuncinya.' },
  { q: 'Apa bedanya Lean FIRE dan Fat FIRE?', a: 'Lean FIRE adalah kemandirian finansial dengan gaya hidup hemat, sehingga FIRE Number lebih kecil dan lebih cepat tercapai. Fat FIRE adalah kemandirian finansial dengan gaya hidup lebih leluasa/mewah, sehingga FIRE Number lebih besar dan butuh lebih lama.' },
  { q: 'Apakah hasil kalkulator FIRE pasti akurat?', a: 'Tidak. Hasilnya estimasi berdasarkan asumsi return, inflasi, dan pengeluaran yang bisa berubah. Ada juga risiko urutan return (sequence-of-returns), biaya kesehatan, dan pajak. Anggap hasilnya sebagai peta arah, bukan jaminan, dan tinjau ulang tiap tahun.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
