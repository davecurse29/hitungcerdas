---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
const datePublished = '2026-07-04';
const dateModified = '2026-07-04';
const today = new Date(datePublished).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
const bcItems = [{ label: 'Beranda', href: '/' }, { label: 'Blog', href: '/blog' }, { label: 'SBN Ritel' }];

const faqs = [
  { q: 'Apa itu SBN Ritel?', a: 'SBN Ritel (Surat Berharga Negara Ritel) adalah surat utang yang diterbitkan pemerintah khusus untuk investor individu WNI, guna membiayai APBN. Sebagai imbalannya, investor menerima kupon (imbal hasil) rutin tiap bulan, dan pokok dikembalikan 100% saat jatuh tempo. Pembayaran dijamin negara berdasarkan undang-undang.' },
  { q: 'Apa bedanya ORI, SR, SBR, dan ST?', a: 'ORI (konvensional) dan SR/Sukuk Ritel (syariah) berkupon tetap dan bisa diperdagangkan di pasar sekunder. SBR (konvensional) dan ST/Sukuk Tabungan (syariah) berkupon mengambang dengan batas minimal, tidak bisa dijual di pasar sekunder, tapi punya fasilitas early redemption (pencairan lebih awal sebagian).' },
  { q: 'Berapa modal minimal beli SBN Ritel?', a: 'Mulai dari Rp 1 juta dan kelipatannya. Batas maksimal umumnya Rp 5 miliar untuk ORI/SR dan Rp 2 miliar untuk SBR/ST, tergantung ketentuan tiap seri.' },
  { q: 'Kenapa SBN Ritel lebih menarik dari deposito?', a: 'Tiga alasan utama: kuponnya biasanya lebih tinggi dari bunga deposito bank (sebagai gambaran, ORI029 awal 2026 menawarkan 5,45%-5,80% vs deposito bank BUMN ~3-3,5%), pajak kuponnya hanya 10% (deposito 20%), dan dijamin penuh oleh negara. Kupon juga dibayar tiap bulan.' },
  { q: 'Bagaimana cara membeli SBN Ritel?', a: 'Beli secara online lewat Mitra Distribusi resmi (bank seperti BRI/BCA/Mandiri/BNI/OCBC atau fintech seperti Bareksa/Bibit/Tanamduit). Daftar untuk mendapatkan SID (Single Investor Identification), lalu pesan saat masa penawaran seri yang diinginkan melalui sistem e-SBN, dan lakukan pembayaran sesuai kode tagihan.' },
  { q: 'Apakah SBN Ritel bebas risiko?', a: 'Risiko gagal bayar hampir nol karena dijamin negara, dan jika ditahan sampai jatuh tempo pokok kembali 100%. Namun untuk ORI/SR ada risiko pasar — bila dijual di pasar sekunder saat suku bunga naik, harganya bisa di bawah nominal. Karena itu SBN Ritel cocok untuk dana jangka menengah, bukan dana darurat.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<Layout title="SBN Ritel (ORI/SR/SBR/ST) 2026: Cara Beli & Banding Deposito" description="Panduan SBN Ritel 2026: apa itu ORI, SR, SBR, ST; perbedaannya; kenapa kupon lebih tinggi dari deposito dengan pajak lebih rendah (10% vs 20%); cara beli lewat mitra distribusi e-SBN mulai Rp 1 juta; dan risikonya." keywords={['sbn ritel', 'ori sr sbr st', 'cara beli sbn', 'obligasi negara ritel 2026', 'sbn vs deposito', 'investasi aman dijamin negara']} canonical="https://hitungcerdas.net/blog/sbn-ritel-ori-sr-cara-beli" ogType="article">
  <ArticleSchema
    headline="SBN Ritel (ORI/SR/SBR/ST) 2026: Cara Beli & Banding Deposito"
    description="Panduan SBN Ritel 2026: jenis ORI/SR/SBR/ST, keunggulan vs deposito, cara beli lewat mitra distribusi e-SBN, dan risikonya."
    datePublished={datePublished}
    dateModified={dateModified}
    slug="sbn-ritel-ori-sr-cara-beli"
    articleSection="Investasi"
    keywords={['sbn ritel', 'ori sr sbr st', 'cara beli sbn', 'sbn vs deposito']}
    wordCount={1750}
  />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>

  <section class="article-hero" style="--cat-color:#0891B2;--cat-color2:#155E75">
    <div class="wrap"><Breadcrumb items={bcItems} /><div class="article-tag">Investasi</div>
      <h1>SBN Ritel (ORI/SR/SBR/ST) 2026: Cara Beli & Banding Deposito</h1>
      <div class="article-meta"><span><i class="ti ti-calendar"></i> {today}</span><span><i class="ti ti-clock"></i> 11 menit baca</span><span><i class="ti ti-user"></i> Tim HitungCerdas</span></div>
    </div>
  </section>
  <AdSlot format="horizontal" />
  <article class="content-section"><div class="wrap-text">
    <p class="lead">Ingin investasi yang aman, imbal hasilnya di atas deposito, dan bisa dimulai cuma Rp 1 juta? SBN Ritel jawabannya. Ini surat utang yang diterbitkan pemerintah untuk masyarakat, dijamin negara, dan membayar kupon rutin tiap bulan. Artikel ini menjelaskan jenisnya, kenapa lebih menarik dari deposito, dan cara membelinya langkah demi langkah.</p>

    <h2>Apa Itu SBN Ritel?</h2>
    <p>SBN Ritel (Surat Berharga Negara Ritel) adalah <strong>surat utang negara khusus investor individu</strong> WNI, diterbitkan untuk membiayai APBN. Sederhananya: kamu "meminjamkan" dana ke negara, lalu menerima <strong>kupon setiap bulan</strong>, dan <strong>pokok kembali 100%</strong> saat jatuh tempo. Pembayaran dijamin undang-undang, sehingga risiko gagal bayarnya hampir nol.</p>

    <h2>4 Jenis SBN Ritel</h2>
    <table class="cmp-table">
      <thead><tr><th>Jenis</th><th>Kupon</th><th>Pasar Sekunder</th><th>Tenor</th><th>Prinsip</th></tr></thead>
      <tbody>
        <tr><td><strong>ORI</strong></td><td>Tetap</td><td>Bisa (tradeable)</td><td>3 &amp; 6 thn</td><td>Konvensional</td></tr>
        <tr><td><strong>SR</strong> (Sukuk Ritel)</td><td>Tetap</td><td>Bisa (tradeable)</td><td>3 &amp; 5 thn</td><td>Syariah</td></tr>
        <tr><td><strong>SBR</strong></td><td>Mengambang + floor</td><td>Tidak (early redemption)</td><td>2 &amp; 4 thn</td><td>Konvensional</td></tr>
        <tr><td><strong>ST</strong> (Sukuk Tabungan)</td><td>Mengambang + floor</td><td>Tidak (early redemption)</td><td>2 &amp; 4 thn</td><td>Syariah</td></tr>
      </tbody>
    </table>
    <p><strong>Kupon tetap</strong> (ORI/SR): besarannya dikunci sampai jatuh tempo — enak untuk perencanaan. <strong>Kupon mengambang dengan batas minimal</strong> (SBR/ST): bisa naik mengikuti suku bunga acuan BI, tapi tidak turun di bawah batas — aman saat bunga naik. SBR/ST tidak bisa dijual di pasar sekunder, tapi punya fasilitas <em>early redemption</em> (mencairkan sebagian lebih awal).</p>

    <AdSlot format="horizontal" />

    <h2>Kenapa Menarik? SBN Ritel vs Deposito</h2>
    <table class="cmp-table">
      <thead><tr><th>Aspek</th><th>SBN Ritel</th><th>Deposito</th></tr></thead>
      <tbody>
        <tr><td>Imbal hasil</td><td>±5%+ (mis. ORI029: 5,45–5,80%)</td><td>±3–3,5% (bank BUMN)</td></tr>
        <tr><td>Pajak</td><td>10% final</td><td>20% final</td></tr>
        <tr><td>Jaminan</td><td>Negara (UU/APBN)</td><td>LPS s.d. Rp 2 miliar</td></tr>
        <tr><td>Bayar imbal hasil</td><td>Tiap bulan</td><td>Umumnya saat jatuh tempo</td></tr>
        <tr><td>Modal minimal</td><td>Rp 1 juta</td><td>Bervariasi</td></tr>
      </tbody>
    </table>
    <p>Kombinasi kupon lebih tinggi + pajak lebih rendah membuat imbal hasil bersih SBN Ritel biasanya lebih menarik dari deposito. Catatan: angka kupon di atas adalah <strong>contoh seri awal 2026</strong>; tiap seri berbeda — cek seri terbaru di kanal resmi Kemenkeu.</p>

    <h2>Cara Membeli SBN Ritel (Langkah demi Langkah)</h2>
    <ul class="info-list">
      <li><strong>Pilih Mitra Distribusi resmi.</strong> Bisa lewat bank (BRI, BCA, Mandiri, BNI, OCBC) atau fintech (Bareksa, Bibit, Tanamduit) yang ditunjuk pemerintah.</li>
      <li><strong>Registrasi &amp; dapatkan SID.</strong> Siapkan e-KTP, NPWP, dan rekening bank untuk memperoleh Single Investor Identification (SID), rekening dana, dan rekening surat berharga. Registrasi bisa dilakukan kapan saja, bahkan sebelum masa penawaran.</li>
      <li><strong>Pesan saat masa penawaran.</strong> Pilih seri yang tersedia, tentukan nominal (minimal Rp 1 juta), lalu konfirmasi pesanan.</li>
      <li><strong>Bayar sesuai kode tagihan.</strong> Kamu menerima billing code, bayar via ATM/mobile banking, lalu memperoleh NTPN sebagai bukti.</li>
      <li><strong>Terima alokasi &amp; kupon bulanan.</strong> Setelah setelmen, kepemilikan tercatat elektronik dan kupon masuk rekeningmu tiap bulan.</li>
    </ul>

    <h2>Risiko yang Perlu Dipahami</h2>
    <ul class="info-list">
      <li><strong>Risiko pasar (ORI/SR).</strong> Jika dijual di pasar sekunder saat suku bunga naik, harga bisa di bawah nominal. Solusi: tahan sampai jatuh tempo → pokok kembali 100%.</li>
      <li><strong>Risiko likuiditas.</strong> SBR/ST tidak bisa dijual di pasar sekunder (hanya early redemption sebagian). Pastikan dana tidak dibutuhkan mendadak.</li>
      <li><strong>Risiko reinvestasi.</strong> Saat jatuh tempo, imbal hasil seri berikutnya bisa lebih rendah.</li>
    </ul>
    <p>Karena itu, SBN Ritel paling cocok untuk <strong>tujuan jangka menengah (2–3 tahun)</strong> — bukan dana darurat yang harus selalu likuid.</p>

    <div class="cta-box">
      <h3>📈 Bandingkan Imbal Hasil Investasimu</h3>
      <p>Sebelum memilih, lihat proyeksinya:</p>
      <ul>
        <li>✅ Simulasi pertumbuhan dana dengan berbagai tingkat return</li>
        <li>✅ Bandingkan dengan target dana darurat &amp; tujuan lain</li>
        <li>✅ Kaitkan dengan rencana jangka panjang (pensiun, FIRE)</li>
      </ul>
      <p style="margin-top:14px"><a href="/kalkulator/investasi" class="btn btn-pri"><i class="ti ti-calculator"></i> Buka Kalkulator Investasi</a></p>
    </div>

    <h2>Kesimpulan</h2>
    <p>SBN Ritel adalah pintu masuk investasi yang aman, terjangkau (mulai Rp 1 juta), dan menguntungkan — kupon di atas deposito, pajak lebih rendah (10% vs 20%), dan dijamin negara. Pahami keempat jenisnya (ORI, SR, SBR, ST), pilih yang sesuai tujuan &amp; prinsipmu, beli lewat mitra distribusi resmi, dan tahan sesuai horizon. Untuk dana jangka menengah yang ingin tumbuh stabil tanpa banyak drama, SBN Ritel layak jadi bagian portofoliomu — lengkapi dengan <a href="/blog/reksadana-untuk-pemula">reksadana</a> dan <a href="/kalkulator/dana-darurat">dana darurat</a> yang sudah aman.</p>

    <h3>📚 Sumber &amp; Referensi</h3>
    <ul class="info-list">
      <li>Kementerian Keuangan RI — Obligasi Negara Ritel (ORI) &amp; SBN Ritel: <a href="https://www.kemenkeu.go.id/ori" target="_blank" rel="noopener">kemenkeu.go.id/ori</a></li>
      <li>DJPPR Kemenkeu — Informasi SBN Ritel: <a href="https://djppr.kemenkeu.go.id" target="_blank" rel="noopener">djppr.kemenkeu.go.id</a></li>
    </ul>

    <h2>Pertanyaan yang Sering Ditanya (FAQ)</h2>
    {faqs.map(f => (<div class="faq-item"><h3>{f.q}</h3><p>{f.a}</p></div>))}

    <h3>📌 Kalkulator &amp; Artikel Terkait</h3>
    <ul class="info-list">
      <li><a href="/kalkulator/investasi">Kalkulator Investasi</a> · <a href="/blog/reksadana-untuk-pemula">Reksadana untuk Pemula</a></li>
      <li><a href="/kalkulator/fire">Kalkulator FIRE</a> · <a href="/blog/cara-menghitung-fire">Cara Menghitung FIRE</a></li>
      <li><a href="/kalkulator/dana-darurat">Kalkulator Dana Darurat</a> · <a href="/kalkulator/pensiun">Kalkulator Pensiun</a></li>
    </ul>

    <p class="article-disclaimer"><em>Artikel ini bersifat edukatif, bukan nasihat atau ajakan investasi. Besaran kupon, jadwal, dan ketentuan tiap seri SBN Ritel mengikuti pengumuman resmi Kemenkeu dan dapat berubah. Investasi tetap memiliki risiko; baca memorandum informasi tiap seri sebelum membeli.</em></p>
  </div></article>
  <AdSlot format="horizontal" />
</Layout>
<style>
  .article-hero { background: linear-gradient(135deg, var(--cat-color) 0%, var(--cat-color2) 100%); color: #fff; padding: 20px 0 48px; }
  .article-hero :global(.breadcrumb-item), .article-hero :global(.breadcrumb-item a) { color: rgba(255, 255, 255, .7); }
  .article-hero :global(.breadcrumb-item a:hover) { color: var(--gold-soft); }
  .article-hero :global(.breadcrumb-item span) { color: #fff; }
  .article-hero :global(.breadcrumb-item i) { color: rgba(255, 255, 255, .4); }
  .article-tag { display: inline-block; font-size: 11px; font-weight: 700; color: var(--gold-soft); letter-spacing: .1em; text-transform: uppercase; margin: 16px 0 12px; }
  .article-hero h1 { color: #fff; font-size: clamp(26px, 3.8vw, 42px); margin: 0 0 20px; max-width: 900px; line-height: 1.2; }
  .article-meta { display: flex; gap: 20px; color: rgba(255, 255, 255, .75); font-size: 13px; flex-wrap: wrap; }
  .article-meta span { display: inline-flex; align-items: center; gap: 6px; }
  .lead { font-size: 17px !important; line-height: 1.7 !important; color: var(--text) !important; padding: 20px 24px; background: var(--bg-soft); border-radius: 12px; border-left: 4px solid #0891B2; margin-bottom: 24px !important; }
  .cmp-table { width: 100%; border-collapse: collapse; margin: 18px 0; font-size: 13.5px; }
  .cmp-table th, .cmp-table td { text-align: left; padding: 9px 10px; border-bottom: 1px solid var(--border); vertical-align: top; }
  .cmp-table thead th { background: var(--bg-soft); font-weight: 700; color: var(--text); }
  .cmp-table tbody tr:last-child td { border-bottom: none; }
  .faq-item { margin: 14px 0; }
  .faq-item h3 { margin-bottom: 4px; }
  .article-disclaimer { font-size: 13px; color: var(--text-mute); margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--border); }
</style>
