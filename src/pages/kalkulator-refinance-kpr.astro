---
// src/pages/kalkulator-refinance-kpr.astro
// Kalkulator Refinance KPR Pro — Take over analysis + break-even
import CalculatorLayout from '../components/CalculatorLayout.astro';
---

<CalculatorLayout
  title="Kalkulator Refinance KPR — Hitung Hemat Take Over KPR ke Bank Lain"
  description="Kalkulator refinance KPR online gratis. Hitung berapa hemat jika pindah KPR ke bank lain dengan bunga lebih rendah. Break-even analysis & rekomendasi take over."
  icon="🔄"
  category="KALKULATOR KEUANGAN"
  categoryColor="blue"
  breadcrumb={[
    { label: 'Kalkulator Keuangan', href: '/kalkulator-keuangan' },
    { label: 'Refinance KPR' }
  ]}
>

  <!-- Info Banner -->
  <div class="info-banner">
    <div class="info-banner-icon">💡</div>
    <div class="info-banner-text">
      <strong>Apa itu Refinance KPR?</strong> Pindahkan KPR dari bank A ke bank B yang menawarkan bunga lebih rendah. 
      Bisa hemat <strong>Rp 100-500 juta</strong> total bunga jika dilakukan di waktu yang tepat. 
      Kalkulator ini hitung apakah refinance worth it untuk kamu.
    </div>
  </div>

  <div class="calc-grid">
    <!-- LEFT: KPR Existing -->
    <div class="calc-panel">
      <h3>🏠 KPR Saat Ini (Existing)</h3>

      <div class="form-group">
        <label class="form-label">Sisa Pokok Pinjaman</label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="sisaPokok" class="form-input" value="350.000.000" inputmode="numeric" data-format="rupiah" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Sisa Tenor</label>
          <div class="form-input-suffix">
            <input type="number" id="sisaTenor" class="form-input" value="12" min="1" max="30" step="1" />
            <span class="suffix">tahun</span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Bunga Sekarang <span class="form-hint">floating</span></label>
          <div class="form-input-suffix">
            <input type="number" id="bungaLama" class="form-input" value="11" min="0" max="30" step="0.1" />
            <span class="suffix">%</span>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Cicilan Bulanan Saat Ini <span class="form-hint">opsional, auto-calc</span></label>
        <div class="form-input-prefix">
          <span class="prefix">Rp</span>
          <input type="text" id="cicilanLama" class="form-input" value="0" inputmode="numeric" data-format="rupiah" placeholder="Otomatis dihitung" />
        </div>
      </div>

      <div class="info-box">
        <span class="info-box-icon">ℹ️</span>
        <div>
          <strong>Tip:</strong> Sisa pokok bisa kamu cek di mobile banking, app KPR, atau call CS bank. Bunga sekarang biasanya floating 10-12%/tahun.
        </div>
      </div>
    </div>

    <!-- RIGHT: KPR New -->
    <div class="calc-panel">
      <h3>🏦 KPR Baru (Take Over)</h3>

      <div class="form-group">
        <label class="form-label">Bunga Bank Baru <span class="form-hint">fix periode awal</span></label>
        <div class="form-input-suffix">
          <input type="number" id="bungaBaru" class="form-input" value="6.5" min="0" max="30" step="0.1" />
          <span class="suffix">%</span>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Periode Fix Baru</label>
          <div class="form-input-suffix">
            <input type="number" id="periodeFix" class="form-input" value="3" min="1" max="10" step="1" />
            <span class="suffix">tahun</span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Bunga Floating Setelah Fix</label>
          <div class="form-input-suffix">
            <input type="number" id="bungaFloat" class="form-input" value="10.5" min="0" max="30" step="0.1" />
            <span class="suffix">%</span>
          </div>
        </div>
      </div>

      <h4 style="margin-top: 24px; margin-bottom: 12px; font-size: 14.5px; color: var(--ink);">Biaya Take Over</h4>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Provisi <span class="form-hint">1-2%</span></label>
          <div class="form-input-suffix">
            <input type="number" id="provisi" class="form-input" value="1" min="0" max="5" step="0.1" />
            <span class="suffix">%</span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Appraisal & Notaris</label>
          <div class="form-input-prefix">
            <span class="prefix">Rp</span>
            <input type="text" id="biayaProses" class="form-input" value="7.000.000" inputmode="numeric" data-format="rupiah" />
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Denda Lunas Awal Bank Lama <span class="form-hint">2-5% sisa pokok</span></label>
        <div class="form-input-suffix">
          <input type="number" id="dendaLunas" class="form-input" value="3" min="0" max="10" step="0.1" />
          <span class="suffix">%</span>
        </div>
      </div>

      <div class="info-box">
        <span class="info-box-icon">⚠️</span>
        <div>
          <strong>Hati-hati:</strong> Setelah periode fix bank baru selesai (biasanya 3 tahun), bunga akan floating lagi. Hitung apakah savings sepanjang fix period cukup tutup biaya take over.
        </div>
      </div>
    </div>
  </div>

  <!-- Result Summary -->
  <section class="result-section">
    <div class="result-hero">
      <div class="result-hero-content">
        <span class="result-hero-label" id="recommendLabel">REKOMENDASI</span>
        <h2 class="result-hero-title" id="recommendTitle">⏳ Menghitung...</h2>
        <p class="result-hero-desc" id="recommendDesc">Masukkan data KPR existing & new untuk lihat hasil</p>
      </div>
      <div class="result-hero-amount" id="recommendAmount">Rp 0</div>
    </div>
  </section>

  <!-- Side-by-Side Comparison -->
  <section class="comparison-section">
    <h2>📊 Perbandingan Side-by-Side</h2>
    <p class="section-sub">Total bayar dari sekarang sampai lunas — apple-to-apple</p>

    <div class="vs-grid">
      <div class="vs-card vs-existing">
        <div class="vs-tag">EXISTING</div>
        <h4>🏠 KPR Sekarang</h4>
        <p class="vs-desc">Tanpa refinance, lanjut bayar bank A</p>
        <table class="vs-table">
          <tr><td>Sisa Pokok</td><td id="exSisaPokok">Rp 0</td></tr>
          <tr><td>Bunga</td><td id="exBunga">0%</td></tr>
          <tr><td>Sisa Tenor</td><td id="exTenor">0 bulan</td></tr>
          <tr><td>Cicilan/bulan</td><td id="exCicilan">Rp 0</td></tr>
          <tr><td>Total Bunga Tersisa</td><td id="exTotalBunga">Rp 0</td></tr>
          <tr class="vs-total"><td>Total Bayar Sampai Lunas</td><td id="exTotalBayar">Rp 0</td></tr>
        </table>
      </div>
      <div class="vs-card vs-new">
        <div class="vs-tag">REFINANCE</div>
        <h4>🏦 KPR Baru (Take Over)</h4>
        <p class="vs-desc">Pindah ke bank B dengan bunga lebih rendah</p>
        <table class="vs-table">
          <tr><td>Pokok Baru</td><td id="newPokok">Rp 0</td></tr>
          <tr><td>Bunga Tahun 1-N (fix)</td><td id="newBungaFix">0%</td></tr>
          <tr><td>Bunga Setelah Fix</td><td id="newBungaFloat">0%</td></tr>
          <tr><td>Cicilan Tahun 1-N</td><td id="newCicilanFix">Rp 0</td></tr>
          <tr><td>Cicilan Setelah Fix</td><td id="newCicilanFloat">Rp 0</td></tr>
          <tr><td>Total Bunga + Biaya</td><td id="newTotalBunga">Rp 0</td></tr>
          <tr class="vs-total"><td>Total Bayar Sampai Lunas</td><td id="newTotalBayar">Rp 0</td></tr>
        </table>
      </div>
    </div>
  </section>

  <!-- Break-even Analysis -->
  <section class="breakeven-section">
    <h2>⚖️ Break-even Analysis</h2>
    <p class="section-sub">Kapan biaya take over balik modal dari savings cicilan?</p>

    <div class="breakeven-grid">
      <div class="breakeven-card">
        <div class="breakeven-icon">💸</div>
        <h4>Total Biaya Take Over</h4>
        <div class="breakeven-amount" id="beTotalBiaya">Rp 0</div>
        <p>Provisi + Appraisal + Notaris + Denda lunas bank lama</p>
      </div>
      <div class="breakeven-card">
        <div class="breakeven-icon">💰</div>
        <h4>Hemat per Bulan</h4>
        <div class="breakeven-amount" id="beHematBulan">Rp 0</div>
        <p>Selisih cicilan lama vs baru (selama periode fix)</p>
      </div>
      <div class="breakeven-card">
        <div class="breakeven-icon">📅</div>
        <h4>Break-even Point</h4>
        <div class="breakeven-amount" id="beBreakEven">- bulan</div>
        <p>Berapa bulan biaya take over balik modal</p>
      </div>
      <div class="breakeven-card highlight">
        <div class="breakeven-icon">🎯</div>
        <h4>Net Saving Total</h4>
        <div class="breakeven-amount" id="beNetSaving">Rp 0</div>
        <p>Total saving sampai lunas (setelah dikurangi biaya)</p>
      </div>
    </div>
  </section>

  <!-- Detail Biaya -->
  <section class="biaya-section">
    <h2>📋 Rincian Biaya Take Over KPR</h2>
    <p class="section-sub">Detail komponen biaya yang dikeluarkan saat refinance</p>

    <div class="biaya-grid">
      <div class="biaya-row">
        <div class="biaya-icon">📝</div>
        <div class="biaya-text">
          <h4>Provisi Bank Baru</h4>
          <p>1-2% dari pokok pinjaman baru</p>
        </div>
        <div class="biaya-amount" id="bdProvisi">Rp 0</div>
      </div>
      <div class="biaya-row">
        <div class="biaya-icon">🏠</div>
        <div class="biaya-text">
          <h4>Appraisal & Notaris</h4>
          <p>Penilaian properti & legal documents</p>
        </div>
        <div class="biaya-amount" id="bdAppraisal">Rp 0</div>
      </div>
      <div class="biaya-row">
        <div class="biaya-icon">💔</div>
        <div class="biaya-text">
          <h4>Denda Lunas Bank Lama</h4>
          <p>Penalti pelunasan dipercepat (2-5% sisa pokok)</p>
        </div>
        <div class="biaya-amount" id="bdDenda">Rp 0</div>
      </div>
      <div class="biaya-row biaya-total">
        <div class="biaya-icon">💸</div>
        <div class="biaya-text">
          <h4>TOTAL BIAYA TAKE OVER</h4>
          <p>Biaya 1x dibayar di awal</p>
        </div>
        <div class="biaya-amount" id="bdTotal">Rp 0</div>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="tips-section">
    <h2>💡 Tips Refinance KPR Cerdas</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon">📊</div>
        <h4>Selisih Bunga &gt;2%</h4>
        <p>Refinance baru worth it kalau selisih bunga &gt;2%/tahun. Kurang dari itu, biaya provisi &amp; admin bisa makan saving.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">⏰</div>
        <h4>Sisa Tenor &gt;5 Tahun</h4>
        <p>Refinance cocok kalau sisa tenor masih panjang. Sisa 2-3 tahun? Hemat bunganya tidak sebanding biaya proses.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">🎯</div>
        <h4>Pilih Periode Fix Panjang</h4>
        <p>Cari bank yang nawarin fix 3-5 tahun. Periode fix lebih lama = saving lebih pasti.</p>
      </div>
      <div class="tip-card">
        <div class="tip-icon">📋</div>
        <h4>Negosiasi Sama Bank Lama</h4>
        <p>Sebelum take over, coba minta penurunan bunga ke bank lama. Bank biasanya kasih kalau ngancam pindah.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section-calc">
    <h2>❓ Pertanyaan Umum Refinance KPR</h2>
    <div class="faq-list">
      <details class="faq-item" open>
        <summary>Kapan refinance KPR worth it?</summary>
        <div class="faq-answer">
          <p><strong>3 kondisi refinance worth it:</strong></p>
          <p><strong>1. Selisih bunga &gt;2%/tahun:</strong> Kalau bank baru kasih 6,5% vs sekarang 10,5%, selisih 4% — pasti hemat.</p>
          <p><strong>2. Sisa tenor &gt;5 tahun:</strong> Saving baru akumulasi banyak kalau sisa tenor masih panjang.</p>
          <p><strong>3. Sisa pokok &gt;Rp 200jt:</strong> Refinance pokok kecil tidak ekonomis karena biaya proses fixed.</p>
          <p>Use rumus: <strong>Break-even (bulan) = Total Biaya Take Over / Hemat per Bulan</strong>. Kalau break-even &lt; 24 bulan, layak refinance.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apa beda Refinance dan Take Over KPR?</summary>
        <div class="faq-answer">
          <p>Secara teknis sama — pindahkan KPR ke bank lain dengan bunga lebih rendah.</p>
          <p><strong>Refinance:</strong> Istilah umum perbankan internasional. Bank baru beli sisa KPR dari bank lama.</p>
          <p><strong>Take Over KPR:</strong> Istilah populer di Indonesia. Same thing.</p>
          <p>Proses: 1) Apply KPR di bank baru, 2) Bank baru bayar sisa pokok ke bank lama, 3) Sertifikat properti dipindah ke bank baru, 4) Kamu bayar cicilan ke bank baru.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Berapa lama proses take over KPR?</summary>
        <div class="faq-answer">
          <p>Estimasi waktu standar:</p>
          <p><strong>Submit aplikasi:</strong> 1-2 hari (online/offline)</p>
          <p><strong>Verifikasi dokumen:</strong> 3-7 hari (slip gaji, NPWP, dll)</p>
          <p><strong>Appraisal properti:</strong> 7-14 hari (bank baru kirim surveyor)</p>
          <p><strong>SP3K (approval):</strong> 7-14 hari</p>
          <p><strong>Akad kredit & pelunasan bank lama:</strong> 14-30 hari</p>
          <p><strong>Total: 1,5-2 bulan.</strong> Lebih lama dari KPR baru karena ada koordinasi dengan bank lama.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apakah bisa take over KPR yang masih fix period?</summary>
        <div class="faq-answer">
          <p>Bisa, tapi mahal! Bank lama akan minta denda lunas dipercepat (2-5% sisa pokok) karena kontrak fix belum selesai.</p>
          <p>Best timing: <strong>Take over saat sudah masuk floating period</strong> (setelah fix 3 tahun selesai). Saat itu kamu free dari penalty.</p>
          <p>Kalau urgent take over di tengah fix period: hitung apakah saving sampai akhir tenor masih jauh &gt; denda lunas. Kalau ya, tetap layak.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Apakah bisa negosiasi ke bank lama sebelum take over?</summary>
        <div class="faq-answer">
          <p>Ya, dan ini strategi smart! Sebelum take over, hubungi RM (Relationship Manager) bank lama, info kamu dapat penawaran bank lain dengan bunga lebih rendah.</p>
          <p>Bank lama sering kasih <strong>"matching rate"</strong> — turunkan bunga kamu ke level competitor untuk retain nasabah. Tanpa pindah bank, tanpa biaya proses.</p>
          <p>Tip: bawa <strong>offering letter</strong> dari bank baru sebagai bukti. Bank lama lebih percaya kalau ada dokumen tertulis.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Related -->
  <section class="related-section">
    <h2>Kalkulator Terkait</h2>
    <div class="related-grid">
      <a href="/kalkulator-kpr" class="related-card">
        <span class="related-icon">🏠</span>
        <h4>Kalkulator KPR</h4>
        <p>Simulasi cicilan KPR baru lengkap</p>
      </a>
      <a href="/kalkulator-gaji-bersih" class="related-card">
        <span class="related-icon">💼</span>
        <h4>Kalkulator Gaji Bersih</h4>
        <p>Cek kemampuan cicilan dari take-home pay</p>
      </a>
      <a href="/kalkulator-investasi" class="related-card">
        <span class="related-icon">📈</span>
        <h4>Kalkulator Investasi</h4>
        <p>Investasikan hasil hemat refinance KPR</p>
      </a>
    </div>
  </section>

</CalculatorLayout>

<style>
.info-banner {
  display: flex;
  gap: 14px;
  padding: 18px 22px;
  background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
  border: 2px solid #3B82F6;
  border-radius: 16px;
  margin-bottom: 32px;
  font-size: 14px;
  color: #1E3A8A;
  line-height: 1.6;
}
.info-banner-icon { font-size: 28px; flex-shrink: 0; }
.info-banner-text strong { color: #1E40AF; }

.result-section {
  margin-top: 32px;
}
.result-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 32px 36px;
  background: linear-gradient(135deg, var(--navy), var(--navy-2));
  border-radius: 24px;
  color: #fff;
  flex-wrap: wrap;
}
.result-hero-content { flex: 1; min-width: 280px; }
.result-hero-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.6);
  margin-bottom: 6px;
}
.result-hero-title {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(28px, 4vw, 38px);
  line-height: 1.1;
  margin: 0 0 10px;
  color: #fff;
}
.result-hero-desc {
  font-size: 14.5px;
  color: rgba(255,255,255,0.75);
  margin: 0;
  line-height: 1.55;
  max-width: 500px;
}
.result-hero-amount {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 52px);
  line-height: 1.1;
  color: var(--gold);
  font-variant-numeric: tabular-nums;
}

.comparison-section, .breakeven-section, .biaya-section,
.tips-section, .faq-section-calc, .related-section {
  margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--line);
}
.comparison-section h2, .breakeven-section h2, .biaya-section h2,
.tips-section h2, .faq-section-calc h2, .related-section h2 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(24px, 3.5vw, 32px);
  margin: 0 0 8px; color: var(--ink);
}
.section-sub { font-size: 14.5px; color: var(--ink-3); margin: 0 0 24px; }

.vs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 700px) {
  .vs-grid { grid-template-columns: 1fr; }
}
.vs-card {
  border: 2px solid var(--line); border-radius: 16px;
  padding: 24px; background: #fff;
}
.vs-card.vs-existing { border-color: #DC2626; background: #FEF2F2; }
.vs-card.vs-new { border-color: #10B981; background: #ECFDF5; }
.vs-tag {
  display: inline-block;
  font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
  padding: 4px 10px; border-radius: 6px; margin-bottom: 10px;
}
.vs-card.vs-existing .vs-tag { background: #FEE2E2; color: #991B1B; }
.vs-card.vs-new .vs-tag { background: #D1FAE5; color: #065F46; }
.vs-card h4 {
  font-size: 18px; font-weight: 700; margin: 0 0 6px; color: var(--ink);
}
.vs-desc {
  font-size: 13px;
  color: var(--ink-3);
  margin: 0 0 14px;
}
.vs-table { width: 100%; font-size: 13.5px; border-collapse: collapse; }
.vs-table td { padding: 8px 0; color: var(--ink-2); }
.vs-table td:last-child {
  text-align: right; font-weight: 600; color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.vs-total td {
  padding-top: 12px !important;
  border-top: 1px dashed currentColor;
  color: var(--ink) !important;
  font-weight: 700; font-size: 15px !important;
}
.vs-card.vs-existing .vs-total td:last-child { color: #DC2626 !important; }
.vs-card.vs-new .vs-total td:last-child { color: #10B981 !important; }

/* Break-even Grid */
.breakeven-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.breakeven-card {
  background: #fff;
  border: 1.5px solid var(--line);
  border-radius: 16px;
  padding: 22px;
  text-align: center;
}
.breakeven-card.highlight {
  background: linear-gradient(135deg, #FEF3C7, #FED7AA);
  border-color: #F59E0B;
}
.breakeven-icon {
  font-size: 32px;
  margin-bottom: 8px;
}
.breakeven-card h4 {
  font-size: 13.5px;
  font-weight: 700;
  margin: 0 0 10px;
  color: var(--ink-3);
  letter-spacing: 0.04em;
}
.breakeven-amount {
  font-family: var(--font-display);
  font-size: 28px;
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: 8px;
  font-variant-numeric: tabular-nums;
}
.breakeven-card.highlight .breakeven-amount {
  color: #92400E;
}
.breakeven-card p {
  font-size: 12.5px;
  color: var(--ink-3);
  margin: 0;
  line-height: 1.5;
}

/* Biaya Detail */
.biaya-grid {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 16px;
  overflow: hidden;
}
.biaya-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 16px;
  align-items: center;
  padding: 18px 22px;
  border-bottom: 1px solid var(--line);
}
.biaya-row:last-child { border-bottom: none; }
.biaya-icon {
  font-size: 24px;
  width: 44px; height: 44px;
  display: grid; place-items: center;
  background: var(--bg-soft);
  border-radius: 10px;
}
.biaya-text h4 {
  font-size: 14.5px;
  font-weight: 700;
  margin: 0 0 2px;
  color: var(--ink);
}
.biaya-text p {
  font-size: 12.5px;
  color: var(--ink-3);
  margin: 0;
}
.biaya-amount {
  font-size: 16px;
  font-weight: 700;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.biaya-total {
  background: var(--navy);
  color: #fff;
}
.biaya-total .biaya-icon { background: rgba(255,255,255,0.12); }
.biaya-total .biaya-text h4 { color: #fff; font-size: 13px; letter-spacing: 0.06em; }
.biaya-total .biaya-text p { color: rgba(255,255,255,0.6); }
.biaya-total .biaya-amount { color: var(--gold); font-size: 20px; }

/* Tips, FAQ, Related */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}
.tip-card {
  background: var(--bg-soft); border-radius: 16px;
  padding: 22px; border: 1px solid var(--line);
}
.tip-icon { font-size: 28px; margin-bottom: 10px; }
.tip-card h4 {
  font-size: 15.5px; font-weight: 700; margin: 0 0 8px; color: var(--ink);
}
.tip-card p {
  font-size: 13.5px; color: var(--ink-3); line-height: 1.55; margin: 0;
}

.faq-section-calc .faq-list { max-width: 100%; }
.faq-section-calc .faq-item {
  background: #fff; border: 1px solid var(--line);
  border-radius: 14px; margin-bottom: 10px; overflow: hidden;
}
.faq-section-calc .faq-item summary {
  list-style: none; cursor: pointer; padding: 16px 20px;
  font-weight: 600; font-size: 14.5px; color: var(--ink);
  display: flex; justify-content: space-between; align-items: center;
}
.faq-section-calc .faq-item summary::-webkit-details-marker { display: none; }
.faq-section-calc .faq-item summary::after {
  content: "+"; font-size: 22px; color: var(--ink-3); transition: transform .2s;
}
.faq-section-calc .faq-item[open] summary::after {
  transform: rotate(45deg); color: var(--blue);
}
.faq-section-calc .faq-answer {
  padding: 0 20px 18px; font-size: 14px;
  color: var(--ink-2); line-height: 1.6;
}
.faq-section-calc .faq-answer p { margin: 0 0 8px; }
.faq-section-calc .faq-answer p:last-child { margin-bottom: 0; }

.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.related-card {
  display: flex; flex-direction: column; padding: 22px;
  background: #fff; border: 1px solid var(--line);
  border-radius: 16px; text-decoration: none; color: var(--ink);
  transition: all .2s;
}
.related-card:hover {
  transform: translateY(-2px); box-shadow: var(--shadow-lg);
  color: var(--ink); text-decoration: none;
}
.related-icon { font-size: 32px; margin-bottom: 10px; }
.related-card h4 { font-size: 15.5px; font-weight: 700; margin: 0 0 6px; }
.related-card p { font-size: 13px; color: var(--ink-3); margin: 0; }

@media print {
  .site-header, .site-footer, .breadcrumb,
  .tips-section, .faq-section-calc, .related-section { display: none !important; }
  .calc-page { padding: 0; }
}
</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber } from '../utils/format.js';
import { hitungCicilan, hitungTotalBunga } from '../utils/loan.js';

const $ = (id) => document.getElementById(id);

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

function recalculate() {
  const sisaPokok = parseRupiah($('sisaPokok').value);
  const sisaTenorTahun = parseInt($('sisaTenor').value) || 1;
  const sisaTenorBulan = sisaTenorTahun * 12;
  const bungaLama = parseFloat($('bungaLama').value) || 0;
  const bungaBaru = parseFloat($('bungaBaru').value) || 0;
  const periodeFix = parseInt($('periodeFix').value) || 1;
  const bungaFloat = parseFloat($('bungaFloat').value) || 0;
  const provisiPersen = parseFloat($('provisi').value) || 0;
  const biayaProses = parseRupiah($('biayaProses').value);
  const dendaLunasPersen = parseFloat($('dendaLunas').value) || 0;

  if (!sisaPokok || sisaPokok <= 0) return;

  // === EXISTING KPR ===
  const cicilanLamaCalc = hitungCicilan(sisaPokok, bungaLama, sisaTenorBulan);
  const totalBungaLama = hitungTotalBunga(sisaPokok, bungaLama, sisaTenorBulan);
  const totalBayarLama = sisaPokok + totalBungaLama;

  // Auto-fill cicilan lama jika kosong
  const cicilanLamaInput = parseRupiah($('cicilanLama').value);
  if (cicilanLamaInput === 0) {
    $('cicilanLama').value = formatNumber(Math.round(cicilanLamaCalc));
  }
  const cicilanLama = cicilanLamaInput || cicilanLamaCalc;

  // === NEW KPR (Fix-to-Floating) ===
  // Tahun 1 sampai periode fix: pakai bunga fix
  const cicilanBaruFix = hitungCicilan(sisaPokok, bungaBaru, sisaTenorBulan);
  
  // Hitung sisa pokok setelah periode fix
  const yearsFix = Math.min(periodeFix, sisaTenorTahun);
  const yearsFloat = Math.max(0, sisaTenorTahun - periodeFix);
  
  let sisaPokokSetelahFix = sisaPokok;
  const iFix = bungaBaru / 100 / 12;
  if (iFix > 0) {
    sisaPokokSetelahFix = sisaPokok * Math.pow(1 + iFix, yearsFix*12) - cicilanBaruFix * (Math.pow(1+iFix, yearsFix*12)-1) / iFix;
  }
  
  // Cicilan floating period
  const cicilanBaruFloat = yearsFloat > 0 
    ? hitungCicilan(sisaPokokSetelahFix, bungaFloat, yearsFloat*12)
    : 0;
  
  // Total bunga baru
  const totalCicilanBaruFix = cicilanBaruFix * yearsFix * 12;
  const totalCicilanBaruFloat = cicilanBaruFloat * yearsFloat * 12;
  const totalCicilanBaru = totalCicilanBaruFix + totalCicilanBaruFloat;
  const totalBungaBaru = totalCicilanBaru - sisaPokok;

  // === BIAYA TAKE OVER ===
  const provisi = sisaPokok * (provisiPersen / 100);
  const dendaLunas = sisaPokok * (dendaLunasPersen / 100);
  const totalBiayaTakeOver = provisi + biayaProses + dendaLunas;
  const totalBayarBaru = sisaPokok + totalBungaBaru + totalBiayaTakeOver;

  // === HEMAT ANALYSIS ===
  const totalHemat = totalBayarLama - totalBayarBaru;
  const hematPerBulan = cicilanLama - cicilanBaruFix;
  const breakEvenBulan = hematPerBulan > 0 ? totalBiayaTakeOver / hematPerBulan : Infinity;

  // === REKOMENDASI ENGINE ===
  let recommendTitle, recommendDesc, recommendColor, recommendAmount;
  
  if (totalHemat > 0 && breakEvenBulan < 24) {
    recommendTitle = '✅ REFINANCE SANGAT DIREKOMENDASIKAN';
    recommendDesc = `Kamu bisa hemat ${formatRupiah(totalHemat)} sampai lunas, dengan break-even hanya ${Math.ceil(breakEvenBulan)} bulan. Refinance worth it!`;
    recommendAmount = `+${formatRupiah(totalHemat)}`;
  } else if (totalHemat > 0 && breakEvenBulan < 48) {
    recommendTitle = '⚠️ REFINANCE BISA, TAPI HATI-HATI';
    recommendDesc = `Hemat ${formatRupiah(totalHemat)} sampai lunas. Break-even ${Math.ceil(breakEvenBulan)} bulan. Pertimbangkan periode fix bank baru — kalau bunga floating lebih tinggi, saving bisa hilang.`;
    recommendAmount = `+${formatRupiah(totalHemat)}`;
  } else if (totalHemat > 0) {
    recommendTitle = '🤔 REFINANCE MARGINAL';
    recommendDesc = `Hemat ${formatRupiah(totalHemat)} sampai lunas, tapi break-even ${Math.ceil(breakEvenBulan)} bulan (terlalu lama). Pertimbangkan negosiasi dengan bank lama dulu.`;
    recommendAmount = `+${formatRupiah(totalHemat)}`;
  } else {
    recommendTitle = '❌ REFINANCE TIDAK MENGUNTUNGKAN';
    recommendDesc = `Refinance malah lebih mahal ${formatRupiah(Math.abs(totalHemat))} sampai lunas. Biaya take over terlalu tinggi atau bunga baru tidak cukup lebih rendah. Tetap di bank lama.`;
    recommendAmount = `-${formatRupiah(Math.abs(totalHemat))}`;
  }

  $('recommendTitle').textContent = recommendTitle;
  $('recommendDesc').textContent = recommendDesc;
  $('recommendAmount').textContent = recommendAmount;

  // === UPDATE DOM ===
  // Existing card
  $('exSisaPokok').textContent = formatRupiah(sisaPokok);
  $('exBunga').textContent = formatPercent(bungaLama, 1);
  $('exTenor').textContent = `${sisaTenorBulan} bulan`;
  $('exCicilan').textContent = formatRupiah(cicilanLama);
  $('exTotalBunga').textContent = formatRupiah(totalBungaLama);
  $('exTotalBayar').textContent = formatRupiah(totalBayarLama);

  // New card
  $('newPokok').textContent = formatRupiah(sisaPokok);
  $('newBungaFix').textContent = `${formatPercent(bungaBaru, 1)} (${yearsFix} thn)`;
  $('newBungaFloat').textContent = yearsFloat > 0 ? formatPercent(bungaFloat, 1) : '—';
  $('newCicilanFix').textContent = formatRupiah(cicilanBaruFix);
  $('newCicilanFloat').textContent = yearsFloat > 0 ? formatRupiah(cicilanBaruFloat) : '—';
  $('newTotalBunga').textContent = formatRupiah(totalBungaBaru + totalBiayaTakeOver);
  $('newTotalBayar').textContent = formatRupiah(totalBayarBaru);

  // Break-even
  $('beTotalBiaya').textContent = formatRupiah(totalBiayaTakeOver);
  $('beHematBulan').textContent = formatRupiah(Math.max(0, hematPerBulan));
  $('beBreakEven').textContent = breakEvenBulan < Infinity ? `${Math.ceil(breakEvenBulan)} bulan` : 'Tidak balik';
  $('beNetSaving').textContent = formatRupiah(totalHemat);

  // Biaya detail
  $('bdProvisi').textContent = formatRupiah(provisi);
  $('bdAppraisal').textContent = formatRupiah(biayaProses);
  $('bdDenda').textContent = formatRupiah(dendaLunas);
  $('bdTotal').textContent = formatRupiah(totalBiayaTakeOver);
}

['sisaTenor','bungaLama','bungaBaru','periodeFix','bungaFloat','provisi','dendaLunas'].forEach(id => {
  $(id).addEventListener('input', recalculate);
  $(id).addEventListener('change', recalculate);
});

recalculate();
</script>