---
// Embeddable widget: Simulasi Cicilan KPR (mini, self-contained)
// Route: /embed/kpr/  — untuk di-iframe di situs lain. Tanpa nav/footer/AdSense.
// noindex + canonical ke kalkulator penuh. Tidak menyentuh kpr.astro.
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Simulasi Cicilan KPR — HitungCerdas</title>
  <meta name="description" content="Hitung cepat cicilan KPR per bulan. Widget gratis oleh HitungCerdas." />
  <meta name="robots" content="noindex, follow" />
  <link rel="canonical" href="https://hitungcerdas.net/kalkulator/kpr/" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #F8FAFC;
      color: #0A2540;
      padding: 14px;
      line-height: 1.5;
    }
    .w {
      max-width: 460px;
      margin: 0 auto;
      background: #fff;
      border: 1px solid #E2E8F0;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 4px 18px rgba(10, 37, 64, .06);
    }
    .w-head {
      background: linear-gradient(135deg, #0A2540, #13335C);
      color: #fff;
      padding: 14px 18px;
    }
    .w-head h1 { font-size: 16px; font-weight: 700; letter-spacing: -.01em; }
    .w-head p { font-size: 11.5px; opacity: .8; margin-top: 2px; }
    .w-body { padding: 16px 18px; }
    .fld { margin-bottom: 12px; }
    .fld label { display: block; font-size: 12.5px; font-weight: 600; color: #475569; margin-bottom: 5px; }
    .inp { position: relative; }
    .inp .pre {
      position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
      font-size: 13px; color: #94A3B8; font-weight: 600; pointer-events: none;
    }
    .inp input, .inp select {
      width: 100%; font-size: 14px; padding: 10px 12px; border: 1px solid #CBD5E1;
      border-radius: 9px; background: #fff; color: #0A2540; outline: none;
      transition: border-color .15s, box-shadow .15s; font-family: inherit;
    }
    .inp.has-pre input { padding-left: 30px; }
    .inp.has-suf input { padding-right: 38px; }
    .inp .suf {
      position: absolute; right: 11px; top: 50%; transform: translateY(-50%);
      font-size: 13px; color: #94A3B8; font-weight: 600; pointer-events: none;
    }
    .inp input:focus, .inp select:focus { border-color: #2563EB; box-shadow: 0 0 0 3px rgba(37, 99, 235, .12); }
    .row { display: flex; gap: 10px; }
    .row .fld { flex: 1; }
    .res {
      margin-top: 4px; background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
      border: 1px solid #BFDBFE; border-radius: 11px; padding: 14px 16px; text-align: center;
    }
    .res .lbl { font-size: 11.5px; font-weight: 600; color: #1E40AF; text-transform: uppercase; letter-spacing: .05em; }
    .res .big { font-size: 26px; font-weight: 800; color: #1E40AF; letter-spacing: -.02em; margin: 3px 0; }
    .res .sub { font-size: 11.5px; color: #1E40AF; opacity: .85; }
    .grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 10px; }
    .cell { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 9px; padding: 9px; text-align: center; }
    .cell .k { font-size: 10px; color: #64748B; font-weight: 600; }
    .cell .v { font-size: 12.5px; font-weight: 700; color: #0A2540; margin-top: 2px; word-break: break-word; }
    .cta {
      display: block; text-align: center; margin-top: 14px; background: #2563EB; color: #fff;
      font-size: 13px; font-weight: 600; padding: 11px; border-radius: 9px; text-decoration: none;
      transition: background .15s;
    }
    .cta:hover { background: #1E40AF; }
    .pw {
      text-align: center; padding: 10px; font-size: 11px; color: #94A3B8;
      border-top: 1px solid #F1F5F9;
    }
    .pw a { color: #2563EB; text-decoration: none; font-weight: 600; }
    .note { font-size: 10.5px; color: #94A3B8; text-align: center; margin-top: 9px; line-height: 1.45; }
  </style>
</head>
<body>
  <div class="w">
    <div class="w-head">
      <h1>Simulasi Cicilan KPR</h1>
      <p>Perkiraan cicilan rumah per bulan</p>
    </div>
    <div class="w-body">
      <div class="fld">
        <label for="harga">Harga Properti</label>
        <div class="inp has-pre"><span class="pre">Rp</span><input id="harga" type="number" inputmode="numeric" value="500000000" min="0" /></div>
      </div>
      <div class="row">
        <div class="fld">
          <label for="dp">Uang Muka (DP)</label>
          <div class="inp has-suf"><input id="dp" type="number" inputmode="numeric" value="20" min="0" max="90" /><span class="suf">%</span></div>
        </div>
        <div class="fld">
          <label for="bunga">Bunga / tahun</label>
          <div class="inp has-suf"><input id="bunga" type="number" inputmode="decimal" value="7" min="0" max="30" step="0.1" /><span class="suf">%</span></div>
        </div>
      </div>
      <div class="fld">
        <label for="tenor">Tenor (Jangka Waktu)</label>
        <div class="inp">
          <select id="tenor">
            <option value="5">5 tahun</option>
            <option value="10">10 tahun</option>
            <option value="15" selected>15 tahun</option>
            <option value="20">20 tahun</option>
            <option value="25">25 tahun</option>
            <option value="30">30 tahun</option>
          </select>
        </div>
      </div>

      <div class="res">
        <div class="lbl">Cicilan per Bulan</div>
        <div class="big" id="cicilan">Rp 0</div>
        <div class="sub" id="resSub">—</div>
      </div>

      <div class="grid">
        <div class="cell"><div class="k">Pokok Pinjaman</div><div class="v" id="pokok">Rp 0</div></div>
        <div class="cell"><div class="k">Total Bunga</div><div class="v" id="bungaTotal">Rp 0</div></div>
        <div class="cell"><div class="k">Total Bayar</div><div class="v" id="totalBayar">Rp 0</div></div>
      </div>

      <a class="cta" href="https://hitungcerdas.net/kalkulator/kpr/" target="_blank" rel="noopener">
        Hitung lengkap (amortisasi, fixed+floating, bandingkan bank) →
      </a>

      <p class="note">Estimasi memakai rumus anuitas. Angka final dari bank dapat berbeda. Bukan nasihat keuangan.</p>
    </div>
    <div class="pw">⚡ Powered by <a href="https://hitungcerdas.net/" target="_blank" rel="noopener">HitungCerdas</a></div>
  </div>

  <script>
    (function () {
      var fmt = new Intl.NumberFormat('id-ID', { maximumFractionDigits: 0 });
      var rp = function (n) { return 'Rp ' + fmt.format(Math.max(0, Math.round(n || 0))); };
      var $ = function (id) { return document.getElementById(id); };
      var ids = ['harga', 'dp', 'bunga', 'tenor'];

      function hitung() {
        var harga = parseFloat($('harga').value) || 0;
        var dp = parseFloat($('dp').value) || 0;
        var bunga = parseFloat($('bunga').value) || 0;
        var tahun = parseInt($('tenor').value, 10) || 0;

        var pinjaman = harga * (1 - dp / 100);
        if (pinjaman < 0) pinjaman = 0;
        var i = bunga / 12 / 100;
        var n = tahun * 12;

        var cicilan = 0;
        if (n > 0) {
          cicilan = i > 0 ? (pinjaman * i) / (1 - Math.pow(1 + i, -n)) : pinjaman / n;
        }
        var totalBayar = cicilan * n;
        var totalBunga = totalBayar - pinjaman;

        $('cicilan').textContent = rp(cicilan);
        $('resSub').textContent = tahun + ' tahun \u00b7 bunga ' + bunga + '%/thn';
        $('pokok').textContent = rp(pinjaman);
        $('bungaTotal').textContent = rp(totalBunga);
        $('totalBayar').textContent = rp(totalBayar);
      }

      ids.forEach(function (id) {
        var el = $(id);
        el.addEventListener('input', hitung);
        el.addEventListener('change', hitung);
      });
      hitung();
    })();
  </script>
</body>
</html>
