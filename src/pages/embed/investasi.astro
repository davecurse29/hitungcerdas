---
// Embeddable widget: Simulasi Investasi (mini, self-contained)
// Route: /embed/investasi/  — untuk di-iframe di situs lain. Tanpa nav/footer/AdSense.
// noindex + canonical ke kalkulator penuh.
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Simulasi Investasi — HitungCerdas</title>
  <meta name="description" content="Proyeksikan pertumbuhan investasimu dengan bunga majemuk. Widget gratis oleh HitungCerdas." />
  <meta name="robots" content="noindex, follow" />
  <link rel="canonical" href="https://hitungcerdas.net/kalkulator/investasi/" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #F8FAFC;
      color: #0A2540;
      padding: 14px;
      line-height: 1.5;
    }
    .w {
      max-width: 460px;
      margin: 0 auto;
      background: #fff;
      border: 1px solid #E2E8F0;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 4px 18px rgba(10, 37, 64, .06);
    }
    .w-head {
      background: linear-gradient(135deg, #065F46, #047857);
      color: #fff;
      padding: 14px 18px;
    }
    .w-head h1 { font-size: 16px; font-weight: 700; letter-spacing: -.01em; }
    .w-head p { font-size: 11.5px; opacity: .85; margin-top: 2px; }
    .w-body { padding: 16px 18px; }
    .fld { margin-bottom: 12px; }
    .fld label { display: block; font-size: 12.5px; font-weight: 600; color: #475569; margin-bottom: 5px; }
    .inp { position: relative; }
    .inp .pre {
      position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
      font-size: 13px; color: #94A3B8; font-weight: 600; pointer-events: none;
    }
    .inp input, .inp select {
      width: 100%; font-size: 14px; padding: 10px 12px; border: 1px solid #CBD5E1;
      border-radius: 9px; background: #fff; color: #0A2540; outline: none;
      transition: border-color .15s, box-shadow .15s; font-family: inherit;
    }
    .inp.has-pre input { padding-left: 30px; }
    .inp.has-suf input { padding-right: 38px; }
    .inp .suf {
      position: absolute; right: 11px; top: 50%; transform: translateY(-50%);
      font-size: 13px; color: #94A3B8; font-weight: 600; pointer-events: none;
    }
    .inp input:focus, .inp select:focus { border-color: #059669; box-shadow: 0 0 0 3px rgba(5, 150, 105, .12); }
    .row { display: flex; gap: 10px; }
    .row .fld { flex: 1; }
    .res {
      margin-top: 4px; background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
      border: 1px solid #A7F3D0; border-radius: 11px; padding: 14px 16px; text-align: center;
    }
    .res .lbl { font-size: 11.5px; font-weight: 600; color: #047857; text-transform: uppercase; letter-spacing: .05em; }
    .res .big { font-size: 26px; font-weight: 800; color: #047857; letter-spacing: -.02em; margin: 3px 0; }
    .res .sub { font-size: 11.5px; color: #047857; opacity: .85; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
    .cell { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 9px; padding: 9px; text-align: center; }
    .cell .k { font-size: 10px; color: #64748B; font-weight: 600; }
    .cell .v { font-size: 13px; font-weight: 700; color: #0A2540; margin-top: 2px; word-break: break-word; }
    .cta {
      display: block; text-align: center; margin-top: 14px; background: #059669; color: #fff;
      font-size: 13px; font-weight: 600; padding: 11px; border-radius: 9px; text-decoration: none;
      transition: background .15s;
    }
    .cta:hover { background: #047857; }
    .pw {
      text-align: center; padding: 10px; font-size: 11px; color: #94A3B8;
      border-top: 1px solid #F1F5F9;
    }
    .pw a { color: #059669; text-decoration: none; font-weight: 600; }
    .note { font-size: 10.5px; color: #94A3B8; text-align: center; margin-top: 9px; line-height: 1.45; }
  </style>
</head>
<body>
  <div class="w">
    <div class="w-head">
      <h1>Simulasi Investasi</h1>
      <p>Proyeksi pertumbuhan dengan bunga majemuk</p>
    </div>
    <div class="w-body">
      <div class="fld">
        <label for="modal">Modal Awal</label>
        <div class="inp has-pre"><span class="pre">Rp</span><input id="modal" type="number" inputmode="numeric" value="10000000" min="0" /></div>
      </div>
      <div class="fld">
        <label for="topup">Top-up per Bulan</label>
        <div class="inp has-pre"><span class="pre">Rp</span><input id="topup" type="number" inputmode="numeric" value="1000000" min="0" /></div>
      </div>
      <div class="row">
        <div class="fld">
          <label for="ret">Return / tahun</label>
          <div class="inp has-suf"><input id="ret" type="number" inputmode="decimal" value="8" min="0" max="50" step="0.5" /><span class="suf">%</span></div>
        </div>
        <div class="fld">
          <label for="tenor">Jangka Waktu</label>
          <div class="inp">
            <select id="tenor">
              <option value="5">5 tahun</option>
              <option value="10" selected>10 tahun</option>
              <option value="15">15 tahun</option>
              <option value="20">20 tahun</option>
              <option value="25">25 tahun</option>
              <option value="30">30 tahun</option>
            </select>
          </div>
        </div>
      </div>

      <div class="res">
        <div class="lbl">Nilai Akhir Investasi</div>
        <div class="big" id="nilai">Rp 0</div>
        <div class="sub" id="resSub">—</div>
      </div>

      <div class="grid">
        <div class="cell"><div class="k">Total Setor</div><div class="v" id="setor">Rp 0</div></div>
        <div class="cell"><div class="k">Total Keuntungan</div><div class="v" id="untung">Rp 0</div></div>
      </div>

      <a class="cta" href="https://hitungcerdas.net/kalkulator/investasi/" target="_blank" rel="noopener">
        Hitung lengkap (real return, DCA, tabel per tahun) →
      </a>

      <p class="note">Proyeksi memakai bunga majemuk dengan asumsi return tetap. Hasil investasi nyata tidak dijamin &amp; bisa berfluktuasi. Bukan nasihat keuangan.</p>
    </div>
    <div class="pw">⚡ Powered by <a href="https://hitungcerdas.net/" target="_blank" rel="noopener">HitungCerdas</a></div>
  </div>

  <script>
    (function () {
      var fmt = new Intl.NumberFormat('id-ID', { maximumFractionDigits: 0 });
      var rp = function (n) { return 'Rp ' + fmt.format(Math.max(0, Math.round(n || 0))); };
      var $ = function (id) { return document.getElementById(id); };
      var ids = ['modal', 'topup', 'ret', 'tenor'];

      function hitung() {
        var modal = parseFloat($('modal').value) || 0;
        var topup = parseFloat($('topup').value) || 0;
        var ret = parseFloat($('ret').value) || 0;
        var tahun = parseInt($('tenor').value, 10) || 0;

        var i = ret / 12 / 100;
        var n = tahun * 12;

        var nilai;
        if (i > 0) {
          var g = Math.pow(1 + i, n);
          nilai = modal * g + topup * ((g - 1) / i);
        } else {
          nilai = modal + topup * n;
        }
        var setor = modal + topup * n;
        var untung = nilai - setor;

        $('nilai').textContent = rp(nilai);
        $('resSub').textContent = tahun + ' tahun \u00b7 return ' + ret + '%/thn';
        $('setor').textContent = rp(setor);
        $('untung').textContent = rp(untung);
      }

      ids.forEach(function (id) {
        var el = $(id);
        el.addEventListener('input', hitung);
        el.addEventListener('change', hitung);
      });
      hitung();
    })();
  </script>
</body>
</html>
