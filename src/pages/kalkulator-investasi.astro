</style>

<script>
import { formatRupiah, parseRupiah, formatPercent, formatNumber, formatRupiahShort } from '../utils/format.js';

const $ = (id) => document.getElementById(id);

document.querySelectorAll('input[data-format="rupiah"]').forEach(input => {
  input.addEventListener('input', (e) => {
    const cursor = e.target.selectionStart;
    const oldLen = e.target.value.length;
    const raw = parseRupiah(e.target.value);
    e.target.value = formatNumber(raw);
    const newLen = e.target.value.length;
    e.target.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));
    recalculate();
  });
  input.addEventListener('blur', () => recalculate());
});

// Auto-fill return based on jenis investasi
$('jenisInvestasi').addEventListener('change', () => {
  const select = $('jenisInvestasi');
  const option = select.options[select.selectedIndex];
  const returnVal = option.dataset.return;
  if (returnVal) {
    $('returnPersen').value = returnVal;
  }
  recalculate();
});

// Strategi visibility
function updateStrategi() {
  const strategi = $('strategi').value;
  if (strategi === 'dca') {
    $('initialGroup').style.display = 'none';
    $('monthlyGroup').style.display = 'block';
  } else if (strategi === 'lumpsum') {
    $('initialGroup').style.display = 'block';
    $('monthlyGroup').style.display = 'none';
    $('initialHint').textContent = 'modal lump sum';
  } else {
    $('initialGroup').style.display = 'block';
    $('monthlyGroup').style.display = 'block';
    $('initialHint').textContent = 'modal awal';
  }
}

function recalculate() {
  const strategi = $('strategi').value;
  const modalAwal = parseRupiah($('modalAwal').value);
  const monthly = parseRupiah($('monthlyInvest').value);
  const tahun = parseInt($('tahun').value) || 1;
  const returnPersen = parseFloat($('returnPersen').value) || 0;
  const inflasi = parseFloat($('inflasi').value) || 0;
  
  const r = returnPersen / 100;
  const rMonthly = r / 12;
  const bulan = tahun * 12;
  const realReturn = (1 + r) / (1 + inflasi/100) - 1;

  let initialValue = 0;
  let monthlyValue = 0;
  if (strategi === 'lumpsum') {
    initialValue = modalAwal;
  } else if (strategi === 'dca') {
    monthlyValue = monthly;
  } else {
    initialValue = modalAwal;
    monthlyValue = monthly;
  }

  // Final value calculation
  // FV of lump sum: PV × (1+r)^n
  const fvLumpSum = initialValue * Math.pow(1 + r, tahun);
  // FV of monthly investment (annuity due): PMT × [((1+rm)^n - 1) / rm]
  const fvMonthly = rMonthly === 0 ? monthlyValue * bulan : monthlyValue * (Math.pow(1 + rMonthly, bulan) - 1) / rMonthly;
  const nilaiAkhir = fvLumpSum + fvMonthly;

  const totalKontribusi = initialValue + (monthlyValue * bulan);
  const keuntungan = nilaiAkhir - totalKontribusi;
  const returnTotal = totalKontribusi > 0 ? (nilaiAkhir / totalKontribusi - 1) * 100 : 0;
  const cagr = totalKontribusi > 0 ? (Math.pow(nilaiAkhir / totalKontribusi, 1/tahun) - 1) * 100 : 0;
  const growthMultiple = totalKontribusi > 0 ? nilaiAkhir / totalKontribusi : 0;

  // Inflation adjusted
  const nilaiRiil = nilaiAkhir / Math.pow(1 + inflasi/100, tahun);

  // Update DOM
  $('periodeLabel').textContent = `(${tahun} tahun)`;
  $('nilaiAkhir').textContent = formatRupiah(nilaiAkhir);
  $('nilaiRiilSecondary').innerHTML = `Setelah inflasi ${inflasi}%/thn: <strong>${formatRupiah(nilaiRiil)}</strong>`;
  $('resTotalModal').textContent = formatRupiah(totalKontribusi);
  $('resKeuntungan').textContent = formatRupiah(keuntungan);
  $('resReturnTotal').textContent = formatPercent(returnTotal, 0);
  $('resCagr').textContent = formatPercent(cagr, 1);
  $('growthPercent').textContent = growthMultiple.toFixed(1).replace('.', ',') + 'x';
  $('growthFill').style.width = `${Math.min((growthMultiple - 1) * 20, 100)}%`;

  // Generate yearly data
  const yearlyData = [];
  let currentValue = initialValue;
  let totalKontribusiYearly = initialValue;
  for (let y = 1; y <= tahun; y++) {
    const yearStart = currentValue;
    // Add monthly contributions for this year
    for (let m = 0; m < 12; m++) {
      currentValue = currentValue * (1 + rMonthly) + monthlyValue;
    }
    const kontribusiTahun = monthlyValue * 12;
    totalKontribusiYearly += kontribusiTahun;
    const returnTahun = currentValue - yearStart - kontribusiTahun;
    const nilaiRiilTahun = currentValue / Math.pow(1 + inflasi/100, y);
    yearlyData.push({
      tahun: y,
      kontribusi: kontribusiTahun,
      totalModal: totalKontribusiYearly,
      returnTahun,
      nilaiAkhir: currentValue,
      nilaiRiil: nilaiRiilTahun,
    });
  }

  // Update yearly table
  let yearlyHtml = '';
  yearlyData.forEach(d => {
    yearlyHtml += `<tr>
      <td>Tahun ${d.tahun}</td>
      <td>${formatRupiah(d.kontribusi)}</td>
      <td>${formatRupiah(d.totalModal)}</td>
      <td style="color: #10B981; font-weight: 600;">+${formatRupiah(d.returnTahun)}</td>
      <td><strong>${formatRupiah(d.nilaiAkhir)}</strong></td>
      <td style="color: var(--ink-3);">${formatRupiah(d.nilaiRiil)}</td>
    </tr>`;
  });
  $('yearlyTableBody').innerHTML = yearlyHtml;

  // DCA vs Lump Sum comparison (using total kontribusi sebagai modal lump sum)
  const fvDca = rMonthly === 0 ? totalKontribusi : (totalKontribusi/bulan) * (Math.pow(1 + rMonthly, bulan) - 1) / rMonthly;
  const fvLump = totalKontribusi * Math.pow(1 + r, tahun);
  $('vsDcaResult').textContent = formatRupiah(fvDca);
  $('vsDcaKontribusi').textContent = formatRupiah(totalKontribusi);
  $('vsDcaUntung').textContent = formatRupiah(fvDca - totalKontribusi);
  $('vsDcaAkhir').textContent = formatRupiah(fvDca);
  $('vsLumpResult').textContent = formatRupiah(fvLump);
  $('vsLumpKontribusi').textContent = formatRupiah(totalKontribusi);
  $('vsLumpUntung').textContent = formatRupiah(fvLump - totalKontribusi);
  $('vsLumpAkhir').textContent = formatRupiah(fvLump);

  const selisih = fvLump - fvDca;
  $('vsConclusion').innerHTML = `
    <strong>💡 Kesimpulan:</strong> Lump Sum lebih untung <strong>${formatRupiah(selisih)}</strong> 
    (${formatPercent((selisih/fvDca)*100, 1)}) dengan kontribusi total yang sama. 
    Tapi DCA lebih aman jika market volatile + mudah disiplin untuk pemula. 
    <strong>Recommendation:</strong> Kalau punya dana besar sekaligus dan market sedang murah → Lump Sum. 
    Kalau dana dari gaji bulanan → DCA otomatis adalah natural choice.
  `;

  // Generate growth chart (SVG line chart)
  renderChart(yearlyData);
}

function renderChart(yearlyData) {
  const svg = $('growthChart');
  const w = 700, h = 320;
  const padding = { top: 30, right: 30, bottom: 50, left: 70 };
  const innerW = w - padding.left - padding.right;
  const innerH = h - padding.top - padding.bottom;
  
  const maxValue = Math.max(...yearlyData.map(d => d.nilaiAkhir));
  const tahun = yearlyData.length;

  const xScale = (i) => padding.left + (i / (tahun - 1 || 1)) * innerW;
  const yScale = (v) => padding.top + innerH - (v / maxValue) * innerH;

  // Generate paths
  const modalPath = yearlyData.map((d, i) => `${i === 0 ? 'M' : 'L'} ${xScale(i)} ${yScale(d.totalModal)}`).join(' ');
  const nilaiPath = yearlyData.map((d, i) => `${i === 0 ? 'M' : 'L'} ${xScale(i)} ${yScale(d.nilaiAkhir)}`).join(' ');
  const riilPath = yearlyData.map((d, i) => `${i === 0 ? 'M' : 'L'} ${xScale(i)} ${yScale(d.nilaiRiil)}`).join(' ');

  // Area fill for nilai akhir
  const areaPath = nilaiPath + ` L ${xScale(tahun-1)} ${padding.top + innerH} L ${xScale(0)} ${padding.top + innerH} Z`;

  // Y axis ticks (5 ticks)
  let yTicks = '';
  for (let i = 0; i <= 5; i++) {
    const v = (maxValue * i) / 5;
    const y = yScale(v);
    yTicks += `
      <line x1="${padding.left}" y1="${y}" x2="${padding.left + innerW}" y2="${y}" stroke="#E2E8F0" stroke-width="1" stroke-dasharray="3,3"/>
      <text x="${padding.left - 10}" y="${y + 4}" text-anchor="end" font-size="11" fill="#94A3B8">${formatRupiahShort(v)}</text>
    `;
  }

  // X axis labels
  let xLabels = '';
  const step = Math.max(1, Math.ceil(tahun / 8));
  for (let i = 0; i < tahun; i += step) {
    xLabels += `<text x="${xScale(i)}" y="${padding.top + innerH + 20}" text-anchor="middle" font-size="11" fill="#94A3B8">T${i+1}</text>`;
  }

  svg.innerHTML = `
    <defs>
      <linearGradient id="areaGrad" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#10B981" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="#10B981" stop-opacity="0"/>
      </linearGradient>
    </defs>
    ${yTicks}
    ${xLabels}
    <path d="${areaPath}" fill="url(#areaGrad)" />
    <path d="${modalPath}" stroke="#94A3B8" stroke-width="2" fill="none" stroke-dasharray="5,5"/>
    <path d="${riilPath}" stroke="#F59E0B" stroke-width="2" fill="none"/>
    <path d="${nilaiPath}" stroke="#10B981" stroke-width="3" fill="none"/>
  `;
}

$('strategi').addEventListener('change', () => {
  updateStrategi();
  recalculate();
});

['tahun', 'returnPersen', 'inflasi'].forEach(id => {
  $(id).addEventListener('input', recalculate);
  $(id).addEventListener('change', recalculate);
});

updateStrategi();
recalculate();
</script>