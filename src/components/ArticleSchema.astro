---
// Article Schema (Schema.org JSON-LD)
// Pakai di setiap blog post untuk:
// - Eligible Google Discover feed
// - Eligible Google News
// - Eligible Top Stories carousel
// - Image carousel di SERP

interface Props {
  headline: string;
  description: string;
  datePublished: string;     // 'YYYY-MM-DD' atau ISO 8601 lengkap
  dateModified?: string;     // 'YYYY-MM-DD' atau ISO 8601 lengkap
  image?: string;            // URL gambar hero. Default: og-image.png
  author?: string;           // Default: 'Tim HitungCerdas'
  slug: string;              // slug blog (untuk URL canonical)
  articleSection?: string;   // Kategori: 'Keuangan', 'Pajak', 'Zakat', dll
  keywords?: string[];       // Array keyword
  wordCount?: number;        // Approximate word count
}

const {
  headline,
  description,
  datePublished,
  dateModified,
  image,
  author = 'Tim HitungCerdas',
  slug,
  articleSection,
  keywords = [],
  wordCount,
} = Astro.props;

const siteUrl = 'https://hitungcerdas.net';
const articleUrl = `${siteUrl}/blog/${slug}`;
const defaultImage = `${siteUrl}/og-image.png`;

// ─── Helper: convert simple date 'YYYY-MM-DD' to ISO 8601 with WIB timezone ───
// Input '2026-06-08'  →  Output '2026-06-08T08:00:00+07:00' (morning publish, WIB)
// Input '2026-06-08T15:30:00+07:00'  →  Pass-through (already ISO)
function toISOWithTimezone(dateStr: string, isModified: boolean = false): string {
  // Already ISO 8601 with timezone — pass through
  if (dateStr.includes('T') && (dateStr.includes('+') || dateStr.includes('Z'))) {
    return dateStr;
  }
  
  // Just YYYY-MM-DD — append default time:
  // - Published: 08:00:00 WIB (morning, typical publish time)
  // - Modified:  17:00:00 WIB (afternoon, typical update time)
  const time = isModified ? '17:00:00' : '08:00:00';
  return `${dateStr}T${time}+07:00`;
}

const publishedISO = toISOWithTimezone(datePublished, false);
const modifiedISO = dateModified 
  ? toISOWithTimezone(dateModified, true) 
  : publishedISO;

// Build Article schema sesuai Schema.org standard
const articleSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": headline,
  "description": description,
  "image": [image || defaultImage],
  "datePublished": publishedISO,
  "dateModified": modifiedISO,
  "author": {
    "@type": "Organization",
    "name": author,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "HitungCerdas",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logo.svg`,
      "width": 64,
      "height": 64
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  },
  "url": articleUrl,
  "inLanguage": "id-ID",
};

// Optional fields - hanya tambah kalau ada
if (articleSection) articleSchema.articleSection = articleSection;
if (keywords.length > 0) articleSchema.keywords = keywords.join(', ');
if (wordCount) articleSchema.wordCount = wordCount;
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
