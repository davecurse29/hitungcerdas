---
// Breadcrumb dengan Schema.org markup untuk SEO
// Auto-generate JSON-LD structured data

interface BreadcrumbItem {
  label?: string;
  href?: string;
  name?: string; // alias untuk label
  url?: string;  // alias untuk href
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const siteUrl = 'https://hitungcerdas.net';

// Terima dua bentuk item: {label, href} ATAU {name, url}
const crumbs = (items || []).map((it) => ({
  label: it.label ?? it.name ?? '',
  href: it.href ?? it.url,
}));

// Normalisasi ke URL absolut ber-trailing-slash (cocok dengan canonical)
const _norm = (u) => {
  try {
    const x = new URL(u);
    if (!/\.[a-z0-9]+$/i.test(x.pathname) && !x.pathname.endsWith('/')) x.pathname += '/';
    return x.toString();
  } catch (e) { return u; }
};

// Setiap ListItem WAJIB punya 'name' + 'item'. Halaman aktif (item terakhir) pakai URL-nya sendiri.
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((item, idx) => {
    const raw = item.href
      ? (item.href.startsWith('http') ? item.href : `${siteUrl}${item.href}`)
      : `${siteUrl}${Astro.url.pathname}`;
    return {
      "@type": "ListItem",
      "position": idx + 1,
      "name": item.label,
      "item": _norm(raw),
    };
  }),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol class="breadcrumb-list">
    {crumbs.map((item, idx) => (
      <li class="breadcrumb-item">
        {item.href && idx < crumbs.length - 1 ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
        {idx < crumbs.length - 1 && (
          <i class="ti ti-chevron-right" aria-hidden="true"></i>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb {
    padding: 16px 0 8px;
  }

  .breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 13px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumb-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-soft);
  }

  .breadcrumb-item a {
    color: var(--text-soft);
    text-decoration: none;
    transition: color .15s;
  }

  .breadcrumb-item a:hover {
    color: var(--blue);
    text-decoration: underline;
  }

  .breadcrumb-item span {
    color: var(--navy);
    font-weight: 600;
  }

  .breadcrumb-item i {
    color: var(--text-mute);
    font-size: 14px;
  }
</style>
