const svgPath = SVG_ICONS[calc.iconSvg] || SVG_ICONS.kpr;
---

<a
  href={`/kalkulator/${calc.slug}/`}
  class="tool-card"
  style={`--tool-color:${calc.iconColor}`}
  data-category={calc.category}
>
  <div class="tool-head">
    <div class="tool-icon" style={`background:${calc.iconBg};color:${calc.iconColor}`}>
      <svg viewBox="0 0 40 40" fill="none" set:html={svgPath} />
    </div>
    <span class="tool-tag" style={`background:${calc.tagBg};color:${calc.tagColor}`}>
      {calc.tag}
    </span>
  </div>

  <div class="tool-body">
    <h3 class="tool-name">{calc.shortTitle}</h3>
    <p class="tool-desc">{calc.description}</p>
  </div>

  <span class="tool-btn">
    Gunakan
    <i class="ti ti-arrow-right" aria-hidden="true"></i>
  </span>
</a>

<style>
  .tool-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 22px;
    transition: var(--tx);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    min-height: 220px;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--tool-color, var(--blue));
    transform: scaleX(0);
    transition: transform .3s ease;
    transform-origin: left;
  }

  .tool-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--tool-color, var(--blue));
  }

  .tool-card:hover::before {
    transform: scaleX(1);
  }

  .tool-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }

  .tool-icon {
    width: 60px;
    height: 60px;
    border-radius: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform .35s cubic-bezier(.34, 1.56, .64, 1);
  }

  .tool-icon svg {
    width: 42px;
    height: 42px;
    display: block;
    transition: transform .35s cubic-bezier(.34, 1.56, .64, 1);
  }

  .tool-card:hover .tool-icon {
    transform: scale(1.08) rotate(-3deg);
  }

  .tool-card:hover .tool-icon svg {
    transform: scale(1.1);
  }

  .tool-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 99px;
    letter-spacing: .04em;
    text-transform: uppercase;
    align-self: flex-start;
    margin-top: 6px;
  }

  .tool-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tool-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.3;
    letter-spacing: -.01em;
    font-family: var(--ff-display);
    margin: 0;
  }

  .tool-desc {
    font-size: 13px;
    color: var(--text-soft);
    line-height: 1.55;
    margin: 0;
  }

  .tool-btn {
    background: var(--navy);
    color: #fff;
    font-size: 12.5px;
    font-weight: 600;
    padding: 9px 16px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: var(--tx);
    align-self: flex-start;
  }

  .tool-card:hover .tool-btn {
    background: var(--green);
    box-shadow: 0 4px 12px rgba(5, 150, 105, .3);
  }

  /* ── Dark mode ── */
  :global([data-theme="dark"]) .tool-card { background: var(--bg-card); }
  :global([data-theme="dark"]) .tool-name { color: var(--text); }
</style>
