---
// src/components/CalculatorLayout.astro
// Wrapper layout untuk semua halaman kalkulator
import Layout from '../layouts/Layout.astro';

const { 
  title, 
  description, 
  icon = '🧮', 
  category = 'Kalkulator',
  categoryColor = 'blue',
  breadcrumb = []
} = Astro.props;
---

<Layout title={title} description={description}>
  <div class="calc-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Beranda</a>
        {breadcrumb.map(item => (
          <>
            <span class="sep">›</span>
            {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
          </>
        ))}
      </nav>

      <header class={`calc-header calc-header-${categoryColor}`}>
        <div class="calc-header-icon">{icon}</div>
        <div class="calc-header-text">
          <span class="calc-category">{category}</span>
          <h1>{title}</h1>
          <p>{description}</p>
        </div>
      </header>

      <div class="calc-body">
        <slot />
      </div>
    </div>
  </div>
</Layout>

<style>
.calc-page { padding: 24px 0 80px; }

.breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  font-size: 13.5px;
  color: var(--ink-3);
  margin-bottom: 24px;
}
.breadcrumb a { color: var(--ink-3); }
.breadcrumb a:hover { color: var(--blue); }
.breadcrumb .sep { color: var(--ink-3); opacity: 0.5; }
.breadcrumb span:last-child { color: var(--ink); font-weight: 500; }

.calc-header {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 28px 28px;
  border-radius: 24px;
  margin-bottom: 32px;
  background: linear-gradient(135deg, var(--navy), var(--navy-2));
  color: #fff;
}
.calc-header-blue { background: linear-gradient(135deg, #1E40AF, #2563EB); }
.calc-header-red { background: linear-gradient(135deg, #991B1B, #DC2626); }
.calc-header-green { background: linear-gradient(135deg, #065F46, #10B981); }
.calc-header-yellow { background: linear-gradient(135deg, #92400E, #F59E0B); }
.calc-header-purple { background: linear-gradient(135deg, #5B21B6, #8B5CF6); }
.calc-header-pink { background: linear-gradient(135deg, #9D174D, #EC4899); }
.calc-header-teal { background: linear-gradient(135deg, #115E59, #14B8A6); }

.calc-header-icon {
  font-size: 48px;
  flex-shrink: 0;
  width: 80px; height: 80px;
  display: grid; place-items: center;
  background: rgba(255,255,255,0.12);
  border-radius: 18px;
}
.calc-category {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.7);
  margin-bottom: 6px;
}
.calc-header h1 {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(28px, 4vw, 40px);
  line-height: 1.1;
  margin: 0 0 8px;
  color: #fff;
}
.calc-header p {
  font-size: 15px;
  color: rgba(255,255,255,0.8);
  margin: 0;
  max-width: 600px;
}

@media (max-width: 600px) {
  .calc-header { flex-direction: column; text-align: center; padding: 24px 20px; }
  .calc-header-icon { width: 64px; height: 64px; font-size: 36px; }
}

.calc-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
@media (max-width: 900px) {
  .calc-grid { grid-template-columns: 1fr; }
}

.calc-panel {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 28px;
}
.calc-panel-dark {
  background: linear-gradient(135deg, var(--navy), var(--navy-2));
  color: #fff;
  border: none;
}
.calc-panel h3 {
  margin: 0 0 20px;
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
}
.calc-panel-dark h3 { color: #fff; }

.form-group { margin-bottom: 18px; }
.form-label {
  display: block;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--ink-2);
  margin-bottom: 6px;
}
.form-hint {
  font-size: 12px;
  color: var(--ink-3);
  font-weight: 400;
  margin-left: 6px;
}
.form-input {
  width: 100%;
  padding: 12px 14px;
  font-size: 15px;
  font-family: inherit;
  border: 1.5px solid var(--line);
  border-radius: 10px;
  background: #fff;
  color: var(--ink);
  transition: border-color .15s var(--ease);
}
.form-input:focus {
  outline: none;
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
}
.form-input-prefix {
  position: relative;
}
.form-input-prefix .prefix {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 14px;
  color: var(--ink-3);
  font-weight: 500;
  pointer-events: none;
}
.form-input-prefix input { padding-left: 38px; }

.form-input-suffix {
  position: relative;
}
.form-input-suffix .suffix {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 14px;
  color: var(--ink-3);
  font-weight: 500;
  pointer-events: none;
}
.form-input-suffix input { padding-right: 50px; }

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

select.form-input {
  cursor: pointer;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'/%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: right 12px center;
  background-size: 16px;
  appearance: none;
  padding-right: 36px;
}

.result-main {
  text-align: center;
  padding: 8px 0 20px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  margin-bottom: 20px;
}
.result-main .label {
  display: block;
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.65);
  margin-bottom: 6px;
}
.result-main .value {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 48px);
  color: var(--gold);
  line-height: 1.1;
}

.result-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.result-card {
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 14px 16px;
}
.result-card .label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.55);
  margin-bottom: 4px;
}
.result-card .value {
  font-size: 17px;
  font-weight: 700;
  color: #fff;
}
.result-card.success .value { color: #34D399; }
.result-card.warning .value { color: #F87171; }

.btn-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 20px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all .15s var(--ease);
}
.btn-action.primary {
  background: var(--navy);
  color: #fff;
}
.btn-action.primary:hover { background: var(--navy-2); }
.btn-action.secondary {
  background: var(--bg-soft);
  color: var(--ink);
}
.btn-action.secondary:hover { background: var(--line); }

.info-box {
  display: flex;
  gap: 12px;
  padding: 14px 16px;
  background: var(--blue-soft);
  border-left: 3px solid var(--blue);
  border-radius: 10px;
  font-size: 13.5px;
  color: var(--ink-2);
  line-height: 1.55;
  margin-top: 16px;
}
.info-box-icon {
  flex-shrink: 0;
  color: var(--blue);
  font-weight: 700;
}
</style>